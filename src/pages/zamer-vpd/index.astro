<script is:inline>
  (function () {
    document.addEventListener('DOMContentLoaded', function () {
      var triggers = [].slice.call(document.querySelectorAll('.osa-zvpd__zoom-btn[data-lightbox-src]'));
      var lb = document.querySelector('.osa-zvpd__lightbox');
      if (triggers.length === 0 || !lb) return;

      var img  = lb.querySelector('.osa-zvpd__lightbox-img');
      var cap  = lb.querySelector('.osa-zvpd__lightbox-cap');
      var close = lb.querySelector('.osa-zvpd__lightbox-close');
      var prev = lb.querySelector('.osa-zvpd__lightbox-nav--prev');
      var next = lb.querySelector('.osa-zvpd__lightbox-nav--next');
      var index = 0;

      function render(i) {
        index = (i + triggers.length) % triggers.length;
        var t = triggers[index];
        img.src = t.getAttribute('data-lightbox-src');
        img.alt = t.getAttribute('data-lightbox-alt') || '';
        cap.textContent = (index + 1) + ' / ' + triggers.length + (img.alt ? ' · ' + img.alt : '');
      }
      function open(i) {
        render(i);
        lb.hidden = false;
        requestAnimationFrame(function () { lb.classList.add('open'); });
        document.documentElement.classList.add('osa-lightbox-lock');
        close.focus();
      }
      function shut() {
        lb.classList.remove('open');
        document.documentElement.classList.remove('osa-lightbox-lock');
        setTimeout(function () { if (!lb.classList.contains('open')) lb.hidden = true; }, 220);
      }

      triggers.forEach(function (t, i) { t.addEventListener('click', function () { open(i); }); });
      close.addEventListener('click', shut);
      prev.addEventListener('click', function () { render(index - 1); });
      next.addEventListener('click', function () { render(index + 1); });
      lb.addEventListener('click', function (e) {
        if (e.target === lb || e.target.classList.contains('osa-zvpd__lightbox-stage')) shut();
      });
      document.addEventListener('keydown', function (e) {
        if (lb.hidden) return;
        if (e.key === 'Escape') shut();
        else if (e.key === 'ArrowLeft') render(index - 1);
        else if (e.key === 'ArrowRight') render(index + 1);
      });
    });
  }());
</script>

<style>
  /*
   * Bespoke investor-focused editorial page. Keeps the parent brand's
   * monochrome palette and Atyp Special type, but relies on:
   *   - full-bleed photo breaks between chapters
   *   - a large numeric chapter mark (01, 02, etc.)
   *   - financial cards with the osa-mono stack for data authority
   *   - a horizontal timeline bar for the two-phase schedule
   *   - a ruled table for areál potential values
   *
   * Any figure that is still pending Marek's confirmation is wrapped in
   * .draft (mustard wash). When the numbers settle, strip the wrappers.
   */

  .osa-zvpd { --zvpd-muted: color-mix(in oklab, var(--fg) 55%, transparent); }

  /* -------------------- HERO -------------------- */
  /* Dark hero with full-bleed photo background. Layer order bg -> scrim
     -> inner content. Using explicit z-index (1, 2, 3) on children; the
     section itself gets background:transparent so the photo isn't hidden
     by the osa-dark scope's own background. */
  .osa-zvpd__hero {
    position: relative;
    isolation: isolate;
    min-height: clamp(560px, 78vh, 780px);
    display: flex;
    align-items: flex-end;
    background: var(--k-100);
  }
  .osa-zvpd__hero-bg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: brightness(0.45) saturate(0.9);
    z-index: 1;
  }
  .osa-zvpd__hero-scrim {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(180deg, rgba(0,0,0,0.4) 0%, rgba(0,0,0,0.15) 40%, rgba(0,0,0,0.75) 100%);
    z-index: 2;
  }
  .osa-zvpd__hero-inner {
    position: relative;
    z-index: 3;
    padding: clamp(80px, 9vh, 120px) var(--gutter) clamp(48px, 7vh, 80px);
    width: 100%;
    max-width: 1200px;
  }
  .osa-zvpd__crumbs {
    display: flex;
    gap: var(--space-3);
    flex-wrap: wrap;
    align-items: center;
    color: var(--fg-muted);
    margin-bottom: var(--space-5);
  }
  .osa-zvpd__crumbs a { color: inherit; text-decoration: underline; text-underline-offset: 3px; }
  .osa-zvpd__kicker { color: var(--fg-muted); display: block; margin-bottom: var(--space-3); }
  .osa-zvpd__h1 {
    font-family: var(--font-sans);
    font-weight: 600;
    font-size: clamp(2.25rem, 5vw, 3.75rem);
    line-height: 1.04;
    letter-spacing: var(--tracking-tight);
    color: var(--fg);
    margin: 0 0 var(--space-5);
    max-width: 22ch;
  }
  .osa-zvpd__h1-sub {
    display: block;
    font-size: clamp(1.125rem, 2vw, 1.5rem);
    font-weight: 500;
    margin-top: var(--space-3);
    color: var(--fg-muted);
    max-width: 32ch;
  }
  .osa-zvpd__lede { color: var(--fg-muted); max-width: 56ch; margin: 0 0 var(--space-6); font-size: var(--text-lg); }
  .osa-zvpd__hero-stats {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-5);
    margin: 0;
    padding-top: var(--space-5);
    border-top: 1px solid rgba(255,255,255,0.2);
    max-width: 720px;
  }
  .osa-zvpd__hero-stats > div { display: grid; gap: var(--space-2); }
  .osa-zvpd__hero-stats dt { color: var(--fg-muted); }
  .osa-zvpd__hero-stats dd { margin: 0; font-size: var(--text-sm); color: var(--fg); line-height: var(--lh-normal); }
  @media (max-width: 720px) {
    .osa-zvpd__hero-stats { grid-template-columns: 1fr; gap: var(--space-4); }
  }

  /* -------------------- CHAPTER HEAD -------------------- */
  .osa-zvpd__chapter-head {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: var(--space-6);
    align-items: start;
    margin-bottom: var(--space-7);
    max-width: 1200px;
  }
  .osa-zvpd__chapter-mark {
    font-family: var(--font-sans);
    font-weight: 600;
    font-size: clamp(2.8rem, 7.2vw, 4.8rem);
    line-height: 0.9;
    color: var(--fg);
    letter-spacing: -0.02em;
    margin: 0;
  }
  .osa-zvpd__chapter-title { margin: var(--space-2) 0 var(--space-4); max-width: 22ch; }
  .osa-zvpd__chapter-lede { margin: 0; color: var(--fg-muted); max-width: 64ch; font-size: var(--text-lg); }
  /* Mobile: drop the oversized numeric mark; the "Kapitola 0X" eyebrow
     carries the wayfinding cue with much less vertical cost. */
  @media (max-width: 720px) {
    .osa-zvpd__chapter-head { grid-template-columns: 1fr; gap: var(--space-3); margin-bottom: var(--space-5); }
    .osa-zvpd__chapter-mark { display: none; }
    .osa-zvpd__chapter-title { margin: var(--space-1) 0 var(--space-3); }
    .osa-zvpd__chapter-lede { font-size: var(--text-md); }
  }

  /* -------------------- OPPORTUNITY TABLE -------------------- */
  .osa-zvpd__opp-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-8);
    align-items: start;
  }
  @media (max-width: 860px) {
    .osa-zvpd__opp-grid { grid-template-columns: 1fr; gap: var(--space-6); }
  }
  .osa-zvpd__opp-figure { margin: 0; }
  .osa-zvpd__opp-figure img { width: 100%; aspect-ratio: 4 / 3; object-fit: cover; display: block; }
  .osa-zvpd__opp-cap { color: var(--fg-muted); font-size: var(--text-xs); margin: var(--space-3) 0 0; }

  .osa-zvpd__opp-table { display: grid; gap: 0; margin: 0; }
  .osa-zvpd__opp-table > div {
    display: grid;
    grid-template-columns: 130px 1fr;
    gap: var(--space-4);
    padding: var(--space-4) var(--space-3);
    margin: 0 calc(-1 * var(--space-3));
    border-top: 1px solid var(--rule);
    transition: background var(--dur-fast) var(--ease-standard);
  }
  .osa-zvpd__opp-table > div:last-child { border-bottom: 1px solid var(--rule); }
  @media (hover: hover) and (pointer: fine) {
    .osa-zvpd__opp-table > div:hover { background: color-mix(in oklab, var(--fg) 5%, transparent); }
  }
  .osa-zvpd__opp-table dt {
    font-family: var(--font-sans);
    font-weight: 600;
    font-size: var(--text-sm);
    color: var(--fg);
    align-self: start;
  }
  .osa-zvpd__opp-table dd { margin: 0; font-size: var(--text-sm); color: var(--fg); line-height: var(--lh-normal); }
  .osa-zvpd__opp-table dd small { display: block; color: var(--fg-muted); font-size: var(--text-xs); margin-top: 2px; }
  @media (max-width: 560px) {
    .osa-zvpd__opp-table > div { grid-template-columns: 1fr; gap: var(--space-2); }
  }

  /* -------------------- FULL-BLEED PHOTO BREAK -------------------- */
  .osa-zvpd__fullbleed { margin: 0; }
  .osa-zvpd__fullbleed img {
    display: block;
    width: 100%;
    height: clamp(220px, 42vh, 520px);
    object-fit: cover;
  }

  /* -------------------- PHASES -------------------- */
  .osa-zvpd__phases {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-6);
    margin-bottom: var(--space-7);
  }
  @media (max-width: 860px) {
    .osa-zvpd__phases { grid-template-columns: 1fr; }
  }
  .osa-zvpd__phase {
    border: 1px solid rgba(255,255,255,0.2);
    padding: var(--space-6);
    display: grid;
    gap: var(--space-4);
    background: rgba(255,255,255,0.02);
  }
  .osa-zvpd__phase-head {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    flex-wrap: wrap;
    gap: var(--space-3);
    padding-bottom: var(--space-4);
    border-bottom: 1px solid rgba(255,255,255,0.2);
  }
  .osa-zvpd__phase-num {
    font-family: var(--font-sans);
    font-weight: 600;
    font-size: var(--text-xl);
    color: var(--fg);
  }
  .osa-zvpd__phase-dates { color: var(--fg-muted); font-size: var(--text-sm); }
  .osa-zvpd__phase-lede { margin: 0; color: var(--fg-muted); font-size: var(--text-base); max-width: 46ch; }
  .osa-zvpd__phase-metrics {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0;
    margin: 0;
  }
  .osa-zvpd__phase-metrics > div {
    display: grid;
    grid-template-columns: 1fr auto;
    align-items: baseline;
    gap: var(--space-3);
    padding: var(--space-3) var(--space-2);
    margin: 0 calc(-1 * var(--space-2));
    border-top: 1px solid rgba(255,255,255,0.12);
    font-size: var(--text-sm);
    transition: background var(--dur-fast) var(--ease-standard);
  }
  @media (hover: hover) and (pointer: fine) {
    .osa-zvpd__phase-metrics > div:hover { background: rgba(255,255,255,0.05); }
  }
  .osa-zvpd__phase-metrics > div:nth-child(-n+2) { border-top: 0; }
  /* The negative horizontal margin (for the hover tint bleed) shifts both
     boxes 8 px outward; that means neighbouring cells overlap by 16 px, so
     inside padding has to absorb those 16 px before the visual gap starts.
     space-6 (32 px) leaves a real 16 px of air between the dd/dt and the
     vertical divider. */
  .osa-zvpd__phase-metrics > div:nth-child(odd) { padding-right: var(--space-6); }
  .osa-zvpd__phase-metrics > div:nth-child(even) { padding-left: var(--space-6); border-left: 1px solid rgba(255,255,255,0.12); }
  .osa-zvpd__phase-metrics dt { color: var(--fg-muted); }
  .osa-zvpd__phase-metrics dd { margin: 0; color: var(--fg); font-weight: 500; }
  .osa-zvpd__phase-metrics dd small { font-weight: 400; color: var(--fg-muted); font-size: 0.82em; }
  @media (max-width: 480px) {
    .osa-zvpd__phase-metrics { grid-template-columns: 1fr; }
    .osa-zvpd__phase-metrics > div:nth-child(2) { border-top: 1px solid rgba(255,255,255,0.12); }
    .osa-zvpd__phase-metrics > div:nth-child(even) { padding-left: 0; border-left: 0; }
    .osa-zvpd__phase-metrics > div:nth-child(odd) { padding-right: 0; }
  }
  .osa-zvpd__phase-target {
    margin: 0;
    padding-top: var(--space-4);
    border-top: 1px solid rgba(255,255,255,0.2);
    color: var(--fg-muted);
    font-size: var(--text-sm);
    display: grid;
    gap: var(--space-1);
  }
  .osa-zvpd__phase-target .osa-eyebrow { color: var(--fg); }

  /* -------------------- TIMELINE --------------------
     Bars sit inside a striped "track" — diagonal hatching mirrors the
     SVGPattern on the chapter background, so the timeline reads as part
     of the same surface rather than a detached widget. No framing rule —
     the hatching alone defines the track. */
  .osa-zvpd__timeline {
    position: relative;
    display: grid;
    gap: var(--space-3);
    padding-top: var(--space-2);
  }
  .osa-zvpd__timeline-years {
    display: grid;
    grid-template-columns: repeat(7, 1fr);
    font-family: var(--font-mono);
    font-size: var(--text-2xs);
    color: var(--fg-muted);
    letter-spacing: var(--tracking-wider);
  }
  .osa-zvpd__timeline-bars {
    position: relative;
    height: 44px;
  }
  .osa-zvpd__timeline-bar {
    position: absolute;
    top: 8px;
    height: 28px;
    display: flex;
    align-items: center;
    padding: 0 12px;
    font-size: var(--text-xs);
    font-weight: 600;
    color: var(--bg);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .osa-zvpd__timeline-bar--p1 { background: var(--fg); }
  .osa-zvpd__timeline-bar--op { background: color-mix(in oklab, var(--fg) 60%, transparent); }
  .osa-zvpd__timeline-bar--p2 { background: var(--fg); }
  @media (max-width: 560px) {
    .osa-zvpd__timeline-years { grid-template-columns: repeat(7, 1fr); font-size: 10px; }
    .osa-zvpd__timeline-bar { font-size: 10px; padding: 0 6px; }
  }

  /* -------------------- PHOTO STRIP --------------------
     Desktop: 2-column grid. Mobile: horizontal scroll-snap slider so the
     strip doesn't stack into a long tower of thumbnails. Swipe-native,
     no JS. The container-wide head stays, but the grid itself escapes
     the container on mobile so the first slide aligns with the gutter. */
  .osa-zvpd__photostrip { padding: var(--space-7) 0; background: var(--bg); }
  .osa-zvpd__photostrip-head { margin-bottom: var(--space-6); max-width: 820px; display: grid; gap: var(--space-2); }
  .osa-zvpd__photostrip-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 4px;
    padding: 0 var(--gutter);
  }
  .osa-zvpd__photostrip-grid figure { margin: 0; }
  .osa-zvpd__photostrip-grid img {
    width: 100%;
    aspect-ratio: 4 / 3;
    object-fit: cover;
    display: block;
  }
  @media (max-width: 720px) {
    .osa-zvpd__photostrip-grid {
      display: flex;
      grid-template-columns: none;
      overflow-x: auto;
      scroll-snap-type: x mandatory;
      -webkit-overflow-scrolling: touch;
      gap: 8px;
      padding: 0 var(--gutter) var(--space-3);
      scroll-padding-left: var(--gutter);
      scrollbar-width: thin;
      scrollbar-color: var(--fg-muted) transparent;
    }
    .osa-zvpd__photostrip-grid > figure {
      flex: 0 0 85%;
      scroll-snap-align: start;
    }
  }

  /* -------------------- FINANCE CARDS --------------------
     Tighter padding so four numbers fit in a single row at ~900px and
     stay 2×2 all the way down to phone widths (no 1-col collapse — the
     cards carry so little text that a single stack leaves the numbers
     floating alone with too much vertical cost). */
  .osa-zvpd__finance {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 0;
    border-top: 1px solid var(--rule);
    margin-bottom: var(--space-7);
  }
  .osa-zvpd__finance-card {
    padding: var(--space-5) var(--space-4);
    border-right: 1px solid var(--rule);
    border-bottom: 1px solid var(--rule);
    display: grid;
    gap: var(--space-2);
    align-content: start;
    transition: background var(--dur-fast) var(--ease-standard);
  }
  .osa-zvpd__finance-card:last-child { border-right: 0; }
  @media (hover: hover) and (pointer: fine) {
    .osa-zvpd__finance-card:hover { background: color-mix(in oklab, var(--fg) 4%, transparent); }
  }
  .osa-zvpd__finance-num {
    font-family: var(--font-sans);
    font-size: clamp(1.75rem, 3.2vw, 2.5rem);
    font-weight: 600;
    line-height: 1;
    letter-spacing: var(--tracking-tight);
    color: var(--fg);
    margin-top: var(--space-1);
    font-variant-numeric: tabular-nums lining-nums;
  }
  .osa-zvpd__finance-unit {
    color: var(--fg-muted);
