---
/*
 * /zamer-vpd/ — bespoke investor landing for the VPD1 investment call.
 *
 * Stands alone from the aktuality template: the aktualita MDX was the
 * previous home for this pitch, but the client wanted a page with its
 * own silhouette (large-image breaks, chapter marks, financial panels)
 * separate from the generic article chrome.
 *
 * Canonical numbers from the two Kindl-verified PDFs:
 *   "Investment call k záměru VPD1.pdf" + "Záměr VPD1 – základní souhrn.pdf".
 * Where a secondary figure only shows up in VPD_Klecany_Nahled (the
 * 5-slide deck), it's still rendered — wrapped in .draft to flag that
 * the number is pending Marek's final sign-off.
 */
import Base from '../../layouts/Base.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import SVGPattern from '../../components/SVGPattern.astro';
import Gallery from '../../components/Gallery.astro';
import { withBase } from '../../utils/url';

const img = (name: string) => withBase(`/images/zamer-vpd/${name}`);
---
<Base
  title="Záměr VPD · Horní kasárna Klecany · investiční příležitost"
  description="Revitalizace areálu 83 327 m² na prahu metropole. Investment call na první developerskou fázi: 331 jednotek 1+kk, IRR 59 %, potenciál 10+ mld. Kč."
  ogImage="/images/zamer-vpd/hub-market-evening.jpg">
  <Header variant="dark" />

  <main class="osa-zvpd">

    {/*
     * HERO — full-bleed photograph with overlaid title column.
     * The photo carries the tone ("evening lights, people, life");
     * the crumbs + H1 + lede + key figures sit on a scrim for legibility.
     */}
    <section class="osa-zvpd__hero osa-dark" aria-labelledby="zvpd-title">
      <img
        class="osa-zvpd__hero-bg"
        src={img('hub-market-people.jpg')}
        alt=""
        aria-hidden="true"
        loading="eager"
        decoding="async" />
      <div class="osa-zvpd__hero-scrim" aria-hidden="true"></div>
      <div class="container-wide osa-zvpd__hero-inner">
        <nav class="osa-zvpd__crumbs osa-eyebrow" aria-label="Drobečková navigace">
          <a href={withBase('/')}>Úvod</a>
          <span aria-hidden="true">·</span>
          <a href={withBase('/projekty/vpd/')}>VPD</a>
          <span aria-hidden="true">·</span>
          <span aria-current="page">Záměr</span>
        </nav>
        <span class="osa-eyebrow osa-zvpd__kicker" data-reveal>
          Investment call · VPD Klecany s.r.o.
        </span>
        <h1 id="zvpd-title" class="osa-zvpd__h1" data-reveal>
          Horní kasárna Klecany.
          <span class="osa-zvpd__h1-sub">Revitalizace areálu 83&nbsp;327&nbsp;m² na prahu metropole.</span>
        </h1>
        <p class="osa-zvpd__lede" data-reveal data-reveal-delay="1">
          Právo odkupu, užívání a stavby zajištěno do roku 2039. Okamžitě realizovatelná první fáze bez nutnosti změny územního plánu. Potenciál v mezích platného ÚP: <span class="draft">10+&nbsp;mld.&nbsp;Kč</span>.
        </p>
        <dl class="osa-zvpd__hero-stats" data-reveal data-reveal-delay="2">
          <div>
            <dt class="osa-eyebrow">Rozloha</dt>
            <dd><span class="osa-figs">83&nbsp;327&nbsp;m²</span></dd>
          </div>
          <div>
            <dt class="osa-eyebrow">Vzdálenost</dt>
            <dd><span class="osa-figs">12&nbsp;km</span> od centra Prahy</dd>
          </div>
          <div>
            <dt class="osa-eyebrow">1.&nbsp;fáze</dt>
            <dd><span class="osa-figs">331</span> jednotek 1+kk · IRR <span class="draft"><span class="osa-figs">59&nbsp;%</span></span></dd>
          </div>
        </dl>
      </div>
    </section>

    {/* ===== CHAPTER 01 · PŘÍLEŽITOST ===== */}
    <section class="osa-zvpd__chapter section" aria-labelledby="ch1-title">
      <div class="container-wide">
        <div class="osa-zvpd__chapter-head" data-reveal>
          <span class="osa-zvpd__chapter-mark">01</span>
          <div>
            <span class="osa-eyebrow">Kapitola 01</span>
            <h2 id="ch1-title" class="osa-h2 osa-zvpd__chapter-title">Příležitost</h2>
            <p class="osa-body osa-zvpd__chapter-lede">
              Jedinečný pozemek na dosah Prahy. Smluvně zajištěná práva, kupní cena pod tržní hodnotou a okamžitě realizovatelná první fáze bez potřeby změny územního plánu.
            </p>
          </div>
        </div>

        <div class="osa-zvpd__opp-grid" data-reveal data-reveal-delay="1">
          <figure class="osa-zvpd__opp-figure osa-zvpd__zoom">
            <button type="button" class="osa-zvpd__zoom-btn" data-lightbox-src={img('hub-renovated-building.jpg')} data-lightbox-alt="Zrekonstruovaná bílá budova ve stylu původních kasáren s novým chodníkem a nasázenou vegetací." aria-label="Zobrazit fotografii: zrekonstruovaná budova">
              <img
                src={img('hub-renovated-building.jpg')}
                alt="Zrekonstruovaná bílá budova ve stylu původních kasáren s novým chodníkem a nasázenou vegetací."
                loading="lazy"
                decoding="async" />
            </button>
            <figcaption class="osa-zvpd__opp-cap">
              Reference: podoba rekonstruované budovy po dokončení 1.&nbsp;fáze.
            </figcaption>
          </figure>

          <dl class="osa-zvpd__opp-table">
            <div>
              <dt>Lokace</dt>
              <dd>Klecany, <span class="osa-figs">12&nbsp;km</span> od&nbsp;centra Prahy<br /><small>na trase plánované tramvaje z&nbsp;Kobylis</small></dd>
            </div>
            <div>
              <dt>Rozloha</dt>
              <dd><span class="osa-figs">83&nbsp;327&nbsp;m²</span> celkem<br /><small>z&nbsp;toho <span class="draft"><span class="osa-figs">77&nbsp;210&nbsp;m²</span></span> zastavitelných (SM)</small></dd>
            </div>
            <div>
              <dt>Kupní cena</dt>
              <dd><span class="draft"><span class="osa-figs">438,6&nbsp;mil.&nbsp;Kč</span>, tj. 82&nbsp;% znalecké hodnoty</span><br /><small>znalecký odhad <span class="draft"><span class="osa-figs">536,2&nbsp;mil.&nbsp;Kč</span></span></small></dd>
            </div>
            <div>
              <dt>Práva</dt>
              <dd>Smluvně zajištěna do&nbsp;roku&nbsp;<strong class="osa-figs">2039</strong><br /><small>právo odkupu, užívání, stavby; plná moc</small></dd>
            </div>
            <div>
              <dt>Potenciál</dt>
              <dd><span class="draft"><span class="osa-figs">88&nbsp;946&nbsp;m²</span> ČPP nových bytů</span><br /><small>+&nbsp;<span class="osa-figs">331</span> rekonstruovaných jednotek</small></dd>
            </div>
            <div>
              <dt>Okolí</dt>
              <dd><span class="draft">Klecanská Alej (<span class="osa-figs">130–175&nbsp;tis.&nbsp;Kč/m²</span>)</span><br /><small>plánovaná tramvaj, cyklostezka do&nbsp;Prahy</small></dd>
            </div>
          </dl>
        </div>
      </div>
    </section>

    {/* ===== FULL-BLEED BREAK ===== */}
    <figure class="osa-zvpd__fullbleed osa-zvpd__zoom">
      <button type="button" class="osa-zvpd__zoom-btn" data-lightbox-src={img('hub-street-sunset.jpg')} data-lightbox-alt="Ulice areálu za západu slunce." aria-label="Zobrazit fotografii: ulice areálu">
        <img
          src={img('hub-street-sunset.jpg')}
          alt="Ulice areálu za západu slunce."
          loading="lazy"
          decoding="async" />
      </button>
    </figure>

    {/* ===== CHAPTER 02 · PLÁN ===== */}
    <section class="osa-zvpd__chapter section osa-dark" aria-labelledby="ch2-title">
      <SVGPattern variant="dark" opacity={0.08}>
        <div class="container-wide">
          <div class="osa-zvpd__chapter-head" data-reveal>
            <span class="osa-zvpd__chapter-mark">02</span>
            <div>
              <span class="osa-eyebrow">Kapitola 02</span>
              <h2 id="ch2-title" class="osa-h2 osa-zvpd__chapter-title">Plán</h2>
              <p class="osa-body osa-zvpd__chapter-lede">
                Dva kroky k transformaci areálu. První fáze Startovací hub využívá stávající budovy a je realizovatelná okamžitě. Druhá fáze Nová čtvrť přichází po uzavření plánovací smlouvy s obcí a navazuje na platný územní plán.
              </p>
            </div>
          </div>

          <div class="osa-zvpd__phases" data-reveal data-reveal-delay="1">
            {/* PHASE 1 */}
            <article class="osa-zvpd__phase">
              <header class="osa-zvpd__phase-head">
                <span class="osa-zvpd__phase-num">① Startovací hub</span>
                <span class="osa-mono osa-zvpd__phase-dates"><span class="draft">06/2026 → 10/2028</span></span>
              </header>
              <p class="osa-zvpd__phase-lede">
                Rekonstrukce 7 stávajících budov na 331 jednotek 1+kk s komunitním a coworkingovým zázemím. Plně v souladu se současným územním plánem, okamžitě realizovatelné.
              </p>
              <dl class="osa-zvpd__phase-metrics">
                <div><dt>HPP</dt><dd class="osa-mono">10&nbsp;144&nbsp;m²</dd></div>
                <div><dt>CAPEX</dt><dd class="osa-mono">≈ 285&nbsp;mil.&nbsp;Kč</dd></div>
                <div><dt>Jednotek 1+kk</dt><dd class="osa-mono">331 <small>(průměr <span class="draft">20,3&nbsp;m²</span>)</small></dd></div>
                <div><dt>Trvání</dt><dd class="osa-mono">2,53 roku</dd></div>
                <div><dt>Project&nbsp;IRR</dt><dd class="osa-mono">59&nbsp;%</dd></div>
                <div><dt>Project&nbsp;ROI</dt><dd class="osa-mono">151&nbsp;%</dd></div>
                <div><dt>Gross&nbsp;Dev.&nbsp;Profit</dt><dd class="osa-mono">421&nbsp;mil.&nbsp;Kč</dd></div>
                <div><dt>Equity IRR <small>(LTC 70&nbsp;%)</small></dt><dd class="osa-mono"><span class="draft">145&nbsp;%</span></dd></div>
              </dl>
              <p class="osa-zvpd__phase-target">
                <span class="osa-eyebrow">Cílová skupina</span>
                Mladí kreativci, živnostníci, podnikatelé a studenti.
              </p>
            </article>

            {/* PHASE 2 */}
            <article class="osa-zvpd__phase">
              <header class="osa-zvpd__phase-head">
                <span class="osa-zvpd__phase-num">② Nová čtvrť</span>
                <span class="osa-mono osa-zvpd__phase-dates"><span class="draft">10/2030 → 11/2032</span></span>
              </header>
              <p class="osa-zvpd__phase-lede">
                Výstavba bytových domů na zbytku areálu, plně v souladu s platným ÚP od roku 2030. Moderní městská čtvrť se startupovým ekosystémem, plánovaná tramvaj a cyklostezka do Prahy.
              </p>
              <dl class="osa-zvpd__phase-metrics">
                <div><dt>ČPP bytů</dt><dd class="osa-mono"><span class="draft">88&nbsp;946&nbsp;m²</span></dd></div>
                <div><dt>HPP (podmíněně)</dt><dd class="osa-mono">118&nbsp;903&nbsp;m²</dd></div>
                <div><dt>Odhad. jednotek</dt><dd class="osa-mono"><span class="draft">≈ 1&nbsp;572</span></dd></div>
                <div><dt>Noví obyvatelé</dt><dd class="osa-mono"><span class="draft">≈ 2&nbsp;853</span></dd></div>
                <div><dt>Start výstavby</dt><dd class="osa-mono">≈ 10/2032</dd></div>
                <div><dt>Potenciál</dt><dd class="osa-mono">10+&nbsp;mld.&nbsp;Kč</dd></div>
              </dl>
              <p class="osa-zvpd__phase-target">
                <span class="osa-eyebrow">Hlavní zdroj výnosu</span>
                Prodej bytových jednotek v novostavbách.
              </p>
            </article>
          </div>

          {/* TIMELINE */}
          <div class="osa-zvpd__timeline" data-reveal data-reveal-delay="2" aria-label="Časová osa obou fází">
            <div class="osa-zvpd__timeline-years">
              <span>2026</span><span>2027</span><span>2028</span><span>2029</span><span>2030</span><span>2031</span><span>2032</span>
            </div>
            <div class="osa-zvpd__timeline-bars">
              <div class="osa-zvpd__timeline-bar osa-zvpd__timeline-bar--p1" style="left: 0%; width: 34%;">
                <span>① Startovací hub</span>
              </div>
              <div class="osa-zvpd__timeline-bar osa-zvpd__timeline-bar--op" style="left: 34%; width: 30%;">
                <span>Provoz hubu</span>
              </div>
              <div class="osa-zvpd__timeline-bar osa-zvpd__timeline-bar--p2" style="left: 64%; width: 36%;">
                <span>② Nová čtvrť</span>
              </div>
            </div>
          </div>
        </div>
      </SVGPattern>
    </section>

    {/* ===== PHOTO STRIP — vizualizace prvni faze ===== */}
    <section class="osa-zvpd__photostrip" aria-labelledby="strip1-title">
      <div class="container-wide osa-zvpd__photostrip-head" data-reveal>
        <span class="osa-eyebrow">Vizualizace · Startovací hub</span>
        <h3 id="strip1-title" class="osa-h3">Referenční podoba rekonstruovaných budov a komunitního zázemí.</h3>
      </div>
      <div class="osa-zvpd__photostrip-grid">
        <figure class="osa-zvpd__zoom" data-reveal>
          <button type="button" class="osa-zvpd__zoom-btn" data-lightbox-src={img('hub-market-daytime.jpg')} data-lightbox-alt="Průmyslová budova ve stylu tržnice s prosklenou střechou.">
            <img src={img('hub-market-daytime.jpg')} alt="Průmyslová budova ve stylu tržnice s prosklenou střechou, před ní dlážděná cesta a záhony." loading="lazy" decoding="async" />
          </button>
        </figure>
        <figure class="osa-zvpd__zoom" data-reveal data-reveal-delay="1">
          <button type="button" class="osa-zvpd__zoom-btn" data-lightbox-src={img('hub-market-evening.jpg')} data-lightbox-alt="Stejná tržnice za soumraku.">
            <img src={img('hub-market-evening.jpg')} alt="Stejná tržnice za soumraku, osvětlené interiéry prosvítají skrz okna." loading="lazy" decoding="async" />
          </button>
        </figure>
        <figure class="osa-zvpd__zoom" data-reveal data-reveal-delay="2">
          <button type="button" class="osa-zvpd__zoom-btn" data-lightbox-src={img('hub-courtyard-trees.jpg')} data-lightbox-alt="Vnitřní dvůr s trávníkem a břízami.">
            <img src={img('hub-courtyard-trees.jpg')} alt="Vnitřní dvůr s trávníkem, břízami a dlážděnou cestou mezi budovami." loading="lazy" decoding="async" />
          </button>
        </figure>
        <figure class="osa-zvpd__zoom" data-reveal data-reveal-delay="3">
          <button type="button" class="osa-zvpd__zoom-btn" data-lightbox-src={img('hub-courtyard-night.jpg')} data-lightbox-alt="Vnitřní dvůr večer, s řetězy světel mezi stromy.">
            <img src={img('hub-courtyard-night.jpg')} alt="Vnitřní dvůr večer, s řetězy světel mezi stromy a lidmi u stolů." loading="lazy" decoding="async" />
          </button>
        </figure>
      </div>
    </section>

    {/* ===== CHAPTER 03 · POTENCIÁL ===== */}
    <section class="osa-zvpd__chapter section" aria-labelledby="ch3-title">
      <div class="container-wide">
        <div class="osa-zvpd__chapter-head" data-reveal>
          <span class="osa-zvpd__chapter-mark">03</span>
          <div>
            <span class="osa-eyebrow">Kapitola 03</span>
            <h2 id="ch3-title" class="osa-h2 osa-zvpd__chapter-title">Potenciál</h2>
            <p class="osa-body osa-zvpd__chapter-lede">
              První fáze (Startovací hub) se zaplatí z vlastního provozu; druhá fáze (Nová čtvrť) otevírá potenciál v řádech miliard. Čísla platí pro stavební náklady k roku 2032 při inflaci 5&nbsp;%&nbsp;p.&nbsp;a.
            </p>
          </div>
        </div>

        {/* FINANCIAL CARDS — 4 column stat grid, mono */}
        <div class="osa-zvpd__finance" data-reveal data-reveal-delay="1">
          <div class="osa-zvpd__finance-card">
            <span class="osa-eyebrow">CAPEX 1.&nbsp;fáze</span>
            <strong class="osa-zvpd__finance-num">≈&nbsp;<span data-count-to="285" data-count-format="int">285</span></strong>
            <span class="osa-zvpd__finance-unit">mil. Kč</span>
          </div>
          <div class="osa-zvpd__finance-card">
            <span class="osa-eyebrow">Gross Dev. Profit</span>
            <strong class="osa-zvpd__finance-num"><span data-count-to="421" data-count-format="int">421</span></strong>
            <span class="osa-zvpd__finance-unit">mil. Kč · 1.&nbsp;fáze</span>
          </div>
          <div class="osa-zvpd__finance-card">
            <span class="osa-eyebrow">Project IRR</span>
            <strong class="osa-zvpd__finance-num"><span data-count-to="59" data-count-format="percent">59&nbsp;%</span></strong>
            <span class="osa-zvpd__finance-unit">za 2,53 roku</span>
          </div>
          <div class="osa-zvpd__finance-card">
            <span class="osa-eyebrow">Project ROI</span>
            <strong class="osa-zvpd__finance-num"><span data-count-to="151" data-count-format="percent">151&nbsp;%</span></strong>
            <span class="osa-zvpd__finance-unit">1.&nbsp;fáze</span>
          </div>
        </div>

        {/* AREÁL VALUE TABLE */}
        <div class="osa-zvpd__areal-wrap" data-reveal data-reveal-delay="2">
          <header class="osa-zvpd__subhead">
            <span class="osa-eyebrow">Celkový potenciál areálu</span>
            <h3 class="osa-h3">Sumární hodnota při prodeji všech jednotek (SH&nbsp;+&nbsp;nové).</h3>
          </header>
          <table class="osa-zvpd__areal">
            <thead>
              <tr>
                <th scope="col">Rok</th>
                <th scope="col">Kupní cena areálu</th>
                <th scope="col">Prodejní cena všech bytů</th>
                <th scope="col">Hrubý zisk</th>
              </tr>
            </thead>
            <tbody>
              <tr>
                <th scope="row">2032</th>
                <td class="osa-mono"><span class="draft">573 mil. Kč</span></td>
                <td class="osa-mono"><span class="draft">≈ 16,7 mld. Kč</span></td>
                <td class="osa-mono"><span class="draft">≈ 16,2 mld. Kč</span></td>
              </tr>
              <tr>
                <th scope="row">2038</th>
                <td class="osa-mono"><span class="draft">689 mil. Kč</span></td>
                <td class="osa-mono"><span class="draft">≈ 22,4 mld. Kč</span></td>
                <td class="osa-mono"><span class="draft">≈ 21,8 mld. Kč</span></td>
              </tr>
            </tbody>
          </table>
          <p class="osa-zvpd__areal-note">
            <span aria-hidden="true">*</span> Stavební náklady k&nbsp;roku 2032 při inflaci&nbsp;5&nbsp;%&nbsp;p.&nbsp;a. Hodnoty v&nbsp;<span class="draft">mustard poli</span> jsou odhadní; před zveřejněním se potvrdí s&nbsp;představenstvem VPD Klecany s.&nbsp;r.&nbsp;o.
          </p>
        </div>

        {/* OPERATING CF */}
        <div class="osa-zvpd__cf" data-reveal data-reveal-delay="3">
          <div>
            <span class="osa-eyebrow">Provozní cash&#8209;flow hubu (roční)</span>
            <p class="osa-body">
              <span class="draft">≈&nbsp;65&nbsp;mil.&nbsp;Kč</span> ročně z&nbsp;pronájmu jednotek po dokončení hubu, při <span class="draft">95&nbsp;% obsazenosti</span>. Gross yield <span class="draft">6,1&nbsp;%</span>. Tržní hodnota hubu po dokončení <span class="draft">≈&nbsp;1,07&nbsp;mld.&nbsp;Kč</span>.
            </p>
          </div>
        </div>
      </div>
    </section>

    {/* ===== FULL-BLEED BREAK 2 ===== */}
    <figure class="osa-zvpd__fullbleed osa-zvpd__zoom">
      <button type="button" class="osa-zvpd__zoom-btn" data-lightbox-src={img('hub-street-daytime.jpg')} data-lightbox-alt="Ulice areálu za denního světla." aria-label="Zobrazit fotografii: ulice areálu">
        <img
          src={img('hub-street-daytime.jpg')}
          alt="Ulice areálu za denního světla."
          loading="lazy"
          decoding="async" />
      </button>
    </figure>

    {/* ===== CHAPTER 04 · NOVÁ ČTVRŤ ===== */}
    <section class="osa-zvpd__chapter section" aria-labelledby="ch4-title">
      <div class="container-wide">
        <div class="osa-zvpd__chapter-head" data-reveal>
          <span class="osa-zvpd__chapter-mark">04</span>
          <div>
            <span class="osa-eyebrow">Kapitola 04</span>
            <h2 id="ch4-title" class="osa-h2 osa-zvpd__chapter-title">Nová čtvrť</h2>
            <p class="osa-body osa-zvpd__chapter-lede">
              Studie od tří různých autorů ukazují, jak může druhá fáze vypadat v praxi: bytové domy v souladu s ÚP, vnitrobloky s veřejnou zelení, parter pro služby a retail, pěší páteř od hubu k nové tramvajové zastávce.
            </p>
          </div>
        </div>
        <div class="osa-zvpd__students" data-reveal data-reveal-delay="1">
          <figure class="osa-zvpd__zoom">
            <button type="button" class="osa-zvpd__zoom-btn" data-lightbox-src={img('vision-student-1.jpg')} data-lightbox-alt="Studentská představa č. 1 — Petr Štoček.">
              <img src={img('vision-student-1.jpg')} alt="Studentská vizualizace náměstí s nízkými bytovými domy, stromy a pěší zónou." loading="lazy" decoding="async" />
            </button>
            <figcaption>Petr Štoček · studentská představa č.&nbsp;1</figcaption>
          </figure>
          <figure class="osa-zvpd__zoom">
