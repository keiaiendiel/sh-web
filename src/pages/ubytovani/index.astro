---
/*
 * L1 Ubytování , dvě srovnávací tabulky (Sdílené pokoje + Privátní apartmány)
 * generované přímo z kolekcí, plus upsell sekce Ubytovací zázemí a Ubytovací
 * služby (z src/data/landing.json). Tabulky vždy sedí na reálné varianty.
 */
import FractalPage from '../../layouts/FractalPage.astro';
import { getCollection } from 'astro:content';
import landing from '../../data/landing.json';

const sdilene = (await getCollection('sdilenePokoje'))
  .filter((e) => !e.data.hidden)
  .sort((a, b) => a.data.order - b.data.order);
const privatni = (await getCollection('apartmany'))
  .filter((e) => !e.data.hidden)
  .sort((a, b) => a.data.order - b.data.order);

const beds = (name: string) => (/dvojl/i.test(name) ? '2 lůžka' : '1 lůžko');

const sdileneRows = sdilene.map((e) => {
  const d = e.data;
  const area = d.spec.plochaKapsle || d.spec.plochaPokoj;
  return {
    label: d.name,
    note: `${area.split('(')[0].trim()} · ${beds(d.name)} · matrace ${d.matrace[0]}`,
    price: d.cena.anchor,
    priceNote: d.pricePending ? 'orientační' : undefined,
    flag: !!d.pricePending,
  };
});
const privatniRows = privatni.map((e) => {
  const d = e.data;
  return {
    label: d.name,
    note: `${d.plocha} · ${d.kapacita} lůžek`,
    price: d.cena.anchor,
  };
});

const zazemiItem = landing.items.find((i) => i.slug === 'ubytovaci-zazemi');
const sluzbyItem = landing.items.find((i) => i.slug === 'ubytovaci-sluzby');

const sections = [
  {
    id: 'sdilene',
    jumpLabel: 'Sdílené pokoje',
    title: 'Sdílené pokoje',
    lede: 'Platíte za lůžko nebo kapsli, ne za celý byt. Koupelnu a kuchyň sdílíte s ostatními rezidenty. Šest formátů od otevřeného lůžka po uzamykatelnou kapsli, seřazené od nejnižší ceny.',
    actions: [
      { label: 'Sdílené pokoje', href: '/ubytovani/sdilene-pokoje/', kind: 'detail' as const },
      { label: 'Rezervovat lůžko', href: '/rezervace/?cesta=luzko', kind: 'reserve' as const },
    ],
    media: [
      { src: '/images/hub/ubytovani/coliving/pokoj-basic-01.jpg', alt: 'Sdílený pokoj se světlým dubovým nábytkem' },
      { src: '/images/hub/ubytovani/coliving/pokoj-privacy-01.jpg', alt: 'Lůžkové boxy s posuvnými dveřmi' },
      { src: '/images/hub/ubytovani/coliving/kapsle-single-01.jpg', alt: 'Privátní uzamykatelná kapsle' },
    ],
    priceRows: sdileneRows,
    priceCaption: 'Anchor cena za měsíc',
  },
  {
    id: 'privatni',
    jumpLabel: 'Privátní apartmány',
    title: 'Privátní apartmány',
    lede: 'Celý byt jen pro vás: vlastní koupelna, kuchyň i vchod. Pět velikostí od 1+kk pro pár po 5+kk pro skupinu deseti. Cena platí za celý byt, takže čím víc vás bude, tím nižší nájem na osobu.',
    actions: [
      { label: 'Privátní apartmány', href: '/ubytovani/privatni/', kind: 'detail' as const },
      { label: 'Rezervovat apartmán', href: '/rezervace/?cesta=apartman', kind: 'reserve' as const },
    ],
    media: [
      { src: '/images/hub/ubytovani/privatni/02-1kk.jpg', alt: 'Privátní apartmán 1+kk' },
      { src: '/images/hub/ubytovani/privatni/03-ext.jpg', alt: 'Exteriér obytné budovy' },
      { src: '/images/hub/ubytovani/privatni/05-4kk-family.jpg', alt: 'Větší apartmán pro skupinu' },
    ],
    priceRows: privatniRows,
    priceCaption: 'Anchor cena za celý byt a měsíc',
  },
  ...(zazemiItem
    ? [{ id: 'zazemi', jumpLabel: 'Ubytovací zázemí', title: zazemiItem.name, lede: zazemiItem.lede, blocks: zazemiItem.blocks ?? [], actions: [{ label: 'Zázemí areálu', href: '/zazemi/', kind: 'detail' as const }] }]
    : []),
  ...(sluzbyItem
    ? [{ id: 'sluzby', jumpLabel: 'Ubytovací služby', title: sluzbyItem.name, lede: sluzbyItem.lede, blocks: sluzbyItem.blocks ?? [] }]
    : []),
];
---
<FractalPage
  title="Ubytování , privátní apartmány a sdílené pokoje · Startovací Hub Klecany"
  description="Šest formátů sdílených pokojů od 3 000 Kč a pět privátních apartmánů 1+kk až 5+kk. Energie, internet a coworking v ceně. Srovnejte ceny a rezervujte si místo."
  hero={{
    eyebrow: 'Ubytování',
    title: 'Privátní apartmán, nebo <em>sdílený pokoj</em>',
    sub: 'Šest formátů sdílených pokojů od 3 000 Kč a pět privátních apartmánů 1+kk až 5+kk. Energie, internet a coworking v ceně.',
    variant: 'cream',
    ariaId: 'ubytovani',
  }}
  sections={sections}
  cta={{
    eyebrow: 'Rezervace',
    title: 'Rezervujte si <em>místo</em>',
    lede: 'Vyberete formát, termín a způsob kontaktu. Z rezervačního oddělení vám zavoláme do 24 hodin. Nezávazná registrace zájmu.',
    cta: { label: 'Nezávazná rezervace', href: '/rezervace/' },
    variant: 'deep',
  }}
  crossLinks={[
    { eyebrow: 'Zázemí', title: 'Coworking, wellness a <em>gastro</em>', href: '/zazemi/', variant: 'ink' },
    { eyebrow: 'Stipendia', title: 'Bydlení <em>za přínos</em> komunitě', href: '/stipendia/', variant: 'rose' },
  ]}
/>
