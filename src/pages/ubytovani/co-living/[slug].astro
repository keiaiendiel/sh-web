---
import Base from '../../../layouts/Base.astro';
import Gallery from '../../../components/Gallery.astro';
import { getCollection, render } from 'astro:content';
import { withBase } from '../../../utils/url';

export async function getStaticPaths() {
  const coliving = await getCollection('coliving');
  return coliving.map((entry) => ({
    params: { slug: entry.data.slug },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { data } = entry;
const { Content } = await render(entry);

const heroSrc = data.hero ? withBase(data.hero) : null;
const formatCena = (n: number) => `${n.toLocaleString('cs-CZ')} Kč`;

type GalleryItem = { src: string; alt: string } | { placeholder: string; alt: string };
const galleryImages: GalleryItem[] = [
  ...(heroSrc ? [{ src: heroSrc, alt: data.heroAlt ?? '' } as GalleryItem] : []),
  { placeholder: 'Společný pokoj nebo lounge před kapslemi, lavice, rostliny, knihovna', alt: 'Společný prostor s pody.' },
  { placeholder: 'Sdílená koupelna a kuchyňka pro coliving rezidenty', alt: 'Sdílené zázemí coliving patra.' },
];
---
<Base
  title={`${data.name} · Startovací Hub Klecany`}
  description={data.popis}
  headerVariant="light">

  <section class="apt-gallery" aria-label={`Galerie typu ${data.name}`}>
    <div class="apt-gallery__inner">
      <aside class="apt-gallery__side">
        <a class="apt-gallery__eyebrow osa-nolink" href={withBase('/ubytovani/#ub-coliving-title')}>Co-living<span aria-hidden="true"> →</span></a>
        <h2 class="apt-gallery__title">{data.name}</h2>
        <p class="apt-gallery__lede">{data.popis}</p>
        <p class="apt-gallery__price">
          <span class="apt-gallery__num">{formatCena(data.cena.anchor)}</span>
          <span class="apt-gallery__unit">/měsíc</span>
          {data.cena.perOsoba && <small class="apt-gallery__per"> ({data.cena.perOsoba})</small>}
        </p>
        <a class="apt-gallery__cta osa-nolink" href={withBase(`/rezervace/?typ=${data.slug}`)}>
          Rezervovat<span aria-hidden="true"> →</span>
        </a>
      </aside>
      <div class="apt-gallery__media">
        <Gallery images={galleryImages} ariaLabel={`Galerie typu ${data.name}`} aspectRatio="4 / 3" />
      </div>
    </div>
  </section>

  <section class="apt-body">
    <div class="apt-body__inner">
      <div class="apt-body__text">
        <Content />

        <h2 class="apt-body__sub">Co k tomu patří</h2>
        <ul class="apt-body__bullets">
          {data.klicove.map((k) => (<li>{k}</li>))}
        </ul>
      </div>

      <aside class="apt-body__spec">
        <h2 class="apt-body__sub">Specifikace</h2>
        <dl class="apt-spec">
          {data.spec.plochaKapsle && <div><dt>Plocha kapsle</dt><dd>{data.spec.plochaKapsle}</dd></div>}
          <div><dt>Plocha pokoje</dt><dd>{data.spec.plochaPokoj}</dd></div>
          <div><dt>Matrace</dt><dd>{data.matrace.join(' nebo ')}</dd></div>
          <div><dt>Vlastní koupelna</dt><dd>{data.spec.koupelna}</dd></div>
          <div><dt>Kuchyň</dt><dd>{data.spec.kuchyn}</dd></div>
          {data.spec.sklon && <div><dt>Spolubydlení</dt><dd>{data.spec.sklon}</dd></div>}
        </dl>
      </aside>
    </div>
  </section>

  <section class="apt-cena">
    <div class="apt-cena__inner">
      <p class="apt-cena__eyebrow">Cena</p>
      <h2 class="apt-cena__title">Co-living cena.</h2>
      <p class="apt-cena__price">
        <span class="apt-cena__num">{formatCena(data.cena.anchor)}</span>
        <span class="apt-cena__unit">/měsíc</span>
        {data.cena.perOsoba && <small class="apt-cena__per"> ({data.cena.perOsoba})</small>}
      </p>
      <p class="apt-cena__lede">
        {data.cena.perOsoba
          ? 'Cena je za kapsli nebo pokoj, sdílíte ji s druhou osobou. Per-osoba kalkulace předpokládá plnou obsazenost.'
          : 'Cena je za jednoho rezidenta.'}
        Pro rezervaci s právem prodloužit pobyt si připravte přibližně 5 až 10 %
        nad základní cenu.
      </p>
      <p class="apt-cena__note">
        Vše v ceně: energie, internet, úklid společných prostor, 5 jízd Hub-shuttle do metra Kobylisy a 1 jízda Hub-taxi po Klecanech měsíčně, přístup do coworkingového sálu, poukaz do sauny 1× týdně.
      </p>
    </div>
  </section>

  <section class="apt-cta">
    <div class="apt-cta__inner">
      <h2 class="apt-cta__title">Rezervace</h2>
      <p class="apt-cta__lede">
        Rezervace je nezávazná. Vyplníte termín nástupu, délku pobytu a kontakt.
        Z rezervačního oddělení vám zavoláme do 24 hodin.
      </p>
      <a class="apt-cta__button" href={withBase(`/rezervace/?typ=${data.slug}`)}>
        Rezervace
      </a>
    </div>
  </section>
</Base>

<style>
  /* Sdílí styling s /ubytovani/privatni/[slug].astro. Pokud bys chtěl refaktorovat,
     extrahuj společné styly do `kit.css` jako .apt-* utility classes. Pro Phase 3
     držíme inline a kopii. */
  /* === GALERIE === */
  .apt-gallery { padding: var(--space-8) var(--gutter); background: var(--bg-muted); color: var(--fg); }
  .apt-gallery__inner { display: grid; grid-template-columns: minmax(0, 1fr) minmax(0, 1.6fr); gap: clamp(28px, 4vw, 56px); max-width: var(--container-wide); margin: 0 auto; align-items: start; }
  .apt-gallery__side { display: flex; flex-direction: column; gap: var(--space-3); position: sticky; top: 100px; }
  .apt-gallery__eyebrow { font: 600 var(--text-2xs) / 1 var(--font-sans); color: var(--accent); letter-spacing: var(--tracking-wider); text-transform: uppercase; margin: 0; display: inline-flex; align-items: center; gap: 4px; width: fit-content; text-decoration: none; border-bottom: 1px solid transparent; transition: border-color 200ms ease; }
  .apt-gallery__eyebrow:hover, .apt-gallery__eyebrow:focus-visible { border-bottom-color: currentColor; outline: none; }
  .apt-gallery__title { font: 600 clamp(1.75rem, 3vw, 2.25rem) / 1.15 var(--font-sans); letter-spacing: var(--tracking-tight); margin: 0; }
  .apt-gallery__lede { font-size: var(--text-md); line-height: 1.55; margin: var(--space-2) 0 var(--space-4); color: var(--fg-soft, var(--fg)); max-width: 38ch; }
  .apt-gallery__price { display: flex; align-items: baseline; gap: 6px; margin: 0 0 var(--space-4); flex-wrap: wrap; }
  .apt-gallery__num { font: 600 clamp(1.75rem, 3vw, 2.25rem) / 1 var(--font-sans); color: var(--accent); letter-spacing: var(--tracking-tight); }
  .apt-gallery__unit { font: 500 var(--text-md) / 1 var(--font-sans); color: var(--fg-soft, var(--fg)); }
  .apt-gallery__per { font: 500 var(--text-sm) / 1 var(--font-sans); color: var(--fg-muted, var(--fg)); }
  .apt-gallery__cta { display: inline-flex; align-items: center; gap: 6px; padding: 12px 22px; font: 600 var(--text-sm) / 1 var(--font-sans); color: var(--accent-on); background: var(--accent); border: 1px solid var(--accent); border-radius: var(--radius-input); text-decoration: none; width: fit-content; transition: background 200ms ease, color 200ms ease; }
  .apt-gallery__cta:hover, .apt-gallery__cta:focus-visible { background: transparent; color: var(--accent); outline: none; }
  .apt-gallery__media { min-width: 0; }
  @media (max-width: 760px) {
    .apt-gallery__inner { grid-template-columns: 1fr; gap: var(--space-5); }
    .apt-gallery__side { position: static; top: auto; }
  }

  .apt-body { padding: var(--space-8) var(--gutter); background: var(--bg); color: var(--fg); }
  .apt-body__inner { display: grid; grid-template-columns: 1.4fr 1fr; gap: var(--space-7); max-width: var(--container); margin: 0 auto; }
  .apt-body__text :global(p) { line-height: 1.65; margin: 0 0 var(--space-4); font-size: var(--text-md); max-width: 60ch; }
  .apt-body__text :global(ul) { margin: 0 0 var(--space-4); padding: 0; list-style: none; display: grid; gap: var(--space-2); }
  .apt-body__text :global(ul li) { padding-left: var(--space-4); position: relative; line-height: 1.5; max-width: 60ch; }
  .apt-body__text :global(ul li::before) { content: ""; position: absolute; left: 0; top: 0.65em; width: 8px; height: 8px; background: var(--accent); }
  .apt-body__text :global(p strong) { font-weight: 600; }
  .apt-body__sub { font: 600 var(--text-xl) / 1.2 var(--font-sans); margin: var(--space-7) 0 var(--space-4); letter-spacing: var(--tracking-tight); }
  .apt-body__spec .apt-body__sub:first-child { margin-top: 0; }
  .apt-body__bullets { margin: 0; padding: 0; list-style: none; display: grid; gap: var(--space-2); }
  .apt-body__bullets li { padding-left: var(--space-4); position: relative; line-height: 1.5; }
  .apt-body__bullets li::before { content: ""; position: absolute; left: 0; top: 0.65em; width: 8px; height: 8px; background: var(--accent); }

  .apt-spec { display: grid; gap: var(--space-3); margin: 0; }
  .apt-spec > div { display: grid; grid-template-columns: 1fr 1.4fr; gap: var(--space-3); padding: var(--space-3) 0; border-top: 1px solid var(--rule, rgba(0,0,0,0.08)); }
  .apt-spec > div:first-child { border-top: 0; padding-top: 0; }
  .apt-spec dt { font: 600 var(--text-2xs) / 1.3 var(--font-sans); letter-spacing: var(--tracking-wider); text-transform: uppercase; color: var(--fg-muted); }
  .apt-spec dd { margin: 0; font-size: var(--text-sm); line-height: 1.5; }

  @media (max-width: 880px) {
    .apt-body__inner { grid-template-columns: 1fr; }
  }

  .apt-cena { padding: var(--space-8) var(--gutter); background: var(--bg-muted, var(--bg)); color: var(--fg); }
  .apt-cena__inner { max-width: var(--container); margin: 0 auto; }
  .apt-cena__eyebrow { font: 600 var(--text-2xs) / 1 var(--font-sans); color: var(--accent); letter-spacing: var(--tracking-wider); text-transform: uppercase; margin: 0 0 var(--space-3); }
  .apt-cena__title { font: 600 clamp(1.5rem, 3vw, 2.25rem) / 1.15 var(--font-sans); margin: 0 0 var(--space-4); letter-spacing: var(--tracking-tight); }
  .apt-cena__price { display: flex; align-items: baseline; flex-wrap: wrap; gap: 8px; margin: 0 0 var(--space-4); }
  .apt-cena__num { font: 600 clamp(2rem, 4vw, 2.75rem) / 1 var(--font-sans); color: var(--accent); letter-spacing: var(--tracking-tight); font-variant-numeric: tabular-nums; }
  .apt-cena__unit { font: 500 var(--text-md) / 1 var(--font-sans); color: var(--fg); }
  .apt-cena__per { font: 400 var(--text-sm) / 1.4 var(--font-sans); color: var(--fg-muted); }
  .apt-cena__lede { color: var(--fg-muted); margin: 0 0 var(--space-5); max-width: 60ch; line-height: 1.5; }
  .apt-cena__note { font-size: var(--text-sm); color: var(--fg-muted); margin: var(--space-5) 0 0; line-height: 1.5; max-width: 60ch; padding-top: var(--space-4); border-top: 1px solid var(--border-muted); }

  .apt-cta { padding: var(--space-8) var(--gutter); background: var(--accent); color: #fff; text-align: center; }
  .apt-cta__inner { max-width: 640px; margin: 0 auto; }
  .apt-cta__title { font: 600 clamp(1.75rem, 3.5vw, 2.5rem) / 1.15 var(--font-sans); margin: 0 0 var(--space-3); letter-spacing: var(--tracking-tight); }
  .apt-cta__lede { font-size: var(--text-md); line-height: 1.5; margin: 0 0 var(--space-5); opacity: 0.92; }
  .apt-cta__button { display: inline-block; padding: 14px 32px; font: 700 var(--text-md) / 1 var(--font-sans); color: var(--accent); background: #fff; border: 1px solid #fff; border-radius: var(--radius-input); text-decoration: none; transition: background 200ms ease, color 200ms ease; }
  .apt-cta__button:hover { background: transparent; color: #fff; }
</style>
