---
import Base from '../../layouts/Base.astro';
import { withBase } from '../../utils/url';
import { getCollection } from 'astro:content';

const cards = (await getCollection('subProjects')).sort((a, b) => a.data.order - b.data.order);

const buildingLabel = (id: string) => {
  switch (id) {
    case 'komunitni-centrum':  return 'Objekt B';
    case 'coworking-centrum':  return 'Přízemí budovy C';
    case 'komunitni-pivovar':  return 'Objekt B';
    case 'sauna-bazen':        return 'Objekty D + E';
    case 'sportoviste-park':   return 'Park před objektem B';
    default:                   return 'Areál';
  }
};

const childServices = (id: string): string[] => {
  switch (id) {
    case 'komunitni-centrum':  return ['Tržnice', 'Kavárna', 'Pekárna', 'Restaurace + hospoda', 'Sdílené dílny', 'Food-trucky'];
    case 'coworking-centrum':  return ['Coworkingový sál s pódiem', 'Ateliéry', 'Nahrávací studia', 'Studovny', 'Zasedací místnosti', 'Recepce'];
    case 'komunitni-pivovar':  return ['Varna a stáčírna', 'Hospoda', 'Work-trade pro rezidenty'];
    case 'sauna-bazen':        return ['Finská sauna', 'Outdoor cool-down deck', 'Venkovní bazén', 'Saunové ceremoniály'];
    case 'sportoviste-park':   return ['Komunitní park', 'Telocvična na vzduchu', 'Ping-pong', 'Dětské hřiště', 'Komunitní zahrádky', 'Grilovací místa'];
    default:                   return [];
  }
};
---
<Base
  title="Areál a komunitní zázemí · Startovací Hub Klecany"
  description="Komunitní centrum s pekárnou a kavárnou, coworking s ateliéry a nahrávacími studii, minipivovar, sauna a bazén, sportoviště a park. Pět provozů v jednom areálu — sdílené zázemí pro všechny rezidenty Hubu."
  headerVariant="dark"
>
  <section class="pj-hero osa-dark">
    <img class="pj-hero__bg" src={withBase('/images/hub/aerial/buildings-a-c.jpg')} alt="" aria-hidden="true" loading="eager" decoding="async" />
    <div class="pj-hero__scrim" aria-hidden="true"></div>
    <div class="pj-hero__inner">
      <span class="osa-eyebrow pj-hero__eyebrow">Areál a zázemí</span>
      <h1 class="pj-hero__title">Pět provozů, jeden areál.</h1>
      <p class="pj-hero__lede">Komunitní centrum s pekárnou a kavárnou; coworking s ateliéry a nahrávacími studii; minipivovar; sauna a bazén; park s tělocvičnou na vzduchu. Všechno v rámci jednoho areálu, všechno v ceně nájmu.</p>
    </div>
  </section>

  <section class="pj-masterplan" aria-labelledby="pj-masterplan-heading">
    <header class="pj-masterplan__head">
      <span class="osa-eyebrow">Masterplan</span>
      <h2 id="pj-masterplan-heading" class="pj-masterplan__heading">Kde co najdete v areálu.</h2>
      <p class="pj-masterplan__lede">Pět provozů sedí ve čtyřech objektech kolem centrálního dvora. Komunitní centrum, pivovar a sportoviště + park v okolí budovy B, coworking v přízemí budovy C, sauna v objektu E, bazén před objektem D.</p>
    </header>
    <figure class="pj-masterplan__figure">
      <img src={withBase('/images/hub/masterplan_fotoreal.jpg')} alt="Fotorealistický masterplan areálu Horních kasáren — popisky budov A1–A6, B, C, D, E, F, P, S a venkovního bazénu v kontextu celého rozvojového území." loading="lazy" decoding="async" />
    </figure>
  </section>

  <section class="pj-grid-section">
    <div class="pj-grid">
      {cards.map((p) => (
        <a class="pj-card" href={withBase(`/areal/${p.id}/`)}>
          <div class="pj-card__thumb" aria-hidden="true" data-img-reveal>
            {p.data.thumbnail
              ? <img src={p.data.thumbnail} alt="" loading="lazy" />
              : <span class="pj-card__placeholder">Vizualizaci připravujeme</span>
            }
          </div>
          <div class="pj-card__body">
            <span class="osa-eyebrow pj-card__building">{buildingLabel(p.id)}</span>
            <h2 class="pj-card__name">{p.data.name}</h2>
            <p class="pj-card__role">{p.data.role}</p>
            {childServices(p.id).length > 0 && (
              <ul class="pj-card__services" aria-label="Provozy a služby v tomto celku">
                {childServices(p.id).map((s) => <li>{s}</li>)}
              </ul>
            )}
            <span class="pj-card__cta">Detail →</span>
          </div>
        </a>
      ))}
    </div>
    <p class="pj-foot-note">Pokud máte nápad na další provoz nebo iniciativu v areálu, napište na <a href="mailto:info@startovacihub.cz">info@startovacihub.cz</a>.</p>
  </section>
</Base>

<style>
  .pj-hero {
    position: relative;
    isolation: isolate;
    min-height: clamp(360px, 50vh, 480px);
    display: flex;
    align-items: flex-end;
    background: var(--k-100);
    color: #fff;
    overflow: hidden;
  }
  .pj-hero__bg {
    position: absolute; inset: 0;
    width: 100%; height: 100%;
    object-fit: cover;
    filter: brightness(0.85);
    z-index: 1;
    object-position: center 35%;
  }
  .pj-hero__scrim {
    position: absolute; inset: 0; z-index: 2;
    background: linear-gradient(180deg, rgba(0,0,0,0) 0%, rgba(0,0,0,0.20) 55%, rgba(0,0,0,0.50) 100%);
    pointer-events: none;
  }
  .pj-hero__inner {
    position: relative; z-index: 3;
    padding: clamp(56px, 9vw, 96px) var(--gutter) clamp(40px, 6vw, 72px);
    max-width: var(--container-wide); margin: 0 auto; width: 100%;
  }
  .pj-hero__inner > * { max-width: 760px; }
  .pj-hero__eyebrow { color: rgba(255,255,255,0.78); display: inline-block; margin-bottom: 14px; }
  .pj-hero__title {
    font-family: var(--font-sans);
    font-size: clamp(36px, 5.5vw, 64px);
    font-weight: 600;
    line-height: 1.04;
    letter-spacing: var(--tracking-tight);
    margin: 0 0 20px;
    text-wrap: balance;
  }
  .pj-hero__lede {
    font-size: clamp(16px, 1.4vw, 19px);
    line-height: 1.55;
    color: rgba(255,255,255,0.88);
    margin: 0;
    max-width: 56ch;
  }

  .pj-masterplan {
    padding: clamp(40px, 6vw, 72px) var(--gutter) clamp(8px, 1vw, 16px);
    max-width: var(--container-wide); margin: 0 auto;
  }
  .pj-masterplan__head { max-width: 720px; display: grid; gap: 8px; margin: 0 0 24px; }
  .pj-masterplan__heading {
    font-family: var(--font-sans);
    font-size: clamp(24px, 2.6vw, 36px);
    font-weight: 600;
    margin: 0;
    letter-spacing: var(--tracking-tight);
    line-height: 1.15;
    text-wrap: balance;
  }
  .pj-masterplan__lede {
    font-size: clamp(15px, 1.25vw, 17px);
    line-height: 1.55;
    color: var(--fg-muted);
    margin: 4px 0 0;
    max-width: 64ch;
  }
  .pj-masterplan__figure {
    margin: 0;
    border: 1px solid var(--border-muted);
    border-radius: var(--radius-input);
    overflow: hidden;
    background: var(--bg);
  }
  .pj-masterplan__figure img { width: 100%; height: auto; display: block; }

  .pj-grid-section {
    padding: clamp(32px, 5vw, 64px) var(--gutter) clamp(64px, 10vw, 96px);
    max-width: var(--container-wide); margin: 0 auto;
  }
  .pj-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 24px;
  }
  @media (max-width: 960px) { .pj-grid { grid-template-columns: repeat(2, minmax(0, 1fr)); } }
  @media (max-width: 600px) { .pj-grid { grid-template-columns: 1fr; } }

  .pj-card {
    display: grid;
    grid-template-rows: auto 1fr;
    border: 1px solid var(--accent-rule);
    border-radius: var(--radius-input);
    background: var(--bg);
    text-decoration: none;
    color: inherit;
    overflow: hidden;
    transition: border-color var(--dur-base) var(--ease-decel), transform var(--dur-base) var(--ease-decel);
  }
  .pj-card:hover { border-color: var(--accent); transform: translateY(-2px); }
  .pj-card__thumb { aspect-ratio: 4/3; background: var(--k-05); display: grid; place-items: center; overflow: hidden; }
  .pj-card__thumb img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .pj-card__placeholder {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--fg-subtle);
  }
  .pj-card__body { display: grid; gap: 8px; padding: 20px 22px 22px; }
  .pj-card__building { color: var(--accent); display: block; }
  .pj-card__name {
    font-family: var(--font-sans);
    font-size: 19px; font-weight: 600;
    margin: 4px 0 0;
    line-height: 1.25;
    letter-spacing: var(--tracking-tight);
  }
  .pj-card__role { font-size: 14px; line-height: 1.55; color: var(--fg-muted); margin: 0; }
  .pj-card__services { list-style: none; padding: 0; margin: 4px 0 0; display: flex; flex-wrap: wrap; gap: 6px; }
  .pj-card__services li {
    display: inline-flex;
    align-items: center;
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--accent);
    line-height: 1;
    padding: 7px 12px 6px;
    background: var(--accent-soft);
    border: 1px solid var(--accent-rule);
    border-radius: 999px;
    white-space: nowrap;
    transition: background var(--dur-base) var(--ease-decel), border-color var(--dur-base) var(--ease-decel);
  }
  .pj-card:hover .pj-card__services li { border-color: var(--accent); background: rgba(90, 42, 95, 0.10); }
  .pj-card__cta { margin-top: 8px; font-size: 13px; font-weight: 600; color: var(--accent); letter-spacing: 0.02em; }

  .pj-foot-note {
    margin: 40px 0 0;
    font-size: 14px; line-height: 1.55;
    color: var(--fg-muted);
    max-width: 720px;
  }
  .pj-foot-note a { color: var(--accent); }
  .pj-foot-note a:hover { text-decoration: underline; }
</style>
