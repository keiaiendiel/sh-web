---
/*
 * Stipendia , L1. Tři sekce (Pobytové, Projektové, Nadace VPD) s akčními
 * tlačítky. Obsah z src/data/stipendia.json.
 *
 * Pozn.: donátorská CTA zatím vedou na mailto vpd@osa2.cz (nemají cílovou
 * stránku). Donátorská větev možná patří na vepde.com , k potvrzení s Markem.
 */
import FractalPage from '../../layouts/FractalPage.astro';
import data from '../../data/stipendia.json';

type Action = { label: string; href: string; kind: 'reserve' | 'detail' | 'link'; external?: boolean };

const actionsBySlug: Record<string, Action[]> = {
  'pobytove-stipendium': [
    { label: 'Požádat o pobytové stipendium', href: '/rezervace/?cesta=stipendium', kind: 'reserve' },
    { label: 'Stát se donátorem', href: 'mailto:vpd@osa2.cz?subject=Donátorství%20pobytové%20stipendium', kind: 'link', external: true },
  ],
  'projektove-stipendium': [
    { label: 'Požádat o projektové stipendium', href: '/rezervace/?cesta=stipendium', kind: 'reserve' },
    { label: 'Stát se donátorem', href: 'mailto:vpd@osa2.cz?subject=Donátorství%20projektové%20stipendium', kind: 'link', external: true },
  ],
  'nadace-vpd': [
    { label: 'Stát se donátorem', href: 'mailto:vpd@osa2.cz?subject=Donátorství%20Nadace%20VPD', kind: 'reserve', external: true },
    { label: 'Stát se sponzorem', href: 'mailto:vpd@osa2.cz?subject=Sponzorství%20Nadace%20VPD', kind: 'link', external: true },
    { label: 'Stát se členem správní rady', href: 'mailto:vpd@osa2.cz?subject=Správní%20rada%20Nadace%20VPD', kind: 'link', external: true },
  ],
};

const sections = data.items.map((it) => {
  const blocks = [...(it.blocks ?? [])];
  if (it.priceNote) blocks.push({ subtitle: 'Co to pokrývá', text: it.priceNote });
  return {
    id: it.slug,
    jumpLabel: it.name,
    title: it.name,
    lede: it.lede,
    blocks,
    actions: actionsBySlug[it.slug] ?? [],
    media: it.images ?? [],
  };
});
---
<FractalPage
  title="Stipendia , pobytové a projektové · Startovací Hub Klecany"
  description={data.intro.lede}
  hero={{
    eyebrow: 'Stipendia',
    title: 'Pobytové, nebo <em>projektové</em>',
    sub: data.intro.lede,
    variant: 'rose',
    ariaId: 'stipendia',
  }}
  sections={sections}
  cta={{
    eyebrow: 'Žádost',
    title: 'Požádejte o <em>stipendium</em>',
    lede: 'Při registraci zájmu zaškrtnete přepínač stipendia. Jakmile otevřeme první kolo, ozveme se s konkrétními podmínkami.',
    cta: { label: 'Požádat o stipendium', href: '/rezervace/?cesta=stipendium' },
    variant: 'deep',
  }}
  crossLinks={[
    { eyebrow: 'Ubytování', title: 'Kde budete <em>bydlet</em>', href: '/ubytovani/', variant: 'cream' },
    { eyebrow: 'Zázemí', title: 'Dílny, ateliéry a <em>komunita</em>', href: '/zazemi/', variant: 'ink' },
  ]}
/>
