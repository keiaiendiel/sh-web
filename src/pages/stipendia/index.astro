---
import Base from '../../layouts/Base.astro';
import SubpageHero from '../../components/SubpageHero.astro';
import CtaBanner from '../../components/CtaBanner.astro';
import CrossLinkPair from '../../components/CrossLinkPair.astro';
import QuickReserveCtas from '../../components/QuickReserveCtas.astro';
import { withBase } from '../../utils/url';

const heroJumps = [
  { label: 'Pobytové stipendium',  href: '#st-pobytove' },
  { label: 'Projektové stipendium', href: '#st-projektove' },
];
---
<Base
  title="Pobytové a projektové stipendium · Startovací Hub Klecany"
  description="Dvě hlavní kategorie stipendií. Pobytové pokrývá bydlení v Hubu za přínos komunitě. Projektové proplatí materiál, dílenský čas a ateliérový nájem konkrétního projektu."
  headerVariant="overlay">

  <SubpageHero
    eyebrow="Stipendijní programy"
    title="Pobytové <em>nebo</em> projektové."
    sub="Dvě hlavní kategorie. Nadační fond Hubu podporuje lidi, kteří mají co dát zpátky: dílny, otevřené prezentace, péče o areál nebo veřejně dostupný výstup projektu."
    variant="cream"
    ribbonPath="M 1200 720 C 1380 380, 1740 240, 2080 380"
    ribbonPathSecondary="M 1280 780 C 1460 460, 1780 320, 2080 460 M 1140 680 C 1340 320, 1740 180, 2080 320 M 1080 640 C 1300 260, 1740 100, 2080 240"
    thickness={48}
    thicknessSecondary={26}
    opacitySecondary={0.4}
    jumps={heroJumps}
    ariaId="stipendia-hero"
  />

  {/* ============ DVĚ KATEGORIE STIPENDIA SIDE-BY-SIDE ============
       Mřížka 2 sloupců na desktopu, 1 sloupec na phone. Každá karta
       má vlastní --section-hue (Pobytové=130 green, Projektové=50 gold)
       + sec-hued recipe (bg wash + blob), aby byly vizuálně oddělené
       od sebe a vystihovaly „dvě cesty". */}
  <section class="stip-types" aria-label="Dvě kategorie stipendia">
    <div class="stip-types__inner">

      {/* === POBYTOVÉ STIPENDIUM === */}
      <article class="stip-card sec-hued" style="--section-hue: 130;" aria-labelledby="st-pobytove">
        <header class="stip-card__head">
          <p class="stip-card__eyebrow">Pobytové stipendium</p>
          <h2 class="stip-card__title" id="st-pobytove">Bydlíte v Hubu výměnou za přínos komunitě.</h2>
          <p class="stip-card__lede">
            Není to dárek. Hub vám sleví nebo dá bydlení zdarma, vy mu vrátíte dovednost, čas
            nebo projekt s veřejným výstupem. Délka tři měsíce až rok.
          </p>
        </header>

        <div class="stip-card__block">
          <h3 class="stip-card__sub">Pro koho dává smysl</h3>
          <p>
            Tvůrci s konkrétním projektem, programátoři, stavebně zruční, praktici předávající
            dovednost. Studenti na semestrální stáži. Lidé po rodičovské hledající měkký restart.
          </p>
        </div>

        <div class="stip-card__block">
          <h3 class="stip-card__sub">Co dostanete</h3>
          <ul class="stip-list">
            <li>Bydlení v jedné z devíti variant (kapsle, sdílený pokoj, apartmán, po dohodě i s rodinou)</li>
            <li>Všechny rezidentské benefity v ceně</li>
            <li>U rolí s pracovním závazkem peněžní příspěvek nebo DPP</li>
          </ul>
        </div>

        <div class="stip-card__block">
          <h3 class="stip-card__sub">Čtyři role, vyberete si jednu</h3>
          <ul class="stip-list stip-list--roles">
            <li><strong>Rezident-tvůrce</strong> , umělec nebo autor s vlastním projektem. Tříměsíční pobyt za dvě otevřené dílny a závěrečnou dokumentaci.</li>
            <li><strong>Správce</strong> , 32 až 40 hodin měsíčně v provozu Hubu (recepce, koordinace akcí, péče o sdílené prostory).</li>
            <li><strong>Stavitel</strong> , týden v měsíci na rekonstrukci areálu, zbytek vlastní práce. Pro lidi se stavebními dovednostmi.</li>
            <li><strong>Programátor</strong> , postaví konkrétní digitální nástroj pro Hub s deliverable na konci.</li>
          </ul>
        </div>

        <a class="stip-card__cta osa-nolink" href={withBase('/rezervace/?cesta=stipendium')}>
          Požádat o pobytové<span aria-hidden="true"> →</span>
        </a>
      </article>

      {/* === PROJEKTOVÉ STIPENDIUM === */}
      <article class="stip-card sec-hued" style="--section-hue: 50;" aria-labelledby="st-projektove">
        <header class="stip-card__head">
          <p class="stip-card__eyebrow">Projektové stipendium</p>
          <h2 class="stip-card__title" id="st-projektove">Fond proplatí materiál, dílny a ateliér konkrétního projektu.</h2>
          <p class="stip-card__lede">
            Není to grant na živobytí. Fond pokryje konkrétní náklady projektu výměnou za
            veřejný výstup a zpětnou vazbu komunitě. Bydlení řešíte zvlášť.
          </p>
        </header>

        <div class="stip-card__block">
          <h3 class="stip-card__sub">Pro koho dává smysl</h3>
          <p>
            Tvůrci s konkrétním projektem a rozpočtem do 30 000 Kč. Studenti uměleckých škol
            dokončující závěrečnou práci. Designéři prototypující malou sérii. Vědci a hackeři
            potřebující dílenský přístup. Komunitní iniciativy s materiálovými náklady.
          </p>
        </div>

        <div class="stip-card__block">
          <h3 class="stip-card__sub">Co fond proplatí</h3>
          <ul class="stip-list">
            <li><strong>Materiál a komponenty</strong> , dřevo, kov, sklo, textil, elektronika, 3D filament, chemie.</li>
            <li><strong>Dílenský čas</strong> , CNC, laser, 3D tiskárny, svářečka. RFID-billed hodiny v Hub dílnách.</li>
            <li><strong>Ateliér D1</strong> , kompletní nebo částečné krytí nájmu po dobu projektu.</li>
            <li><strong>Externí služby</strong> , tisk, řezání, povrchová úprava, fotodokumentace výstupu.</li>
          </ul>
        </div>

        <div class="stip-card__block">
          <h3 class="stip-card__sub">Co se za to očekává</h3>
          <ul class="stip-list">
            <li><strong>Veřejný výstup</strong> , výstava, prototyp, publikace, otevřená dokumentace nebo open-source repo.</li>
            <li><strong>Dva milníky</strong> během projektu a jeden závěrečný report s rozpočtem.</li>
            <li><strong>Jedna otevřená dílna</strong> nebo workshop, kde projekt ukážete komunitě.</li>
          </ul>
        </div>

        <a class="stip-card__cta osa-nolink" href={withBase('/rezervace/?cesta=stipendium')}>
          Požádat o projektové<span aria-hidden="true"> →</span>
        </a>
      </article>

    </div>
  </section>

  {/* ============ JAK POŽÁDAT ============ */}
  <section class="sec-block sec-hued" style="--section-hue: 200;">
    <div class="sec-block__inner">
      <header class="sec-block__head">
        <p class="sec-block__eyebrow">Postup</p>
        <h2 class="sec-block__title">Jak požádat.</h2>
        <p class="sec-block__lede">
          Žádost je nezávazná. Po podání vás kontaktujeme do týdne, probereme záměr telefonicky
          a domluvíme se na detailech. Můžete žádat o obě kategorie zároveň, pokud váš projekt
          zapadá.
        </p>
      </header>

      <ol class="sec-steps">
        <li>
          <span class="sec-steps__n">1.</span>
          <div>
            <h3>Podejte žádost přes rezervační formulář</h3>
            <p>Vyberte „Žádost o stipendium", upřesněte kategorii a popište projekt v několika větách.</p>
          </div>
        </li>
        <li>
          <span class="sec-steps__n">2.</span>
          <div>
            <h3>Krátký telefonát do týdne</h3>
            <p>Probereme záměr, rozsah a načasování. Pokud projekt zapadá, pošleme strukturu žádosti k doplnění.</p>
          </div>
        </li>
        <li>
          <span class="sec-steps__n">3.</span>
          <div>
            <h3>Dohoda o stipendiu</h3>
            <p>U pobytového stipendia podepíšeme dohodu o pobytu a přínosu. U projektového dohodu o pokrytí nákladů s konkrétními milníky.</p>
          </div>
        </li>
      </ol>
    </div>
  </section>

  <QuickReserveCtas
    variant="light"
    highlight="stipendium"
    eyebrow="Kam dál"
    title="Tři rychlé cesty do formuláře."
    hint={'Pokud váháte mezi kategoriemi, vyberte „Obě" v dalším kroku. Probereme společně.'}
  />

  <CtaBanner
    eyebrow="Zájem o stipendium"
    title="Stipendium pro <em>lidi s projektem</em>."
    lede="Žádost je nezávazná. Po podání vás kontaktujeme do týdne telefonicky."
    cta={{ label: 'Požádat o stipendium', href: '/rezervace/?cesta=stipendium' }}
    variant="deep"
  />

  <CrossLinkPair
    items={[
      { eyebrow: 'Ubytování', title: 'Apartmán, <em>nebo</em> co-living.', href: '/ubytovani/', variant: 'deep' },
      { eyebrow: 'Coworking', title: 'Sál, ateliér, <em>dílna</em>.',      href: '/coworking/', variant: 'cream' },
    ]}
  />
</Base>

<style>
  /* === 2 KATEGORIE SIDE-BY-SIDE === */
  .stip-types {
    padding: var(--space-7) var(--gutter);
    background: var(--bg);
  }
  .stip-types__inner {
    max-width: var(--container-wide);
    margin: 0 auto;
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: clamp(16px, 1.8vw, 24px);
    align-items: start;
  }
  @media (max-width: 880px) {
    .stip-types__inner { grid-template-columns: 1fr; }
  }

  .stip-card {
    padding: clamp(20px, 2.4vw, 32px);
    border-radius: var(--radius-input);
    border: 1px solid hsl(var(--section-hue, 240) 30% 82%);
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }
  .stip-card__head {
    display: flex;
    flex-direction: column;
    gap: 4px;
    margin-bottom: var(--space-1);
  }
  .stip-card__eyebrow {
    font: 600 var(--text-2xs) / 1 var(--font-sans);
    letter-spacing: var(--tracking-wider);
    text-transform: uppercase;
    color: hsl(var(--section-hue, 240) 50% 30%);
    margin: 0;
  }
  .stip-card__title {
    font: 600 clamp(1.25rem, 2.2vw, 1.625rem) / 1.2 var(--font-sans);
    letter-spacing: var(--tracking-tight);
    margin: 0;
    color: var(--fg);
  }
  .stip-card__lede {
    font: 500 var(--text-md) / 1.55 var(--font-sans);
    color: var(--fg-muted);
    margin: 8px 0 0;
  }

  .stip-card__block {
    border-top: 1px solid hsl(var(--section-hue, 240) 30% 82%);
    padding-top: var(--space-3);
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }
  .stip-card__sub {
    font: 600 var(--text-2xs) / 1 var(--font-sans);
    letter-spacing: var(--tracking-wider);
    text-transform: uppercase;
    color: hsl(var(--section-hue, 240) 45% 38%);
    margin: 0;
  }
  .stip-card__block p {
    font: 500 var(--text-sm) / 1.55 var(--font-sans);
    color: var(--fg);
    margin: 0;
  }

  .stip-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 8px;
  }
  .stip-list li {
    font: 500 var(--text-sm) / 1.5 var(--font-sans);
    color: var(--fg);
    padding-left: 18px;
    position: relative;
  }
  .stip-list li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0.65em;
    width: 6px;
    height: 6px;
    border-radius: 2px;
    background: hsl(var(--section-hue, 240) 50% 50%);
  }
  .stip-list strong { color: var(--fg); font-weight: 700; }

  .stip-card__cta {
    margin-top: auto;
    align-self: flex-start;
    display: inline-flex;
    align-items: center;
    gap: 4px;
    padding: 12px 20px;
    font: 600 var(--text-sm) / 1 var(--font-sans);
    color: var(--accent-on);
    background: hsl(var(--section-hue, 240) 50% 32%);
    border-radius: var(--radius-input);
    text-decoration: none;
    transition: background 200ms ease, transform 200ms ease;
  }
  .stip-card__cta:hover,
  .stip-card__cta:focus-visible {
    background: hsl(var(--section-hue, 240) 55% 24%);
    transform: translateY(-1px);
    outline: none;
  }

  /* Numbered process list, sjednocuje s vizuálním jazykem subpage. */
  .sec-steps {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: var(--space-5);
  }
  .sec-steps > li {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: var(--space-4);
    align-items: start;
  }
  .sec-steps__n {
    font: 700 clamp(1.5rem, 3vw, 2rem) / 1 var(--font-sans);
    color: var(--accent);
    letter-spacing: var(--tracking-tight);
    font-variant-numeric: tabular-nums;
    min-width: 2.5ch;
  }
  .sec-steps h3 {
    font: 600 var(--text-lg) / 1.25 var(--font-sans);
    margin: 0 0 4px;
    letter-spacing: var(--tracking-tight);
  }
  .sec-steps p {
    margin: 0;
    color: var(--fg-muted);
    line-height: 1.5;
  }
</style>
