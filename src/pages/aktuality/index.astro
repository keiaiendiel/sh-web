---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import ArticleCard from '../../components/ArticleCard.astro';

const all = await getCollection('aktuality', e => !e.data.draft);
const sorted = all.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
---
<Base
  title="Aktuality - Občanské sdružení Alternativa II"
  description="Články, zprávy a oznámení ze spolku OSA II. Co připravujeme, čím žijeme, co se nám daří.">
  <Header />
  <main class="osa-aktuality">
    <section class="section">
      <div class="container">
        <header class="osa-aktuality__head" data-reveal>
          <span class="osa-eyebrow">Aktuality</span>
          <h1 class="osa-h1 osa-aktuality__title">Co se u nás děje.</h1>
          <p class="osa-body osa-aktuality__lede">
            Krátké zprávy, oznámení a tematické texty od lidí, kteří spolek tvoří.
          </p>
        </header>

        {sorted.length === 0 && (
          <div class="osa-aktuality__empty" data-reveal data-reveal-delay="1">
            <p>Zatím tu nic nemáme. První texty dorazí brzy.</p>
          </div>
        )}

        {sorted.length > 0 && (
          <ul class="osa-aktuality__grid" role="list">
            {sorted.map((a, i) => (
              <li data-reveal data-reveal-delay={String((i % 3) + 1)}><ArticleCard
                slug={a.id}
                title={a.data.title}
                lead={a.data.lead}
                date={a.data.date}
                hero={a.data.hero}
                hero_alt={a.data.hero_alt}
                author={a.data.author}
                tags={a.data.tags}
              /></li>
            ))}
          </ul>
        )}
      </div>
    </section>
  </main>
  <Footer />
</Base>

<style>
  .osa-aktuality__head {
    display: grid;
    gap: var(--space-3);
    max-width: 72ch;
    margin: 0 0 var(--space-7);
  }
  .osa-aktuality__title { margin: 0; }
  .osa-aktuality__lede  { margin: 0; color: var(--fg-muted); }
  .osa-aktuality__empty {
    padding: var(--space-8) 0;
    color: var(--fg-muted);
    border-top: 1px solid var(--rule);
    border-bottom: 1px solid var(--rule);
  }
  .osa-aktuality__grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    grid-auto-rows: 1fr;
    gap: 0;
    border-top: 1px solid var(--rule);
    border-left: 1px solid var(--rule);
  }
  .osa-aktuality__grid > li {
    display: flex;
  }
  .osa-aktuality__grid > li > * { flex: 1; }
</style>
