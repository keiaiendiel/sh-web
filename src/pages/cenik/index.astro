---
import Base from '../../layouts/Base.astro';
import SubpageHero from '../../components/SubpageHero.astro';
import CtaBanner from '../../components/CtaBanner.astro';
import CrossLinkPair from '../../components/CrossLinkPair.astro';
import Icon from '../../components/Icon.astro';
import ResidentBenefits from '../../components/ResidentBenefits.astro';
import { getCollection } from 'astro:content';
import { withBase } from '../../utils/url';

/**
 * Ceník , subscription-style comparison (Notion/Vercel pricing pattern).
 * Vrchol „vždy v ceně" pruh stanoví floor co dostává každý rezident, karty
 * pod ním ukazují co každý tier přidává navíc (subscription tier ladder).
 *
 * Cards používají CSS subgrid pro zarovnání řádků napříč tiery , každá
 * sekce karty se rezervuje stejnou výšku jako odpovídající sekce sousední
 * karty, takže nadpisy + cena + facts + features + CTA leží na stejné lince.
 *
 * Anchor cena = pobyt 12+ měsíců (per CLAUDE.md pricing lock 2026-05-12).
 */

const apartmany = (await getCollection('apartmany'))
  .filter((a) => !a.data.hidden)
  .sort((a, b) => a.data.order - b.data.order);
const coliving = (await getCollection('sdilenePokoje'))
  .filter((c) => !c.data.hidden)
  .sort((a, b) => a.data.cena.anchor - b.data.cena.anchor);

/* Per-coliving metadata , kontext sdílení pokoje (krátký descriptor
   pro card facts). Vše ostatní (popis, klicove, spec) čte ceník přímo
   z content collection, aby detail page a card byly v sync. */
interface CoMeta {
  pokoj: string;
}
const coMeta: Record<string, CoMeta> = {
  'pokoj-basic':     { pokoj: 'Sdílíte pokoj se 3 dalšími rezidenty, bez příček' },
  'dvojluzko-basic': { pokoj: 'Společné dvojlůžko v pokoji s dalšími lůžky, bez příček' },
  'pokoj-privacy':   { pokoj: '4 až 6 lůžek s dělícími stěnami v jednom pokoji' },
  'kapsle-single':   { pokoj: '3 až 6 kapslí v jednom pokoji' },
  'kapsle-double':   { pokoj: '2 až 5 dalších kapslí v jednom pokoji' },
  'dvouluzko':       { pokoj: 'Žádný další spolubydlící v místnosti' },
};

const fmt = (n: number) => n.toLocaleString('cs-CZ');

/* === Coworking tarify (zdroj: /coworking/) === */
interface CowPlan {
  name: string;
  hook: string;
  price: string;
  forResidents: string;
  features: string[];
  hue: 25 | 50 | 130 | 200 | 240; /* per-card hue, matchuje /coworking/ section hues */
}
const cowPlans: CowPlan[] = [
  {
    name: 'Coworkingový sál',
    hook: 'Volný stůl 24/7, žádné rezervace. Wi-Fi, kávovary, telefonní budky.',
    price: '2 900 Kč/měs',
    forResidents: 'V ceně bydlení',
    features: ['30 až 40 míst', '2 kávovary, voda, čaj', '4 telefonní budky', 'Tiskárna za kredit'],
    hue: 200,
  },
  {
    name: 'Fixní stůl',
    hook: 'Stejný stůl každý den, dva monitory, ergonomická židle, uzamykatelná skříňka.',
    price: '4 200 Kč/měs',
    forResidents: 'Cena platí i pro rezidenty',
    features: ['Dva monitory 27"', 'Uzamykatelná skříňka', '24/7 přístup', 'Smlouva od 3 měsíců'],
    hue: 50,
  },
  {
    name: 'Sdílená kancelář pro 4',
    hook: 'Privátní místnost v patře, čtyři stoly, whiteboard, vlastní zámek.',
    price: '15 000 Kč/měs',
    forResidents: '3 750 Kč na osobu při plném obsazení',
    features: ['15 až 20 m²', 'Whiteboard 1,5 × 1,2 m', '24/7 přístup', 'Smlouva od 6 měsíců'],
    hue: 130,
  },
  {
    name: 'Zasedací místnost',
    hook: 'Smart TV 65", konferenční kamera, tabule. Pro 6 osob.',
    price: '350 Kč/hod',
    forResidents: '4 hodiny v měsíci zdarma',
    features: ['1 200 Kč/půlden', '2 000 Kč/den', '07:00 až 22:00', 'Rezervace přes aplikaci'],
    hue: 240,
  },
];

/* === Doplňky a služby , 5 tematických skupin === */
interface MiscRow {
  label: string;
  detail: string;
  price: string;
  icon: string;       /* lucide-static icon name */
}
interface MiscGroup {
  eyebrow: string;
  title: string;
  lede?: string;
  hue: number;        /* CSS hue pro colorize, ikona + cena přebírají */
  rows: MiscRow[];
}
const miscGroups: MiscGroup[] = [
  {
    eyebrow: 'Tvořivá práce',
    title: 'Ateliéry a dílny.',
    lede: 'Pro řemeslníky, tvůrce a lidi, kteří potřebují postavit něco většího než vejde do bytu.',
    hue: 25,           /* orange , kreativní práce */
    rows: [
      { icon: 'palette', label: 'Ateliér D1',          detail: 'Vlastní zámek, 15 až 25 m², denní světlo, 16 A zásuvka', price: '6 500 Kč/měs za 20 m² (~325 Kč/m²)' },
      { icon: 'hammer',  label: 'Dílna členství',      detail: 'Ruční nářadí, pracovní stoly, pájecí stanice, elektrické nářadí', price: '490 Kč/měs' },
      { icon: 'cog',     label: 'Dílna těžké stroje',  detail: 'CNC, laser, 3D tiskárny , RFID zámek a automatické účtování', price: '150 Kč/hod' },
    ],
  },
  {
    eyebrow: 'Úložiště a parking',
    title: 'Kontejner, parkování, úložna kol.',
    lede: 'Parkování a úložna kol jsou pro rezidenty zdarma. Pro stěhování nebo projektové vybavení si můžete dlouhodobě pronajmout 20stopý kontejner.',
    hue: 50,           /* yellow , utility/parking */
    rows: [
      { icon: 'container',     label: 'Kontejnerový sklad', detail: '20stopý kontejner v areálu, vlastní zámek, ~14 m². Pro stěhování nebo projektové vybavení.', price: 'Cena na vyžádání' },
      { icon: 'parking-circle', label: 'Parkovací stání',   detail: 'V areálu, vyhrazené místo pro rezidenty. Externí návštěvníci dle dohody.',                  price: 'Pro rezidenty zdarma' },
      { icon: 'bike',           label: 'Úložna kol',        detail: 'Krytá uzamykatelná místnost pro kola a koloběžky, přístup čipem.',                          price: 'Pro rezidenty zdarma' },
    ],
  },
  {
    eyebrow: 'Komunitní park',
    title: 'Záhony a grilovací místa.',
    lede: 'Záhony v severní části parku, voda, kompost a základní nářadí v ceně. Rezervace na sezónu jaro až podzim.',
    hue: 130,          /* green , zahrada */
    rows: [
      { icon: 'sprout',  label: 'Komunitní záhon',  detail: 'Plocha podle dohody, typicky 2 až 8 m². Voda, kompost a nářadí v ceně.', price: 'od 30 Kč/m² měsíčně' },
      { icon: 'flame',   label: 'Grilovací místo',  detail: '3 až 4 stání s pevnými grily, lavičkami a stoly. Rezervace přes aplikaci.', price: 'Pro rezidenty zdarma' },
    ],
  },
  {
    eyebrow: 'Wellness',
    title: 'Bazén a sauna.',
    lede: 'Bazén je pro rezidenty zdarma kdykoli. Saunu mají rezidenti s tarifem 12+ jednou týdně v ceně. Pro externí návštěvníky a krátkodobé pobyty platí samostatný vstup.',
    hue: 200,          /* water blue , wellness */
    rows: [
      { icon: 'waves',    label: 'Bazén',  detail: 'Vlastní bazén areálu, samostatný objekt vedle sauny a wellness zóny.', price: 'Pro rezidenty zdarma' },
      { icon: 'droplets', label: 'Sauna',  detail: 'Veřejná sauna pro 6 až 8 osob, harmonogram čtvrtek až sobota večer.',  price: 'Pro rezidenty 1× týdně zdarma (tarif 12+)' },
    ],
  },
  {
    eyebrow: 'Recepce a administrativa',
    title: 'Služby kanceláře Hubu.',
    lede: 'Recepce funguje 7 dní v týdnu. Některé administrativní věci vyřídíte přímo s námi, ne přes prahu městského úřadu.',
    hue: 240,          /* brand indigo , admin */
    rows: [
      { icon: 'inbox',          label: 'Příjem balíků',                  detail: 'Sběrné místo pro zásilky, oznámení do aplikace, uložení až 14 dní.', price: 'Pro rezidenty zdarma' },
      { icon: 'building',       label: 'Virtuální sídlo OSVČ nebo s.r.o.', detail: 'Adresa Hubu jako fakturační a evidenční sídlo, příjem úředních zásilek, sken na e-mail.', price: 'Cena na vyžádání' },
      { icon: 'scroll-text',    label: 'Zakládání s.r.o.',               detail: 'Spolupráce s notářem, právní šablona, registrace u rejstříkového soudu.', price: 'Cena na vyžádání' },
    ],
  },
];
---
<Base
  title="Ceník bydlení a tvorby · Startovací Hub Klecany"
  description="Kompletní ceník 11 formátů bydlení, 4 coworking tarifů, ateliérů, dílen a skladů. Měsíční ceny při ročním pobytu, kratší pobyty s mírným příplatkem."
  headerVariant="overlay">

  <SubpageHero
    eyebrow="Ceník"
    title="Co a <em>za kolik</em>."
    sub="Jedenáct formátů bydlení, čtyři coworking tarify, ateliéry a dílny. Otevřené ceny bez skrytých poplatků."
    variant="cream"
    ribbonPath="M 1080 180 C 1340 100, 1640 280, 1820 200 C 1980 130, 2080 340, 1920 480 C 1780 600, 1480 560, 1380 720"
    ribbonPathSecondary="M 100 260 C 280 180, 480 320, 660 240 C 820 170, 940 280, 880 420"
    thickness={56}
    thicknessSecondary={32}
    opacitySecondary={0.45}
    jumps={[
      { href: '#ck-coliving-h', label: 'Sdílené pokoje' },
      { href: '#ck-apt-h', label: 'Apartmány' },
      { href: '#ck-cw-h', label: 'Pracovní prostory' },
      { href: '#ck-misc-h', label: 'Doplňky a služby' },
    ]}
    ariaId="cenik-hero"
  />

  {/* ============ VŽDY V CENĚ, 8 chip karet sdílených napříč Ceníkem a detail page ============ */}
  <ResidentBenefits />

  {/* ============ SDÍLENÉ POKOJE (6 variant) ============ */}
  <section class="ck-sec" aria-labelledby="ck-coliving-h">
    <div class="ck-sec__inner">
      <header class="ck-sec__head">
        <p class="ck-sec__eyebrow">Sdílené pokoje</p>
        <h2 class="ck-sec__title" id="ck-coliving-h">Lůžka a kapsle ve sdíleném pokoji.</h2>
        <p class="ck-sec__lede">
          Šest variant seřazených od nejnižší ceny. Liší se hlavně mírou soukromí a počtem osob v pokoji.
          Koupelnu a kuchyň sdílíte se zbytkem patra. Energie, internet, pět jízd kyvadlové dopravy
          MyShelter k metru měsíčně a sauna 1× týdně v ceně každého tarifu.
        </p>
      </header>

      <div class="ck-grid ck-grid--cards ck-grid--4">
        {coliving.map((c) => {
          const meta = coMeta[c.data.slug];
          return (
            <article class="ck-card" aria-labelledby={`ck-co-${c.data.slug}-h`}>
              <header class="ck-card__head">
                <h3 class="ck-card__name" id={`ck-co-${c.data.slug}-h`}>{c.data.shortName}</h3>
                <p class="ck-card__hook">{c.data.popis}</p>
              </header>
              <div class="ck-card__price">
                <span class="ck-card__price-prefix">od</span>
                <span class="ck-card__price-num">{fmt(c.data.cena.anchor)}</span>
                <span class="ck-card__price-unit">Kč<span class="ck-card__price-period">/měs</span></span>
              </div>
              {c.data.pricePending && (
                <p style="margin:4px 0 0;font-size:var(--text-2xs);color:var(--rose);font-weight:600;">Cena orientační, k potvrzení.</p>
              )}
              <dl class="ck-card__facts">
                <div><dt>Matrace</dt><dd>{c.data.matrace.join(' / ')}</dd></div>
                <div><dt>Plocha pokoje</dt><dd>{c.data.spec.plochaPokoj}</dd></div>
                <div><dt>Pokoj</dt><dd>{meta?.pokoj}</dd></div>
              </dl>
              <ul class="ck-card__features" aria-label={`Co ${c.data.shortName} obsahuje`}>
                {c.data.klicove.slice(0, 5).map((f) => (
                  <li><span class="ck-card__check"><Icon name="check" size={14} /></span><span>{f}</span></li>
                ))}
              </ul>
              <div class="ck-card__actions">
                <a class="ck-card__detail osa-nolink" href={withBase(`/ubytovani/sdilene-pokoje/${c.data.slug}/`)}>Detail →</a>
                <a class="ck-card__cta osa-nolink" href={withBase(`/rezervace/?typ=${c.data.slug}`)}>Rezervovat</a>
              </div>
            </article>
          );
        })}
      </div>
    </div>
  </section>

  {/* ============ PRIVÁTNÍ APARTMÁNY (5 velikostí) ============ */}
  <section class="ck-sec ck-sec--alt" aria-labelledby="ck-apt-h">
    <div class="ck-sec__inner">
      <header class="ck-sec__head">
        <p class="ck-sec__eyebrow">Privátní apartmány</p>
        <h2 class="ck-sec__title" id="ck-apt-h">Vlastní byt s kuchyní a koupelnou.</h2>
        <p class="ck-sec__lede">
          Pět velikostí od 1+kk až po 5+kk pro skupinu až patnácti lidí. Cena je za celý byt,
          v přepočtu na osobu při plném obsazení vychází 1 800 až 3 340 Kč. Vlastní vchod,
          koupelna a kuchyň , nic v bytě nesdílíte. Kyvadlová doprava MyShelter, sauna a coworking v ceně.
        </p>
      </header>

      <div class="ck-grid ck-grid--cards ck-grid--5">
        {apartmany.map((a) => {
          const perPerson = Math.round(a.data.cena.anchor / a.data.kapacita);
          return (
            <article class="ck-card" aria-labelledby={`ck-apt-${a.data.slug}-h`}>
              <header class="ck-card__head">
                <h3 class="ck-card__name" id={`ck-apt-${a.data.slug}-h`}>{a.data.shortName}</h3>
                <p class="ck-card__hook">{a.data.popis}</p>
              </header>
              <div class="ck-card__price">
                <span class="ck-card__price-prefix">od</span>
                <span class="ck-card__price-num">{fmt(a.data.cena.anchor)}</span>
                <span class="ck-card__price-unit">Kč<span class="ck-card__price-period">/měs</span></span>
              </div>
              <dl class="ck-card__facts">
                <div><dt>Plocha</dt><dd>{a.data.plocha}</dd></div>
                <div><dt>Kapacita</dt><dd>{a.data.kapacita} lůžek · {fmt(perPerson)} Kč na osobu</dd></div>
                <div><dt>Koupelna</dt><dd>{a.data.koupelna}</dd></div>
              </dl>
              <ul class="ck-card__features" aria-label={`Co ${a.data.shortName} obsahuje`}>
                {a.data.klicove.slice(0, 5).map((f) => (
                  <li><span class="ck-card__check"><Icon name="check" size={14} /></span><span>{f}</span></li>
                ))}
              </ul>
              <div class="ck-card__actions">
                <a class="ck-card__detail osa-nolink" href={withBase(`/ubytovani/privatni/${a.data.slug}/`)}>Detail →</a>
                <a class="ck-card__cta osa-nolink" href={withBase(`/rezervace/?typ=${a.data.slug}`)}>Rezervovat</a>
              </div>
            </article>
          );
        })}
      </div>
    </div>
  </section>

  {/* ============ COWORKING TARIFY ============ */}
  <section class="ck-sec" aria-labelledby="ck-cw-h">
    <div class="ck-sec__inner">
      <header class="ck-sec__head">
        <p class="ck-sec__eyebrow">Coworking</p>
        <h2 class="ck-sec__title" id="ck-cw-h">Pracovní prostory.</h2>
        <p class="ck-sec__lede">
          Volný stůl v sále mají rezidenti v ceně bydlení. Ostatní tarify jsou samostatné
          produkty, dostupné i bez bydlení v Hubu.
        </p>
      </header>
      <div class="ck-grid ck-grid--4">
        {cowPlans.map((c) => (
          <article class="ck-mini" style={`--card-hue: ${c.hue};`}>
            <h3 class="ck-mini__name">{c.name}</h3>
            <p class="ck-mini__hook">{c.hook}</p>
            <p class="ck-mini__price"><strong>{c.price}</strong></p>
            <p class="ck-mini__residents">{c.forResidents}</p>
            <ul class="ck-mini__features">
              {c.features.map((f) => <li>{f}</li>)}
            </ul>
          </article>
        ))}
      </div>
    </div>
  </section>

  {/* ============ DOPLŇKY A SLUŽBY (5 tematických skupin) ============ */}
  <section class="ck-sec ck-sec--alt" aria-labelledby="ck-misc-h">
    <div class="ck-sec__inner">
      <header class="ck-sec__head">
        <p class="ck-sec__eyebrow">Doplňky a služby</p>
        <h2 class="ck-sec__title" id="ck-misc-h">Tvořivá práce, sklady, zahrádky, recepce.</h2>
        <p class="ck-sec__lede">
          Samostatné produkty nad rámec bydlení a coworkingu. Některé jsou v ceně bydlení 12+ měsíců,
          další podle aktuálního ceníku nebo na vyžádání.
        </p>
      </header>

      {miscGroups.map((g) => (
        <div class="ck-misc-group" style={`--card-hue: ${g.hue}`}>
          <header class="ck-misc-group__head">
            <p class="ck-misc-group__eyebrow">{g.eyebrow}</p>
            <h3 class="ck-misc-group__title">{g.title}</h3>
            {g.lede && <p class="ck-misc-group__lede">{g.lede}</p>}
          </header>
          <div class={`ck-mini-grid ck-mini-grid--${g.rows.length}`}>
            {g.rows.map((m) => (
              <article class="ck-mini-card">
                <span class="ck-mini-card__icon" aria-hidden="true"><Icon name={m.icon} size={20} /></span>
                <h4 class="ck-mini-card__label">{m.label}</h4>
                <p class="ck-mini-card__detail">{m.detail}</p>
                <p class="ck-mini-card__price">{m.price}</p>
              </article>
            ))}
          </div>
        </div>
      ))}
    </div>
  </section>

  <section class="ck-disclaimer" aria-label="Poznámka k cenám">
    <div class="ck-disclaimer__inner">
      <p>
        <span class="ck-disclaimer__star" aria-hidden="true">*</span>
        Všechny ceny jsou měsíční, vč. DPH, při pobytu 12+ měsíců. Kratší pobyty se navyšují
        přibližně o 5 % (6 měsíců), 10 % (3 měsíce) nebo 20 % (1 měsíc). Aktuální detaily
        a podmínky doladíme telefonicky před podpisem.
      </p>
    </div>
  </section>

  <CtaBanner
    eyebrow="Rezervace"
    title="Vyberte si <em>variantu</em>, ozveme se do 24 hodin."
    lede="Pořád nezávazná registrace. Telefonicky doladíme délku, termín a doplňky."
    cta={{ label: 'Nezávazná rezervace', href: '/rezervace/' }}
    variant="rose"
  />

  <CrossLinkPair
    items={[
      { eyebrow: 'Ubytování', title: 'Apartmán, <em>nebo</em> sdílený pokoj.',  href: '/ubytovani/',  variant: 'deep' },
      { eyebrow: 'Stipendia', title: 'Pobytové, <em>nebo</em> projektové.', href: '/stipendia/', variant: 'rose' },
    ]}
  />
</Base>

<style>
  /* ============ SECTION SHELL ============ */
  .ck-sec { padding: var(--space-8) var(--gutter); background: var(--bg); }
  .ck-sec--alt { background: var(--bg-muted, var(--k-05)); border-top: 1px solid var(--border-muted); border-bottom: 1px solid var(--border-muted); }
  .ck-sec__inner { max-width: var(--container-wide); margin: 0 auto; }
  .ck-sec__head { max-width: 65ch; margin: 0 0 var(--space-6); }
  .ck-sec__eyebrow {
    font: 600 var(--text-2xs) / 1 var(--font-sans);
    color: var(--accent);
    letter-spacing: var(--tracking-wider);
    text-transform: uppercase;
    margin: 0 0 var(--space-3);
  }
  .ck-sec__title {
    font: 600 clamp(1.5rem, 3vw, 2rem) / 1.15 var(--font-sans);
    letter-spacing: var(--tracking-tight);
    margin: 0 0 var(--space-3);
  }
  .ck-sec__lede { color: var(--fg-muted); margin: 0; line-height: 1.55; }

  /* ============ DISCLAIMER (pricing footnote) ============ */
  .ck-disclaimer {
    padding: var(--space-5) var(--gutter) var(--space-6);
    background: var(--bg-muted, var(--k-05));
    border-top: 1px solid var(--border-muted);
  }
  .ck-disclaimer__inner {
    max-width: var(--container-wide);
    margin: 0 auto;
  }
  .ck-disclaimer p {
    margin: 0;
    font: 500 var(--text-xs) / 1.55 var(--font-sans);
    color: var(--fg-muted);
    max-width: 75ch;
  }
  .ck-disclaimer__star {
    color: var(--accent);
    font-weight: 700;
    margin-right: 4px;
  }

  /* ============ GRID ============ */
  .ck-grid { display: grid; gap: clamp(8px, 0.8vw, 10px); align-items: stretch; }
  /* Subgrid karty mají 5 sjednocených řádků: head / price / facts / features / cta */
  .ck-grid--cards {
    grid-template-rows:
      auto  /* 1: head (name + hook) */
      auto  /* 2: price */
      auto  /* 3: facts */
      auto  /* 4: features list */
      auto; /* 5: cta */
  }
  .ck-grid--4 { grid-template-columns: repeat(4, minmax(0, 1fr)); }
  .ck-grid--5 { grid-template-columns: repeat(5, minmax(0, 1fr)); }
  @media (max-width: 1180px) {
