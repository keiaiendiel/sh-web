---
import Base from '../layouts/Base.astro';
import SubpageHero from '../components/SubpageHero.astro';
import Icon from '../components/Icon.astro';
import StrukturaNode from '../components/StrukturaNode.astro';
import baseTree from '../data/struktura-webu.json';
import dopravaData from '../data/doprava.json';
import { getCollection } from 'astro:content';

const heroRibbon = 'M 120 720 C 520 420, 980 860, 1380 540 C 1700 300, 1980 560, 2060 420';

const legend = [
  { status: 'live', icon: 'check', label: 'v provozu' },
  { status: 'prep', icon: 'clock', label: 'v přípravě' },
  { status: 'locked', icon: 'lock', label: 'na heslo' },
];

const stripTags = (s) => (s ?? '').replace(/<[^>]+>/g, '');
const slugFromHref = (href, prefix) => (href ?? '').replace(prefix, '').replace(/\/$/, '');

/* Zázemí: ke každé kategorii dogeneruj jednotlivé provozy jako děti, každý
   deep-link na #slug sekce na L2 stránce kategorie. Data-driven z kolekce
   `zazemi`, aby se strom držel v synchronu s obsahem. */
const zazemiCats = await getCollection('zazemi');
const zazemiItems = Object.fromEntries(zazemiCats.map((c) => [c.id, c.data.items ?? []]));

/* Strom rozšířený o hloubku 3 (obsah pod kategoriemi zázemí a větvemi dopravy). */
const tree = baseTree.map((node) => {
  if (node.href === '/zazemi/') {
    return {
      ...node,
      children: (node.children ?? []).map((cat) => {
        const catId = slugFromHref(cat.href, '/zazemi/');
        const items = zazemiItems[catId] ?? [];
        return {
          ...cat,
          children: items.map((it) => ({
            label: it.name,
            href: `/zazemi/${catId}/#${it.slug}`,
            status: 'live',
          })),
        };
      }),
    };
  }
  if (node.href === '/doprava/') {
    return {
      ...node,
      children: (node.children ?? []).map((branch) => {
        const branchSlug = slugFromHref(branch.href, '/doprava/');
        const item = dopravaData.items.find((i) => i.slug === branchSlug);
        const sections = item?.sections ?? [];
        return {
          ...branch,
          children: sections.map((s) => ({
            label: stripTags(s.title),
            href: `/doprava/${branchSlug}/#${s.id}`,
            status: 'live',
          })),
        };
      }),
    };
  }
  return node;
});
---
<Base
  title="Struktura webu · Startovací Hub Klecany"
  description="Mapa všech veřejných stránek webu Startovacího Hubu Klecany i jejich obsahu. Klikací strom: ubytování, zázemí, doprava, stipendia, ceník a další."
  headerVariant="overlay">

  <SubpageHero
    eyebrow="Mapa webu"
    title="Struktura <em>webu</em>"
    sub="Přehled všech veřejných stránek a jejich obsahu. Každá položka vede přímo na danou stránku nebo sekci, odsazení ukazuje vnoření. Ikona u položky říká, v jakém je stavu."
    variant="ink"
    ribbonPath={heroRibbon}
    ariaId="struktura"
  />

  <section class="sec-block">
    <div class="sec-block__inner">
      <ul class="legend">
        {legend.map((item) => (
          <li class="legend__item">
            <span class={`legend__chip legend__chip--${item.status}`} aria-hidden="true">
              <Icon name={item.icon} size={15} strokeWidth={2.25} />
            </span>
            <span class="legend__label">{item.label}</span>
          </li>
        ))}
      </ul>

      <nav class="strom" aria-label="Struktura webu">
        <ul class="strom__root">
          {tree.map((node) => <StrukturaNode node={node} />)}
        </ul>
      </nav>
    </div>
  </section>
</Base>

<style>
  .legend {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3) var(--space-6);
    margin: 0 0 var(--space-7);
    padding: var(--space-4) var(--space-5);
    border: 1px solid var(--border);
    border-radius: var(--radius-input);
    background: var(--bg-elevated, var(--bg));
  }
  .legend__item {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    font: 500 var(--text-sm) / 1 var(--font-sans);
    color: var(--fg-muted);
  }
  .legend__chip {
    display: inline-grid;
    place-items: center;
    width: 26px;
    height: 26px;
    flex: none;
    border-radius: 50%;
  }
  .legend__chip--live {
    background: var(--accent-soft);
    color: var(--accent);
    border: 1px solid var(--accent-rule);
  }
  .legend__chip--prep {
    background: var(--rose);
    color: var(--plum-deep);
  }
  .legend__chip--locked {
    background: var(--bg-muted);
    color: var(--fg-muted);
    border: 1px solid var(--border);
  }

  .strom__root {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
  }
</style>
