---
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { withBase } from '../utils/url';

const suggestions = [
  { href: withBase('/'),            label: 'Úvodní strana' },
  { href: withBase('/projekty/'),   label: 'Projekty' },
  { href: withBase('/o-spolku/'),   label: 'O spolku' },
  { href: withBase('/kontakty/'),   label: 'Kontakty' },
];
---
<Base
  title="Stránka nenalezena - Občanské sdružení Alternativa II"
  description="Stránka neexistuje nebo byla přesunuta. Zkuste úvodní stranu nebo odkazy níže.">
  <Header />
  <main>
    <section class="section">
      <div class="container">
        <div class="osa-404" data-reveal>
          <span class="osa-eyebrow osa-404__code">Chyba 404</span>
          <h1 class="osa-h1 osa-404__title">Stránka nenalezena.</h1>
          <p class="osa-body osa-404__lede">
            Stránka, kterou hledáte, neexistuje nebo byla přesunuta. Přes nový web osa2.cz
            vede na obsah řada dřívějších adres, některé kotvy ale mohly zaniknout.
          </p>
          <div class="osa-404__rule" aria-hidden="true"></div>
          <nav class="osa-404__nav" aria-label="Navigační návrhy">
            <span class="osa-eyebrow osa-404__navlabel">Pokračujte</span>
            <ul class="osa-404__list" role="list">
              {suggestions.map(s => (
                <li><a href={s.href} class="osa-404__link">{s.label} <span class="osa-404__arrow" aria-hidden="true">→</span></a></li>
              ))}
            </ul>
          </nav>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</Base>

<style>
  .osa-404 {
    display: grid;
    gap: var(--space-4);
    max-width: 64ch;
    padding: var(--space-9) 0 var(--space-8);
  }
  .osa-404__code { color: var(--fg-muted); }
  .osa-404__title { margin: 0; text-wrap: balance; }
  .osa-404__lede {
    margin: 0;
    color: var(--fg-muted);
    max-width: 52ch;
  }
  .osa-404__rule {
    height: 1px;
    background: var(--rule);
    margin: var(--space-5) 0 var(--space-3);
    width: 100%;
  }
  .osa-404__nav { display: grid; gap: var(--space-3); }
  .osa-404__navlabel { color: var(--fg-muted); }
  .osa-404__list {
    display: grid;
    gap: 0;
  }
  .osa-404__link {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: var(--space-4);
    padding: var(--space-4) 0;
    border-bottom: 1px solid var(--rule);
    font-family: var(--font-sans);
    font-weight: 600;
    font-size: var(--text-lg);
    letter-spacing: var(--tracking-tight);
    color: var(--fg);
    transition: color var(--dur-fast) linear;
  }
  .osa-404__link:hover { color: var(--fg-muted); }
  .osa-404__arrow {
    color: var(--fg-muted);
    font-weight: 500;
    transition: transform var(--dur-base) var(--ease-standard);
  }
  .osa-404__link:hover .osa-404__arrow {
    transform: translateX(3px);
    color: var(--fg);
  }

  @media (max-width: 560px) {
    .osa-404 { padding: var(--space-7) 0 var(--space-6); }
  }
</style>
