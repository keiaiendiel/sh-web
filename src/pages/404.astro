---
import Base from '../layouts/Base.astro';
import { withBase } from '../utils/url';
---
<Base title="Stránka nenalezena — Startovací Hub Klecany" description="Hledaný obsah neexistuje. Zkuste se vrátit na úvod.">
  <section class="hub-404">
    <div>
      <p class="hub-404__code">404</p>
      <h1>Stránka nenalezena</h1>
      <p class="hub-404__lead">Hledaný obsah na našem webu neexistuje. Zkuste úvod nebo nějakou ze sekcí.</p>
      <p class="hub-404__nav">
        <a href={withBase('/')}>Úvod</a>
        <span aria-hidden="true">·</span>
        <a href={withBase('/projekty/')}>Projekty</a>
        <span aria-hidden="true">·</span>
        <a href={withBase('/faq/')}>FAQ</a>
      </p>
    </div>
  </section>
</Base>

<style>
  .hub-404 { min-height: 60vh; display: grid; place-items: center; padding: 96px 24px; text-align: center; }
  .hub-404__code { font-size: clamp(96px, 12vw, 200px); font-weight: 700; line-height: 1; margin: 0; color: var(--accent); letter-spacing: -0.02em; }
  .hub-404 h1 { font-size: clamp(28px, 3vw, 44px); font-weight: 700; margin: 16px 0 8px; }
  .hub-404__lead { font-size: 17px; color: var(--k-70, #4a4a4a); margin: 0 auto 24px; max-width: 480px; line-height: 1.55; }
  .hub-404__nav { font-size: 16px; }
  .hub-404__nav a { color: var(--accent); font-weight: 600; text-decoration: none; margin: 0 12px; }
  .hub-404__nav a:hover { text-decoration: underline; }
</style>
