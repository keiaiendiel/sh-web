---
/*
 * Doprava , L2 detail (sdilena-mobilita / privatni-mobilita). Fraktál: každý
 * blok z doprava.json (kyvadlovka, MHD, taxi, půjčovna / cyklostezka,
 * parkoviště) = jedna zig-zag Section. Reálná foto kde je, jinak placeholder.
 */
import FractalPage from '../../layouts/FractalPage.astro';
import data from '../../data/doprava.json';

export async function getStaticPaths() {
  return data.items.map((it) => ({ params: { branch: it.slug }, props: { it } }));
}

const { it } = Astro.props;

function mediaFor(sub: string) {
  const s = (sub || '').toLowerCase();
  if (s.includes('shuttle') || s.includes('kyvadl')) {
    return [{ src: '/images/hub/doprava/hub-shuttle-zastavka.jpg', alt: sub }];
  }
  if (s.includes('cyklo') || s.includes('kolo') || s.includes('pěš')) {
    return [{ src: '/images/hub/doprava/cyklostezka.jpg', alt: sub }];
  }
  if (s.includes('mhd') || s.includes('hromadn')) {
    return [{ src: '/images/hub/okoli/01-areal-dostupnost.jpg', alt: sub }];
  }
  return [{ placeholder: `${sub} , foto nebo schéma se připravuje`, alt: sub }];
}

const sections = (it.blocks ?? []).map((b, i) => ({
  id: `blok-${i + 1}`,
  jumpLabel: b.subtitle ?? `Detail ${i + 1}`,
  title: b.subtitle ?? '',
  lede: b.text,
  media: mediaFor(b.subtitle ?? ''),
}));

const variant = it.slug === 'privatni-mobilita' ? 'cream' : 'ink';
const crossOther = it.slug === 'privatni-mobilita'
  ? { eyebrow: 'Doprava', title: 'Sdílená <em>mobilita</em>', href: '/doprava/sdilena-mobilita/', variant: 'ink' as const }
  : { eyebrow: 'Doprava', title: 'Privátní <em>mobilita</em>', href: '/doprava/privatni-mobilita/', variant: 'cream' as const };
---
<FractalPage
  title={`${it.name} · Doprava · Startovací Hub Klecany`}
  description={it.lede}
  hero={{
    eyebrow: 'Doprava',
    title: it.name,
    sub: it.lede,
    variant,
    ariaId: it.slug,
  }}
  sections={sections}
  cta={{
    eyebrow: 'Rezervace',
    title: 'Bydlete <em>na prahu</em> metropole',
    lede: 'Vyberte si formát bydlení a způsob kontaktu. Z rezervačního oddělení vám zavoláme do 24 hodin.',
    cta: { label: 'Nezávazná rezervace', href: '/rezervace/' },
    variant: 'deep',
  }}
  crossLinks={[
    crossOther,
    { eyebrow: 'Zázemí', title: 'Celé <em>zázemí</em> Hubu', href: '/zazemi/', variant: 'cream' },
  ]}
/>
