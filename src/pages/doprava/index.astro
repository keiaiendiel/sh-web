---
/*
 * Doprava , L1 „landing dopravního startupu". Dvě sekce (Sdílená mobilita,
 * Privátní mobilita), bez L3. Obsah z src/data/doprava.json.
 */
import FractalPage from '../../layouts/FractalPage.astro';
import data from '../../data/doprava.json';

const sections = data.items.map((it) => {
  const blocks = [...(it.blocks ?? [])];
  if (it.priceNote) blocks.push({ subtitle: 'V ceně bydlení', text: it.priceNote });
  return {
    id: it.slug,
    jumpLabel: it.name,
    title: it.name,
    lede: it.lede,
    blocks,
    media: it.images ?? [],
  };
});
---
<FractalPage
  title="Doprava , kyvadlová doprava, MHD, kolo a auto · Startovací Hub Klecany"
  description={data.intro.lede}
  hero={{
    eyebrow: 'Doprava',
    title: 'Jak se sem <em>dostanete</em>',
    sub: data.intro.lede,
    variant: 'ink',
    ariaId: 'doprava',
  }}
  sections={sections}
  cta={{
    eyebrow: 'Rezervace',
    title: 'Bydlete <em>na prahu</em> metropole',
    lede: 'Vyberte si formát bydlení a způsob kontaktu. Z rezervačního oddělení vám zavoláme do 24 hodin.',
    cta: { label: 'Nezávazná rezervace', href: '/rezervace/' },
    variant: 'deep',
  }}
  crossLinks={[
    { eyebrow: 'Ubytování', title: 'Kde budete <em>bydlet</em>', href: '/ubytovani/', variant: 'cream' },
    { eyebrow: 'Zázemí', title: 'Celé <em>zázemí</em> Hubu', href: '/zazemi/', variant: 'ink' },
  ]}
/>
