---
import Base from '../../layouts/Base.astro';
import Gallery from '../../components/Gallery.astro';
import Icon from '../../components/Icon.astro';
import SubpageHero from '../../components/SubpageHero.astro';
import CtaBanner from '../../components/CtaBanner.astro';
import CrossLinkPair from '../../components/CrossLinkPair.astro';
import { withBase } from '../../utils/url';

const heroJumps = [
  { label: 'Wellness',       href: '#km-wellness' },
  { label: 'Komunitní park', href: '#km-park' },
  { label: 'Gastro',         href: '#km-gastro' },
  { label: 'Klubovna',       href: '#km-klubovna' },
];
---
<Base
  title="Komunita, wellness, park, gastro · Startovací Hub Klecany"
  description="Sauna, bazén, komunitní zahrádky, grilovací místa, kantýna a pekárna, klubovna pro akce. Komunitní program v areálu Hubu Klecany."
  headerVariant="overlay">

  <SubpageHero
    eyebrow="Komunitní zázemí"
    title="Bazén, <em>sauna</em>, jídelna, klubovna."
    sub="Vlastní bazén a sauna, jídelna s minipivovarem, klubovna a komunitní park s grilem. Týdenní vstup do sauny v ceně bydlení."
    variant="ink"
    ribbonPath="M 180 580 C 380 720, 620 540, 820 660 C 1020 780, 1240 620, 1340 720"
    ribbonPathSecondary="M 1380 200 C 1580 280, 1820 140, 2000 220 S 2180 360, 2080 460"
    thickness={48}
    thicknessSecondary={26}
    opacitySecondary={0.55}
    jumps={heroJumps}
    ariaId="komunita-hero"
  />

  <section class="sec-feature">
    <div class="sec-feature__inner">
      <div class="sec-feature__col">
        <div class="sec-feature__head">
          <p class="sec-feature__eyebrow">Wellness</p>
          <h2 class="sec-feature__title" id="km-wellness">Bazén a sauna v samostatném objektu.</h2>
        </div>
        <div class="sec-feature__text">
          <h3 id="km-bazen">Bazén</h3>
          <p>
            Bazén v samostatném objektu uprostřed areálu. Relax po práci, místo pro letní setkání,
            kondiční plavání. Provozní detaily doplníme před otevřením.
          </p>
          <h3 id="km-sauna">Sauna a wellness</h3>
          <p>
            Sauna pro 6 až 8 osob, k tomu sprchy a odpočinková zóna. Topíme dle harmonogramu,
            navrhujeme čtvrtek až sobotu večer. Rezidenti s tarifem 12+ mají v ceně poukaz
            1× týdně, jinak vstupné podle ceníku.
          </p>
        </div>
      </div>
      <div class="sec-feature__col">
        <div class="sec-feature__media">
          <Gallery
            images={[
              { src: withBase('/images/hub/komunita/bazen.jpg'), alt: 'Bazén v centrálním dvoře areálu, sluneční terasa, relax po práci.' },
              { placeholder: 'Sauna a wellness, 6 až 8 osob, sprchy, odpočinková zóna', alt: 'Sauna interiér.' },
            ]}
            ariaLabel="Wellness" />
        </div>
        <dl class="sec-feature__spec">
          <div><dt>Sauna návrh</dt><dd>Čt až So 18:00 až 22:00</dd></div>
          <div><dt>Kapacita sauny</dt><dd>6 až 8 osob</dd></div>
          <div><dt>Tarif 12+</dt><dd>1 vstup týdně zdarma</dd></div>
          <div><dt>Externí</dt><dd>Cena podle ceníku</dd></div>
        </dl>
      </div>
    </div>
  </section>

  <section class="sec-feature sec-feature--alt">
    <div class="sec-feature__inner">
      <div class="sec-feature__col">
        <div class="sec-feature__head">
          <p class="sec-feature__eyebrow">Venkovní park</p>
          <h2 class="sec-feature__title" id="km-park">Zahrádky, grilovací místa, hřiště.</h2>
        </div>
        <div class="sec-feature__text">
          <h3 id="km-zahradky">Komunitní zahrádky</h3>
          <p>
            V severní části parku, plocha rozdělená na malé záhony. Rezidenti si je rezervují na
            sezónu od jara do podzimu, voda, kompost a základní nářadí v&nbsp;ceně. Pro nováčky
            jednou ročně otevíráme začátečnický workshop s&nbsp;místním zahradníkem.
          </p>
          <h3 id="km-gril">Grilovací místa</h3>
          <p>
            Tři až čtyři pevné grily s lavičkami a stoly. Rezervace přes komunitní aplikaci na
            konkrétní den a čas. Uhlí a podpalovač si přineste vlastní, nebo kupte v kantýně.
          </p>
          <h3 id="km-hriste">Hřiště a venkovní posezení</h3>
          <p>
            Otevřené hřiště v parku, venkovní posezení s lavičkami a stoly. Typ hřiště (dětské,
            sportovní, multifunkční) doplníme před otevřením.
          </p>
        </div>
      </div>
      <div class="sec-feature__col">
        <div class="sec-feature__media">
          <Gallery
            images={[
              { placeholder: 'ko01 Grilovací místo, rodinné grilování v sobotu poledne, 8 až 12 lidí', alt: 'Grilovací místo v komunitním parku.' },
              { placeholder: 'Komunitní zahrádky, sezónní záhony', alt: 'Komunitní zahrádky.' },
            ]}
            ariaLabel="Venkovní park" />
        </div>
        <dl class="sec-feature__spec">
          <div><dt>Park rozloha</dt><dd>18 000 m²</dd></div>
          <div><dt>Vstup</dt><dd>Volný pro rezidenty i externí</dd></div>
          <div><dt>Grilovací místa</dt><dd>3 až 4 stálá, rezervace v aplikaci</dd></div>
          <div><dt>Zahrádky</dt><dd>Sezónní záhony pro rezidenty</dd></div>
        </dl>
      </div>
    </div>
  </section>

  <section class="sec-feature">
    <div class="sec-feature__inner">
      <div class="sec-feature__col">
        <div class="sec-feature__head">
          <p class="sec-feature__eyebrow">Gastro</p>
          <h2 class="sec-feature__title" id="km-gastro">Kantýna, restaurace, pekárna.</h2>
        </div>
        <div class="sec-feature__text">
          <h3 id="km-kantyna">Kantýna</h3>
          <p>
            Polední menu v pracovní dny. Tři až čtyři hlavní jídla (z toho jedno vegetariánské
            a jedno levné maso), polévka, salát. Cena 130 až 180 Kč podle tržního průměru
            Praha-okolí 2026. Vstup volný pro všechny. Po až Pá 11:00 až 14:00.
          </p>
          <h3 id="km-restaurace">Restaurace</h3>
          <p>
            Večery a víkendy v kuchyňském bloku budovy B. Sezónní menu, jednoduchá á la carte,
            sobotní brunch s živou hudbou, nedělní rodinný oběd. Po až Pá 17:00 až 22:00, So a
            Ne 11:00 až 22:00.
          </p>
          <h3 id="km-pekarna">Pekárna</h3>
          <p>
            Ranní směna pro rezidenty i obyvatele Klecan. Čerstvý chléb, croissanty, sladké
            pečivo, káva s sebou. Po až Pá 6:30 až 10:30.
          </p>
        </div>
      </div>
      <div class="sec-feature__col">
        <div class="sec-feature__media">
          <Gallery
            images={[
              { src: withBase('/images/hub/komunita/gastro/1-kantyna-busy.jpg'), alt: 'Kantýna v budově B v plném provozu, dlouhé stoly, otevřená kuchyně.' },
              { src: withBase('/images/hub/komunita/gastro/2-ext-minipivovar.jpg'), alt: 'Exteriér s minipivovarem v budově B, dřevěná terasa, venkovní posezení.' },
              { src: withBase('/images/hub/komunita/gastro/3-ext-dinner-outside.jpg'), alt: 'Venkovní gastro zóna, dřevěné stoly, lidé u večeře za soumraku.' },
            ]}
            ariaLabel="Gastro" />
        </div>
        <dl class="sec-feature__spec">
          <div><dt>Kantýna</dt><dd>Po až Pá 11:00 až 14:00</dd></div>
          <div><dt>Restaurace</dt><dd>Po až Pá 17:00 až 22:00, víkend 11:00 až 22:00</dd></div>
          <div><dt>Pekárna</dt><dd>Po až Pá 6:30 až 10:30</dd></div>
          <div><dt>Cena oběda</dt><dd>130 až 180 Kč</dd></div>
        </dl>
      </div>
    </div>
  </section>

  <section class="sec-feature sec-feature--alt">
    <div class="sec-feature__inner">
      <div class="sec-feature__col">
        <div class="sec-feature__head">
          <p class="sec-feature__eyebrow">Klubovna</p>
          <h2 class="sec-feature__title" id="km-klubovna">Společenský prostor pro 30 až 50 osob.</h2>
        </div>
        <div class="sec-feature__text">
          <p>
            V patrech budovy C, v jádře areálu, společně s coworkingem v 1. NP. Kapacita 30 až 50
            lidí. Stoly s lavicemi, projektor a plátno, ozvučení, kávovar, lednička.
          </p>
          <p>
            Pravidelné akce: úterní kvízový večer, čtvrteční desky, nedělní filmový klub.
            Rezidenti si mohou klubovnu rezervovat i pro soukromé akce (narozeniny, workshopy).
            Pro externí spolky pronájem dohodou.
          </p>
        </div>
      </div>
      <div class="sec-feature__col">
        <div class="sec-feature__media">
          <Gallery
            images={[
              { src: withBase('/images/hub/komunita/klubovna.jpg'), alt: 'Klubovna v budově C s eventem, lidé u stolů, kulturní život uvnitř Hubu.' },
            ]}
            ariaLabel="Klubovna" />
        </div>
        <dl class="sec-feature__spec">
          <div><dt>Pravidelné akce</dt><dd>Kvíz Út 20:00, desky Čt 19:00, film Ne 19:00</dd></div>
          <div><dt>Kapacita</dt><dd>30 až 50 osob</dd></div>
          <div><dt>Vybavení</dt><dd>Projektor, ozvučení, kávovar, lednička</dd></div>
          <div><dt>Rezervace</dt><dd>Přes komunitní aplikaci</dd></div>
        </dl>
      </div>
    </div>
  </section>

  <CtaBanner
    eyebrow="Rezervace"
    title="Bydlení s <em>komunitou</em> pod jednou střechou."
    lede="Rezervace je nezávazná. Z rezervačního oddělení vám zavoláme do 24 hodin."
    cta={{ label: 'Nezávazná rezervace', href: '/rezervace/' }}
    variant="ink"
  />

  <CrossLinkPair
    items={[
      { eyebrow: 'Ubytování', title: 'Apartmán, <em>nebo</em> co-living.', href: '/ubytovani/', variant: 'deep' },
      { eyebrow: 'Coworking', title: 'Sál, ateliér, <em>dílna</em>.',      href: '/coworking/', variant: 'cream' },
    ]}
  />
</Base>
