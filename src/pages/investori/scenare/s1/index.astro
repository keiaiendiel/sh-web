---
/*
 * /investori/scenare/s1/ , detail investičně-realizačního scénáře S1 base.
 * Obsah z hlavičky listu „S1 (base)": základní informace, popis projektu
 * Startovací hub, dějství scénáře s marketingovou komunikací a základní
 * struktura ekonometrického modelu. Kompletní ekonometrický model (Gross
 * Yield, ROI, IRR, CAPEX/OPEX po dějstvích) je rozpracovaný, převedeme ho
 * v další fázi.
 */
import InvestorPage from '../../../../layouts/InvestorPage.astro';
import { withBase } from '../../../../utils/url';
import s1 from '../../../../data/investori/s1.json';

type Radek = { label: string; d: string; v: unknown; f?: string; h?: string };
const isText = (r: Radek) => typeof r.v === 'string';
---
<InvestorPage title="Scénář S1 base , podklady pro investory VPD&#9312;" active="scenare">
  <div class="inv-shell">
    <header class="inv-hero">
      <p class="inv-hero__eyebrow" data-no-typograf>VPD&#9312; · základní scénář</p>
      <h1 class="inv-hero__title" data-no-typograf>{s1.titul}</h1>
      <p class="inv-hero__sub" data-no-typograf>{s1.podtitul}</p>
      <div class="inv-hero__meta">
        <span class="inv-chip inv-chip--accent" data-no-typograf>{s1.badge}</span>
      </div>
      <nav class="inv-jumps" aria-label="Sekce na stránce">
        <a href="#informace">Základní informace</a>
        <a href="#projekt">Projekt Startovací hub</a>
        <a href="#dejstvi">Dějství scénáře</a>
        <a href="#model">Ekonometrický model</a>
      </nav>
    </header>

    <section class="inv-section" id="informace">
      <div class="inv-section__head">
        <h2 class="inv-section__title" data-no-typograf>{s1.zakladniInformace.titul}</h2>
      </div>
      <div class="inv-card">
        <div class="inv-facts">
          {(s1.zakladniInformace.radky as Radek[]).map((r) => (
            <div class="inv-facts__row">
              <p class="inv-facts__label">{r.label}</p>
              <p class:list={['inv-facts__value', { 'inv-facts__value--text': isText(r) }]} data-no-typograf>{r.d}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section class="inv-section" id="projekt">
      <div class="inv-section__head">
        <h2 class="inv-section__title" data-no-typograf>{s1.projekt.titul}</h2>
      </div>
      <div class="inv-card" style="margin-bottom: var(--space-4);">
        <p class="inv-prose" data-no-typograf>{s1.projekt.popis}</p>
      </div>
      <div class="s1-cols">
        <div class="inv-card">
          <p class="inv-prose inv-prose--sm" data-no-typograf>{s1.projekt.proUbytovane}</p>
        </div>
        <div class="inv-card">
          <p class="inv-prose inv-prose--sm" data-no-typograf>{s1.projekt.proDevelopera}</p>
        </div>
      </div>
    </section>

    <section class="inv-section" id="dejstvi">
      <div class="inv-section__head">
        <h2 class="inv-section__title" data-no-typograf>{s1.scenar.titul}</h2>
      </div>
      <ol class="s1-acts">
        {s1.scenar.dejstvi.map((d) => (
          <li class="inv-card s1-act">
            <p class="inv-prose inv-prose--sm" data-no-typograf>{d.dejstvi}</p>
            {d.marketing && (
              <aside class="s1-act__marketing">
                <p class="s1-act__label" data-no-typograf>{s1.scenar.marketingHeader}</p>
                <p class="inv-prose inv-prose--sm" data-no-typograf>{d.marketing}</p>
              </aside>
            )}
          </li>
        ))}
      </ol>
      <p class="inv-note" data-no-typograf>{s1.scenar.footnote}</p>
    </section>

    <section class="inv-section" id="model">
      <div class="inv-section__head">
        <h2 class="inv-section__title" data-no-typograf>{s1.model.titul}</h2>
        <p class="inv-section__sub" data-no-typograf>{s1.model.infoTitul}</p>
      </div>
      <div class="inv-card" style="margin-bottom: var(--space-4);">
        <p class="inv-prose" data-no-typograf>{s1.model.popis}</p>
      </div>

      <h3 class="s1-sub" data-no-typograf>{s1.model.strukturaTitul}</h3>
      <div class="inv-table-wrap">
        <table class="inv-table">
          <thead>
            <tr>
              <th>Dějství</th>
              <th data-no-typograf>{s1.model.strukturaHeaders[0]}</th>
              <th data-no-typograf>{s1.model.strukturaHeaders[1]}</th>
            </tr>
          </thead>
          <tbody>
            {s1.model.struktura.map((r) => (
              <tr>
                <td class="txt" data-no-typograf style="white-space: pre-line;">{r.faze}</td>
                <td data-no-typograf>{r.obsah.d}</td>
                <td data-no-typograf>{r.delka.d}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>

      <div class="s1-pending">
        <p class="s1-pending__title">Kompletní ekonometrický model převádíme do webové podoby.</p>
        <p class="inv-prose inv-prose--sm">
          Gross Yield, Gross Profit, Project ROI, Project IRR a Equity IRR po
          jednotlivých dějstvích, včetně CAPEX a OPEX rozpadů a editovatelných
          vstupních parametrů se živým přepočtem. Do té doby model najdete
          v listu „S1 (base)" zdrojové tabulky.
        </p>
      </div>
    </section>

    <div class="inv-actions">
      <a class="inv-btn inv-btn--ghost" href={withBase('/investori/scenare/')}>Zpět na scénáře</a>
      <a class="inv-btn inv-btn--ghost" href={withBase('/investori/udaje-a-vypocty/')}>Základní údaje &amp; výpočty</a>
    </div>
  </div>
</InvestorPage>

<style>
  .s1-cols {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: var(--space-4);
  }
  .s1-acts {
    display: grid;
    gap: var(--space-3);
    margin: 0;
    padding: 0;
    list-style: none;
    counter-reset: act;
  }
  .s1-act {
    display: grid;
    grid-template-columns: minmax(0, 1.4fr) minmax(0, 1fr);
    gap: var(--space-5);
  }
  .s1-act__marketing {
    border-left: 3px solid var(--accent-rule);
    padding-left: var(--space-4);
  }
  .s1-act__label {
    font: 600 var(--text-2xs) / 1.3 var(--font-mono);
    letter-spacing: var(--tracking-wider);
    text-transform: uppercase;
    color: var(--accent);
    margin: 0 0 var(--space-2);
  }
  .s1-sub {
    font: 700 var(--text-xl) / var(--lh-snug) var(--font-sans);
    color: var(--fg);
    margin: var(--space-5) 0 var(--space-3);
  }
  .s1-pending {
    margin-top: var(--space-5);
    padding: var(--space-5);
    border: 1px dashed var(--k-30);
    border-radius: var(--radius-input);
    background: hsl(var(--hue) 14% 97%);
  }
  .s1-pending__title {
    font: 700 var(--text-md) / var(--lh-snug) var(--font-sans);
    color: var(--fg);
    margin: 0 0 var(--space-2);
  }
  @media (max-width: 820px) {
    .s1-act { grid-template-columns: 1fr; gap: var(--space-3); }
  }
</style>
