---
import Base from '../../layouts/Base.astro';
import Calculator from '../../components/Calculator.astro';
import InvestorForm from '../../components/InvestorForm.astro';
import { readFile } from 'node:fs/promises';
import path from 'node:path';

const scenariosPath = path.resolve(process.cwd(), 'public/data/scenarios.json');
const { scenarios, _disclaimer } = JSON.parse(await readFile(scenariosPath, 'utf8'));
---
<Base
  title="Pro investory — Startovací Hub Klecany"
  description="Shrnutí záměru VPD1, modelované scénáře návratnosti a možnost si nezávazně namodelovat svou pozici."
  headerVariant="light"
  showRoleChip={true}
  activeRole="investor"
>
  <section class="hub-page-hero">
    <h1>Pro investory</h1>
    <p class="hub-lead">Investiční záměr VPD1 hledá kapitál, který urychlí start první etapy a zajistí stabilní provoz Hubu, dokud se areál nedotvoří do plné podoby. Tady najdete shrnutí záměru, scénáře a možnost si nezávazně namodelovat svou pozici.</p>
  </section>

  <section class="hub-section hub-section--prose">
    <h2 class="hub-section__heading">Shrnutí záměru</h2>
    <p>VPD1 je revitalizační záměr v areálu bývalých horních kasáren v Klecanech. Cílem je postupné přivedení areálu do obyvatelné a produktivní podoby s potenciálem 1500+ bytových jednotek a navazujících funkcí (komunitní centrum, družstevní záložna, coworking, drobné služby). Startovací Hub je první etapa, která začíná z menšího provozního celku, abychom co nejdřív přivedli areál do reálného fungování, ověřili poptávku a navázali první rezidenty.</p>
    <p>Investice směřuje do startu a stabilizace Hubu plus do dotvoření právního a kapitálového rámce pro pokračování záměru. Návratnost je modelovaná v několika scénářích. Investice probíhá přes některý z definovaných právních vehiklů (Družstvo, Fond Kvalifikovaných Investorů VPD, Bytové Družstvo VPD), výběr finalizujeme s právním zajištěním na míru velikosti vstupu.</p>
  </section>

  <section class="hub-section hub-section--prose">
    <h2 class="hub-section__heading">Operátor a partneři</h2>
    <p>Záměr vede Veřejně Prospěšný Developer (VPD) pod hlavičkou Občanského sdružení Alternativa II, z.s. (OSA). OSA je nezisková platforma fungující dvacátým rokem bez veřejných dotací, na členských příspěvcích a vlastní činnosti. Za posledních patnáct let realizovala desítky projektů v urbanismu, kultuře, vzdělávání, tvorbě i komunitní práci. Detail OSA, dosavadní projekty a tým najdete na osa2.cz; podrobnější popis záměru VPD1 a jeho fází na osa2.cz/zamer-vpd/.</p>
    <p><a class="hub-external-cta" href="https://osa2.cz/zamer-vpd/" rel="noopener" target="_blank">Záměr VPD na osa2.cz →</a></p>
  </section>

  <section class="hub-section">
    <h2 class="hub-section__heading">Pět modelovaných scénářů</h2>
    <p class="hub-section__intro">Konzervativní, základní, optimistický a dvě varianty pro různé délky závazku.</p>
    <div class="hub-scenario-grid">
      {scenarios.map((s: any) => (
        <article class="hub-scenario-card">
          <header><span class="hub-scenario-card__id">{s.id}</span><h3>{s.name}</h3></header>
          <p>{s.description}</p>
          <dl>
            <div><dt>Cílový roční výnos</dt><dd>{s.nominalYieldPct.toLocaleString('cs')} % p.a.</dd></div>
            <div><dt>Doba</dt><dd>{s.termYears} let</dd></div>
          </dl>
          <p class="hub-scenario-card__assumption">{s.keyAssumption}</p>
        </article>
      ))}
    </div>
    <p class="hub-disclaimer">{_disclaimer}</p>
  </section>

  <Calculator />

  <section class="hub-section">
    <InvestorForm />
  </section>
</Base>

<style>
  .hub-page-hero { padding: 96px 24px 48px; max-width: 1440px; margin: 0 auto; }
  .hub-page-hero h1 { font-size: clamp(40px, 5vw, 80px); font-weight: 700; margin: 0 0 24px; letter-spacing: -0.02em; }
  .hub-lead { font-size: 20px; line-height: 1.5; max-width: 720px; color: var(--k-90); margin: 0; }

  .hub-section { padding: 64px 24px; max-width: 1440px; margin: 0 auto; }
  .hub-section__heading { font-size: clamp(28px, 3vw, 44px); font-weight: 700; margin: 0 0 24px; letter-spacing: -0.01em; }
  .hub-section--prose p { font-size: 17px; line-height: 1.65; max-width: 720px; color: var(--k-90); margin: 0 0 16px; }
  .hub-section__intro { font-size: 17px; line-height: 1.5; max-width: 720px; color: var(--k-90); margin: 0 0 32px; }

  .hub-external-cta { display: inline-block; font-weight: 600; text-decoration: underline; text-underline-offset: 3px; }

  .hub-scenario-grid { display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap: 16px; }
  @media (max-width: 960px) { .hub-scenario-grid { grid-template-columns: repeat(2, minmax(0, 1fr)); } }
  @media (max-width: 600px) { .hub-scenario-grid { grid-template-columns: 1fr; } }
  .hub-scenario-card { padding: 24px 20px; border: 1px solid var(--k-30); display: grid; gap: 12px; }
  .hub-scenario-card header { display: flex; align-items: baseline; gap: 12px; }
  .hub-scenario-card__id { font-weight: 700; color: var(--accent); font-size: 14px; letter-spacing: 0.05em; }
  .hub-scenario-card h3 { margin: 0; font-size: 18px; }
  .hub-scenario-card p { margin: 0; font-size: 14px; line-height: 1.55; color: var(--k-70, #4a4a4a); }
  .hub-scenario-card dl { display: grid; gap: 8px; margin: 0; }
  .hub-scenario-card dl div { display: flex; justify-content: space-between; gap: 12px; }
  .hub-scenario-card dt { font-size: 13px; color: var(--k-70, #4a4a4a); }
  .hub-scenario-card dd { margin: 0; font-weight: 600; font-size: 13px; }
  .hub-scenario-card__assumption { font-size: 12px; color: var(--k-60, #6a6a6a); border-top: 1px solid var(--k-10, #ececec); padding-top: 8px; margin-top: 4px; }
  .hub-disclaimer { max-width: 720px; margin: 24px 0 0; font-size: 13px; color: var(--k-70, #4a4a4a); line-height: 1.55; }
</style>
