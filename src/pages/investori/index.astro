---
/*
 * /investori/ , přihlášení do podkladů pro investory.
 * Klientská kontrola: SHA-256("email:heslo") proti allowlistu.
 * Po úspěchu uloží otisk do localStorage a přesměruje na ?next=
 * (default Investiční záměr).
 */
import InvestorPage from '../../layouts/InvestorPage.astro';
import { withBase } from '../../utils/url';
import { INVESTOR_ACCESS, INVESTOR_AUTH_KEY } from '../../utils/investorAuth';

const defaultNext = withBase('/investori/zamer/');
const basePrefix = withBase('/');
---
<InvestorPage title="Přihlášení , podklady pro investory VPD1" gate={false}>
  <div class="inv-login">
    <div class="inv-login__card">
      <p class="inv-login__eyebrow" data-no-typograf>Záměr VPD1 · Klecany</p>
      <h1 class="inv-login__title">Podklady pro investory</h1>
      <p class="inv-login__lede">
        Detailní informace k investičnímu záměru jsou určené pro jednání
        s partnery. Přihlaste se účtem, který jste od nás dostali.
      </p>
      <p class="inv-login__error" data-login-error role="alert">
        Tohle nesedí. Zkontrolujte e-mail i heslo a zkuste to znovu.
      </p>
      <form data-login-form novalidate>
        <label for="inv-email">E-mail</label>
        <input id="inv-email" name="email" type="email" autocomplete="username" required autofocus />
        <label for="inv-pass">Heslo</label>
        <input id="inv-pass" name="password" type="password" autocomplete="current-password" required />
        <button type="submit" class="inv-btn">Přihlásit se</button>
      </form>
      <p class="inv-login__hint">
        Nemáte přístup? Napište na <a href="mailto:vpd@osa2.cz">vpd@osa2.cz</a>.
      </p>
    </div>
  </div>

  <script is:inline define:vars={{ allow: INVESTOR_ACCESS, key: INVESTOR_AUTH_KEY, defaultNext, basePrefix }}>
    (function () {
      var form = document.querySelector('[data-login-form]');
      var error = document.querySelector('[data-login-error]');

      function nextUrl() {
        var next = new URLSearchParams(location.search).get('next') || '';
        /* Open-redirect guard: jen interní cesty pod basem webu. */
        if (next.indexOf(basePrefix) === 0 && next.indexOf('//') === -1) return next;
        return defaultNext;
      }

      /* Už přihlášený? Rovnou dovnitř. */
      try {
        if (allow.indexOf(localStorage.getItem(key)) !== -1) {
          location.replace(nextUrl());
          return;
        }
      } catch (e) {}

      function sha256hex(text) {
        var data = new TextEncoder().encode(text);
        return crypto.subtle.digest('SHA-256', data).then(function (buf) {
          return Array.prototype.map.call(new Uint8Array(buf), function (b) {
            return b.toString(16).padStart(2, '0');
          }).join('');
        });
      }

      form.addEventListener('submit', function (ev) {
        ev.preventDefault();
        var email = form.email.value.trim().toLowerCase();
        var pass = form.password.value;
        sha256hex(email + ':' + pass).then(function (hash) {
          if (allow.indexOf(hash) !== -1) {
            try { localStorage.setItem(key, hash); } catch (e) {}
            location.href = nextUrl();
          } else {
            error.classList.add('is-visible');
            form.password.value = '';
            form.password.focus();
          }
        });
      });
    })();
  </script>
</InvestorPage>
