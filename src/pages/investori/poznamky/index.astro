---
/*
 * /investori/poznamky/ , Poznámky & doplňkové informace (list 7 tabulky).
 * Číslovaný seznam 1:1 ze zdroje včetně rozpracovaných bodů; čistíme jen
 * prázdné řádky bez textu.
 */
import InvestorPage from '../../../layouts/InvestorPage.astro';
import { withBase } from '../../../utils/url';
import poznamky from '../../../data/investori/poznamky.json';
import meta from '../../../data/investori/meta.json';
---
<InvestorPage title="Poznámky , podklady pro investory VPD1" active="poznamky">
  <div class="inv-shell inv-shell--narrow">
    <header class="inv-hero">
      <p class="inv-hero__eyebrow" data-no-typograf>VPD1 · doplňkový kontext</p>
      <h1 class="inv-hero__title" data-no-typograf>{poznamky.titul}</h1>
      <div class="inv-hero__meta">
        <span class="inv-chip inv-chip--accent" data-no-typograf>{meta.badge}</span>
      </div>
    </header>

    <div class="inv-card">
      <div class="inv-notes">
        {poznamky.polozky.map((p) => (
          <div class="inv-notes__item">
            <p class="inv-notes__num" data-no-typograf>{p.cislo}</p>
            <p class="inv-notes__text" data-no-typograf>{p.text}</p>
          </div>
        ))}
      </div>
    </div>

    <div class="inv-actions">
      <a class="inv-btn inv-btn--ghost" href={withBase('/investori/zamer/')}>Zpět na investiční záměr</a>
    </div>
  </div>
</InvestorPage>
