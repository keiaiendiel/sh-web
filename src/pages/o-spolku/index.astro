---
import Base from '../../layouts/Base.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import OrgChart from '../../components/OrgChart.astro';
import ValuesMatrix from '../../components/ValuesMatrix.astro';
import DocumentList from '../../components/DocumentList.astro';
import InlineCTA from '../../components/InlineCTA.astro';
import Gallery from '../../components/Gallery.astro';
import { withBase } from '../../utils/url';
---
<Base title="O spolku - Občanské sdružení Alternativa II, z.s.">
  <Header variant="dark" />
  <main>
    <section
      class="osa-about__hero osa-dark"
      style={`--about-pattern: url('${withBase('/graphics/osa-bg-pattern-2.svg')}')`}>
      <div class="container-wide osa-about__hero-inner">
        <nav aria-label="Drobečková navigace" class="osa-about__crumbs osa-eyebrow">
          <a href={withBase('/')}>Úvod</a> <span aria-hidden="true">·</span>
          <span aria-current="page">O spolku</span>
        </nav>
        <h1 class="osa-about__h1" data-reveal>
          Ideologický a právní kořen spolku.
          <span class="osa-about__h1-sub">Platforma, která nic neprovozuje; rámec, bez kterého by projekty nemohly růst.</span>
        </h1>
        <p class="osa-about__lede" data-reveal data-reveal-delay="1">
          OSA II je zapsaný spolek založený v roce 2006 dvanácti studenty jako nezávislá, projektově orientovaná organizace. Od té doby kolem spolku vyrostlo téměř dvacet autonomních projektů, od komunitních zahrad přes kulturní památky až po LARP festivaly.
        </p>
      </div>
    </section>

    {/* ===== NARRATIVE + KLÍČOVÁ ČÍSLA =====
         Two-column: long-form paragraphs left, compact VPD-style datalist
         right. Stack under 900 px. Numbers consciously kept to four
         meaningful figures — independence, longevity, reach, shared
         value base. */}
    <section class="section section--tight osa-about__narrative">
      <div class="container-wide osa-about__narrative-grid">
        <div class="osa-about__kdojsme osa-longform" data-reveal>
          <p>
            Spolek funguje jako platforma. Sám přímo nic neprovozuje. Zajišťuje společný právní rámec, zázemí a konsensuální rozhodování; výkonnou činnost provádějí autonomní projekty, které si vedou vlastní členskou základnu, hospodaření i programovou linii.
          </p>
          <p>
            Spolek odmítá státní granty a dotace. Provoz financuje ze tří pilířů: dobrovolnická práce členů, metoda DIY a vlastní hospodářská činnost (členské příspěvky a služby na živnostenské bázi).
          </p>
          <p>
            Nejvyšším orgánem je Členský sněm. Statutárním orgánem je Představenstvo. Výkonnou úroveň tvoří autonomní projekty a kluby. O strategických rozhodnutích rozhoduje spolek konsensem.
          </p>
        </div>
        <aside class="osa-about__stats" data-reveal data-reveal-delay="1" aria-label="Spolek v číslech">
          <dl class="osa-about__numbers">
            <div>
              <dt>Založeno</dt>
              <dd><span class="osa-figs">2006</span><br /><small>před 20 lety, registrace u MV ČR</small></dd>
            </div>
            <div>
              <dt>Autonomních projektů</dt>
              <dd><span class="osa-figs">20+</span><br /><small>včetně klubů a decentralizovaných výkonných složek</small></dd>
            </div>
            <div>
              <dt>Oblastí činnosti</dt>
              <dd><span class="osa-figs">8</span><br /><small>urbanismus, kultura, sport, média, vzdělávání, tvorba, komunita, LARP</small></dd>
            </div>
            <div>
              <dt>Ze státních dotací</dt>
              <dd><span class="osa-figs">0&nbsp;Kč</span><br /><small>nezávislost na veřejných zdrojích je podmínka autonomie</small></dd>
            </div>
          </dl>
        </aside>
      </div>
    </section>

    {/* ===== VIZE · POSLÁNÍ · SMYSL =====
         Bespoke chapter-head layout matching the VPD investor page
         (big "01" numeric mark + small sub-head above the heading +
         body lede). Mobile drops the big mark and the sub-head
         alone carries the wayfinding. */}
    <section class="section osa-about__vize">
      <div class="container-wide">
        <header class="osa-about__sub-head" data-reveal>
          <span class="osa-eyebrow">Vize, poslání, smysl</span>
          <h2 class="osa-h2">Proč spolek existuje.</h2>
        </header>

        <div class="osa-about__chapter" data-reveal>
          <span class="osa-about__chapter-mark" aria-hidden="true">01</span>
          <div>
            <span class="osa-eyebrow">Čeho chceme dosáhnout</span>
            <h3 class="osa-h3 osa-about__chapter-title">Vize</h3>
            <p class="osa-body osa-about__chapter-body">
              Moderní, prosperující a hodnotově orientovaná společnost. Každý jedinec v ní má zázemí a podmínky pro plnohodnotnou a všestrannou seberealizaci.
            </p>
          </div>
        </div>

        <div class="osa-about__chapter" data-reveal>
          <span class="osa-about__chapter-mark" aria-hidden="true">02</span>
          <div>
            <span class="osa-eyebrow">Jak toho chceme dosáhnout</span>
            <h3 class="osa-h3 osa-about__chapter-title">Poslání</h3>
            <p class="osa-body osa-about__chapter-body">
              Podporujeme seberealizaci, aktivní bytí, vědu, kulturu, sport, tělovýchovu, vzdělávání, volný čas, humanitární aktivity, občanskou angažovanost i sociálně a ekologicky šetrné podnikání.
            </p>
          </div>
        </div>

        <div class="osa-about__chapter" data-reveal>
          <span class="osa-about__chapter-mark" aria-hidden="true">03</span>
          <div>
            <span class="osa-eyebrow">Proč to děláme</span>
            <h3 class="osa-h3 osa-about__chapter-title">Smysl</h3>
            <p class="osa-body osa-about__chapter-body">
              Rozvinuté zájmy, hodnoty a aktivity jednotlivce jsou předpokladem rozvinuté společnosti. Osobní štěstí a obecné blaho rostou spolu. Proto stavíme zázemí, kde se co nejvíce lidí může plnohodnotně rozvíjet.
            </p>
          </div>
        </div>
      </div>
    </section>

    {/* Values come before the org chart so the page reads ideology →
         structure: axioms establish what the spolek is about, org chart
         then shows how it's arranged around those axioms. */}
    <ValuesMatrix dark={true} />

    <section class="section">
      <div class="container-wide">
        <header class="osa-about__sub-head" data-reveal>
          <span class="osa-eyebrow">Organizační struktura</span>
          <h2 class="osa-h2">Tři úrovně, decentralizovaná výkonná část.</h2>
        </header>
        <div data-reveal>
          <OrgChart />
        </div>
      </div>
    </section>

    <section class="section osa-about__metod">
      <div class="container-wide">
        <header class="osa-about__sub-head" data-reveal>
          <span class="osa-eyebrow">Metodologie a hospodaření</span>
          <h2 class="osa-h2">Proč odmítáme státní dotace.</h2>
        </header>
        <div class="osa-longform osa-about__metod-body" data-reveal>
          <p>
            Hospodaření spolku stojí na třech pilířích: dobrovolnická práce, metoda DIY a vlastní hospodářská činnost.
          </p>
          <p>
            Dobrovolnická práce dovoluje startovat projekty s minimálním počátečním kapitálem a přitahuje členy, které projekt vnitřně zajímá. Metoda DIY drží provozní náklady nízko a nutí spolek rozvíjet vlastní kompetence, místo aby je kupoval. Vlastní hospodářská činnost zahrnuje výběr členských příspěvků a poskytování služeb vybraných projektů veřejnosti i firmám na standardní živnostenské bázi.
          </p>
          <p>
            Nezávislost na veřejných zdrojích považujeme za nezbytnou podmínku vlastní autonomie a rozhodovací pružnosti.
          </p>
        </div>
        <div class="osa-about__metod-ctas" data-reveal>
          <InlineCTA href={withBase('/o-spolku/metodologie/')}>Celý text o metodologii DIY</InlineCTA>
          <InlineCTA href={withBase('/o-spolku/historie/')}>Historie spolku od roku 2006</InlineCTA>
        </div>
      </div>
    </section>

    <section class="section">
      <div class="container-wide">
        <header class="osa-about__sub-head" data-reveal>
          <span class="osa-eyebrow">Spolkové dokumenty</span>
          <h2 class="osa-h2">Stanovy, výroční zprávy, šablony smluv.</h2>
        </header>
        <div data-reveal>
          <DocumentList />
        </div>
      </div>
    </section>

    <Gallery title="Z činností spolku." />
  </main>
  <Footer />
</Base>

<style>
  /* Dark hero: same shape as landing/VPD so the three pages share one silhouette.
     Background motif is the outlined-triangle OSA pattern (companion to the filled
     pattern on the landing hero), layered via ::before under the content. */
  .osa-about__hero {
    border-bottom: 1px solid var(--rule);
    position: relative;
    isolation: isolate;
  }
  .osa-about__hero::before {
    content: "";
    position: absolute;
    inset: 0;
    background-image: var(--about-pattern);
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
    opacity: 0.2;
    z-index: 0;
    pointer-events: none;
  }
  .osa-about__hero-inner { position: relative; z-index: 1; }
  .osa-about__hero-inner {
    padding-top: clamp(var(--space-7), 8vw, var(--space-9));
    padding-bottom: var(--space-9);
    display: grid;
    gap: var(--space-5);
  }
  .osa-about__crumbs {
    display: flex; gap: var(--space-2); flex-wrap: wrap;
    color: var(--fg-muted);
  }
  .osa-about__crumbs a { text-decoration: underline; text-underline-offset: 3px; }
  .osa-about__crumbs [aria-current] { color: var(--fg); }

  .osa-about__h1 {
    font-family: var(--font-sans);
    font-weight: 600;
    font-size: clamp(2.25rem, 5vw + 0.5rem, 4rem);
    line-height: 1.05;
    letter-spacing: var(--tracking-tight);
    color: var(--fg);
    margin: 0;
    max-width: 22ch;
    text-wrap: balance;
  }
  .osa-about__h1-sub {
    display: block;
    color: var(--fg-muted);
    font-weight: 500;
    font-size: clamp(1.25rem, 1.8vw + 0.5rem, 1.75rem);
    margin-top: var(--space-3);
    max-width: 28ch;
  }
  .osa-about__lede {
    margin: 0;
    color: var(--fg-muted);
    font-size: var(--text-lg);
    max-width: 62ch;
  }

  /* ---------- Narrative + compact datalist ---------- */
  .osa-about__narrative-grid {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(280px, 380px);
    gap: var(--space-8);
    align-items: start;
  }
  .osa-about__stats { margin: 0; }
  .osa-about__numbers {
    display: grid;
    gap: 0;
    margin: 0;
  }
  .osa-about__numbers > div {
    display: grid;
    grid-template-columns: 140px 1fr;
    gap: var(--space-4);
    padding: var(--space-3) 0;
    border-top: 1px solid var(--rule);
  }
  .osa-about__numbers > div:last-child { border-bottom: 1px solid var(--rule); }
  .osa-about__numbers dt {
    font-family: var(--font-sans);
    font-weight: 600;
    font-size: var(--text-sm);
    color: var(--fg);
    align-self: start;
  }
  .osa-about__numbers dd {
    margin: 0;
    font-size: var(--text-sm);
    color: var(--fg);
    line-height: var(--lh-normal);
  }
  .osa-about__numbers dd small {
    display: block;
    color: var(--fg-muted);
    font-size: var(--text-xs);
    margin-top: 2px;
  }
  @media (max-width: 900px) {
    .osa-about__narrative-grid {
      grid-template-columns: 1fr;
      gap: var(--space-6);
    }
  }
  @media (max-width: 560px) {
    .osa-about__numbers > div { grid-template-columns: 1fr; gap: var(--space-2); }
  }

  /* ---------- Vize / poslání / smysl — VPD chapter-head vocabulary ---------- */
  .osa-about__chapter {
    display: grid;
    grid-template-columns: auto 1fr;
    column-gap: var(--space-6);
    padding: var(--space-6) 0;
    border-top: 1px solid var(--rule);
    align-items: start;
  }
  .osa-about__chapter:last-of-type { border-bottom: 1px solid var(--rule); }
  .osa-about__chapter-mark {
    font-family: var(--font-sans);
    font-weight: 600;
    font-size: clamp(2.8rem, 7.2vw, 4.8rem);
    line-height: 0.9;
    color: var(--fg);
    letter-spacing: -0.02em;
    min-width: 3ch;
  }
  .osa-about__chapter-title {
    margin: var(--space-1) 0 var(--space-2);
    font-weight: 600;
  }
  .osa-about__chapter-body {
    margin: 0;
    max-width: 64ch;
  }
  @media (max-width: 720px) {
    .osa-about__chapter {
      grid-template-columns: 1fr;
      column-gap: 0;
      row-gap: var(--space-2);
      padding: var(--space-5) 0;
    }
    .osa-about__chapter-mark { display: none; }
    .osa-about__chapter-title { font-size: var(--text-2xl); }
  }

  .osa-about__sub-head {
    display: grid;
    gap: var(--space-2);
    margin: 0 0 var(--space-6);
  }
  .osa-about__kdojsme > * { margin: 0 0 var(--space-4); }
  .osa-about__metod-body > * { margin: 0 0 var(--space-4); }
  .osa-about__metod-ctas {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-6);
    margin-top: var(--space-6);
  }
</style>
