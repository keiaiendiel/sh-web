---
import Base from '../../layouts/Base.astro';
import SubpageHero from '../../components/SubpageHero.astro';
import CtaBanner from '../../components/CtaBanner.astro';
import CrossLinkPair from '../../components/CrossLinkPair.astro';
import { withBase } from '../../utils/url';

const heroJumps = [
  { label: 'Vzdělávání',       href: '#ok-skoly' },
  { label: 'Zdravotnictví',    href: '#ok-zdravotnictvi' },
  { label: 'Obchody',          href: '#ok-obchody' },
  { label: 'Sport',            href: '#ok-sport' },
  { label: 'Kavárny a kultura', href: '#ok-kavarny' },
];
---
<Base
  title="Okolí Klecan, co tu je a co tu není · Startovací Hub"
  description="Klecany jsou klidná obec na severním okraji Prahy. Mateřská škola v areálu, skate hala, lékaři, lékárna, obchody, kavárna Klícka, bus 374 do metra Kobylisy."
  headerVariant="overlay">

  <SubpageHero
    eyebrow="Okolí a dostupnost"
    title="Klecany, <em>15 km</em> od Prahy."
    sub="Klidná obec na severním okraji Prahy. V docházkové vzdálenosti školy, lékaři, obchody, sport a kavárny."
    variant="cream"
    ribbonPath="M 240 540 C 240 360, 440 300, 640 360 C 820 410, 940 520, 900 680 C 860 800, 600 840, 400 790 C 220 740, 140 640, 200 560 C 215 545, 225 545, 240 540"
    ribbonPathSecondary="M 460 100 C 780 140, 1080 320, 1120 580 C 1140 720, 1000 780, 900 740"
    thickness={16}
    thicknessSecondary={22}
    opacityPrimary={0.55}
    opacitySecondary={0.45}
    jumps={heroJumps}
    ariaId="okoli-hero"
  />

  <section class="ok-map-section" aria-label="Mapa polohy Hubu v Klecanech">
    <div class="ok-map-section__inner">
      <header class="ok-map-section__head">
        <p class="sec-block__eyebrow">Poloha areálu</p>
        <h2 class="sec-block__title">Horní Kasárna, 250 67 Klecany.</h2>
        <p class="sec-block__lede">
          Severní okraj Klecan, 15 minut autobusem na metro Kobylisy, 30 minut do centra Prahy.
        </p>
      </header>
      <div class="ok-map" id="ok-map-frame" data-ok-map role="application" aria-label="Interaktivní mapa areálu Horních kasáren v Klecanech"></div>
      <p class="ok-map__address">
        <strong>Horní kasárna Klecany</strong>
        <a href="https://maps.app.goo.gl/vCF6VbW7Z49sggau6" target="_blank" rel="noopener">Otevřít v Mapách →</a>
      </p>
    </div>
  </section>

  <script is:inline>
    (function () {
      function buildMap(el) {
        if (el.dataset.mapBound) return;
        el.dataset.mapBound = '1';
        var center = [50.181447, 14.424094];
        var map = L.map(el, {
          center: center, zoom: 16,
          zoomControl: false, attributionControl: false,
          scrollWheelZoom: false,
        });
        var tiles = L.tileLayer('https://{s}.basemaps.cartocdn.com/rastertiles/voyager_nolabels/{z}/{x}/{y}{r}.png', {
          attribution: '&copy; <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a> &copy; <a href="https://carto.com/">CARTO</a>',
          subdomains: 'abcd', maxZoom: 19,
        }).addTo(map);
        var icon = L.divIcon({
          html:
            '<svg width="30" height="40" viewBox="0 0 28 36" fill="none" xmlns="http://www.w3.org/2000/svg">' +
            '<path d="M14 0C6.27 0 0 6.27 0 14c0 9.33 14 22 14 22S28 23.33 28 14C28 6.27 21.73 0 14 0z" fill="#5A2A5F"/>' +
            '<circle cx="14" cy="14" r="5" fill="#ffffff"/>' +
            '</svg>',
          className: '', iconSize: [30, 40], iconAnchor: [15, 40], popupAnchor: [0, -42],
        });
        var gmaps = 'https://maps.app.goo.gl/vCF6VbW7Z49sggau6';
        var popupHtml =
          '<a href="' + gmaps + '" target="_blank" rel="noopener" class="ok-map-popup">' +
            '<strong>Horní kasárna Klecany</strong>' +
            '<span class="ok-map-popup__cta">Otevřít v Mapách →</span>' +
          '</a>';
        L.marker(center, { icon: icon })
          .addTo(map)
          .bindPopup(popupHtml, { className: 'ok-map-popup-wrap' })
          .openPopup()
          .on('click', function () { window.open(gmaps, '_blank'); });
        L.control.attribution({ prefix: false }).addTo(map);
        L.control.zoom({ position: 'bottomright' }).addTo(map);
        el.addEventListener('click', function () { map.scrollWheelZoom.enable(); }, { once: true });
        /* Tile-sizing race fix: i s IntersectionObserverem (gating init až do
           viewportu) leaflet někdy změří kontejner příliš brzy a nakreslí jen
           1 dlaždici nahoře vlevo („drobný čtvereček"). Pojistka: rAF, několik
           setTimeoutů, ResizeObserver, tile load event, window.load, visibility
           change , kdykoli jeden z těchto signálů přijde, force invalidate. */
        requestAnimationFrame(function () { map.invalidateSize(); });
        [80, 250, 800, 1600].forEach(function (ms) {
          setTimeout(function () { map.invalidateSize(); }, ms);
        });
        tiles.once('load', function () { map.invalidateSize(); });
        if ('ResizeObserver' in window) {
          var ro = new ResizeObserver(function () { map.invalidateSize(); });
          ro.observe(el);
        }
        window.addEventListener('load', function () { map.invalidateSize(); }, { once: true });
        document.addEventListener('visibilitychange', function () {
          if (!document.hidden) map.invalidateSize();
        });
      }

      function bind() {
        var el = document.getElementById('ok-map-frame');
        if (!el || !window.__hubLoadLeaflet) return;
        /* Defer init dokud se kontejner nedostane k viewportu , při cold loadu
           layout ještě může „dosedat" (fonty, lazy obrázky výš na stránce),
           a Leaflet zachytí špatné rozměry. IntersectionObserver garantuje,
           že init běží až má kontejner finální velikost. */
        if (!('IntersectionObserver' in window)) {
          window.__hubLoadLeaflet(function () { buildMap(el); });
          return;
        }
        var io = new IntersectionObserver(function (entries) {
          entries.forEach(function (e) {
            if (e.isIntersecting) {
              io.unobserve(e.target);
              window.__hubLoadLeaflet(function () { buildMap(el); });
            }
          });
        }, { rootMargin: '300px 0px' });
        io.observe(el);
      }
      document.addEventListener('astro:page-load', bind);
    }());
  </script>

  <section class="sec-block sec-hued" style="--section-hue: 130;">
    <div class="sec-block__inner">
      <header class="sec-block__head">
        <p class="sec-block__eyebrow" id="ok-skoly">Vzdělávání</p>
        <h2 class="sec-block__title">Školy a školky.</h2>
      </header>
      <dl class="sec-table">
        <div class="sec-table__row"><dt><a href="https://msastra.cz/" rel="noopener">MŠ Astra (Montessori)</a></dt><dd>Dolní Kasárna 766, 0 m od Hubu (v rámci areálu), Po až Pá 7:00 až 17:00, česko-anglická Montessori</dd></div>
        <div class="sec-table__row"><dt><a href="https://www.zsmsklecany.cz/" rel="noopener">ZŠ a MŠ Klecany</a></dt><dd>U Školky 74, výuka na Sídlišti 375, 1,3 km, 16 minut pěšky, 5 minut na kole</dd></div>
        <div class="sec-table__row"><dt><a href="https://zus.klecany.cz/" rel="noopener">ZUŠ Klecany</a></dt><dd>Klecany 375, 1,4 km, 17 minut pěšky, hudba a výtvarné obory</dd></div>
        <div class="sec-table__row"><dt>Gymnázia v Praze 8</dt><dd>Thomase Manna (Střížkovská, 8,5 km, 15 minut autem), Karlínské gymnázium (15 minut bus + metro)</dd></div>
        <div class="sec-table__row"><dt>Letecká SŠ Odolena Voda</dt><dd>Commute 15 až 20 minut autem</dd></div>
      </dl>
    </div>
  </section>

  <section class="sec-block sec-block--alt sec-hued" style="--section-hue: 200;">
    <div class="sec-block__inner">
      <header class="sec-block__head">
        <p class="sec-block__eyebrow" id="ok-zdravotnictvi">Zdravotnictví</p>
        <h2 class="sec-block__title">Lékaři a lékárna v U Školy 17.</h2>
        <p class="sec-block__lede">V jedné budově na adrese U Školy 17 (1,3 km, 16 minut pěšky, 5 minut na kole).</p>
      </header>
      <dl class="sec-table">
        <div class="sec-table__row"><dt>Ordinace Jach-Ta</dt><dd>Praktický lékař, dr. Jáchym Bednář, dr. Pavla Stachoňová, Po a Čt do 18:00, online recepty přes Smartmedix</dd></div>
        <div class="sec-table__row"><dt>MUDr. Vosečková</dt><dd>Praktický lékař, Po až Pá 8:00 až 13:00</dd></div>
        <div class="sec-table__row"><dt>MUDr. Ondráčková</dt><dd>Zubařka, Po 10 až 17, Út až Čt 8 až 15, Pá 8 až 12, online rezervace</dd></div>
        <div class="sec-table__row"><dt>Lékárna Klecany</dt><dd>Po, Út do 16:00, Čt do 18:00, víkend zavřeno</dd></div>
      </dl>
      <p class="sec-block__text">
        Pohotovost ani 24h lékárna v Klecanech nejsou. Nejbližší 24h lékárna je v&nbsp;centru
        Prahy, přes metro Kobylisy 25 až 30 minut.
      </p>
    </div>
  </section>

  <section class="sec-block sec-hued" style="--section-hue: 25;">
    <div class="sec-block__inner">
      <header class="sec-block__head">
        <p class="sec-block__eyebrow" id="ok-obchody">Obchody</p>
        <h2 class="sec-block__title">Potraviny, drogerie, velký nákup.</h2>
      </header>
      <dl class="sec-table">
        <div class="sec-table__row"><dt>Potraviny Klecany</dt><dd>V Honech 690/1, 1,6 km, 20 minut pěšky, Po až Ne 7:00 až 19:00, běžné potraviny, čerstvé pečivo, jízdenky PID</dd></div>
        <div class="sec-table__row"><dt>Drogerie Och!</dt><dd>Do Klecánek 58, 1,1 km, 13 minut pěšky, otevřeno od 8:30</dd></div>
        <div class="sec-table__row"><dt><a href="https://www.lidl.cz" rel="noopener">Lidl Zdiby</a></dt><dd>Ke Zdibsku 272, 3,5 km, 6 minut autem, 15 minut na kole, Po až Ne do 21:00, hlavní velký nákup</dd></div>
        <div class="sec-table__row"><dt><a href="https://www.albert.cz" rel="noopener">Albert Roztoky</a></dt><dd>Tyršovo nám., 4,2 km přes Přívoz Klecánky, 25 minut s přívozem, alternativa s cestou přes Vltavu</dd></div>
      </dl>
      <p class="sec-block__text">Rohlík.cz a Košík.cz doručují přímo do Klecan.</p>
    </div>
  </section>

  <section class="sec-block sec-block--alt sec-hued" style="--section-hue: 240;">
    <div class="sec-block__inner">
      <header class="sec-block__head">
        <p class="sec-block__eyebrow">Pošta, banka, balíkomat</p>
        <h2 class="sec-block__title">Logistika v docházce.</h2>
      </header>
      <dl class="sec-table">
        <div class="sec-table__row"><dt><a href="https://www.ceskaposta.cz" rel="noopener">Česká pošta Klecany</a></dt><dd>Do Klecánek 52, 1,1 km</dd></div>
        <div class="sec-table__row"><dt><a href="https://www.zasilkovna.cz" rel="noopener">Z-BOX Zásilkovna</a></dt><dd>Do Klecánek 58, 1,1 km, nonstop (vyžaduje Bluetooth a aplikaci)</dd></div>
        <div class="sec-table__row"><dt><a href="https://www.alza.cz/alzabox" rel="noopener">AlzaBox Klecany</a></dt><dd>Do Klecánek 58, 1,1 km, nonstop (vyžaduje aplikaci Alza)</dd></div>
        <div class="sec-table__row"><dt>MONETA bankomat</dt><dd>U Školky 74, 1,3 km, nonstop bezkontaktní</dd></div>
        <div class="sec-table__row"><dt>KB bankomat</dt><dd>Zdibsko 164, cca 2 km, nonstop</dd></div>
      </dl>
    </div>
  </section>

  <section class="sec-block sec-hued" style="--section-hue: 130;">
    <div class="sec-block__inner">
      <header class="sec-block__head">
        <p class="sec-block__eyebrow" id="ok-sport">Sport a venkovní aktivity</p>
        <h2 class="sec-block__title">Skate hala 100 metrů, fotbal, cyklostezka.</h2>
      </header>
      <dl class="sec-table">
        <div class="sec-table__row"><dt><a href="https://www.skateskola.cz/" rel="noopener">Skate hala Klecany</a></dt><dd>Dolní Kasárna, 100 m od Hubu (v rámci areálu), Po až Pá 14:00 až 21:00, So až Ne 10:00 až 21:00, krytý dřevěný skatepark</dd></div>
        <div class="sec-table__row"><dt>Fotbal TJ Sokol</dt><dd>Na Skalkách 368/33, 1,8 km, 23 minut pěšky, 7 minut na kole</dd></div>
        <div class="sec-table__row"><dt>Workout a gril park</dt><dd>Centrum obce u fotbalu, 1,8 km, veřejně přístupné, revitalizovaný</dd></div>
        <div class="sec-table__row"><dt>EuroVelo 7</dt><dd>Vltavské nábřeží, 2,5 km, 30 minut pěšky, 10 minut na kole, podél Vltavy směr Praha i Mělník</dd></div>
      </dl>
    </div>
  </section>

  <section class="sec-block sec-block--alt sec-hued" style="--section-hue: 50;">
    <div class="sec-block__inner">
      <header class="sec-block__head">
        <p class="sec-block__eyebrow" id="ok-kavarny">Kavárny, restaurace, kultura</p>
        <h2 class="sec-block__title">Klícka, Sportklub, KC Rychta.</h2>
      </header>
      <dl class="sec-table">
        <div class="sec-table__row"><dt>Kavárna Klícka</dt><dd>Náměstí Třebízského 54, 1,5 km, 20 minut pěšky, výběrová káva Coffee Spot, řemeslné pivo, domácí pečivo, Čt do 21:00</dd></div>
        <div class="sec-table__row"><dt>Sportklub Restaurace</dt><dd>Na Skalkách 368/33 u fotbalu, 1,8 km, Po až Ne 11:00 až 23:00, denní menu, pizza večer</dd></div>
        <div class="sec-table__row"><dt>KC Rychta</dt><dd>Klecany, 1,6 km, kapacita 232 osob, koncerty, plesy, kulturní program KVČ</dd></div>
        <div class="sec-table__row"><dt>Letní kino Roztoky</dt><dd>4,5 km přes přívoz, sezónní vybrané večery v létě</dd></div>
      </dl>
    </div>
  </section>

  <section class="sec-block sec-hued" style="--section-hue: 240;">
    <div class="sec-block__inner">
      <header class="sec-block__head">
        <p class="sec-block__eyebrow">Brigády a práce</p>
        <h2 class="sec-block__title">Alza, HOPI a PURTEX v okolí.</h2>
        <p class="sec-block__lede">Pro studenty, kteří hledají brigádu nebo doplňkový příjem.</p>
      </header>
      <dl class="sec-table">
        <div class="sec-table__row"><dt>Alza.cz Zdiby</dt><dd>Zdibsko 615, 2,5 km, 30 minut pěšky, 10 minut na kole, skladník na noční směny, nástupní mzda 31 900 Kč</dd></div>
        <div class="sec-table__row"><dt>PURTEX s.r.o.</dt><dd>Parkerova 617 Zdibsko, 2,5 km, údržba a provozní personál</dd></div>
        <div class="sec-table__row"><dt>HOPI</dt><dd>Region Zdiby, logistika a rozvoz potravin</dd></div>
      </dl>
    </div>
  </section>

  <section class="sec-block sec-block--alt sec-hued" style="--section-hue: 200;">
    <div class="sec-block__inner">
      <header class="sec-block__head">
        <p class="sec-block__eyebrow">Co tu není (otevřeně přiznáno)</p>
        <h2 class="sec-block__title">Žádný noční život, řidší víkendová doprava.</h2>
      </header>
      <div class="sec-block__text">
        <ul>
          <li>Noční život po 23:00. Žádné kluby, žádné noční bary. Bereme to jako vlastnost, ne nedostatek: hluboký spánek pro tvrdou práci.</li>
          <li>Víkendová lékárna. Řešíme přes Rohlík/Košík nebo cestou do Prahy.</li>
          <li>Hypermarket v docházce. Lidl Zdiby na kole nebo autem, donáška přes online supermarkety.</li>
          <li>Linka 374 jezdí o víkendech řidčeji (30 až 60 min), poslední spoj 22:50. Hub-shuttle a Hub-taxi tento gap pokrývají.</li>
        </ul>
      </div>
    </div>
  </section>

  <CtaBanner
    eyebrow="Rezervace"
    title="Bydlení blízko Prahy <em>bez ceny centra</em>."
    lede="Hluboká práce v Klecanech, rušný život v Praze. Rezervace je nezávazná."
    cta={{ label: 'Nezávazná rezervace', href: '/rezervace/' }}
    variant="cream"
  />

  <CrossLinkPair
    items={[
      { eyebrow: 'Doprava',  title: 'Patnáct minut <em>autobusem</em> na metro.',     href: '/doprava/',  variant: 'deep' },
      { eyebrow: 'Komunita', title: 'Bazén, <em>sauna</em>, jídelna a&nbsp;klubovna.', href: '/komunita/', variant: 'ink' },
    ]}
  />
</Base>

<style>
  /* Mapa polohy: Leaflet s CARTO Voyager basemap. Přírodní cream/sand barvy,
     plum pin, popup, attribution dole vpravo. Address line pod mapou. */
  .ok-map-section {
    padding: var(--space-8) 0;
    background: var(--bg);
  }
  .ok-map-section__inner {
    width: calc(100% - 2 * var(--gutter));
    max-width: var(--container-wide);
    margin: 0 auto;
    display: grid;
    gap: var(--space-5);
  }
  .ok-map-section__head { display: grid; gap: var(--space-2); max-width: 64ch; }

  .ok-map {
    position: relative;
    aspect-ratio: 21 / 9;
    border-radius: var(--radius-input);
    overflow: hidden;
    background: var(--bg-muted);
    border: 1px solid var(--accent-rule);
    /* Isolation: isolate vytváří lokální stacking context, takže Leaflet
       interní z-indexy (panes až 800) se nepokoušejí překrýt mobile drawer
       menu (z-index 29). Bez isolation Leaflet leakuje skrz parent. */
    isolation: isolate;
  }
  .ok-map :global(.leaflet-container) {
    width: 100%;
    height: 100%;
    background: var(--k-05);
    font-family: var(--font-sans);
    z-index: 0;
  }
  .ok-map :global(.leaflet-control-attribution) {
    background: rgba(255, 255, 255, 0.92) !important;
    color: var(--fg-muted) !important;
    font-size: 10px !important;
    padding: 1px 6px !important;
  }
  .ok-map :global(.leaflet-control-attribution a) { color: var(--fg) !important; }
  .ok-map :global(.leaflet-control-zoom a) {
    color: var(--accent) !important;
    background: #fff !important;
    border: 1px solid var(--accent-rule) !important;
  }
  .ok-map :global(.leaflet-control-zoom a:hover) {
    background: var(--accent-soft) !important;
  }
  .ok-map :global(.ok-map-popup-wrap .leaflet-popup-content-wrapper) {
    background: #fff;
    color: var(--fg);
    border-radius: var(--radius-input);
    box-shadow: 0 10px 28px hsl(var(--hue) 39% 27% / 0.18);
    padding: 4px 8px;
  }
  .ok-map :global(.ok-map-popup-wrap .leaflet-popup-tip) {
    background: #fff;
    box-shadow: 0 10px 28px hsl(var(--hue) 39% 27% / 0.18);
  }
  .ok-map :global(.ok-map-popup) {
    display: flex;
    flex-direction: column;
    gap: 2px;
    text-decoration: none;
    color: var(--fg);
    padding: 6px 8px;
    min-width: 160px;
  }
  .ok-map :global(.ok-map-popup strong) {
    font: 600 13px / 1.3 var(--font-sans);
    color: var(--fg);
  }
  .ok-map :global(.ok-map-popup__cta) {
    font: 500 12px / 1.3 var(--font-sans);
    color: var(--accent);
  }

  .ok-map__address {
    margin: 0;
    font: 500 var(--text-sm) / 1.5 var(--font-sans);
    color: var(--fg-soft, var(--fg));
    display: flex;
    align-items: baseline;
    gap: var(--space-3);
    flex-wrap: wrap;
  }
  .ok-map__address strong { color: var(--fg); }
  .ok-map__address a {
    color: var(--accent);
    text-decoration: none;
    border-bottom: 1px solid var(--accent-rule);
    padding-bottom: 1px;
  }
  .ok-map__address a:hover { border-bottom-color: var(--accent); }

  @media (max-width: 760px) {
    .ok-map { aspect-ratio: 21 / 9; }
  }
</style>
