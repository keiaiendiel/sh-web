---
/*
 * Galerie , reálná foto-mřížka (ne zig-zag). Každá kategorie: nadpis + dva
 * obdélníky vedle sebe (desktop), klik otevře lightbox.
 */
import Base from '../../layouts/Base.astro';
import SubpageHero from '../../components/SubpageHero.astro';
import PhotoGrid from '../../components/PhotoGrid.astro';
import Lightbox from '../../components/Lightbox.astro';
import CtaBanner from '../../components/CtaBanner.astro';
import CrossLinkPair from '../../components/CrossLinkPair.astro';

/* Šest kategorií dle klientské tabulky Koncept webu: Privátní apartmány,
   Sdílené pokoje, Co-livingové zázemí, Co-workingové zázemí, Sdílená mobilita,
   Okolí areálu. Coliving je zastřešující pojem kampusu (gastro, wellness,
   komunita), co-working kryje práci a dílny. */
const categories = [
  {
    heading: 'Privátní apartmány', group: 'g-privatni', more: '/ubytovani/privatni/',
    images: [
      { src: '/images/hub/ubytovani/02-1kk.jpg', alt: 'Privátní apartmán 1+kk' },
      { src: '/images/hub/ubytovani/04-int.jpg', alt: 'Interiér apartmánu' },
      { src: '/images/hub/ubytovani/05-4kk-family.jpg', alt: 'Větší apartmán pro skupinu' },
      { src: '/images/hub/ubytovani/03-ext.jpg', alt: 'Exteriér obytné budovy za soumraku' },
    ],
  },
  {
    heading: 'Sdílené pokoje', group: 'g-sdilene', more: '/ubytovani/sdilene-pokoje/',
    images: [
      { src: '/images/hub/ubytovani/coliving/pokoj-basic-01.jpg', alt: 'Sdílený pokoj se základní mírou soukromí' },
      { src: '/images/hub/ubytovani/coliving/pokoj-privacy-01.jpg', alt: 'Lůžkové boxy s posuvnými dveřmi' },
      { src: '/images/hub/ubytovani/coliving/kapsle-single-01.jpg', alt: 'Uzamykatelná kapsle' },
      { src: '/images/hub/ubytovani/coliving/kapsle-double-01.jpg', alt: 'Kapslové dvojlůžko' },
    ],
  },
  {
    heading: 'Co-livingové zázemí', group: 'g-coliving', more: '/zazemi/',
    images: [
      { src: '/images/hub/komunita/gastro/01-kantyna.jpg', alt: 'Kantýna v kuchyňském bloku B' },
      { src: '/images/hub/komunita/wellness-01-bazen.jpg', alt: 'Venkovní bazén' },
      { src: '/images/hub/komunita/wellness-02-sauna.jpg', alt: 'Sauna' },
      { src: '/images/hub/komunita/gastro/04-pekarna.jpg', alt: 'Pekárna' },
      { src: '/images/hub/komunita/05-komunitni-zahrady.jpg', alt: 'Komunitní zahrádky' },
      { src: '/images/hub/komunita/04-klubovna.jpg', alt: 'Společenský sál a klubovna' },
    ],
  },
  {
    heading: 'Co-workingové zázemí', group: 'g-coworking', more: '/zazemi/coworking/',
    images: [
      { src: '/images/hub/coworking/cowork-interier-sal-c.jpg', alt: 'Coworkingový sál' },
      { src: '/images/hub/coworking/02-cowork-interier-vlastni-stul.jpg', alt: 'Sdílené pracovní stoly' },
      { src: '/images/hub/coworking/03-cowork-interior-zasedacka.jpg', alt: 'Zasedací místnost' },
      { src: '/images/hub/coworking/cowork-interior-dilna.jpg', alt: 'Dílna' },
    ],
  },
  {
    heading: 'Sdílená mobilita', group: 'g-mobilita', more: '/doprava/sdilena-mobilita/',
    images: [
      { src: '/images/hub/doprava/hub-shuttle-zastavka.jpg', alt: 'Zastávka kyvadlové dopravy MyShelter v areálu' },
      { src: '/images/hub/doprava/cyklostezka.jpg', alt: 'Cyklostezka EuroVelo 7 podél Vltavy' },
      { src: '/images/hub/okoli/01-areal-dostupnost.jpg', alt: 'Mapa dostupnosti areálu' },
      { src: '/images/hub/okoli/04-topview-update.jpg', alt: 'Letecký pohled na areál a okolí' },
    ],
  },
  {
    heading: 'Okolí areálu', group: 'g-okoli', more: '/zazemi/okoli/',
    images: [
      { src: '/images/hub/okoli/02-cyklostezka.jpg', alt: 'Údolí Vltavy pod Klecanami' },
      { src: '/images/hub/okoli/03-exterier-1.jpg', alt: 'Exteriér areálu' },
      { src: '/images/hub/areal/areal-entry.jpg', alt: 'Vstup do areálu' },
      { src: '/images/hub/komunita/venkovni-01-zahrady.jpg', alt: 'Komunitní park' },
    ],
  },
];
---
<Base
  title="Galerie · Startovací Hub Klecany"
  description="Fotografie a vizualizace areálu: ubytování, coworking, gastronomie, wellness, komunitní park a okolí Hubu v Klecanech."
  headerVariant="overlay">

  <SubpageHero
    eyebrow="Galerie"
    title="Podívejte se <em>dovnitř</em>"
    sub="Ubytování, coworking, gastronomie, wellness i okolí areálu. Část fotek jsou vizualizace, reálné snímky průběžně doplňujeme."
    variant="deep"
    ribbonPath="M 120 720 C 520 420, 980 860, 1380 540 C 1700 300, 1980 560, 2060 420"
    ariaId="galerie"
  />

  <div class="gal-wrap">
    {categories.map((c) => (
      <PhotoGrid
        eyebrow="Galerie"
        heading={c.heading}
        images={c.images}
        columns={2}
        aspect="16 / 10"
        group={c.group}
        moreHref={c.more}
        moreLabel="Více v sekci"
      />
    ))}
  </div>

  <CtaBanner
    eyebrow="Rezervace"
    title="Líbí se vám to? <em>Rezervujte</em>"
    lede="Vyberte si formát bydlení a způsob kontaktu. Z rezervačního oddělení vám zavoláme do 24 hodin."
    cta={{ label: 'Nezávazná rezervace', href: '/rezervace/' }}
    variant="deep"
  />
  <CrossLinkPair
    items={[
      { eyebrow: 'Ubytování', title: 'Apartmány a <em>sdílené pokoje</em>', href: '/ubytovani/', variant: 'cream' },
      { eyebrow: 'Zázemí', title: 'Celé <em>zázemí</em> Hubu', href: '/zazemi/', variant: 'ink' },
    ]}
  />

  <Lightbox />
</Base>

<style>
  .gal-wrap {
    width: calc(100% - 2 * var(--gutter));
    max-width: var(--container-wide);
    margin: 0 auto;
    padding: var(--space-8) 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-8);
  }
</style>
