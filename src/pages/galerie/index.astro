---
/*
 * Galerie , reálná foto-mřížka sjednocená s ručním zrcadlem: 4 kategorie
 * (Ubytování, Zázemí, Doprava, Okolí) s podsekcemi, střídavě tónované sekce,
 * 3sloupcová mřížka + lightbox. Data (75 fotek) v src/data/galerie.json.
 */
import Base from '../../layouts/Base.astro';
import SubpageHero from '../../components/SubpageHero.astro';
import PhotoGrid from '../../components/PhotoGrid.astro';
import Lightbox from '../../components/Lightbox.astro';
import CtaBanner from '../../components/CtaBanner.astro';
import CrossLinkPair from '../../components/CrossLinkPair.astro';
import categories from '../../data/galerie.json';

type Img = { src: string; alt: string };
type Group = { title: string | null; id: string; images: Img[] };
type Category = { title: string; id: string; groups: Group[] };

const cats = categories as Category[];

/* Chip „skoky" v banneru , jeden na hlavní kategorii (href = #<id>). */
const GALLERY_JUMPS = cats.map((c) => ({ href: `#${c.id}`, label: c.title }));
---
<Base
  title="Galerie · Startovací Hub Klecany"
  description="Fotografie a vizualizace areálu: ubytování, coworking, gastronomie, wellness, komunitní park a okolí Hubu v Klecanech."
  headerVariant="overlay">

  <SubpageHero
    eyebrow="Galerie"
    title="Podívejte se <em>dovnitř</em>"
    variant="deep"
    ribbonPath="M 120 720 C 520 420, 980 860, 1380 540 C 1700 300, 1980 560, 2060 420"
    ariaId="galerie"
    jumps={GALLERY_JUMPS}
  />

  <div class="gal">
    {cats.map((c) => (
      <section class="gal-sec" id={c.id} aria-label={c.title}>
        <div class="gal-sec__inner">
          <h2 class="gal-sec__title">{c.title}</h2>
          {c.groups.map((g) => (
            <PhotoGrid
              heading={g.title ?? undefined}
              images={g.images}
              columns={3}
              aspect="4 / 3"
              group={g.id}
            />
          ))}
        </div>
      </section>
    ))}
  </div>

  <CtaBanner
    eyebrow="Rezervace"
    title="Líbí se vám to? <em>Rezervujte</em>"
    lede="Vyberte si formát bydlení a způsob kontaktu. Z rezervačního oddělení vám zavoláme do 24 hodin."
    cta={{ label: 'Nezávazná rezervace', href: '/rezervace/' }}
    variant="deep"
  />
  <CrossLinkPair
    items={[
      { eyebrow: 'Ubytování', title: 'Apartmány a <em>sdílené pokoje</em>', href: '/ubytovani/', variant: 'cream' },
      { eyebrow: 'Zázemí', title: 'Celé <em>zázemí</em> Hubu', href: '/zazemi/', variant: 'ink' },
    ]}
  />

  <Lightbox />
</Base>

<style>
  .gal { width: 100%; }
  /* Hlavní kategorie = celá-šířková sekce se střídavým tónem (jako zrcadlo). */
  .gal-sec {
    padding: clamp(32px, 5vw, 60px) 0;
    border-bottom: 1px solid var(--border-muted);
    /* odsazení kvůli fixní liště při skoku z chip */
    scroll-margin-top: 84px;
  }
  .gal-sec:nth-of-type(even) { background: var(--bg-muted); }
  .gal-sec:last-of-type { border-bottom: 0; }
  .gal-sec__inner {
    width: calc(100% - 2 * var(--gutter));
    max-width: var(--container-wide);
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: var(--space-7);
  }
  .gal-sec__title {
    font: 600 clamp(1.6rem, 3vw, 2.4rem) / 1.15 var(--font-sans);
    letter-spacing: var(--tracking-tight);
    margin: 0;
    color: var(--fg);
  }
</style>
