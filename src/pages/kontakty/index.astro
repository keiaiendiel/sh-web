---
import Base from '../../layouts/Base.astro';
import SubpageHero from '../../components/SubpageHero.astro';
import Arrow from '../../components/Arrow.astro';
import { getEntry } from 'astro:content';
import { withBase } from '../../utils/url';

const orgEntry = await getEntry('org', 'identity');
const org = orgEntry?.data;

const heroRibbon = 'M 120 720 C 520 420, 980 860, 1380 540 C 1700 300, 1980 560, 2060 420';
const gmapsHref = 'https://www.google.com/maps?q=Dolní+Kasárna+798,+250+67+Klecany';
const email = org?.email ?? 'vpd@osa2.cz';
---
<Base
  title="Kontakt · Startovací Hub Klecany"
  description="Kde najdete Startovací Hub Klecany: Dolní Kasárna 798, 250 67 Klecany. Provozuje Občanské sdružení Alternativa II, z.s."
  headerVariant="overlay">

  <SubpageHero
    eyebrow="Kontakty"
    title="Kde nás <em>najdete</em>"
    sub="Startovací Hub stojí v rozvojovém území horních kasáren v Klecanech, patnáct minut autobusem od metra Kobylisy."
    variant="cream"
    ribbonPath={heroRibbon}
    ariaId="kontakty"
  />

  <section class="sec-block">
    <div class="sec-block__inner">
      <div class="kn-grid">
        <div class="kn-info">
          <p class="kn-eyebrow">Adresa</p>
          <p class="kn-address">Dolní Kasárna 798<br />250 67 Klecany</p>

          <a class="kn-maplink osa-nolink" href={gmapsHref} target="_blank" rel="noopener">
            Otevřít v Mapách <Arrow dir="right" variant="chevron" size={14} weight={2.4} />
          </a>

          <dl class="kn-meta">
            <div class="kn-meta__row">
              <dt>E-mail</dt>
              <dd><a href={`mailto:${email}`}>{email}</a></dd>
            </div>
            <div class="kn-meta__row">
              <dt>Provozovatel</dt>
              <dd>Občanské sdružení Alternativa II, z.s. (<a href="https://www.alternativa2.info/" rel="noopener">alternativa2.info</a>)</dd>
            </div>
          </dl>

          <p class="kn-note">
            Vaše údaje používáme jen k vyřízení konkrétní žádosti. Více v <a href={withBase('/gdpr/')}>zásadách ochrany osobních údajů</a>.
          </p>
        </div>

        <div class="kn-map-wrap">
          <div class="kn-map" data-kontakty-map role="application" aria-label="Mapa Hubu Klecany"></div>
        </div>
      </div>
    </div>
  </section>
</Base>

<style>
  .kn-grid {
    display: grid;
    grid-template-columns: minmax(0, 0.85fr) minmax(0, 1.15fr);
    gap: var(--space-7);
    align-items: stretch;
  }
  .kn-info { display: flex; flex-direction: column; }
  .kn-eyebrow {
    font: 500 var(--text-2xs) / 1 var(--font-sans);
    letter-spacing: var(--tracking-wider);
    text-transform: uppercase;
    color: var(--accent);
    margin: 0 0 var(--space-3);
  }
  .kn-address {
    font: 700 clamp(1.5rem, 2.4vw, 2.25rem) / 1.15 var(--font-sans);
    letter-spacing: var(--tracking-tight);
    color: var(--fg);
    margin: 0 0 var(--space-4);
  }
  .kn-maplink {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    align-self: flex-start;
    padding: 11px 18px;
    border: 1px solid var(--accent-rule);
    border-radius: var(--radius-input);
    background: var(--accent-soft);
    color: var(--accent);
    font: 600 var(--text-sm) / 1 var(--font-sans);
    text-decoration: none;
    transition: background 200ms var(--ease-quart), color 200ms var(--ease-quart), transform 200ms var(--ease-quart);
  }
  .kn-maplink:hover,
  .kn-maplink:focus-visible {
    background: var(--accent);
    color: #fff;
    transform: translateY(-1px);
    outline: none;
  }
  .kn-meta {
    margin: var(--space-6) 0 0;
    display: grid;
    gap: 0;
    border-top: 1px solid var(--border);
  }
  .kn-meta__row {
    display: grid;
    grid-template-columns: 140px 1fr;
    gap: var(--space-4);
    padding: var(--space-4) 0;
    border-bottom: 1px solid var(--border);
    align-items: baseline;
  }
  .kn-meta__row dt {
    font: 500 var(--text-sm) / 1.3 var(--font-sans);
    color: var(--fg-muted);
    margin: 0;
  }
  .kn-meta__row dd {
    margin: 0;
    font: 500 var(--text-md) / 1.4 var(--font-sans);
    color: var(--fg);
  }
  .kn-note {
    margin: var(--space-6) 0 0;
    font: 400 var(--text-sm) / 1.6 var(--font-sans);
    color: var(--fg-muted);
    max-width: 46ch;
  }

  .kn-map-wrap {
    position: relative;
    isolation: isolate;
    min-height: 420px;
    border-radius: var(--radius-input);
    overflow: hidden;
    border: 1px solid var(--border);
    background: var(--bg-muted);
  }
  .kn-map { position: absolute; inset: 0; }
  .kn-map :global(.leaflet-container) {
    width: 100%;
    height: 100%;
    background: var(--bg-muted);
    font-family: var(--font-sans);
  }

  @media (max-width: 860px) {
    .kn-grid { grid-template-columns: 1fr; gap: var(--space-6); }
    .kn-map-wrap { min-height: 320px; order: -1; }
  }
</style>

<script is:inline>
  /* Kontaktní mapa: lazy Leaflet přes sdílený window.__hubLoadLeaflet z Base.
     Bind se jednou per session, re-run při astro:page-load (SPA navigace). */
  (function () {
    if (window.__hubKontaktyMapBound) return;
    window.__hubKontaktyMapBound = true;

    function init(el) {
      if (el.dataset.mapBound) return;
      el.dataset.mapBound = '1';
      var L = window.L;
      var center = [50.179823, 14.406268];
      var map = L.map(el, {
        center: center,
        zoom: 15,
        scrollWheelZoom: false,
        attributionControl: false,
      });
      L.tileLayer('https://{s}.basemaps.cartocdn.com/rastertiles/voyager_nolabels/{z}/{x}/{y}{r}.png', {
        maxZoom: 19,
      }).addTo(map);
      var icon = L.divIcon({ className: 'kn-pin', html: '<span></span>', iconSize: [22, 22], iconAnchor: [11, 11] });
      var gmaps = 'https://www.google.com/maps?q=Dolní+Kasárna+798,+250+67+Klecany';
      var popup =
        '<a href="' + gmaps + '" target="_blank" rel="noopener" class="ok-map-popup">' +
        '<strong>Startovací Hub Klecany</strong><br>Dolní Kasárna 798, 250 67 Klecany<br>' +
        '<span class="ok-map-popup__cta">Otevřít v Mapách →</span></a>';
      L.marker(center, { icon: icon }).addTo(map).bindPopup(popup, { className: 'ok-map-popup-wrap' });
      L.control.attribution({ prefix: false }).addTo(map);
      var fix = function () { map.invalidateSize(); };
      requestAnimationFrame(fix);
      [200, 600, 1200].forEach(function (ms) { setTimeout(fix, ms); });
      if (window.ResizeObserver) { new ResizeObserver(fix).observe(el); }
    }

    function boot() {
      var el = document.querySelector('[data-kontakty-map]');
      if (!el || !window.__hubLoadLeaflet) return;
      el.dataset.mapBound = '';
      window.__hubLoadLeaflet(function () { init(el); });
    }
    document.addEventListener('astro:page-load', boot);
  }());
</script>

<style is:global>
  /* Plum pin + popup, sdílený vzhled s footer/okolí mapou. */
  .kn-pin span {
    display: block;
    width: 18px;
    height: 18px;
    margin: 2px;
    border-radius: 50%;
    background: var(--accent);
    border: 3px solid #fff;
    box-shadow: 0 2px 6px rgba(0, 0, 0, 0.35);
  }
</style>
