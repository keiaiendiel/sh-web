---
/* LAB: hero CTA tlačítka , porovnání variant (noindex, mimo nav i sitemapu).
   Cíl: informativní popisek MIMO tlačítko (menším písmem nad/pod), akční text
   tlačítka velkým písmem. Část variant používá Apple „liquid glass" look,
   část drží brand sharp. Každá varianta sedí v plném hero kontextu, ať se dá
   vybrat. Tahle stránka se nikam nelinkuje, smaže se po výběru. */
import '../../styles/tokens.css';
import { withBase } from '../../utils/url';
import BrandLogo from '../../components/BrandLogo.astro';
import Arrow from '../../components/Arrow.astro';

const heroFrames = [
  withBase('/images/hub/hero/h00.jpg'),
  withBase('/images/hub/hero/h03.jpg'),
  withBase('/images/hub/hero/h04.jpg'),
  withBase('/images/hub/hero/h01.jpg'),
  withBase('/images/hub/hero/h02.jpg'),
  withBase('/images/hub/hero/h00.jpg'),
];

const A = { href: withBase('/rezervace/?cesta=apartman'), label: 'Pronajmout apartmán', note: 'privátní apartmány 1+kk až 5+kk' };
const L = { href: withBase('/rezervace/?cesta=luzko'),    label: 'Pronajmout lůžko',    note: 'sdílené pokoje od dvou lůžek' };

const variants = [
  { id: 'A', tag: 'Liquid glass · popisek jako eyebrow nad tlačítkem', kind: 'Apple glass' },
  { id: 'B', tag: 'Liquid glass · arrow v kroužku, popisek pod tlačítkem', kind: 'Apple glass' },
  { id: 'C', tag: 'Solid pill · nejvyšší kontrast, popisek nad', kind: 'Apple glass' },
  { id: 'D', tag: 'Brand sharp · editorial, popisek pod linkou', kind: 'Brand' },
  { id: 'E', tag: 'Glass island · double-bezel, popisek uvnitř rámu nad jádrem', kind: 'Apple glass' },
  { id: 'F', tag: 'Minimal underline · ultra-light, popisek pod', kind: 'Brand' },
];
---

<!doctype html>
<html lang="cs">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="robots" content="noindex, nofollow" />
  <title>LAB , hero CTA varianty</title>
</head>
<body>
  <div class="lab-rail" aria-hidden="true">
    {variants.map((v) => <a class="lab-rail__dot" href={`#v-${v.id}`}><span>{v.id}</span></a>)}
  </div>

  {variants.map((v, i) => (
    <section class={`panel panel--${v.id}`} id={`v-${v.id}`} style={`--frame: url('${heroFrames[i]}')`}>
      <div class="panel__bg"></div>
      <div class="panel__scrim"></div>

      <span class="panel__tag">
        <b>Varianta {v.id}</b>
        <span class="panel__kind" data-kind={v.kind}>{v.kind}</span>
        {v.tag}
      </span>

      <div class="panel__inner">
        <BrandLogo class="panel__logo" />
        <p class="panel__lede">your perfect living &amp; working space</p>

        {/* ====================== VARIANTA A , liquid glass, note nad ====================== */}
        {v.id === 'A' && (
          <div class="cta cta--A" role="group" aria-label="Rychlý pronájem">
            {[A, L].map((c) => (
              <div class="vA">
                <span class="vA__note">{c.note}</span>
                <a class="glass vA__btn" href={c.href}>
                  <span class="glass__sheen" aria-hidden="true"></span>
                  <span class="vA__label">{c.label}</span>
                  <span class="vA__arrow" aria-hidden="true"><Arrow dir="right" variant="chevron" size={18} weight={2.4} /></span>
                </a>
              </div>
            ))}
          </div>
        )}

        {/* ============ VARIANTA B , liquid glass, button-in-button arrow, note pod ============ */}
        {v.id === 'B' && (
          <div class="cta cta--B" role="group" aria-label="Rychlý pronájem">
            {[A, L].map((c) => (
              <div class="vB">
                <a class="glass vB__btn" href={c.href}>
                  <span class="glass__sheen" aria-hidden="true"></span>
                  <span class="vB__label">{c.label}</span>
                  <span class="vB__icon" aria-hidden="true"><Arrow dir="right" variant="chevron" size={18} weight={2.6} /></span>
                </a>
                <span class="vB__note">{c.note}</span>
              </div>
            ))}
          </div>
        )}

        {/* ====================== VARIANTA C , solid pill, note nad ====================== */}
        {v.id === 'C' && (
          <div class="cta cta--C" role="group" aria-label="Rychlý pronájem">
            {[A, L].map((c, idx) => (
              <div class="vC">
                <span class="vC__note">{c.note}</span>
                <a class={`vC__btn ${idx === 0 ? 'vC__btn--solid' : 'glass vC__btn--ghost'}`} href={c.href}>
                  {idx !== 0 && <span class="glass__sheen" aria-hidden="true"></span>}
                  <span class="vC__label">{c.label}</span>
                  <span class="vC__arrow" aria-hidden="true"><Arrow dir="right" variant="chevron" size={18} weight={2.4} /></span>
                </a>
              </div>
            ))}
          </div>
        )}

        {/* ====================== VARIANTA D , brand sharp, note pod linkou ====================== */}
        {v.id === 'D' && (
          <div class="cta cta--D" role="group" aria-label="Rychlý pronájem">
            {[A, L].map((c) => (
              <div class="vD">
                <a class="vD__btn" href={c.href}>
                  <span class="vD__label">{c.label}</span>
                  <span class="vD__arrow" aria-hidden="true"><Arrow dir="right" variant="line" size={20} weight={2} /></span>
                </a>
                <span class="vD__rule" aria-hidden="true"></span>
                <span class="vD__note">{c.note}</span>
              </div>
            ))}
          </div>
        )}

        {/* ============ VARIANTA E , glass island double-bezel, note uvnitř nad jádrem ============ */}
        {v.id === 'E' && (
          <div class="cta cta--E" role="group" aria-label="Rychlý pronájem">
            {[A, L].map((c) => (
              <a class="glass vE" href={c.href}>
                <span class="glass__sheen" aria-hidden="true"></span>
                <span class="vE__note">{c.note}</span>
                <span class="vE__core">
                  <span class="vE__label">{c.label}</span>
                  <span class="vE__icon" aria-hidden="true"><Arrow dir="right" variant="chevron" size={18} weight={2.6} /></span>
                </span>
              </a>
            ))}
          </div>
        )}

        {/* ====================== VARIANTA F , minimal underline, note pod ====================== */}
        {v.id === 'F' && (
          <div class="cta cta--F" role="group" aria-label="Rychlý pronájem">
            {[A, L].map((c) => (
              <div class="vF">
                <a class="vF__btn" href={c.href}>
                  <span class="vF__label">{c.label}</span>
                  <span class="vF__arrow" aria-hidden="true"><Arrow dir="right" variant="line" size={22} weight={1.8} /></span>
                  <span class="vF__line" aria-hidden="true"></span>
                </a>
                <span class="vF__note">{c.note}</span>
              </div>
            ))}
          </div>
        )}
      </div>
    </section>
  ))}

<style>
  :global(html) { scroll-behavior: smooth; }
  :global(body) { margin: 0; background: var(--plum-deep); color: #fff; font-family: var(--font-sans); }

  /* ============ PANEL (jeden hero na variantu) ============ */
  .panel {
    position: relative;
    isolation: isolate;
    min-height: 100dvh;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    overflow: hidden;
    padding: var(--space-9) var(--gutter);
  }
  .panel__bg {
    position: absolute; inset: 0; z-index: -2;
    background-image: var(--frame);
    background-size: cover; background-position: center;
    filter: brightness(0.84);
    transform: scale(1.04);
  }
  .panel__scrim {
    position: absolute; inset: 0; z-index: -1;
    background:
      linear-gradient(to bottom, rgba(0,0,0,0.40) 0%, rgba(0,0,0,0.10) 22%, rgba(0,0,0,0) 42%),
      linear-gradient(to top, rgba(0,0,0,0.62) 0%, rgba(0,0,0,0.28) 38%, rgba(0,0,0,0) 72%);
  }
  .panel__tag {
    position: absolute; top: 18px; left: 18px; z-index: 3;
    display: inline-flex; align-items: center; gap: 10px; flex-wrap: wrap;
    max-width: calc(100% - 36px);
    padding: 7px 14px;
    font: 500 var(--text-xs)/1.3 var(--font-mono);
    letter-spacing: 0.02em;
    color: rgba(255,255,255,0.86);
    background: rgba(10,4,12,0.42);
    border: 1px solid rgba(255,255,255,0.16);
    border-radius: 999px;
    backdrop-filter: blur(10px); -webkit-backdrop-filter: blur(10px);
  }
  .panel__tag b { color:#fff; font-family: var(--font-sans); font-weight: 700; letter-spacing: var(--tracking-wide); }
  .panel__kind {
    padding: 2px 8px; border-radius: 999px; font-size: 10px; letter-spacing: 0.12em; text-transform: uppercase;
  }
  .panel__kind[data-kind="Apple glass"] { background: rgba(120,180,255,0.22); color:#cfe3ff; }
  .panel__kind[data-kind="Brand"]       { background: rgba(214,170,219,0.22); color:#f0d9f3; }

  .panel__inner { text-align: center; max-width: var(--container); width: 100%; }
  :global(.panel__logo) { display:block; margin: 0 auto var(--space-2); height: clamp(1.8rem, 3vw, 3rem); width:auto; max-width: 90%; color:#fff; }
  .panel__lede {
    margin: 0 auto var(--space-8);
    font: 500 clamp(1.05rem, 1.5vw, 1.5rem)/1.4 var(--font-sans);
    letter-spacing: var(--tracking-wide);
    color: rgba(255,255,255,0.92);
  }

  /* ============ LIQUID GLASS , společná báze pro Apple varianty ============
     Vrstvy: poloprůhledný tint + heavy backdrop blur+saturate (lensing),
     jemný horní inset highlight (světlo na hraně skla), měkký rim border,
     a „sheen" pseudo-prvek = specular odlesk, který se na hover přejede. */
  .glass {
    position: relative;
    overflow: hidden;
    background: linear-gradient(150deg, rgba(255,255,255,0.22), rgba(255,255,255,0.06) 46%, rgba(255,255,255,0.10));
    border: 1px solid rgba(255,255,255,0.30);
    backdrop-filter: blur(18px) saturate(170%) brightness(1.06);
    -webkit-backdrop-filter: blur(18px) saturate(170%) brightness(1.06);
    box-shadow:
      0 1px 0 0 rgba(255,255,255,0.55) inset,
      0 -8px 18px -10px rgba(255,255,255,0.30) inset,
      0 14px 30px -12px rgba(0,0,0,0.55),
      0 2px 6px -2px rgba(0,0,0,0.35);
    color: #fff;
    text-decoration: none;
    transition: transform 520ms cubic-bezier(0.32,0.72,0,1), box-shadow 520ms cubic-bezier(0.32,0.72,0,1), border-color 520ms ease, background 520ms ease;
  }
  .glass__sheen {
    position: absolute; inset: 0; pointer-events: none; z-index: 0; border-radius: inherit;
    background: linear-gradient(105deg, transparent 30%, rgba(255,255,255,0.45) 48%, transparent 62%);
    transform: translateX(-120%);
    transition: transform 900ms cubic-bezier(0.32,0.72,0,1);
  }
  .glass:hover { transform: translateY(-3px); border-color: rgba(255,255,255,0.55); }
  .glass:active { transform: translateY(-1px) scale(0.99); }
  .glass:hover .glass__sheen { transform: translateX(120%); }
  .glass:focus-visible { outline: 2px solid #fff; outline-offset: 3px; }
  .glass > :not(.glass__sheen) { position: relative; z-index: 1; }

  /* ---------- A: glass pill, note jako eyebrow nad ---------- */
  .cta--A { display:flex; gap: clamp(20px,3vw,44px); justify-content:center; flex-wrap:wrap; }
  .vA { display:flex; flex-direction:column; align-items:center; gap: 12px; }
  .vA__note {
    font: 600 var(--text-xs)/1 var(--font-sans);
    text-transform: uppercase; letter-spacing: 0.18em;
    color: rgba(255,255,255,0.78);
  }
  .vA__btn {
    display:inline-flex; align-items:center; gap: 14px;
    padding: 20px 38px; border-radius: 999px;
    font: 700 clamp(1.15rem,1.4vw,1.5rem)/1 var(--font-sans);
    letter-spacing: var(--tracking-tight);
  }
  .vA__arrow { display:inline-flex; transition: transform 420ms cubic-bezier(0.32,0.72,0,1); }
  .vA__btn:hover .vA__arrow { transform: translateX(4px); }

  /* ---------- B: glass pill, arrow v kroužku (button-in-button), note pod ---------- */
  .cta--B { display:flex; gap: clamp(20px,3vw,44px); justify-content:center; flex-wrap:wrap; }
  .vB { display:flex; flex-direction:column; align-items:center; gap: 12px; }
  .vB__btn {
    display:inline-flex; align-items:center; gap: 18px;
    padding: 14px 14px 14px 34px; border-radius: 999px;
    font: 700 clamp(1.15rem,1.4vw,1.5rem)/1 var(--font-sans);
    letter-spacing: var(--tracking-tight);
  }
  .vB__icon {
    display:inline-grid; place-items:center; width: 46px; height: 46px; border-radius: 999px;
    background: rgba(255,255,255,0.92); color: var(--plum-deep);
    box-shadow: 0 1px 0 rgba(255,255,255,0.6) inset, 0 6px 14px -6px rgba(0,0,0,0.5);
    transition: transform 420ms cubic-bezier(0.32,0.72,0,1);
  }
  .vB__btn:hover .vB__icon { transform: translate(3px,-2px) scale(1.06); }
  .vB__note { font: 500 var(--text-sm)/1.3 var(--font-sans); color: rgba(255,255,255,0.74); letter-spacing: var(--tracking-tight); }

  /* ---------- C: solid white primary + glass ghost secondary, note nad ---------- */
  .cta--C { display:flex; gap: clamp(20px,3vw,44px); justify-content:center; flex-wrap:wrap; align-items:flex-end; }
  .vC { display:flex; flex-direction:column; align-items:center; gap: 12px; }
  .vC__note { font: 600 var(--text-xs)/1 var(--font-sans); text-transform: uppercase; letter-spacing: 0.18em; color: rgba(255,255,255,0.78); }
  .vC__btn {
    display:inline-flex; align-items:center; gap: 14px;
    padding: 20px 40px; border-radius: 999px; text-decoration:none;
    font: 700 clamp(1.15rem,1.4vw,1.5rem)/1 var(--font-sans);
    letter-spacing: var(--tracking-tight);
    transition: transform 520ms cubic-bezier(0.32,0.72,0,1), box-shadow 520ms ease, background 320ms ease, color 320ms ease;
  }
  .vC__btn--solid {
    background: #fff; color: var(--plum-deep);
    box-shadow: 0 1px 0 rgba(255,255,255,0.9) inset, 0 18px 34px -14px rgba(0,0,0,0.6);
  }
  .vC__btn--solid:hover { transform: translateY(-3px); box-shadow: 0 1px 0 rgba(255,255,255,0.9) inset, 0 24px 44px -14px rgba(0,0,0,0.65); }
  .vC__btn--ghost { color:#fff; }
  .vC__arrow { display:inline-flex; transition: transform 420ms cubic-bezier(0.32,0.72,0,1); }
  .vC__btn:hover .vC__arrow { transform: translateX(4px); }

  /* ---------- D: brand sharp editorial, note pod tenkou linkou ---------- */
  .cta--D { display:flex; gap: clamp(28px,5vw,72px); justify-content:center; flex-wrap:wrap; }
  .vD { display:flex; flex-direction:column; align-items:flex-start; gap: 14px; }
  .vD__btn {
    display:inline-flex; align-items:baseline; gap: 16px; text-decoration:none; color:#fff;
    font: 700 clamp(1.6rem,2.6vw,2.6rem)/1 var(--font-sans);
    letter-spacing: var(--tracking-tight);
  }
  .vD__arrow { display:inline-flex; align-self:center; transition: transform 380ms var(--ease-quart); }
  .vD__btn:hover .vD__arrow { transform: translateX(6px); }
  .vD__rule { width: 56px; height: 2px; background: var(--rose); transition: width 380ms var(--ease-quart); }
  .vD__btn:hover ~ .vD__rule, .vD:hover .vD__rule { width: 100%; }
  .vD__note { font: 500 var(--text-sm)/1.3 var(--font-sans); color: rgba(255,255,255,0.80); letter-spacing: var(--tracking-wide); text-transform: uppercase; }

  /* ---------- E: glass island double-bezel, note uvnitř rámu nad jádrem ---------- */
  .cta--E { display:flex; gap: clamp(20px,3vw,40px); justify-content:center; flex-wrap:wrap; }
  .vE {
    display:flex; flex-direction:column; align-items:stretch; gap: 12px;
    padding: 14px; border-radius: 26px; min-width: 270px;
  }
  .vE__note { font: 600 var(--text-xs)/1 var(--font-sans); text-transform: uppercase; letter-spacing: 0.16em; color: rgba(255,255,255,0.80); padding: 2px 6px; text-align:left; }
  .vE__core {
    display:flex; align-items:center; justify-content:space-between; gap: 16px;
    padding: 16px 18px; border-radius: 16px;
    background: rgba(255,255,255,0.14);
    box-shadow: 0 1px 0 rgba(255,255,255,0.35) inset, 0 -1px 1px rgba(255,255,255,0.10) inset;
    transition: background 420ms ease;
  }
  .vE:hover .vE__core { background: rgba(255,255,255,0.22); }
  .vE__label { font: 700 clamp(1.1rem,1.3vw,1.35rem)/1 var(--font-sans); letter-spacing: var(--tracking-tight); }
  .vE__icon { display:inline-grid; place-items:center; width: 38px; height: 38px; border-radius: 999px; background: rgba(255,255,255,0.92); color: var(--plum-deep); transition: transform 420ms cubic-bezier(0.32,0.72,0,1); }
  .vE:hover .vE__icon { transform: translate(3px,-2px); }

  /* ---------- F: minimal underline ---------- */
  .cta--F { display:flex; gap: clamp(28px,5vw,80px); justify-content:center; flex-wrap:wrap; }
  .vF { display:flex; flex-direction:column; align-items:flex-start; gap: 10px; }
  .vF__btn { position:relative; display:inline-flex; align-items:center; gap: 14px; text-decoration:none; color:#fff; padding-bottom: 8px; font: 600 clamp(1.5rem,2.4vw,2.4rem)/1 var(--font-sans); letter-spacing: var(--tracking-tight); }
  .vF__arrow { display:inline-flex; transition: transform 380ms var(--ease-quart); opacity:0.85; }
  .vF__btn:hover .vF__arrow { transform: translateX(7px); opacity:1; }
  .vF__line { position:absolute; left:0; bottom:0; height:2px; width:100%; background: rgba(255,255,255,0.3); }
  .vF__line::after { content:''; position:absolute; left:0; bottom:0; height:100%; width:0; background:#fff; transition: width 420ms var(--ease-quart); }
  .vF__btn:hover .vF__line::after { width:100%; }
  .vF__note { font: 500 var(--text-sm)/1.3 var(--font-sans); color: rgba(255,255,255,0.78); letter-spacing: var(--tracking-wide); }

  /* ============ LEVÝ RAIL (rychlá navigace mezi variantami) ============ */
  .lab-rail { position: fixed; right: 16px; top: 50%; transform: translateY(-50%); z-index: 10; display:flex; flex-direction:column; gap: 10px; }
  .lab-rail__dot {
    display:grid; place-items:center; width: 34px; height: 34px; border-radius: 999px;
    font: 700 var(--text-xs)/1 var(--font-sans); color:#fff; text-decoration:none;
    background: rgba(10,4,12,0.42); border: 1px solid rgba(255,255,255,0.22);
    backdrop-filter: blur(10px); -webkit-backdrop-filter: blur(10px);
    transition: background 220ms ease, transform 220ms ease;
  }
  .lab-rail__dot:hover { background: rgba(255,255,255,0.9); color: var(--plum-deep); transform: scale(1.08); }

  @media (max-width: 600px) {
    .cta--A, .cta--B, .cta--C, .cta--D, .cta--E, .cta--F { flex-direction:column; align-items:center; gap: 18px; }
    .vD, .vF { align-items:center; text-align:center; }
    .lab-rail { right: 8px; gap: 7px; }
    .lab-rail__dot { width: 28px; height:28px; }
  }
  @media (prefers-reduced-motion: reduce) {
    .glass, .glass__sheen, .vA__arrow, .vB__icon, .vC__arrow, .vD__arrow, .vD__rule, .vE__core, .vE__icon, .vF__arrow, .vF__line::after { transition: none; }
    :global(html) { scroll-behavior: auto; }
  }
</style>
</body>
</html>
