---
import Base from '../../layouts/Base.astro';
import Gallery from '../../components/Gallery.astro';
import Icon from '../../components/Icon.astro';
import SubpageHero from '../../components/SubpageHero.astro';
import CtaBanner from '../../components/CtaBanner.astro';
import CrossLinkPair from '../../components/CrossLinkPair.astro';
import { withBase } from '../../utils/url';

const heroJumps = [
  { label: 'Coworkingový sál',  href: '#cw-sal' },
  { label: 'Sdílená kancelář',  href: '#cw-shared' },
  { label: 'Zasedací místnost', href: '#cw-zasedacka' },
  { label: 'Ateliéry a dílny',  href: '#cw-ateliery-dilny' },
];
---
<Base
  title="Coworking od 2 900 Kč, sál, ateliér, dílna · Startovací Hub"
  description="Pět typů pracovních prostor v budově C: volný stůl, fixní stůl, sdílená kancelář, zasedací místnost, ateliér a dílna. Pro rezidenty Hubu volný stůl v ceně bydlení."
  headerVariant="overlay">

  <SubpageHero
    eyebrow="Coworking"
    title="Sál, fixní stůl, <em>ateliér</em> nebo dílna."
    sub="Volný stůl 24/7 pro rezidenty v ceně bydlení. Pět tarifů, čtyři dílny, jeden ateliér."
    variant="cream"
    ribbonPath="M 880 460 C 1180 360, 1500 600, 1720 500 C 1900 420, 1980 660, 1840 760"
    thickness={56}
    jumps={heroJumps}
    ariaId="coworking-hero"
  />

  <section class="sec-feature">
    <div class="sec-feature__inner">
      <div class="sec-feature__col">
        <div class="sec-feature__head">
          <p class="sec-feature__eyebrow">Coworkingový sál</p>
          <h2 class="sec-feature__title" id="cw-sal">Pro rezidenty zdarma, externí 2 900 Kč.</h2>
        </div>
        <div class="sec-feature__text">
          <p>
            Otevřený sál s denním světlem z velkých oken. Dřevěné podlahy, ergonomické židle, dva
            kávovary, vodní stanice, Wi-Fi přes celý prostor a tiché telefonní budky. Kapacita 30
            až 40 míst, provoz 24/7, přístup čipem.
          </p>
          <ul>
            <li>30 až 40 volných stolů, žádné rezervace</li>
            <li>Wi-Fi přes celý prostor</li>
            <li>2 kávovary, voda, čaj zdarma</li>
            <li>4 tiché telefonní budky pro hovory</li>
            <li>Tiskárna a skener za drobný kredit</li>
            <li>Pohovkový kout pro neformální schůzky</li>
          </ul>
        </div>
      </div>
      <div class="sec-feature__col">
        <div class="sec-feature__media">
          <Gallery
            images={[
              { src: withBase('/images/hub/coworking/cowork-interier-sal-c.jpg'), alt: 'Coworkingový sál v 1. NP budovy C, denní světlo z velkých oken, dřevěné podlahy.' },
              { src: withBase('/images/hub/coworking/cowork-interier-sal-c-empty.jpg'), alt: 'Coworkingový sál prázdný, jasná stavební podoba prostoru.' },
            ]}
            ariaLabel="Coworkingový sál" />
        </div>
        <dl class="sec-feature__spec">
          <div><dt>Provoz</dt><dd>24/7, přístup čipem</dd></div>
          <div><dt>Kapacita</dt><dd>30 až 40 míst</dd></div>
          <div><dt>Pro rezidenty</dt><dd>Zdarma, neomezený přístup</dd></div>
          <div><dt>Pro externí</dt><dd>2 900 Kč/měs</dd></div>
        </dl>
      </div>
    </div>
  </section>

  <section class="sec-feature sec-feature--alt">
    <div class="sec-feature__inner">
      <div class="sec-feature__col">
        <div class="sec-feature__head">
          <p class="sec-feature__eyebrow">Fixní stůl</p>
          <h2 class="sec-feature__title" id="cw-fix">Váš vlastní stůl. 4 200 Kč/měs.</h2>
        </div>
        <div class="sec-feature__text">
          <p>
            Stejný stůl, na kterém pracujete každý den. Dva monitory, ergonomická židle, lampa,
            organizér, pod stolem uzamykatelná skříňka.
          </p>
          <p>
            Pro lidi, kteří potřebují víc soustředění než ve volném sále. Pro grafiky a programátory
            se dvěma obrazovkami. Pro lidi, kteří chtějí stálé zázemí v Hubu i bez bydlení.
          </p>
        </div>
      </div>
      <div class="sec-feature__col">
        <div class="sec-feature__media">
          <Gallery
            images={[
              { src: withBase('/images/hub/coworking/cowork-interier-vlastni-stul-1.jpg'), alt: 'Fixní stůl personalizovaný, dva monitory, ergonomické židle, rostlina.' },
            ]}
            ariaLabel="Fixní stůl" />
        </div>
        <dl class="sec-feature__spec">
          <div><dt>Provoz</dt><dd>24/7</dd></div>
          <div><dt>Cena</dt><dd>4 200 Kč/měs</dd></div>
          <div><dt>Smlouva</dt><dd>Minimálně 3 měsíce, výpověď 30 dnů</dd></div>
          <div><dt>Vybavení</dt><dd>2× monitor 27", ergonomická židle, lampa, uzamykatelná skříňka</dd></div>
        </dl>
      </div>
    </div>
  </section>

  <section class="sec-feature">
    <div class="sec-feature__inner">
      <div class="sec-feature__col">
        <div class="sec-feature__head">
          <p class="sec-feature__eyebrow">Sdílená kancelář</p>
          <h2 class="sec-feature__title" id="cw-shared">Privátní místnost pro čtyři. 15 000 Kč/měs.</h2>
        </div>
        <div class="sec-feature__text">
          <p>
            Privátní místnost v patře budovy C, 15 až 20 m². Čtyři samostatné stoly nebo dva
            propojené, whiteboard 1,5 × 1,2 m, vlastní zámek.
          </p>
          <p>
            Pro startupové týmy, agentury, malé inženýrské skupiny. Při plném obsazení 3 750 Kč
            na osobu měsíčně.
          </p>
        </div>
      </div>
      <div class="sec-feature__col">
        <div class="sec-feature__media">
          <Gallery
            images={[
              { src: withBase('/images/hub/coworking/cowork-interier-pro4.jpg'), alt: 'Privátní místnost pro čtyřčlenný tým, samostatné stoly, whiteboard.' },
              { src: withBase('/images/hub/coworking/cowork-interier-pro4-busy.jpg'), alt: 'Privátní místnost pro čtyřčlenný tým v provozu, lidé u stolů.' },
            ]}
            ariaLabel="Sdílená kancelář" />
        </div>
        <dl class="sec-feature__spec">
          <div><dt>Provoz</dt><dd>24/7, přístupový čip</dd></div>
          <div><dt>Kapacita</dt><dd>4 stoly s ergonomickými židlemi</dd></div>
          <div><dt>Cena</dt><dd>15 000 Kč/měs za celý prostor</dd></div>
          <div><dt>Smlouva</dt><dd>Minimálně 6 měsíců, výpověď 60 dnů</dd></div>
        </dl>
      </div>
    </div>
  </section>

  <section class="sec-feature sec-feature--alt">
    <div class="sec-feature__inner">
      <div class="sec-feature__col">
        <div class="sec-feature__head">
          <p class="sec-feature__eyebrow">Zasedací místnost</p>
          <h2 class="sec-feature__title" id="cw-zasedacka">Dvě místnosti pro 6 osob. 350 Kč/hod.</h2>
        </div>
        <div class="sec-feature__text">
          <p>
            Dvě místnosti v patře budovy C, každá pro 6 osob. Smart TV 65" s HDMI/AirPlay/Miracast,
            konferenční mikrofon a kamera, tabule, kávovar a voda. Rezervace přes komunitní
            aplikaci nebo na recepci.
          </p>
        </div>
      </div>
      <div class="sec-feature__col">
        <div class="sec-feature__media">
          <Gallery
            images={[
              { src: withBase('/images/hub/coworking/cowork-interior-zasedacka.jpg'), alt: 'Zasedací místnost se smart TV a konferenčním zázemím.' },
            ]}
            ariaLabel="Zasedací místnost" />
        </div>
        <dl class="sec-feature__spec">
          <div><dt>Otevírací doba</dt><dd>07:00 až 22:00 po rezervaci</dd></div>
          <div><dt>Cena externí</dt><dd>350 Kč/hod, 1 200 Kč/půlden, 2 000 Kč/den</dd></div>
          <div><dt>Pro rezidenty</dt><dd>4 hodiny v měsíci zdarma</dd></div>
          <div><dt>Pro fixní stůl</dt><dd>4 hodiny v měsíci zdarma</dd></div>
        </dl>
      </div>
    </div>
  </section>

  <section class="sec-feature">
    <div class="sec-feature__inner">
      <div class="sec-feature__col">
        <div class="sec-feature__head">
          <p class="sec-feature__eyebrow">Ateliéry a dílny</p>
          <h2 class="sec-feature__title" id="cw-ateliery-dilny">Tvořivá práce v D1 a H1 až H3.</h2>
        </div>
        <div class="sec-feature__text">
          <h3>Ateliér (15 až 25 m²)</h3>
          <p>
            Ateliérový blok D1. Vlastní zámek, velká okna pro denní světlo, jednofázová zásuvka
            16 A (380 V možno doplnit), umyvadlo. Pro malíře, grafiky, keramiky a řemeslníky
            s vlastním nářadím.
          </p>
          <p>
            6 500 Kč měsíčně za ateliér 20 m², tedy přibližně 325 Kč/m². Ateliér je samostatný
            produkt nad rámec bydlení, bez slevy pro rezidenty.
          </p>
          <h3>Dílny (H1, H2, H3, D1, D2)</h3>
          <p>
            Členství 490 Kč měsíčně otevírá ruční nářadí, pracovní stoly, pájecí stanice, brusky
            a elektrické nářadí. Těžké stroje (CNC, laser, 3D tiskárny) za 150 Kč/hod s RFID
            zámkem a automatickým účtováním.
          </p>
        </div>
      </div>
      <div class="sec-feature__col">
        <div class="sec-feature__media">
          <Gallery
            images={[
              { src: withBase('/images/hub/coworking/cowork-interior-dilna.jpg'), alt: 'Dílna v H1 až H3, hardware a nářadí.' },
              { placeholder: 'cw04 Ateliér v D1 s tvůrcem u pracovního stolu', alt: 'Ateliér s denním světlem a tvůrcem.' },
              { placeholder: 'cw04 CNC dílna s těžkými stroji v provozu', alt: 'CNC dílna s těžkými stroji.' },
            ]}
            ariaLabel="Ateliéry a dílny" />
        </div>
        <dl class="sec-feature__spec">
          <div><dt>Ateliéry provoz</dt><dd>24/7</dd></div>
          <div><dt>Ateliér cena</dt><dd>6 500 Kč/měs za 20 m²</dd></div>
          <div><dt>Dílny základní</dt><dd>06:00 až 22:00</dd></div>
          <div><dt>Dílna členství</dt><dd>490 Kč/měs</dd></div>
          <div><dt>Dílna těžké stroje</dt><dd>150 Kč/hod RFID-billed</dd></div>
        </dl>
      </div>
    </div>
  </section>

  <CtaBanner
    eyebrow="Rezervace"
    title="Místo pro <em>práci a tvorbu</em>."
    lede="Rezervace je nezávazná, slouží i pro coworking bez bydlení. Z rezervačního oddělení vám zavoláme do 24 hodin."
    cta={{ label: 'Nezávazná rezervace', href: '/rezervace/' }}
    variant="deep"
  />

  <CrossLinkPair
    items={[
      { eyebrow: 'Komunita',  title: 'Bazén, <em>sauna</em>, jídelna a&nbsp;klubovna.', href: '/komunita/',  variant: 'ink' },
      { eyebrow: 'Stipendia', title: 'Pro lidi <em>s&nbsp;projektem</em>.',             href: '/stipendia/', variant: 'rose' },
    ]}
  />
</Base>
