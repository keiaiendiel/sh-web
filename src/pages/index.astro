</Base>

<script is:inline>
  document.addEventListener('astro:page-load', () => {
    const mapEl = document.getElementById('lp-landing-map');
    if (!mapEl || mapEl.dataset.mapBound || typeof L === 'undefined') return;
    mapEl.dataset.mapBound = '1';
    const center = [50.181447059112294, 14.424094125168379];
    const map = L.map(mapEl, {
      center, zoom: 16,
      zoomControl: false, attributionControl: false,
      scrollWheelZoom: false,
    });
    L.tileLayer('https://{s}.basemaps.cartocdn.com/rastertiles/voyager_nolabels/{z}/{x}/{y}{r}.png', {
      attribution: '&copy; <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a> &copy; <a href="https://carto.com/">CARTO</a>',
      subdomains: 'abcd', maxZoom: 19,
    }).addTo(map);
    const icon = L.divIcon({
      html:
        '<svg width="30" height="40" viewBox="0 0 28 36" fill="none" xmlns="http://www.w3.org/2000/svg">' +
        '<path d="M14 0C6.27 0 0 6.27 0 14c0 9.33 14 22 14 22S28 23.33 28 14C28 6.27 21.73 0 14 0z" fill="#5A2A5F"/>' +
        '<circle cx="14" cy="14" r="5" fill="#ffffff"/>' +
        '</svg>',
      className: '', iconSize: [30, 40], iconAnchor: [15, 40], popupAnchor: [0, -42],
    });
    const gmaps = 'https://maps.app.goo.gl/vCF6VbW7Z49sggau6';
    const popupHtml =
      '<a href="' + gmaps + '" target="_blank" rel="noopener" class="lp-map-popup">' +
        '<strong>Horní kasárna Klecany</strong>' +
        '<span class="lp-map-popup__cta">Otevřít v Mapách →</span>' +
      '</a>';
    L.marker(center, { icon })
      .addTo(map)
      .bindPopup(popupHtml, { className: 'lp-map-popup-wrap' })
      .openPopup()
      .on('click', () => window.open(gmaps, '_blank'));
    L.control.attribution({ prefix: false }).addTo(map);
    L.control.zoom({ position: 'bottomright' }).addTo(map);
    mapEl.addEventListener('click', () => map.scrollWheelZoom.enable(), { once: true });
  });
</script>

<style>
  /* ============ HERO ROTATION ============ */
  /* 4 slides absolutely overlapped, 20 s cyklus, 5 s na slide,
     swipe 1 s. animation-delay posunuje každý slide v cyklu. */
  .lp-hero {
    position: relative;
    isolation: isolate;
    /* Full-screen na desktop i mobile. dvh = dynamic viewport height,
       řeší iOS Safari URL bar bez jumping při scrollu. Fallback vh pro
       starší prohlížeče. Header je position: fixed (overlay variant),
       takže hero může jít plně pod něj. */
    min-height: 100vh;
    min-height: 100dvh;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    padding: var(--space-9) var(--gutter) var(--space-8);
    gap: var(--space-6);
    color: #fff;
    background: var(--k-100);
    overflow: hidden;
  }
  .lp-hero__rotation {
    position: absolute;
    inset: 0;
    z-index: -2;
  }
  /* 4 slidy jako horizontal carousel: 4 s nehybný hold, pak 1 s swipe
     celé fotky doleva. Sousední slide zároveň zprava vplouvá dovnitř,
     takže přechod je jeden plynulý sweep bez cross-fade.
     Slide N animation-delay = N × 5 s − 1 s (pre-roll, aby slide 0 byl
     hned na svém místě při page loadu). */
  .lp-hero__slide {
    position: absolute;
    inset: 0;
    transform: translateX(100%);
    animation: lp-hero-swipe 20s cubic-bezier(0.65, 0, 0.35, 1) infinite;
    will-change: transform;
  }

  @keyframes lp-hero-swipe {
    /* 20 s smyčka = 100 %. 0-5 % (1 s): swipe-in zprava. 5-25 % (4 s):
       hold na středu. 25-30 % (1 s): swipe-out doleva. 30-100 %: hidden
       off-screen vlevo dokud se animace neresetuje. Boundary teleport
       z -100 % zpět na 100 % se děje off-screen, uživatel ho nevidí. */
    0%   { transform: translateX(100%); }
    5%   { transform: translateX(0); }
    25%  { transform: translateX(0); }
    30%  { transform: translateX(-100%); }
    100% { transform: translateX(-100%); }
  }

  .lp-hero__bg {
    position: absolute;
    inset: 0;
    width: 100%; height: 100%;
    object-fit: cover;
    filter: brightness(0.88);
  }
  .lp-hero__scrim {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to top,
      rgba(0,0,0,0.75) 0%,
      rgba(0,0,0,0.45) 35%,
      rgba(0,0,0,0.05) 75%
    );
    z-index: -1;
  }
  .lp-hero__inner {
    max-width: var(--container);
    margin: 0 auto;
    width: 100%;
    text-align: center;
  }
  .lp-hero__title {
    font: 600 clamp(2.5rem, 6vw, 4.75rem) / 1.05 var(--font-sans);
    letter-spacing: var(--tracking-tight);
    margin: 0 auto var(--space-2);
    max-width: 18ch;
  }
  .lp-hero__lede {
    font: 600 var(--text-2xs) / 1 var(--font-sans);
    letter-spacing: var(--tracking-wider);
    text-transform: uppercase;
    margin: 0;
    color: rgba(255,255,255,0.75);
  }

  /* reduced-motion: freeze on slide 0 */
  @media (prefers-reduced-motion: reduce) {
    .lp-hero__slide { animation: none; transform: translateX(-100%); }
    .lp-hero__slide[data-slide="0"] { transform: translateX(0); }
  }

  /* ============ JUMP STRIP DESKTOP (uvnitř hero) ============ */
  /* Bílé outline buttony nad tmavým hero, Rezervace bílý fill. */
  .lp-jumps {
    width: 100%;
    max-width: var(--container-wide);
    margin: 0 auto;
  }
  .lp-jumps__inner {
    display: flex;
    gap: 10px;
    justify-content: center;
    flex-wrap: wrap;
  }
  .lp-jumps__item {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    padding: 11px 22px;
    font: 600 var(--text-sm) / 1 var(--font-sans);
    color: #fff;
    background: transparent;
    border: 1px solid rgba(255,255,255,0.75);
    border-radius: var(--radius-input);
    text-decoration: none;
    white-space: nowrap;
    transition: background 180ms ease, color 180ms ease, border-color 180ms ease;
    backdrop-filter: blur(2px);
  }
  .lp-jumps__item :global(svg) { flex-shrink: 0; }
  .lp-jumps__item:hover,
  .lp-jumps__item:focus-visible {
    background: rgba(255,255,255,0.12);
    border-color: #fff;
    color: #fff;
    outline: none;
  }
  .lp-jumps__item--primary {
    background: #fff;
    color: var(--fg);
    border-color: #fff;
  }
  .lp-jumps__item--primary:hover,
  .lp-jumps__item--primary:focus-visible {
    background: rgba(255,255,255,0.86);
    color: var(--fg);
    border-color: #fff;
  }

  /* Mobile varianta žije pod hero v normalním flow s bílým pozadím. */
  .lp-jumps--mobile { display: none; }

  @media (max-width: 760px) {
    /* Hero zkráceno na 70 % viewportu, aby pod ním zbylo místo pro
       mobile jump strip. */
    .lp-hero {
      min-height: 70vh;
      min-height: 70dvh;
      padding: var(--space-7) var(--gutter);
    }
    .lp-jumps--desktop { display: none; }
