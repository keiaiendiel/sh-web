    }
    .lp-jumps--mobile .lp-jumps__inner {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 10px;
      max-width: 520px;
      margin: 0 auto;
    }
    .lp-jumps--mobile .lp-jumps__item {
      flex-direction: column;
      align-items: center;
      justify-content: center;
      gap: 8px;
      aspect-ratio: 1;
