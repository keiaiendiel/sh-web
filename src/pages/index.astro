    stroke-width: 44;
  }
  .lp-tile--reserve .lp-tile__ribbon { opacity: 0.85; }
  .lp-tile__ribbon[data-ribbon-reveal] path {
    stroke-dasharray: 1;
    stroke-dashoffset: 1;
    pathLength: 1;
  }
  /* Po reveal pokračuje breathing infinite loop. Range 0.42-0.72 (na container
     overlay opacity 0.55 idle → multiplikuje se na path). */
  .lp-tile__ribbon[data-ribbon-reveal].is-revealed path {
    animation:
      ribbon-snake-draw 2.6s var(--ease-snake) forwards,
      ribbon-breathe 7s ease-in-out 2.6s infinite;
  }

  /* Hover: lift + ribbon nice */
  .lp-tile:hover,
  .lp-tile:focus-visible {
    transform: translateY(-2px);
    border-color: var(--accent);
    box-shadow: 0 1px 2px rgba(0,0,0,0.04), 0 12px 32px hsl(var(--hue) 39% 27% / 0.14);
