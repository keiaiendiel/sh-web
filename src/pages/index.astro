---
import Base from '../layouts/Base.astro';
import OsaGlyph from '../components/OsaGlyph.astro';
---
<Base title="OSA — v pohybu">
  <main style="padding: var(--space-9); display: grid; gap: var(--space-6); justify-items: start; max-width: 920px; margin-inline: auto;">
    <OsaGlyph size="4rem" />
    <h1 class="osa-h1">OSA, v pohybu</h1>
    <p class="osa-body">Scaffolding ověřen. Tokeny připojeny. Atyp Special a Space Grotesk načteny.</p>
    <p class="osa-eyebrow">Fáze 0 hotova</p>
  </main>
</Base>
