---
import Base from '../layouts/Base.astro';
import { withBase } from '../utils/url';
import { getCollection, getEntry } from 'astro:content';

const subProjects = (await getCollection('subProjects')).sort((a, b) => a.data.order - b.data.order);

// Hero rotation — 4 background images sliding horizontally on a 20s loop.
const heroImages = [
  withBase('/images/hub/hero/sh-1.jpg'),
  withBase('/images/hub/hero/sh-2.jpg'),
  withBase('/images/hub/hero/sh-3.jpg'),
  withBase('/images/hub/hero/sh-4.jpg'),
];

// Living formats — kapsle gets the real photo; the others shift one slot down.
const formats = [
  {
    name: 'Kapsle',
    src: withBase('/images/hub/interior/kapsle.jpg'),
    body: 'Nejlevnější varianta. Spací modul ve sdílené jednotce, sdílená koupelna a kuchyň. Pro krátkodobé pobyty a lidi, pro které je hlavní cena.',
  },
  {
    name: 'Klidnější uzavíratelné místo',
    src: withBase('/images/hub/interior/interior-01.jpg'),
    body: 'Privátní mikropokoj s vlastními dveřmi a stolem. Sdílené sociální zázemí s pár sousedy. Pro lidi, kteří potřebují klid na práci nebo studium.',
  },
  {
    name: 'Jednolůžkový pokoj',
    src: withBase('/images/hub/interior/interior-02.jpg'),
    body: 'Plnohodnotný menší pokoj s vlastním sociálním zázemím. Sdílená kuchyň s pár sousedy. Pro delší pobyty a stabilnější rezidenty.',
  },
  {
    name: 'Sdílený pokoj',
    src: withBase('/images/hub/interior/interior-03.jpg'),
    body: 'Dvojlůžkový pokoj sdílený se spolubydlícím. Levnější varianta delšího pobytu pro studenty a lidi, kteří jsou v pohodě se sdílením.',
  },
];

// Four-claim grid — short, parallel, scannable. Replaces the prior prose
// sections (koncept / pro koho / sdílené prostory) with a unified 2×2.
const claims = [
  {
    eyebrow: 'Koncept',
    title: 'Sedm budov, ~331 jednotek 1+kk.',
    body: 'Rekonstrukce A1–A6 a budovy C v jádru areálu Horních kasáren. Privátní jednotky 1+kk se sklopnou postelí a vlastním sociálním zázemím.',
  },
  {
    eyebrow: 'Pro koho',
    title: 'Lidé, kteří startují.',
    body: 'Pracující studenti, OSVČ na začátku, mladí kreativci, začínající podnikatelé. Hub dává smysl tomu, kdo hledá flexibilní bydlení blízko Prahy.',
  },
  {
    eyebrow: 'Sdílené prostory',
    title: 'Privátní jednotka, sdílený zbytek.',
    body: 'Coworking v budově C, sauna v objektu E, venkovní bazén před D, tržnice s minipivovarem v B, komunitní park s grilem a sportem.',
  },
  {
    eyebrow: 'Stipendium',
    title: 'Popsaný výběr, ne slevový kód.',
    body: 'Pro lidi, kteří by Hubu dávali smysl, ale bez podpory by si pobyt nemohli dovolit. Vybíráme podle záměru, který v Hubu chcete rozjet.',
  },
];

// Editorial zigzag — 5 rows alternating ltr/rtl with slight overlap rhythm.
const zigzag = [
  {
    dir: 'ltr',
    src: withBase('/images/hub/hero/sh-1.jpg'),
    alt: 'Mladí lidé v okolí zrekonstruované budovy v duchu kasáren.',
    eyebrow: 'Místo',
    title: 'Areál horních kasáren · 12 km od Prahy.',
    body: 'Klecany jsou těsně za hranicí Prahy. Areál je na trase plánované tramvajové zastávky Výzkumný ústav I. (vydáno stavební povolení) a navrhované cyklostezky podél Vltavy.',
    eager: true,
  },
  {
    dir: 'rtl',
    src: withBase('/images/hub/interior/hub-market-evening.jpg'),
    alt: 'Tržnice za soumraku v objektu B s prosvícenými okny.',
    eyebrow: 'Komunita',
    title: 'Tržnice, minipivovar a food-trucky v objektu B.',
    body: 'V budově B vzniká tržnice s minipivovarem, pekárnou a zázemím pro food-trucky. V přízemí budovy C bude coworkingový sál s pódiem.',
  },
  {
    dir: 'ltr',
    src: withBase('/images/hub/hero/sh-2.jpg'),
    alt: 'Interiér 1+kk se sklopnou postelí a balkonem.',
    eyebrow: 'Bydlení',
    title: '~331 privátních jednotek 1+kk.',
    body: 'Každá jednotka má vlastní sociální zázemí — sprchu, umyvadlo a toaletu. Sklopná postel uvolní obytný prostor přes den. Ve formátu mikrostudia 1+kk.',
  },
  {
    dir: 'rtl',
    src: withBase('/images/hub/exterior/hub-courtyard-trees.jpg'),
    alt: 'Vnitřní dvůr s břízami, lavicemi a večerním osvětlením.',
    eyebrow: 'Areál',
    title: 'Vnitřní dvůr a zázemí.',
    body: 'Sedm rekonstruovaných budov (A1–A6 + C) na ~6 700 m² čistých podlahových ploch. Mezi nimi sauna v objektu E, venkovní bazén před objektem D a komunitní park s grilovacími místy.',
  },
  {
    dir: 'ltr',
    src: withBase('/images/hub/hero/sh-4.jpg'),
    alt: 'Pracovní zákoutí v jednotce 1+kk s knihovnou a stolem.',
    eyebrow: 'Pro koho',
    title: 'Pracující studenty, OSVČ a mladí kreativci.',
    body: 'Hub je dimenzovaný pro lidi, kteří startují — začínající podnikatele, studenty pracující na bakalářce nebo diplomce, OSVČ na začátku kariéry. Pro někoho je to startovní bydlení; pro jiného přechodné mezikolečko.',
  },
];
---
<Base
  title="Startovací hub"
  description="Nájemní bydlení blízko Prahy s komunitním a coworkingovým zázemím v areálu horních kasáren v Klecanech. Přijímáme nezávazné před-rezervace."
  headerVariant="dark"
  ogImage={withBase('/og/default.png')}
>
  <section class="hub-hero osa-dark">
    <div class="hub-hero__bg-stack" aria-hidden="true">
      {heroImages.map((src, i) => (
        <img
          class={`hub-hero__bg hub-hero__bg--${i}`}
          src={src}
          alt=""
          loading={i === 0 ? 'eager' : 'lazy'}
          decoding="async"
          fetchpriority={i === 0 ? 'high' : 'auto'}
        />
      ))}
    </div>
    <div class="hub-hero__scrim" aria-hidden="true"></div>
    <div class="hub-hero__inner">
      <div class="hub-hero__kicker-row">
        <span class="osa-eyebrow hub-hero__kicker">Areál horních kasáren · Klecany</span>
        <a class="osa-eyebrow hub-hero__kicker-out" href="https://keiaiendiel.github.io/vpd-web/vpd1/" rel="noopener">Záměr VPD1 →</a>
      </div>
      <h1 class="hub-hero__title">Startovací hub.</h1>
      <p class="hub-hero__lede">Nájemní bydlení blízko Prahy s komunitním a coworkingovým zázemím. Hledáme mladé kreativce, začínající podnikatele a pracující studenty.</p>
      <a class="hub-hero__cta" href={withBase('/rezervace/')}>Rezervace →</a>
    </div>
  </section>

  <section class="hub-section hub-formats">
    <header class="osa-sub-head">
      <span class="osa-eyebrow">Co Hub nabídne</span>
      <h2 class="hub-section__heading">Čtyři režimy obsazení jednotky.</h2>
    </header>
    <div class="hub-formats__grid">
      {formats.map((f) => (
        <article class="hub-format-card">
          <figure class="hub-format-card__media">
            <img src={f.src} alt={`Vizualizace formátu: ${f.name}`} loading="lazy" />
          </figure>
          <h3>{f.name}</h3>
          <p>{f.body}</p>
        </article>
      ))}
    </div>
    <p class="hub-formats__note">Architektonický základ Hubu je 331 jednotek 1+kk s privátním sociálním zázemím (sprcha, umyvadlo, toaleta). Výše uvedené formáty popisují způsoby obsazení těchto jednotek, ne fyzicky odlišné typy místností.</p>
  </section>

  <section class="hub-claims-section">
    <div class="hub-claims" role="list">
      {claims.map((c) => (
        <article class="hub-claims__item" role="listitem">
          <span class="osa-eyebrow hub-claims__eyebrow">{c.eyebrow}</span>
          <h3 class="hub-claims__title">{c.title}</h3>
          <p class="hub-claims__body">{c.body}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="hub-zigzag">
    <header class="osa-sub-head hub-zigzag__head">
      <span class="osa-eyebrow">Vizualizace</span>
      <h2 class="hub-section__heading">Jak to bude vypadat.</h2>
    </header>
    {zigzag.map((row, i) => (
      <div
        class:list={['hub-zigzag__row', `hub-zigzag__row--${row.dir}`]}
        data-row={i}
        data-zigzag-reveal>
        <figure class="hub-zigzag__media">
          <button
            type="button"
            class="hub-zigzag__media-trigger"
            data-lightbox-open
            data-index={i}
            aria-label={`Otevřít ve zvětšení: ${row.alt}`}>
            <img src={row.src} alt={row.alt} loading={row.eager ? 'eager' : 'lazy'} decoding="async" />
          </button>
        </figure>
        <div class="hub-zigzag__copy">
          <span class="osa-eyebrow">{row.eyebrow}</span>
          <h3>{row.title}</h3>
          <p>{row.body}</p>
        </div>
      </div>
    ))}
  </section>

  <!-- Lightbox overlay — opens on zigzag image click; arrow keys / buttons navigate. -->
  <div class="hub-lightbox" id="hub-lightbox" role="dialog" aria-modal="true" aria-label="Vizualizace areálu" hidden>
    <button class="hub-lightbox__close" type="button" aria-label="Zavřít">×</button>
    <button class="hub-lightbox__nav hub-lightbox__nav--prev" type="button" aria-label="Předchozí">‹</button>
    <button class="hub-lightbox__nav hub-lightbox__nav--next" type="button" aria-label="Další">›</button>
    <figure class="hub-lightbox__figure">
      <img class="hub-lightbox__img" src="" alt="" />
      <figcaption class="hub-lightbox__caption">
        <span class="osa-eyebrow hub-lightbox__caption-eyebrow"></span>
        <span class="hub-lightbox__caption-title"></span>
        <span class="hub-lightbox__caption-counter"></span>
      </figcaption>
    </figure>
  </div>

  <section class="hub-cta-pair">
    <div class="hub-cta-pair__grid">
      <article class="hub-cta-card hub-cta-card--primary">
        <div class="hub-cta-card__content">
          <span class="osa-eyebrow hub-cta-card__kicker">Chci tu bydlet</span>
          <p class="hub-cta-card__lede">Otevřeli jsme nezávazné před-rezervace. Vyplnění je krátké, nic neúčtujeme a žádný závazek nevzniká.</p>
          <a class="hub-cta-card__btn hub-cta-card__btn--primary" href={withBase('/rezervace/')}>Vyplnit před-rezervaci →</a>
        </div>
      </article>

      <article class="hub-cta-card hub-cta-card--secondary">
        <div class="hub-cta-card__content">
          <span class="osa-eyebrow hub-cta-card__kicker">Investice do záměru</span>
          <p class="hub-cta-card__lede">Nezajímá vás bydlení, ale revitalizace celého areálu? Záměr VPD1 cílí na strategické a finanční partnery.</p>
          <a class="hub-cta-card__btn hub-cta-card__btn--secondary" href="https://keiaiendiel.github.io/vpd-web/vpd1/" rel="noopener">Záměr VPD1 →</a>
        </div>
      </article>
    </div>
  </section>

  <section class="hub-section">
    <header class="osa-sub-head">
      <span class="osa-eyebrow">Provozy</span>
      <h2 class="hub-section__heading">Jak se Hub rozrůstá.</h2>
    </header>
    <p class="hub-section__intro">Hub se nerozjede naráz. Skládá se z propojených provozů, které vznikají postupně — některé v aktivní přípravě, jiné teprve dolaďujeme.</p>
    <div class="hub-projects-teaser">
      {subProjects.map((p) => (
        <a class="hub-teaser-card" href={withBase(`/projekty/${p.id}/`)}>
          <h3>{p.data.name}</h3>
          <p>{p.data.role}</p>
          <span class="hub-teaser-card__cta">Detail →</span>
        </a>
      ))}
      <a class="hub-teaser-card hub-teaser-card--more" href={withBase('/projekty/')}>
        <h3>Další provozy</h3>
        <p>Hub se rozrůstá. Podívejte se na všechny provozy a jejich postup.</p>
        <span class="hub-teaser-card__cta">Provozy →</span>
      </a>
    </div>
  </section>

  <section class="hub-section hub-place">
    <div class="hub-place__grid">
      <div>
        <header class="osa-sub-head">
          <span class="osa-eyebrow">Místo</span>
          <h2 class="hub-section__heading">Kde to je.</h2>
        </header>
        <p>Klecany leží severně od Prahy, 12 km od centra. Areál je na trase plánované tramvajové zastávky Výzkumný ústav I. (na hranici Klecany / Zdiby; vydáno stavební povolení) a navrhované cyklolávky Roztoky–Klecany.</p>
        <a class="hub-place__cta" href={withBase('/o-arealu/#misto')}>O areálu a kontextu →</a>
      </div>
      <figure class="hub-place__map">
        <img src={withBase('/images/hub/masterplan.jpg')} alt="Schéma areálu Horních kasáren — Hub jádro (A1–A6 + C) zvýrazněno." loading="lazy" />
        <figcaption>Areál Horních kasáren — sedm budov etapy 1 (A1–A6 a C) v rámci celkového záměru.</figcaption>
      </figure>
    </div>
  </section>

  <section class="hub-map-strip" aria-labelledby="hub-map-heading">
    <div class="hub-map-strip__inner">
      <header class="hub-map-strip__head">
        <span class="osa-eyebrow">Klecany na mapě</span>
        <h2 id="hub-map-heading" class="hub-map-strip__heading">Severní okraj Prahy, hned za Vltavou.</h2>
      </header>
      <div class="hub-map-strip__frame" id="hub-landing-map" role="application" aria-label="Interaktivní mapa areálu Horní kasárna Klecany"></div>
      <p class="hub-map-strip__address">
        <strong>Horní kasárna Klecany</strong>
        <a href="https://maps.app.goo.gl/vCF6VbW7Z49sggau6" target="_blank" rel="noopener">Otevřít v Mapách →</a>
      </p>
    </div>
  </section>

  <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" crossorigin="anonymous" />
  <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js" crossorigin="anonymous" is:inline></script>

  <section class="hub-section">
    <header class="osa-sub-head">
      <span class="osa-eyebrow">FAQ</span>
      <h2 class="hub-section__heading">Časté otázky.</h2>
    </header>
    {await Promise.all(['q1', 'q5', 'q7'].map(async (id) => {
      const entry = await getEntry('faq', id);
      return entry ? (
        <details class="hub-faq-mini">
          <summary>{entry.data.question}</summary>
          <p>{entry.data.answer}</p>
        </details>
      ) : null;
    }))}
    <p class="hub-faq-mini__more"><a href={withBase('/faq/')}>Všechny otázky →</a></p>
  </section>
</Base>

<script is:inline>
  document.addEventListener('DOMContentLoaded', () => {
    // Reveal-on-scroll for zigzag rows.
    const rows = document.querySelectorAll('[data-zigzag-reveal]');
    if (rows.length) {
      if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
        rows.forEach((r) => r.classList.add('is-revealed'));
      } else {
        const io = new IntersectionObserver((entries) => {
          entries.forEach((e) => {
            if (e.isIntersecting) {
              e.target.classList.add('is-revealed');
              io.unobserve(e.target);
            }
          });
        }, { rootMargin: '0px 0px -8% 0px', threshold: 0.05 });
        rows.forEach((r) => io.observe(r));
      }
    }

    // Lightbox — arrow nav, ESC close, click outside close.
    const lightbox = document.getElementById('hub-lightbox');
    const triggers = document.querySelectorAll('[data-lightbox-open]');
    if (!lightbox || !triggers.length) return;

    const slides = Array.from(triggers).map((t) => {
      const img = t.querySelector('img');
      const row = t.closest('[data-zigzag-reveal]');
      return {
        src: img.src,
        alt: img.alt,
        eyebrow: row?.querySelector('.osa-eyebrow')?.textContent?.trim() ?? '',
        title: row?.querySelector('h3')?.textContent?.trim() ?? '',
      };
    });

    let active = 0;
    const lbImg     = lightbox.querySelector('.hub-lightbox__img');
    const lbEyebrow = lightbox.querySelector('.hub-lightbox__caption-eyebrow');
    const lbTitle   = lightbox.querySelector('.hub-lightbox__caption-title');
    const lbCounter = lightbox.querySelector('.hub-lightbox__caption-counter');

    function render() {
      const s = slides[active];
      lbImg.src = s.src;
      lbImg.alt = s.alt;
      lbEyebrow.textContent = s.eyebrow;
      lbTitle.textContent = s.title;
      lbCounter.textContent = `${active + 1} / ${slides.length}`;
    }
    function open(i) {
      active = i;
      render();
      lightbox.hidden = false;
      requestAnimationFrame(() => lightbox.classList.add('is-open'));
      document.documentElement.classList.add('osa-nav-lock');
    }
    function close() {
      lightbox.classList.remove('is-open');
      document.documentElement.classList.remove('osa-nav-lock');
      setTimeout(() => { lightbox.hidden = true; }, 220);
    }
    function step(delta) {
      active = (active + delta + slides.length) % slides.length;
      render();
    }

    triggers.forEach((t, i) => t.addEventListener('click', () => open(i)));
    lightbox.querySelector('.hub-lightbox__close').addEventListener('click', close);
    lightbox.querySelector('.hub-lightbox__nav--prev').addEventListener('click', () => step(-1));
    lightbox.querySelector('.hub-lightbox__nav--next').addEventListener('click', () => step(1));
    lightbox.addEventListener('click', (e) => {
      if (e.target === lightbox) close();
    });
    document.addEventListener('keydown', (e) => {
      if (lightbox.hidden) return;
      if (e.key === 'Escape') close();
      else if (e.key === 'ArrowLeft')  step(-1);
      else if (e.key === 'ArrowRight') step(1);
    });

    // Leaflet map under "Místo" — same pattern as /o-arealu/.
    const mapEl = document.getElementById('hub-landing-map');
    if (mapEl && typeof L !== 'undefined') {
      const center = [50.181447059112294, 14.424094125168379];
      const map = L.map(mapEl, {
        center, zoom: 16,
        zoomControl: false, attributionControl: false,
        scrollWheelZoom: false,
      });
      L.tileLayer('https://{s}.basemaps.cartocdn.com/rastertiles/voyager_nolabels/{z}/{x}/{y}{r}.png', {
        attribution: '&copy; <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a> &copy; <a href="https://carto.com/">CARTO</a>',
        subdomains: 'abcd', maxZoom: 19,
      }).addTo(map);
      const icon = L.divIcon({
        html:
          '<svg width="30" height="40" viewBox="0 0 28 36" fill="none" xmlns="http://www.w3.org/2000/svg">' +
          '<path d="M14 0C6.27 0 0 6.27 0 14c0 9.33 14 22 14 22S28 23.33 28 14C28 6.27 21.73 0 14 0z" fill="#5A2A5F"/>' +
          '<circle cx="14" cy="14" r="5" fill="#ffffff"/>' +
          '</svg>',
        className: '', iconSize: [30, 40], iconAnchor: [15, 40], popupAnchor: [0, -42],
      });
      const gmaps = 'https://maps.app.goo.gl/vCF6VbW7Z49sggau6';
      const popupHtml =
        '<a href="' + gmaps + '" target="_blank" rel="noopener" class="op-map-popup">' +
          '<strong>Horní kasárna Klecany</strong>' +
          '<span class="op-map-popup__cta">Otevřít v Mapách →</span>' +
        '</a>';
      L.marker(center, { icon })
        .addTo(map)
        .bindPopup(popupHtml, { className: 'op-map-popup-wrap' })
        .openPopup()
        .on('click', () => window.open(gmaps, '_blank'));
      L.control.attribution({ prefix: false }).addTo(map);
      L.control.zoom({ position: 'bottomright' }).addTo(map);
      mapEl.addEventListener('click', () => map.scrollWheelZoom.enable(), { once: true });
    }
  });
</script>

<style>
  /* HERO -- full-bleed slide carousel + scrim, content above. */
  .hub-hero {
    position: relative;
    isolation: isolate;
    min-height: clamp(560px, 88vh, 820px);
    display: flex;
    align-items: flex-end;
    background: var(--k-100);
    color: #fff;
    overflow: hidden;
  }
  .hub-hero__bg-stack { position: absolute; inset: 0; z-index: 1; overflow: hidden; }
  .hub-hero__bg {
    position: absolute; inset: 0;
    width: 100%; height: 100%;
    object-fit: cover;
    filter: brightness(0.52) saturate(0.92);
    transform: translateX(100%);
    will-change: transform;
    animation-name: hub-hero-slide;
    animation-duration: 20s;
    animation-iteration-count: infinite;
    animation-timing-function: cubic-bezier(0.5, 0, 0.2, 1);
  }
  /* Negative delay on image 0 so it starts already on-screen at 5% of cycle. */
  .hub-hero__bg--0 { animation-delay: -1s; }
  .hub-hero__bg--1 { animation-delay: 4s;  }
  .hub-hero__bg--2 { animation-delay: 9s;  }
  .hub-hero__bg--3 { animation-delay: 14s; }

  @keyframes hub-hero-slide {
    0%      { transform: translateX(100%); }
    5%      { transform: translateX(0); }
    25%     { transform: translateX(0); }
    30%     { transform: translateX(-100%); }
    100%    { transform: translateX(-100%); }
  }
  @media (prefers-reduced-motion: reduce) {
    .hub-hero__bg                        { animation: none; transform: translateX(100%); }
    .hub-hero__bg--0                     { transform: translateX(0); }
  }
  .hub-hero__scrim {
    position: absolute; inset: 0; z-index: 2;
    background: linear-gradient(180deg, rgba(0,0,0,0.30) 0%, rgba(0,0,0,0.18) 38%, rgba(0,0,0,0.72) 100%);
    pointer-events: none;
  }
  .hub-hero__inner {
    position: relative; z-index: 3;
    padding: clamp(72px, 10vw, 112px) var(--gutter) clamp(56px, 8vw, 88px);
    max-width: var(--container-wide); margin: 0 auto; width: 100%;
    display: grid; gap: clamp(24px, 3vw, 36px);
  }
  /* Entrance cascade — each hero child lifts and fades in with a 90ms step.
     Runs once per element instantiation (fresh on cold load AND after every
     view-transition arrival, since main is replaced). Reduced-motion below
     skips the keyframes entirely. */
  .hub-hero__inner > * {
    animation: hub-hero-enter 720ms cubic-bezier(0.16, 1, 0.3, 1) both;
  }
  .hub-hero__inner > *:nth-child(1) { animation-delay:  60ms; }
  .hub-hero__inner > *:nth-child(2) { animation-delay: 150ms; }
  .hub-hero__inner > *:nth-child(3) { animation-delay: 240ms; }
  .hub-hero__inner > *:nth-child(4) { animation-delay: 330ms; }
  @keyframes hub-hero-enter {
    from { opacity: 0; transform: translateY(14px); }
    to   { opacity: 1; transform: translateY(0); }
  }
  @media (prefers-reduced-motion: reduce) {
    .hub-hero__inner > * { animation: none; }
  }
  .hub-hero__kicker-row {
    display: flex; align-items: baseline; justify-content: space-between;
    gap: 24px; flex-wrap: wrap;
    /* Match the visible width of "Startovací hub." H1 so the right kicker
       lines up just beyond the end of the word "hub.". */
    max-width: clamp(320px, 48vw, 660px);
  }
  .hub-hero__kicker     { color: rgba(255,255,255,0.78); }
  .hub-hero__kicker-out {
    color: rgba(255,255,255,0.78);
    text-decoration: underline;
    text-decoration-thickness: 1px;
    text-underline-offset: 4px;
    text-decoration-color: rgba(255,255,255,0.4);
    transition:
      color var(--dur-fast) linear,
      text-decoration-color var(--dur-fast) linear;
  }
  .hub-hero__kicker-out:hover {
    color: #fff;
    text-decoration-color: #fff;
  }
  .hub-hero__title {
    font-family: var(--font-sans); font-weight: 600;
    font-size: clamp(48px, 7vw, 96px);
    line-height: 1.0; letter-spacing: -0.025em;
    margin: 0; max-width: 14ch;
  }
  .hub-hero__lede {
    font-size: clamp(16px, 1.35vw, 19px);
    line-height: 1.55;
    max-width: 38ch;
    color: rgba(255,255,255,0.88);
    margin: 0;
  }
  /* Hero CTA — outline at rest, white wipe fills from bottom on hover.
     Pattern A (outline → fill): default white border + white text;
     on hover the white fill rises from the bottom, text turns black. */
  .hub-hero__cta {
    position: relative;
    isolation: isolate;
    overflow: hidden;
    justify-self: start;
    display: inline-flex; align-items: center; gap: 8px;
    padding: 16px 32px;
    background: transparent;
    color: #fff;
    border: 1px solid #fff;
    border-radius: var(--radius-input);
    font: 600 17px / 1 var(--font-sans);
    text-decoration: none;
    margin-top: 8px;
    transition: color 160ms cubic-bezier(0.65, 0, 0.35, 1);
  }
  .hub-hero__cta::after {
    content: "";
    position: absolute;
    inset: 0;
    background: #fff;
    z-index: -1;
    clip-path: inset(100% 0 0 0);
    transition: clip-path 220ms cubic-bezier(0.65, 0, 0.35, 1);
  }
  .hub-hero__cta:hover::after,
  .hub-hero__cta:focus-visible::after {
    clip-path: inset(0 0 0 0);
  }
  .hub-hero__cta:hover,
  .hub-hero__cta:focus-visible { color: var(--k-100); }
  .hub-hero__cta:focus-visible {
    outline: 2px solid #fff;
    outline-offset: 3px;
  }
  .hub-hero__cta:active { transform: translateY(1px); }
  @media (prefers-reduced-motion: reduce) {
    .hub-hero__cta,
    .hub-hero__cta::after { transition: none; }
  }
  @media (max-width: 720px) {
    .hub-hero__kicker-out { display: none; }
  }

  /* SECTION SHELL */
  .hub-section {
    padding: clamp(48px, 6vw, 72px) var(--gutter);
    max-width: var(--container-wide);
    margin: 0 auto;
  }
  .hub-section__heading {
    font-family: var(--font-sans);
    font-size: clamp(28px, 3vw, 44px);
    font-weight: 600;
    margin: 0;
    letter-spacing: var(--tracking-tight);
    line-height: 1.1;
    text-wrap: balance;
  }
  .hub-section__intro {
    font-size: 18px;
    color: var(--fg-muted);
    margin: 0 0 32px;
    max-width: 720px;
    line-height: 1.55;
  }
  .osa-sub-head { margin-bottom: 32px; }
  .osa-sub-head .osa-eyebrow { color: var(--fg-subtle); display: block; margin-bottom: 8px; }

  /* FORMATS GRID -- 4-up cards under hero (migrated from /obyvatele/). */
  .hub-formats__grid {
    display: grid; gap: 24px;
    grid-template-columns: repeat(4, minmax(0, 1fr));
  }
  @media (max-width: 960px) { .hub-formats__grid { grid-template-columns: repeat(2, minmax(0, 1fr)); } }
  @media (max-width: 560px) { .hub-formats__grid { grid-template-columns: 1fr; } }
  .hub-format-card {
    display: grid; gap: 12px;
    border: 1px solid var(--border-muted);
    border-radius: var(--radius-input);
    background: var(--bg);
    padding: 0 0 20px;
    transition: border-color var(--dur-base) var(--ease-decel);
  }
  .hub-format-card:hover { border-color: var(--accent); }
  .hub-format-card__media {
    margin: 0;
    border-radius: var(--radius-input) var(--radius-input) 0 0;
    overflow: hidden;
    aspect-ratio: 4/3;
  }
  .hub-format-card__media img {
    width: 100%; height: 100%;
    object-fit: cover; display: block;
  }
  .hub-format-card h3 {
    font-size: 17px; font-weight: 600;
    margin: 4px 20px 0; line-height: 1.3;
  }
  .hub-format-card p {
    font-size: 14px; line-height: 1.55;
    color: var(--fg-muted); margin: 0 20px;
  }
  .hub-formats__note {
    margin-top: 32px;
    font-size: 14px; line-height: 1.55;
    color: var(--fg-muted);
    max-width: 880px;
  }

  /* CLAIMS 2x2 -- four parallel claims with a thin cross divider in the middle.
     Achieved via per-cell border-right / border-bottom on the relevant cells. */
  .hub-claims-section {
    padding: clamp(40px, 5vw, 64px) var(--gutter);
    max-width: var(--container-wide); margin: 0 auto;
  }
  .hub-claims {
    display: grid;
    grid-template-columns: 1fr 1fr;
    border: 1px solid var(--border-muted);
    border-radius: var(--radius-input);
    overflow: hidden;
    background: var(--bg);
  }
  .hub-claims__item {
    padding: clamp(32px, 5vw, 56px);
    display: grid; gap: 12px;
    align-content: start;
  }
  /* Internal cross dividers — only on items that need a right or bottom rule. */
  .hub-claims__item:nth-child(1) {
    border-right: 1px solid var(--border-muted);
    border-bottom: 1px solid var(--border-muted);
  }
  .hub-claims__item:nth-child(2) {
    border-bottom: 1px solid var(--border-muted);
  }
  .hub-claims__item:nth-child(3) {
    border-right: 1px solid var(--border-muted);
  }
  .hub-claims__eyebrow { color: var(--accent); }
  .hub-claims__title {
    font-family: var(--font-sans);
    font-size: clamp(20px, 1.8vw, 24px);
    font-weight: 600;
    line-height: 1.2;
    letter-spacing: var(--tracking-tight);
    margin: 4px 0 0;
    text-wrap: balance;
  }
  .hub-claims__body {
    font-size: 15px;
    line-height: 1.6;
    color: var(--fg-muted);
    margin: 0;
    max-width: 42ch;
  }
  @media (max-width: 720px) {
    .hub-claims { grid-template-columns: 1fr; }
    .hub-claims__item { padding: 24px 20px; }
    .hub-claims__item:nth-child(1),
    .hub-claims__item:nth-child(2),
    .hub-claims__item:nth-child(3) {
      border-right: 0;
      border-bottom: 1px solid var(--border-muted);
    }
  }

  /* ZIGZAG -- 5 alternating rows (ltr/rtl). Slight overlap rhythm pulls
     each row up by ~10vw, creating a single continuous ribbon while
     copy and image stay vertically centered to each other. Reveal-on-
     scroll fade-in for delight. */
  .hub-zigzag {
    padding: clamp(48px, 6vw, 72px) var(--gutter) clamp(56px, 7vw, 96px);
    max-width: var(--container-wide); margin: 0 auto;
  }
  .hub-zigzag__head { margin-bottom: clamp(40px, 6vw, 72px); }
  .hub-zigzag__row {
    display: grid; grid-template-columns: 1fr 1fr;
    gap: clamp(32px, 5vw, 64px);
    align-items: center;
    padding: 0;
    /* reveal-on-scroll initial state */
    opacity: 0;
    transform: translateY(28px);
    transition:
      opacity 700ms var(--ease-decel),
      transform 700ms var(--ease-decel);
  }
  .hub-zigzag__row.is-revealed,
  .hub-zigzag__row[data-row='0'] {
    opacity: 1;
    transform: translateY(0);
  }
  .hub-zigzag__row + .hub-zigzag__row {
    margin-top: clamp(-100px, -5vw, -40px);
  }
  .hub-zigzag__row--rtl .hub-zigzag__media { order: 2; }
  .hub-zigzag__row--rtl .hub-zigzag__copy  { order: 1; }
  .hub-zigzag__media { margin: 0; }
  .hub-zigzag__media-trigger {
    display: block; width: 100%;
    padding: 0; margin: 0;
    background: transparent; border: 0;
    cursor: zoom-in;
    border-radius: var(--radius-input);
    overflow: hidden;
    transition: box-shadow 300ms var(--ease-decel);
  }
  .hub-zigzag__media-trigger:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 4px;
  }
  .hub-zigzag__media img {
    width: 100%; height: auto;
    aspect-ratio: 4/3; object-fit: cover; display: block;
    border-radius: var(--radius-input);
    transition: transform 600ms var(--ease-decel);
  }
  .hub-zigzag__media-trigger:hover img {
    transform: scale(1.015);
  }
  .hub-zigzag__copy { max-width: 480px; }
  .hub-zigzag__copy .osa-eyebrow {
    display: inline-block; color: var(--accent);
    margin-bottom: 12px;
  }
  .hub-zigzag__copy h3 {
    font-family: var(--font-sans);
    font-size: clamp(22px, 2.4vw, 32px);
    font-weight: 600;
    margin: 0 0 12px;
    letter-spacing: var(--tracking-tight);
    line-height: 1.15;
    text-wrap: balance;
  }
  .hub-zigzag__copy p {
    font-size: clamp(15px, 1.25vw, 17px);
    line-height: 1.6;
    color: var(--fg);
    margin: 0;
  }
  @media (max-width: 720px) {
    .hub-zigzag__row {
      grid-template-columns: 1fr;
      gap: 16px;
    }
    .hub-zigzag__row + .hub-zigzag__row { margin-top: 32px; }
    .hub-zigzag__row--rtl .hub-zigzag__media { order: 1; }
    .hub-zigzag__row--rtl .hub-zigzag__copy  { order: 2; }
  }
  @media (prefers-reduced-motion: reduce) {
    .hub-zigzag__row { opacity: 1; transform: none; transition: none; }
    .hub-zigzag__row:hover .hub-zigzag__media img { transform: none; }
  }

  /* CTA PAIR -- two side-by-side cards: residents (plum, prominent) and
     investors (subtle outline). Both stick to the brand line aesthetic. */
  .hub-cta-pair {
    padding: clamp(40px, 5vw, 64px) var(--gutter);
    max-width: var(--container-wide); margin: 0 auto;
  }
  .hub-cta-pair__grid {
    display: grid; grid-template-columns: 1.05fr 0.95fr;
    gap: 16px;
  }
  @media (max-width: 720px) {
    .hub-cta-pair__grid { grid-template-columns: 1fr; }
  }
  .hub-cta-card {
    border-radius: var(--radius-input);
    overflow: hidden;
    border: 1px solid var(--accent-rule);
    background: var(--bg);
    color: var(--k-100);
    transition: box-shadow var(--dur-base) var(--ease-decel),
                border-color var(--dur-base) var(--ease-decel);
  }
  .hub-cta-card:hover {
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.08);
    border-color: var(--fg-subtle);
  }
  .hub-cta-card--primary:hover {
    border-color: var(--accent);
    box-shadow: 0 4px 20px rgba(90, 42, 95, 0.12);
  }
  .hub-cta-card--primary {
    border: 2px solid var(--accent);
  }
  .hub-cta-card--secondary { background: var(--bg); }
  .hub-cta-card__content {
    display: grid; gap: 14px;
    padding: clamp(32px, 5vw, 48px);
  }
  .hub-cta-card__kicker { color: var(--accent); }
  .hub-cta-card--secondary .hub-cta-card__kicker { color: var(--fg-subtle); }
  .hub-cta-card__lede {
    font-size: clamp(15px, 1.3vw, 17px);
    line-height: 1.55;
    color: var(--fg);
    margin: 0;
    max-width: 48ch;
  }
  /* Dual CTA buttons — wipe pattern. Primary (plum) is filled at rest
     and retracts on hover. Secondary (black outline) fills on hover. */
  .hub-cta-card__btn {
    position: relative;
    isolation: isolate;
    overflow: hidden;
    display: inline-flex; align-items: center; gap: 8px;
    justify-self: start;
    margin-top: 8px;
    padding: 13px 24px;
    border-radius: var(--radius-input);
    font: 600 15px / 1 var(--font-sans);
    text-decoration: none;
    transition: color 160ms cubic-bezier(0.65, 0, 0.35, 1);
  }
  .hub-cta-card__btn::after {
    content: "";
    position: absolute;
    inset: 0;
    z-index: -1;
    transition: clip-path 220ms cubic-bezier(0.65, 0, 0.35, 1);
  }
  /* Primary: plum filled at rest → plum stroke + plum text on hover. */
  .hub-cta-card__btn--primary {
    background: transparent;
    color: #fff;
    border: 1px solid var(--accent);
  }
  .hub-cta-card__btn--primary::after {
    background: var(--accent);
    clip-path: inset(0 0 0 0);
  }
  .hub-cta-card__btn--primary:hover,
  .hub-cta-card__btn--primary:focus-visible { color: var(--accent); }
  .hub-cta-card__btn--primary:hover::after,
  .hub-cta-card__btn--primary:focus-visible::after {
    clip-path: inset(100% 0 0 0);
  }
  /* Secondary: black outline at rest → black fill + white text on hover. */
  .hub-cta-card__btn--secondary {
    background: transparent;
    color: var(--k-100);
    border: 1px solid var(--k-100);
  }
  .hub-cta-card__btn--secondary::after {
    background: var(--k-100);
    clip-path: inset(100% 0 0 0);
  }
  .hub-cta-card__btn--secondary:hover,
  .hub-cta-card__btn--secondary:focus-visible { color: #fff; }
  .hub-cta-card__btn--secondary:hover::after,
  .hub-cta-card__btn--secondary:focus-visible::after {
    clip-path: inset(0 0 0 0);
  }
  @media (prefers-reduced-motion: reduce) {
    .hub-cta-card__btn,
    .hub-cta-card__btn::after { transition: none; }
  }

  /* PROJECTS TEASER */
  .hub-projects-teaser {
    display: grid; grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 16px;
  }
  @media (max-width: 960px) { .hub-projects-teaser { grid-template-columns: repeat(2, minmax(0, 1fr)); } }
  @media (max-width: 600px) { .hub-projects-teaser { grid-template-columns: 1fr; } }
  .hub-teaser-card {
    display: block; padding: 24px 20px;
    border: 1px solid var(--accent-rule);
    border-radius: var(--radius-input);
    text-decoration: none; color: inherit;
    transition: border-color var(--dur-base) var(--ease-decel);
  }
  .hub-teaser-card:hover { border-color: var(--accent); }
  .hub-teaser-card h3 { font-size: 18px; margin: 0 0 8px; }
  .hub-teaser-card p { font-size: 14px; line-height: 1.5; color: var(--fg-muted); margin: 0 0 12px; }
  .hub-teaser-card__cta { font-size: 13px; color: var(--accent); font-weight: 600; }
  .hub-teaser-card--more { background: var(--k-05); }

  /* PLACE */
  .hub-place__grid {
    display: grid; grid-template-columns: 1fr 1.4fr;
    gap: 32px; align-items: center;
  }
  @media (max-width: 720px) { .hub-place__grid { grid-template-columns: 1fr; } }
  .hub-place p {
    font-size: clamp(16px, 1.35vw, 18px); line-height: 1.65;
    max-width: 540px; margin: 16px 0 24px;
    color: var(--fg);
  }
  .hub-place__cta {
    color: var(--accent); font-weight: 600;
    text-decoration: none;
  }
  .hub-place__cta:hover { text-decoration: underline; }
  .hub-place__map img {
    width: 100%; height: auto;
    border: 1px solid var(--border-muted);
    border-radius: var(--radius-input);
    display: block;
  }
  .hub-place__map figcaption {
    font-size: 13px; color: var(--fg-subtle);
    margin-top: 8px;
  }

  /* FAQ MINI */
  .hub-faq-mini {
    padding: 4px 0;
    border-bottom: 1px solid var(--border-muted);
  }
  .hub-faq-mini summary {
    font-weight: 600; cursor: pointer;
    padding: 16px 0; list-style: none;
    font-size: 17px; line-height: 1.4;
    display: flex; align-items: center; gap: 12px;
  }
  .hub-faq-mini summary::-webkit-details-marker { display: none; }
  .hub-faq-mini summary::before {
    content: '+'; display: inline-block;
    width: 16px; text-align: center;
    color: var(--accent);
    transition: transform var(--dur-base) var(--ease-decel);
  }
  .hub-faq-mini[open] summary::before { transform: rotate(45deg); }
  .hub-faq-mini p {
    padding: 0 0 16px 28px;
    line-height: 1.6; color: var(--fg-muted);
    margin: 0;
  }
  .hub-faq-mini__more { margin: 32px 0 0; }
  .hub-faq-mini__more a {
    color: var(--accent); font-weight: 600;
    text-decoration: none;
  }
  .hub-faq-mini__more a:hover { text-decoration: underline; }

  /* MAP STRIP -- full-width Leaflet map under the "Místo" section. */
  .hub-map-strip {
    padding: clamp(48px, 7vw, 80px) var(--gutter);
    max-width: var(--container-wide); margin: 0 auto;
  }
  .hub-map-strip__inner { max-width: var(--container-wide); margin: 0 auto; }
  .hub-map-strip__head { margin-bottom: 24px; max-width: 760px; }
  .hub-map-strip__head .osa-eyebrow { color: var(--accent); display: block; margin-bottom: 8px; }
  .hub-map-strip__heading {
    font-family: var(--font-sans);
    font-size: clamp(24px, 2.6vw, 32px);
    font-weight: 600;
    line-height: 1.15;
    letter-spacing: var(--tracking-tight);
    margin: 0;
    text-wrap: balance;
  }
  .hub-map-strip__frame {
    position: relative;
    width: 100%;
    height: clamp(320px, 44vh, 460px);
    border: 1px solid var(--border-muted);
    border-radius: var(--radius-input);
    overflow: hidden;
    background: var(--k-05);
  }
  .hub-map-strip__address {
    margin: 16px 0 0;
    font-size: 14px; line-height: 1.55; color: var(--fg-muted);
  }
  .hub-map-strip__address strong { color: var(--k-100); font-weight: 600; }
  .hub-map-strip__address a {
    color: var(--accent); font-weight: 600;
    text-decoration: none; margin-left: 12px;
  }
  .hub-map-strip__address a:hover { text-decoration: underline; }

  /* Leaflet brand overrides — shared between landing + /o-arealu/.
     z-index 0 forces the map to create its own stacking context so its
     internal panes (200–800) don't escape above the sticky header (30). */
  :global(.leaflet-container) {
    background: var(--k-05);
    font-family: var(--font-sans);
    z-index: 0;
  }
  :global(.leaflet-control-attribution) {
    background: rgba(255, 255, 255, 0.92) !important;
    color: var(--fg-muted) !important;
    font-size: 10px !important;
    border-top: 1px solid var(--border-muted) !important;
    padding: 2px 8px !important;
  }
  :global(.leaflet-control-attribution a) { color: var(--fg) !important; }
  :global(.leaflet-control-zoom a) {
    background: var(--bg) !important; color: var(--fg-muted) !important;
    border-color: var(--border-muted) !important; font-family: var(--font-sans);
  }
  :global(.leaflet-control-zoom a:hover) {
    background: var(--accent) !important; color: #fff !important;
    border-color: var(--accent) !important;
  }
  :global(.op-map-popup-wrap .leaflet-popup-content-wrapper) {
    background: var(--bg);
    border: 1px solid var(--accent);
    box-shadow: 0 8px 32px rgba(90, 42, 95, 0.18);
    border-radius: var(--radius-input); padding: 0;
  }
  :global(.op-map-popup-wrap .leaflet-popup-tip) { background: var(--bg); border: 1px solid var(--accent); }
  :global(.op-map-popup-wrap .leaflet-popup-content) { margin: 0; width: auto !important; min-width: 200px; }
  :global(.op-map-popup-wrap .leaflet-popup-close-button) { color: var(--fg-subtle) !important; padding: 6px 8px 0 0 !important; }
  :global(.op-map-popup-wrap .leaflet-popup-close-button:hover) { color: var(--accent) !important; }
  :global(.op-map-popup) {
    display: grid; gap: 4px;
    padding: 14px 16px;
    color: var(--k-100);
    font: 500 13px / 1.5 var(--font-sans);
    text-decoration: none; cursor: pointer;
  }
  :global(.op-map-popup strong) { font-weight: 600; color: var(--k-100); letter-spacing: 0.02em; }
  :global(.op-map-popup span) { color: var(--fg-muted); font-size: 12px; }
  :global(.op-map-popup .op-map-popup__cta) { color: var(--accent); font-weight: 600; margin-top: 4px; }

  /* LIGHTBOX -- fullscreen overlay; ESC + arrow-key navigation. */
  .hub-lightbox {
    position: fixed; inset: 0;
    z-index: 60;
    background: rgba(0, 0, 0, 0.92);
    display: flex; align-items: center; justify-content: center;
