  .lp-tile:hover .lp-tile__arrow--cross,
  .lp-tile:focus-visible .lp-tile__arrow--cross {
    transform: translate(2px, -2px);
  }

  /* Ribbon: big background arc, peeká z pod typo (z-index 0) */
  .lp-tile__ribbon {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 0;
    opacity: 0.55;
    transition: opacity 240ms var(--ease-standard), transform 360ms var(--ease-standard);
  }
  .lp-tile__ribbon svg {
    width: 100%;
    height: 100%;
    overflow: visible;
    display: block;
  }
  .lp-tile__ribbon path {
    fill: none;
    stroke: var(--accent);
    stroke-width: 36;
    stroke-linecap: round;
    stroke-linejoin: round;
  }
  .lp-tile--reserve .lp-tile__ribbon path {
