---
import Base from '../layouts/Base.astro';
import { withBase } from '../utils/url';

/* Phase 1 landing: minimální shell. Hero z Site_Copy § 0.1 (H1 + lede),
   primary CTA na rezervaci, sekundární na ubytování, pod tím seznam 8 sekcí.
   Phase 2 dodá hero rotaci (5 záběrů), „Co Hub nabízí" 4 karty se swipe
   galleryí a section teaser bloky. Tier A rendery Huga zatím placeholdery,
   pre-render hero-1.jpg drží místo. */

const heroImage = withBase('/images/hub/hero/hero-1.jpg');

const sections = [
  { path: '/ubytovani/', label: 'Ubytování',  hint: '9 typů pokojů a apartmánů' },
  { path: '/coworking/', label: 'Coworking',  hint: '5 tarifů od volného stolu po dílnu' },
  { path: '/komunita/',  label: 'Komunita',   hint: 'Wellness, sport, gastro, kultura' },
  { path: '/okoli/',     label: 'Okolí',      hint: 'Klecany, 15 km severně od Prahy' },
  { path: '/doprava/',   label: 'Doprava',    hint: 'Hub-shuttle, bus 374, Hub-taxi' },
  { path: '/stipendia/', label: 'Stipendia',  hint: 'Pobytové stipendium 4 role' },
  { path: '/novinky/',   label: 'Novinky',    hint: 'Postup, otevírací termíny, výzvy' },
  { path: '/galerie/',   label: 'Galerie',    hint: 'Fotky a vizualizace areálu' },
];
---
<Base
  title="Startovací Hub Klecany"
  description="Horní kasárny Klecan, otevřené pro bydlení a práci. Devět typů pokojů a apartmánů, coworking, dílny, sauna, společná kuchyně, kavárna. Bývalé vojenské kasárny nad Vltavou, patnáct kilometrů severně od centra Prahy. Areál se otevírá postupně od roku 2026."
  headerVariant="dark">

  <section class="lp-hero">
    <img class="lp-hero__bg" src={heroImage} alt="" aria-hidden="true" loading="eager" decoding="async" />
    <div class="lp-hero__inner">
      <p class="lp-hero__eyebrow">Horní kasárny Klecan</p>
      <h1 class="lp-hero__title">
        Otevřené pro bydlení a práci.
      </h1>
      <p class="lp-hero__lede">
        Devět typů pokojů a apartmánů, od kapsle pro jednoho po byt 5+kk pro skupinu.
        Coworking, dílny, sauna, společná kuchyně, kavárna. Pobytové stipendium dvakrát ročně.
      </p>
      <p class="lp-hero__sub">
        Areál se otevírá postupně od roku 2026. Bývalé vojenské kasárny nad Vltavou,
        patnáct kilometrů severně od centra Prahy.
      </p>
      <div class="lp-hero__cta-row">
        <a class="lp-hero__cta lp-hero__cta--primary" href={withBase('/rezervace/')}>Rezervace</a>
        <a class="lp-hero__cta" href={withBase('/ubytovani/')}>Podívat se na pokoje</a>
      </div>
    </div>
  </section>

  <section class="lp-grid">
    <div class="lp-grid__inner">
      <p class="lp-grid__eyebrow">Co tu je</p>
      <h2 class="lp-grid__title">Osm sekcí.</h2>
      <p class="lp-grid__intro">
        Plné stránky doplňujeme v dalších fázích restrukturalizace.
        Sekce níže fungují jako rozcestník, rezervace běží.
      </p>
      <ul class="lp-grid__list">
        {sections.map((s) => (
          <li class="lp-grid__item">
            <a class="lp-grid__link" href={withBase(s.path)}>
              <span class="lp-grid__label">{s.label}</span>
              <span class="lp-grid__hint">{s.hint}</span>
            </a>
          </li>
        ))}
      </ul>
    </div>
  </section>
</Base>

<style>
  /* Hero, dark, full bleed s photo bg + scrim. */
  .lp-hero {
    position: relative;
    isolation: isolate;
    min-height: 78vh;
    display: grid;
    align-items: end;
    padding: var(--space-9) var(--gutter) var(--space-8);
    color: #fff;
    background: var(--k-100);
    overflow: hidden;
  }
  .lp-hero__bg {
    position: absolute;
    inset: 0;
    width: 100%; height: 100%;
    object-fit: cover;
    z-index: -2;
    filter: brightness(0.7);
  }
  .lp-hero::before {
    content: "";
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to top,
      rgba(0,0,0,0.7) 0%,
      rgba(0,0,0,0.45) 35%,
      rgba(0,0,0,0.05) 75%
    );
    z-index: -1;
  }
  .lp-hero__inner {
    max-width: var(--container);
    margin: 0 auto;
    width: 100%;
  }
  .lp-hero__eyebrow {
    font: 600 var(--text-2xs) / 1 var(--font-sans);
    color: rgba(255,255,255,0.85);
    letter-spacing: var(--tracking-wider);
    text-transform: uppercase;
    margin: 0 0 var(--space-4);
  }
  .lp-hero__title {
    font: 600 clamp(2.5rem, 6vw, 4.5rem) / 1.05 var(--font-sans);
    letter-spacing: var(--tracking-tight);
    margin: 0 0 var(--space-5);
    max-width: 18ch;
  }
  .lp-hero__lede {
    font-size: clamp(1.05rem, 1.6vw, 1.25rem);
    line-height: 1.45;
    margin: 0 0 var(--space-3);
    max-width: 52ch;
    color: rgba(255,255,255,0.95);
  }
  .lp-hero__sub {
    font-size: var(--text-sm);
    line-height: 1.5;
    margin: 0 0 var(--space-6);
    max-width: 52ch;
    color: rgba(255,255,255,0.75);
  }
  .lp-hero__cta-row {
    display: flex;
    gap: var(--space-3);
    flex-wrap: wrap;
  }
  .lp-hero__cta {
    display: inline-flex;
    align-items: center;
    padding: 12px 22px;
    font: 600 var(--text-sm) / 1 var(--font-sans);
    color: #fff;
    border: 1px solid rgba(255,255,255,0.4);
    border-radius: var(--radius-input);
    text-decoration: none;
    transition: background 200ms ease, color 200ms ease, border-color 200ms ease;
  }
  .lp-hero__cta:hover {
    background: #fff;
    color: var(--k-100);
    border-color: #fff;
  }
  .lp-hero__cta--primary {
    background: var(--accent);
    border-color: var(--accent);
  }
  .lp-hero__cta--primary:hover {
    background: #fff;
    color: var(--accent);
  }

  /* Section grid pod hero. */
  .lp-grid {
    padding: var(--space-8) var(--gutter);
    background: var(--bg);
    color: var(--fg);
  }
  .lp-grid__inner {
    max-width: var(--container);
    margin: 0 auto;
  }
  .lp-grid__eyebrow {
    font: 600 var(--text-2xs) / 1 var(--font-sans);
    color: var(--accent);
    letter-spacing: var(--tracking-wider);
    text-transform: uppercase;
    margin: 0 0 var(--space-3);
  }
  .lp-grid__title {
    font: 600 clamp(1.75rem, 3.5vw, 2.5rem) / 1.1 var(--font-sans);
    margin: 0 0 var(--space-4);
    letter-spacing: var(--tracking-tight);
  }
  .lp-grid__intro {
    color: var(--fg-muted);
    margin: 0 0 var(--space-7);
    max-width: 50ch;
    font-size: var(--text-md);
  }
  .lp-grid__list {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 1px;
    background: var(--rule, rgba(0,0,0,0.12));
    border: 1px solid var(--rule, rgba(0,0,0,0.12));
  }
  .lp-grid__item { background: var(--bg); }
  .lp-grid__link {
    display: flex;
    flex-direction: column;
    gap: 6px;
    padding: var(--space-5);
    color: inherit;
    text-decoration: none;
    transition: background 160ms ease, color 160ms ease;
  }
  .lp-grid__link:hover {
    background: var(--accent);
    color: var(--accent-on);
  }
  .lp-grid__link:hover .lp-grid__hint { color: rgba(255,255,255,0.85); }
  .lp-grid__label {
    font: 600 var(--text-lg) / 1.2 var(--font-sans);
    letter-spacing: var(--tracking-tight);
  }
  .lp-grid__hint {
    font-size: var(--text-xs);
    color: var(--fg-muted);
    line-height: 1.4;
  }

  @media (max-width: 1024px) {
    .lp-grid__list { grid-template-columns: repeat(2, minmax(0, 1fr)); }
  }
  @media (max-width: 600px) {
    .lp-grid__list { grid-template-columns: 1fr; }
    .lp-hero { min-height: 70vh; padding-top: var(--space-7); }
  }
</style>
