---
import Base from '../layouts/Base.astro';
import Gallery from '../components/Gallery.astro';
import Icon from '../components/Icon.astro';
import Arrow from '../components/Arrow.astro';
import PriceTable from '../components/PriceTable.astro';
import ResidentBenefits from '../components/ResidentBenefits.astro';
import { getCollection } from 'astro:content';
import { withBase } from '../utils/url';

/* === Srovnávací tabulky (z kolekcí, vždy sedí na reálné varianty) === */
const _sdilene = (await getCollection('sdilenePokoje'))
  .filter((e) => !e.data.hidden)
  .sort((a, b) => a.data.order - b.data.order);
const _privatni = (await getCollection('apartmany'))
  .filter((e) => !e.data.hidden)
  .sort((a, b) => a.data.order - b.data.order);
const _beds = (name) => (/dvojl/i.test(name) ? '2 lůžka' : '1 lůžko');
const sdileneRows = _sdilene.map((e) => {
  const d = e.data;
  const area = (d.spec.plochaKapsle || d.spec.plochaPokoj).split('(')[0].trim();
  return {
    label: d.name,
    note: `${area} · ${_beds(d.name)} · matrace ${d.matrace[0]}`,
    price: d.cena.anchor,
    priceNote: d.pricePending ? 'orientační' : undefined,
    flag: !!d.pricePending,
  };
});
const privatniRows = _privatni.map((e) => {
  const d = e.data;
  return { label: d.name, note: `${d.plocha} · ${d.kapacita} lůžek`, price: d.cena.anchor };
});

/* Phase 2 landing per SH_Web_Site_Copy.md § 0.1 + SH_Web_Visualization_List
   § 1.1 + 1.2. Hero rotace 4 záběrů (Tier A rendery z vault hero-update),
   „Co Hub nabízí" 4 karty s horizontal scroll-snap gallery, section teasery
   pro 8 sekcí, masterplan, finální CTA panel.

   Hero rotace: swipe přes 4 slidy, 5 s na slide, 20 s celkový cyklus.
   `prefers-reduced-motion: reduce` zastaví na slide 1. */

/* === HERO ROTACE (4 záběry) === */
/* Tier A rendery z vault Visualizations/h - Hero/hero-update.
   Každý slide má desktop (landscape) a phone (portrait) variantu,
   <picture> přepíná v zlomu 768 px. */
const heroSlides = [
  {
    desktop: withBase('/images/hub/hero/h00.jpg'),
    phone:   withBase('/images/hub/hero/h00-phone.jpg'),
    alt: 'Startovací Hub Klecany, hero úvod.',
  },
  {
    desktop: withBase('/images/hub/hero/h01.jpg'),
    phone:   withBase('/images/hub/hero/h01-phone.jpg'),
    alt: 'Privátní apartmány v parteru po setmění, lidé před vstupem mezi břízami, teplá světla v oknech.',
  },
  {
    desktop: withBase('/images/hub/hero/h02.jpg'),
    phone:   withBase('/images/hub/hero/h02-phone.jpg'),
    alt: 'Chodba s privátními kapslemi v dřevěném obložení, lavice a rostlina v lounge, tlumené ambientní světlo.',
  },
  {
    desktop: withBase('/images/hub/hero/h03.jpg'),
    phone:   withBase('/images/hub/hero/h03-phone.jpg'),
    alt: 'Vnitřní dvůr areálu za modré hodiny, lidé u dlouhého stolu venku, světla v oknech renovovaných budov.',
  },
  {
    desktop: withBase('/images/hub/hero/h04.jpg'),
    phone:   withBase('/images/hub/hero/h04-phone.jpg'),
    alt: 'Privátní apartmán 1+kk: žena vaří v kuchyni, muž čte u stolu, postel u okna, teplé večerní světlo.',
  },
];

/* === SEKCE ZIG-ZAG (5 řad, one-pager) === */
/* Každá sekce má anchor id pro scroll z tile gridu pod hero. Eyebrow + title +
   lede + CTAs do detail page na jedné straně, gallery na druhé. Sudé řady mají
   gallery vlevo přes :nth-of-type(even) flip. Okolí + Doprava merged do jedné
   sekce s 2 CTAs. */
type GalleryItem =
  | { src: string; alt: string }
  | { placeholder: string; alt: string };
type SectionCta = { href: string; label: string };
type Section = {
  id: string;
  eyebrow: string;
  title: string;
  lede: string;
  ctas: SectionCta[];
  gallery: GalleryItem[];
  /* Bezier d-form pro section ribbon pozadí, viewBox 0 0 1600 600.
     Sudé sekce dostanou scaleX(-1) takže path se zrcadlí, navrhuj path
     s důrazem v levé spodní třetině (negativní prostor pod textem). */
  ribbonPath: string;
};

const sections: Section[] = [
  {
    id: 'ubytovani',
    eyebrow: 'Ubytování',
    title: 'Privátní apartmán, nebo sdílený pokoj?',
    lede: 'Šest formátů sdílených pokojů od otevřeného lůžka po uzamykatelnou kapsli a pět privátních apartmánů 1+kk až 5+kk. V ceně energie, internet, coworkingový sál a pět jízd Hub-shuttle k metru měsíčně.',
    ctas: [{ href: '/ubytovani/', label: 'Možnosti ubytování' }],
    ribbonPath: 'M -80 480 C 120 320, 320 240, 540 360 S 940 520, 1120 380 S 1400 280, 1560 360',
    gallery: [
      { src: withBase('/images/hub/ubytovani/01-kapsle.jpg'), alt: 'Uzamykatelná kapsle, dřevěné obložení a tlumené ambientní světlo.' },
      { src: withBase('/images/hub/ubytovani/02-1kk.jpg'), alt: 'Privátní apartmán 1+kk, postel u okna, kuchyňský kout a jídelní stůl.' },
      { src: withBase('/images/hub/ubytovani/03-ext.jpg'), alt: 'Privátní apartmány v parteru za soumraku, alej bříz, teplá světla v oknech.' },
      { src: withBase('/images/hub/ubytovani/04-int.jpg'), alt: 'Interiér privátního apartmánu, večerní atmosféra s teplým světlem.' },
      { src: withBase('/images/hub/ubytovani/05-4kk-family.jpg'), alt: 'Privátní apartmán 4+kk: rodina v obývacím pokoji s otevřenou kuchyní, dlouhý jídelní stůl pro osm.' },
    ],
  },
  {
    id: 'zazemi',
    eyebrow: 'Zázemí',
    title: 'Gastronomie, wellness, coworking, komunita.',
    lede: 'Kantýna, pekárna a restaurace, venkovní bazén a sauny, coworkingový sál s dílnami a komunitní park se zahrádkami. Většina zázemí je pro ubytované v ceně nebo za zvýhodněnou sazbu, část otevřená i návštěvníkům.',
    ctas: [{ href: '/zazemi/', label: 'Celé zázemí Hubu' }],
    ribbonPath: 'M -60 380 C 180 460, 360 220, 580 380 S 960 540, 1140 360 S 1380 220, 1560 360',
    gallery: [
      { src: withBase('/images/hub/komunita/01-bazen.jpg'), alt: 'Venkovní bazén v jádře areálu, sluneční terasa, relax po práci.' },
      { src: withBase('/images/hub/komunita/gastro/01-kantyna.jpg'), alt: 'Kantýna v kuchyňském bloku B, dřevěné stoly.' },
      { src: withBase('/images/hub/coworking/cowork-interier-sal-c.jpg'), alt: 'Coworkingový sál v budově C s pódiem a kuchyňským koutem.' },
      { src: withBase('/images/hub/komunita/05-komunitni-zahrady.jpg'), alt: 'Komunitní zahrádky v parku, sezónní záhony pro rezidenty.' },
    ],
  },
  {
    id: 'doprava',
    eyebrow: 'Doprava',
    title: 'Na prahu metropole.',
    lede: 'Hub-shuttle k metru Kobylisy, sdílená elektrokola a auta, lokální taxi. Pět jízd shuttle a jednu jízdu taxi máte měsíčně v ceně. Cyklostezka EuroVelo 7 podél Vltavy deset minut na kole.',
    ctas: [{ href: '/doprava/', label: 'Dopravní dostupnost' }],
    ribbonPath: 'M -80 460 C 180 300, 380 460, 600 340 S 980 460, 1160 380 S 1380 280, 1560 380',
    gallery: [
      { src: withBase('/images/hub/okoli/01-areal-dostupnost.jpg'), alt: 'Mapa dostupnosti areálu, vzdálenosti na metro a do centra Prahy.' },
      { src: withBase('/images/hub/doprava/cyklostezka.jpg'), alt: 'Cyklostezka EuroVelo 7 podél Vltavy z Prahy do Klecan.' },
      { src: withBase('/images/hub/doprava/hub-shuttle-zastavka.jpg'), alt: 'Zastávka Hub-shuttle v areálu.' },
      { src: withBase('/images/hub/okoli/04-topview-update.jpg'), alt: 'Letecký pohled na areál Horních kasáren a obec Klecany.' },
    ],
  },
  {
    id: 'stipendia',
    eyebrow: 'Stipendia',
    title: 'Bydlení a tvorba za přínos komunitě.',
    lede: 'Pobytové stipendium pro lidi s projektem a projektové stipendium na materiál a dílenský čas. Bydlení nebo zvýhodněná cena za konkrétní vstup do života Hubu. Při registraci zaškrtnete zájem a ozveme se s podmínkami.',
    ctas: [{ href: '/stipendia/', label: 'Pobytová a projektová stipendia' }],
    ribbonPath: 'M -60 420 C 160 540, 380 260, 600 400 S 960 520, 1140 380 S 1380 240, 1560 380',
    gallery: [
      { src: withBase('/images/hub/stipendia/01-atelier.jpg'), alt: 'Ateliér s rezidentem-tvůrcem v práci, denní světlo, velký stůl.' },
      { src: withBase('/images/hub/stipendia/02-rezident.jpg'), alt: 'Rezident u rozdělané práce, soustředění v denním světle.' },
      { src: withBase('/images/hub/stipendia/03-rezidenti.jpg'), alt: 'Skupina rezidentů u společného stolu, plánování nebo večeře.' },
    ],
  },
  {
    id: 'galerie',
    eyebrow: 'Galerie',
    title: 'Podívejte se dovnitř.',
    lede: 'Fotografie a vizualizace ubytování, coworkingu, gastronomie a okolí areálu. Část snímků jsou rendery, reálné fotky průběžně doplňujeme.',
    ctas: [{ href: '/galerie/', label: 'Otevřít galerii' }],
    ribbonPath: 'M -80 520 C 140 360, 360 480, 580 340 S 940 460, 1140 380 S 1380 280, 1560 360',
    gallery: [
      { src: withBase('/images/hub/ubytovani/privatni/03-ext.jpg'), alt: 'Exteriér obytné budovy za soumraku.' },
      { src: withBase('/images/hub/coworking/cowork-interier-sal-c.jpg'), alt: 'Coworkingový sál v budově C.' },
      { src: withBase('/images/hub/komunita/wellness/wellness-01-bazen.jpg'), alt: 'Venkovní bazén v areálu.' },
      { src: withBase('/images/hub/areal/areal-entry.jpg'), alt: 'Vstup do areálu Horních kasáren.' },
    ],
  },
  {
    id: 'vice',
    eyebrow: 'Ceník a novinky',
    title: 'Ceny a novinky na jednom místě.',
    lede: 'Srovnání cen všech formátů ubytování i rezervovatelného zázemí v jednom přehledu. Novinky o spuštění rezervací a postupu rekonstrukce připravujeme.',
    ctas: [
      { href: '/cenik/',   label: 'Ceník' },
      { href: '/novinky/', label: 'Novinky' },
    ],
    ribbonPath: 'M -80 460 C 180 300, 380 460, 600 340 S 980 460, 1160 380 S 1380 280, 1560 380',
    gallery: [
      { src: withBase('/images/hub/areal/masterplan_update.jpg'), alt: 'Masterplán areálu Horních kasáren.' },
      { src: withBase('/images/hub/areal/building-c.jpg'), alt: 'Budova C v areálu.' },
    ],
  },
];

/* === RIBBON TILES (pod hero) ===
   Pět scroll dlaždic + Rezervace tile (6 celkem, 3×2 grid). Vizuální jazyk
   sjednocen s CrossLinkPair komponentou: 4 varianty (deep, cream, rose, ink)
   rotují tak aby žádné dva sousedy neměly stejnou. Eyebrow (uppercase small caps)
   + bold title, vpravo dole 36×36 kruhová šipka. Ribbon arc zůstává v pozadí. */
/* Tile variant zigzag: 1, 3, 5 cream + 2, 4, 6 ink. Stejný ribbon stroke
   napříč ink tiles, stejný ribbon stroke napříč cream tiles. */
const tiles = [
  { eyebrow: 'Apartmány, kapsle, lůžka',     title: 'Ubytování', href: '#ubytovani', variant: 'cream',
    path: 'M 60 240 C 220 100, 380 320, 540 200 C 660 100, 720 260, 760 340' },
  { eyebrow: 'Gastro, wellness, coworking',  title: 'Zázemí',    href: '#zazemi',    variant: 'ink',
    path: 'M 80 120 C 240 280, 400 80, 560 240 C 680 360, 740 200, 760 320' },
  { eyebrow: 'Shuttle, kolo, taxi',          title: 'Doprava',   href: '#doprava',   variant: 'cream',
    path: 'M 80 200 C 240 80, 420 280, 580 160 C 700 80, 740 240, 760 320' },
  { eyebrow: 'Pobyt za projekt',             title: 'Stipendia', href: '#stipendia', variant: 'ink',
    path: 'M 60 240 C 200 100, 380 320, 520 200 C 660 80, 740 240, 760 360' },
  { eyebrow: 'Fotky a vizualizace',          title: 'Galerie',   href: '#galerie',   variant: 'cream',
    path: 'M 80 200 C 200 360, 420 80, 580 240 C 700 360, 740 200, 760 100' },
];
---
<Base
  title="Startovací Hub Klecany · Bydlení a coworking 15 min od Prahy"
  description="Devět typů bydlení od sdíleného lůžka po byt 5+kk, coworking, dílny, sauna a kavárna. Horní kasárna Klecany, patnáct minut autobusem od metra Kobylisy. Od 3 000 Kč měsíčně, energie a internet v ceně."
  headerVariant="overlay">

  {/* ============ HERO ROTATION ============ */}
  <section class="lp-hero" data-hero-mode="video" aria-label="Startovací Hub Klecany, hero galerie">
    <div class="lp-hero__rotation" aria-hidden="true">
      {heroSlides.map((slide, i) => (
        <div class="lp-hero__slide" data-slide={i} style={`animation-delay: ${i * 5 - 1}s`}>
          <picture>
            <source media="(max-width: 768px)" srcset={slide.phone} />
            <img class="lp-hero__bg" src={slide.desktop} alt={slide.alt} loading={i === 0 ? 'eager' : 'lazy'} decoding="async" fetchpriority={i === 0 ? 'high' : undefined} />
          </picture>
        </div>
      ))}
    </div>
    {/* Video varianta: skrytá defaultně, JS přepíná na data-hero-mode="video".
        Browser load only on demand (preload="none" + lazy src set via JS) aby
        prefence „slides" měla žádný bandwidth overhead. */}
    <video
      class="lp-hero__video"
      data-hero-video
      data-src-desktop={withBase('/videos/hero-reel-1.mov')}
      data-src-phone={withBase('/videos/hero-reel-1-phone.mov')}
      muted
      loop
      playsinline
      preload="auto"
      aria-hidden="true"></video>
    <div class="lp-hero__scrim" aria-hidden="true"></div>

    <div class="lp-hero__inner">
      <h1 class="lp-hero__title">Bydlení a tvorba na prahu metropole.</h1>
      <p class="lp-hero__lede">Energie a internet v ceně, coworking a sauna v areálu.</p>
    </div>

    {/* Tři rychlá CTA do rezervačního formuláře s předvyplněnou cestou.
        Desktop: full-width pruh u spodního okraje hero, zarovnaný na content
        edge (stejná šířka jako header bar). Mobil/tablet: in-flow pod textem. */}
    <div class="lp-hero__quick">
      <a class="lp-hero__quick-btn osa-nolink" href={withBase('/rezervace/?cesta=luzko')}>Rezervovat lůžko</a>
      <a class="lp-hero__quick-btn osa-nolink" href={withBase('/rezervace/?cesta=apartman')}>Rezervovat apartmán</a>
      <a class="lp-hero__quick-btn osa-nolink" href={withBase('/rezervace/?cesta=stipendium')}>Požádat o&nbsp;stipendium</a>
    </div>

    {/* Scroll cue: kruhový button s chevron-down, jemně poskakuje + pulsing ring,
        klik smooth-scrolluje na jump strip pod hero. */}
    <a class="lp-hero__scroll-cue osa-nolink" href="#lp-jumps" aria-label="Skrolovat na možnosti">
      <Icon name="chevron-down" size={24} strokeWidth={2} />
    </a>
  </section>

  <script is:inline>
    /* Hero video: default loop reel. Uživatelé s prefers-reduced-motion: reduce
       dostanou statické slides (bez autoplaying motion). Žádný toggle, žádný
       localStorage. Video src se nastaví lazily podle viewportu. */
    (function () {
      if (window.__hubHeroVideoBound) return;
      window.__hubHeroVideoBound = true;
      function bind() {
        var hero = document.querySelector('.lp-hero');
        var video = document.querySelector('[data-hero-video]');
        if (!hero || !video) return;
        if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
          hero.dataset.heroMode = 'slides';
          return;
        }
        hero.dataset.heroMode = 'video';
        if (!video.src) {
          var isPhone = window.matchMedia('(max-width: 768px)').matches;
          video.src = isPhone ? video.dataset.srcPhone : video.dataset.srcDesktop;
        }
        video.play().catch(function () {});
      }
      document.addEventListener('astro:page-load', bind);
    }());
  </script>

  {/* Tile grid POD hero (3×2). Pět scroll-anchor dlaždic + Rezervace tile
      jako šestá. Každá dlaždice má velký ribbon arc jako pozadí (peeká z
      pod typo), per spec § 04 banner influence (plakátovější vibe). */}
  <section class="lp-tiles" id="lp-jumps" aria-label="Skok do sekcí">
    <div class="lp-tiles__grid">
      {tiles.map((t) => (
        <a class={`lp-tile lp-tile--${t.variant} osa-nolink`} href={t.href}>
          <span class="lp-tile__ribbon" aria-hidden="true" data-ribbon-reveal>
            <svg viewBox="0 0 800 600" preserveAspectRatio="xMidYMid slice">
              <path d={t.path} />
            </svg>
          </span>
          <span class="lp-tile__type">
            <span class="lp-tile__eyebrow">{t.eyebrow}</span>
            <span class="lp-tile__title" set:html={t.title} />
          </span>
          {/* Šipka v 36×36 kruhu, chevron-down = scroll v rámci stránky. */}
          <span class="lp-tile__arrow" aria-hidden="true">
            <Icon name="chevron-down" size={18} strokeWidth={2} />
          </span>
        </a>
      ))}

      <a class="lp-tile lp-tile--reserve osa-nolink" href={withBase('/rezervace/')}>
        <span class="lp-tile__ribbon" aria-hidden="true" data-ribbon-reveal>
          <svg viewBox="0 0 800 600" preserveAspectRatio="xMidYMid slice">
            <path d="M 540 80 C 720 100, 760 240, 600 320 C 460 400, 380 280, 540 200" />
          </svg>
        </span>
        <span class="lp-tile__pulse" aria-hidden="true"></span>
        <span class="lp-tile__type">
          <span class="lp-tile__eyebrow">Nezávazná rezervace</span>
          <span class="lp-tile__title">Rezervujte si&nbsp;místo</span>
        </span>
        <span class="lp-tile__arrow lp-tile__arrow--filled" aria-hidden="true">
          <Icon name="arrow-right" size={18} strokeWidth={2} />
        </span>
      </a>
    </div>
  </section>

  {/* ============ ZIG-ZAG SEKCE (5 řad, one-pager) ============ */}
  <div class="lp-sections">
    {sections.map((sec) => (
      <>
        <section class="lp-section" id={sec.id} aria-labelledby={`${sec.id}-title`}>
          <span class="lp-section__ribbon" aria-hidden="true" data-ribbon-reveal>
            <svg viewBox="0 0 1600 600" preserveAspectRatio="xMidYMid slice">
              <path d={sec.ribbonPath} vector-effect="non-scaling-stroke" />
            </svg>
          </span>
          <div class="lp-section__inner">
            <div class="lp-section__text" data-reveal>
              <p class="lp-section__eyebrow">{sec.eyebrow}</p>
              <h2 class="lp-section__title" id={`${sec.id}-title`}>{sec.title}</h2>
              <p class="lp-section__lede">{sec.lede}</p>
              <div class="lp-section__ctas">
                {sec.ctas.map((cta) => (
                  <a class="lp-section__cta osa-nolink" href={withBase(cta.href)}>
                    <span class="lp-section__cta-label">{cta.label}</span>
                    <Arrow dir="right" variant="chevron" size={16} weight={2.4} class="lp-section__cta-arrow" />
                  </a>
                ))}
              </div>
            </div>
            <div class="lp-section__media" data-reveal data-reveal-delay="1">
              <Gallery images={sec.gallery} ariaLabel={sec.eyebrow} aspectRatio="4 / 3" />
            </div>
          </div>

          {sec.id === 'ubytovani' && (
            <div class="lp-summary">
              {/* Dvě srovnávací tabulky generované z kolekcí (sdílené pokoje +
                  privátní apartmány). Nahrazují dřívější náhledové karty. */}
              <a class="lp-summary__card-link osa-nolink lp-summary__card-link--coliving" href={withBase('/ubytovani/sdilene-pokoje/')}>
                <article class="lp-summary__card lp-summary__card--coliving" aria-labelledby="lp-summary-coliving-h">
                  <header class="lp-summary__head">
                    <h3 class="lp-summary__h" id="lp-summary-coliving-h">Sdílené pokoje</h3>
                  </header>
                  <PriceTable rows={sdileneRows} caption="Anchor cena za měsíc" />
                  <span class="lp-summary__cta">
                    <span class="lp-summary__cta-label">Zobrazit sdílené pokoje</span>
                    <Arrow dir="right" variant="chevron" size={15} weight={2.4} class="lp-summary__cta-arrow" />
                  </span>
                </article>
              </a>

              <a class="lp-summary__card-link osa-nolink lp-summary__card-link--privatni" href={withBase('/ubytovani/privatni/')}>
                <article class="lp-summary__card lp-summary__card--privatni" aria-labelledby="lp-summary-privatni-h">
                  <header class="lp-summary__head">
                    <h3 class="lp-summary__h" id="lp-summary-privatni-h">Privátní apartmány</h3>
                  </header>
                  <PriceTable rows={privatniRows} caption="Anchor cena za celý byt" />
                  <span class="lp-summary__cta">
                    <span class="lp-summary__cta-label">Zobrazit apartmány</span>
                    <Arrow dir="right" variant="chevron" size={15} weight={2.4} class="lp-summary__cta-arrow" />
                  </span>
                </article>
              </a>
            </div>
          )}

          {sec.id === 'ubytovani' && (
            <div class="lp-section__benefits">
              <ResidentBenefits eyebrow={false} />
            </div>
          )}

        </section>
      </>
    ))}
  </div>

  {/* ============ FINÁLNÍ CTA BANNER ============
       SH/07 ribbon banner styling (plum-deep + plum stroke). Contained,
       ne full-bleed, žije uvnitř container-wide stejně jako landing sekce.
       Pod ním footer (plum-deep), čímž celý spodek zaplaví plum. */}
  <section class="lp-cta-wrap" aria-label="Závěrečná výzva k registraci">
    <a class="lp-cta-banner osa-nolink" href={withBase('/rezervace/')} data-ribbon-reveal>
      <span class="lp-cta-banner__bg" aria-hidden="true">
        <svg viewBox="0 0 2100 700" preserveAspectRatio="xMidYMid slice">
          <path d="M 1280 80 C 1580 140, 1900 320, 1920 520 C 1940 680, 1600 720, 1460 540" />
        </svg>
      </span>
      <span class="lp-cta-banner__type">
        <span class="lp-cta-banner__eyebrow">Rezervace</span>
        <span class="lp-cta-banner__h">Rezervujte si <em>místo</em>.</span>
        <span class="lp-cta-banner__lede">
          Vyberete pokoj, termín a způsob kontaktu. Z rezervačního oddělení vám zavoláme do 24 hodin.
        </span>
      </span>
      <span class="lp-cta-banner__cta">
        <span>Nezávazná rezervace</span>
        <Arrow dir="right" variant="chevron" size={16} weight={2.4} />
      </span>
    </a>
  </section>
</Base>

<style>
  /* ============ HERO ROTATION ============ */
  /* 4 slides absolutely overlapped, 20 s cyklus, 5 s na slide,
     swipe 1 s. animation-delay posunuje každý slide v cyklu. */
  .lp-hero {
    position: relative;
    isolation: isolate;
    /* Full-screen na desktop i mobile. dvh = dynamic viewport height,
       řeší iOS Safari URL bar bez jumping při scrollu. Fallback vh pro
       starší prohlížeče. Header je position: fixed (overlay variant),
       takže hero může jít plně pod něj. Horizontální gutter je na
       __inner aby content alignoval s header bar pattern (max-width +
       padding-x + margin auto).
       Background image fallback (h00 desktop): vyplní hero okamžitě
       z CSS než se IMG slide dolaďí, žádný plum-deep flash při cold
       reload. Slide carousel se layeruje navrch přes z-index -2. */
    min-height: 100vh;
    min-height: 100dvh;
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: var(--space-9) 0;
    color: #fff;
    background-color: var(--plum-deep);
    background-image: url('/sh-web/images/hub/hero/h00.jpg');
    background-size: cover;
    background-position: center;
    overflow: hidden;
  }
  @media (max-width: 768px) {
    .lp-hero { background-image: url('/sh-web/images/hub/hero/h00-phone.jpg'); }
  }
  .lp-hero__rotation {
    position: absolute;
    inset: 0;
    z-index: -2;
  }
  /* Video varianta: skrytá defaultně. Přepnutí přes data-hero-mode="video"
     na .lp-hero. Video pokrývá celou plochu (object-fit cover) jako slides.
     Slides rotation skryta, video viditelné. */
  .lp-hero__video {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    z-index: -2;
    display: none;
    pointer-events: none;
    filter: brightness(0.87);
  }
  .lp-hero[data-hero-mode="video"] .lp-hero__rotation { display: none; }
  .lp-hero[data-hero-mode="video"] .lp-hero__video { display: block; }
  /* Video režim překryje i CSS background-image fallback (h00.jpg). */
  .lp-hero[data-hero-mode="video"] {
    background-image: none;
  }
  /* Tři rychlá CTA pod hero lede textem: lůžko, apartmán, stipendium.
     Sjednocený glass-morph styling, jednořádkové bez podtextu. */
  .lp-hero__quick {
    /* Width pattern: matches header bar + tile grid (container-wide, gutter-aware). */
    width: calc(100% - 2 * var(--gutter));
    max-width: var(--container-wide);
    margin: var(--space-5) auto 0;
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
  }
  .lp-hero__quick-btn {
    display: inline-flex;
    align-items: center;
    padding: 10px 18px;
    font: 600 var(--text-sm) / 1.1 var(--font-sans);
    letter-spacing: var(--tracking-tight);
    border-radius: var(--radius-input);
    border: 1px solid rgba(255, 255, 255, 0.55);
    background: rgba(255, 255, 255, 0.08);
    color: #fff;
    text-decoration: none;
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    transition:
      background 220ms ease,
      border-color 220ms ease,
      color 220ms ease,
      transform 220ms cubic-bezier(0.32, 0.72, 0, 1);
  }
  .lp-hero__quick-btn:hover,
  .lp-hero__quick-btn:focus-visible {
    background: #fff;
    color: var(--plum-deep);
    border-color: #fff;
    transform: translateY(-1px);
    outline: none;
  }
  /* Desktop: tři CTA jako full-width pruh u spodní hrany hero, centrovaný na
     content edge (stejná šířka jako header bar). Tlačítka mají rovný díl šířky
     a větší, h3-ish font. Sedí nad scroll-cue chevronem. */
  @media (min-width: 769px) {
    /* Hero text mírně níž ke středu (klient: posunout trošku níž). */
    .lp-hero__inner {
      transform: translateY(-2vh);
    }
    .lp-hero__quick {
      position: absolute;
      left: var(--gutter);
      right: var(--gutter);
      bottom: clamp(96px, 12vh, 140px);
      margin: 0 auto;
      flex-wrap: nowrap;
      justify-content: space-between;
      gap: clamp(20px, 3vw, 56px);
    }
    .lp-hero__quick-btn {
      /* Rovná šířka (mezi obsahem a full-third) → symetrie, prostřední
         tlačítko sedí přesně na střed = zarovnané se scroll-cue šipkou.
         Klient: výraznější a větší , bump font, padding, weight i šířka. */
      flex: 0 1 auto;
      width: clamp(230px, 21vw, 320px);
      justify-content: center;
      text-align: center;
      padding: clamp(14px, 1.3vw, 18px) 24px;
      font-weight: 700;
      font-size: clamp(1rem, 1.25vw, 1.1875rem);
      line-height: 1.15;
    }
  }
  @media (max-width: 540px) {
    /* Mobile: úzká vertikální řada nalevo, ne full-width. Tlačítka jen tak
     * široká kolik vyžaduje text + minimal padding , čitelné ale subtle. */
    .lp-hero__quick {
      flex-direction: column;
      align-items: flex-start;
      gap: 8px;
    }
    .lp-hero__quick-btn {
      width: auto;
      align-self: flex-start;
      padding: 7px 14px;
      font-size: 0.8125rem;
    }
  }
  /* 5 slidů jako horizontal carousel: 4 s nehybný hold, pak 1 s swipe
     celé fotky doleva. Sousední slide zároveň zprava vplouvá dovnitř,
     takže přechod je jeden plynulý sweep bez cross-fade.
     Slide N animation-delay = N × 5 s. Slide 0 (h00) má delay 0,
     swipne-in jako první při page loadu (krátká 1 s brand-deep
     opona předtím než h00 vplouvá zprava).
     Smyčka 25 s (5 × 5 s). Keyframes: swipe-in 4 %, hold 4 až 20 %,
     swipe-out 20 až 24 %. */
  .lp-hero__slide {
    position: absolute;
    inset: 0;
    transform: translateX(100%);
    animation: lp-hero-swipe 25s cubic-bezier(0.65, 0, 0.35, 1) infinite;
    will-change: transform;
  }

  @keyframes lp-hero-swipe {
    0%   { transform: translateX(100%); }
    4%   { transform: translateX(0); }
    20%  { transform: translateX(0); }
    24%  { transform: translateX(-100%); }
    100% { transform: translateX(-100%); }
  }

  /* Brightness 0.87 (~13 % ztmavení) , hero video/fotka o kus tmavší pro
     atmosféru a čitelnost bílého copy. Scrim ztlumený v dolních pixelech
     (60→30 %) ať atmosféra fotky proteče. */
  .lp-hero__bg {
    position: absolute;
    inset: 0;
    width: 100%; height: 100%;
    object-fit: cover;
    filter: brightness(0.87);
  }
  .lp-hero__scrim {
    position: absolute;
    inset: 0;
    /* Dvě vrstvy: top scrim pro čitelnost menu nad video bg + bottom scrim
       pro čitelnost hero title/lede. Stack: top gradient zhasne na 35 %,
       bottom gradient nabíhá od 70 %, mezi nimi čistá fotka/video. */
    background:
      linear-gradient(
        to bottom,
        rgba(0,0,0,0.4) 0%,
        rgba(0,0,0,0.18) 18%,
        rgba(0,0,0,0) 35%
      ),
      linear-gradient(
        to top,
        rgba(0,0,0,0.6) 0%,
        rgba(0,0,0,0.3) 35%,
        rgba(0,0,0,0) 70%
      );
    z-index: -1;
  }
  .lp-hero__inner {
    /* Width pattern: matches tile grid edge (1480 max, gutter-aware). */
    width: calc(100% - 2 * var(--gutter));
    max-width: var(--container-wide);
    margin: 0 auto;
    text-align: left;
  }
  .lp-hero__title {
    font: 600 clamp(1.625rem, 4.2vw, 2.875rem) / 1.18 var(--font-sans);
    letter-spacing: var(--tracking-tight);
    margin: 0 0 var(--space-4);
    max-width: 22ch;
    text-wrap: balance;
  }
  .lp-hero__lede {
    font: 600 clamp(1rem, 1.25vw, 1.25rem) / 1.45 var(--font-sans);
    letter-spacing: var(--tracking-wide);
    margin: 0;
    color: rgba(255,255,255,0.92);
    max-width: 36ch;
  }

  /* === SCROLL CUE === */
  /* Kruhový button dole na hero, který smooth-scrolluje na jump strip.
     Glass-morph styling (blur + transparent), uvnitř bouncing chevron,
     kolem subtle pulsing ring jako delight cue. */
  .lp-hero__scroll-cue {
    position: absolute;
    bottom: clamp(20px, 4vh, 36px);
    left: 50%;
    transform: translateX(-50%);
    width: 48px;
    height: 48px;
    border-radius: 999px;
    border: 1.5px solid rgba(255, 255, 255, 0.55);
    background: rgba(0, 0, 0, 0.22);
    color: #fff;
    display: grid;
    place-items: center;
    text-decoration: none;
    cursor: pointer;
    backdrop-filter: blur(6px);
    -webkit-backdrop-filter: blur(6px);
    transition: border-color 220ms ease, background 220ms ease, transform 220ms cubic-bezier(0.2, 0, 0, 1);
    z-index: 1;
  }
  .lp-hero__scroll-cue::before {
    /* Subtle pulse ring, drží rytmus s bounce uvnitř. */
    content: '';
    position: absolute;
    inset: -6px;
    border-radius: 999px;
    border: 1px solid rgba(255, 255, 255, 0.45);
    opacity: 0;
    animation: lp-hero-cue-ping 2.6s cubic-bezier(0.4, 0, 0.2, 1) infinite;
    pointer-events: none;
  }
  .lp-hero__scroll-cue :global(svg) {
    display: block;
    animation: lp-hero-cue-bounce 2.6s cubic-bezier(0.4, 0, 0.2, 1) infinite;
  }
  .lp-hero__scroll-cue:hover,
  .lp-hero__scroll-cue:focus-visible {
    border-color: #fff;
    background: rgba(255, 255, 255, 0.18);
    transform: translateX(-50%) translateY(2px);
    outline: none;
  }
  .lp-hero__scroll-cue:hover :global(svg),
  .lp-hero__scroll-cue:focus-visible :global(svg) {
    animation-play-state: paused;
  }
  @keyframes lp-hero-cue-bounce {
    0%, 20%, 100% { transform: translateY(0); }
    50%          { transform: translateY(5px); }
    70%          { transform: translateY(0); }
  }
  @keyframes lp-hero-cue-ping {
    0%   { opacity: 0.7; transform: scale(1); }
    70%  { opacity: 0;   transform: scale(1.45); }
    100% { opacity: 0;   transform: scale(1.45); }
  }

  /* reduced-motion: freeze on slide 0, vypnout cue animace */
  @media (prefers-reduced-motion: reduce) {
    .lp-hero__slide { animation: none; transform: translateX(-100%); }
    .lp-hero__slide[data-slide="0"] { transform: translateX(0); }
    .lp-hero__scroll-cue :global(svg),
    .lp-hero__scroll-cue::before { animation: none; }
    .lp-hero__scroll-cue::before { opacity: 0; }
  }

  /* ============ TILE GRID (3×2, pod hero) ============
     Pět scroll-anchor dlaždic + Rezervace tile jako šestá. Velký ribbon arc
     na pozadí (z-index 0, peeká z pod typo), typo zaplňuje plochu. Variant
     fill drží light na landingu (cream/soft) protože foto v sekcích níže
     potřebují bílé pozadí, výraznější colorize jde do subpage hero.
     Per spec § 04 banner influence, plakátový styl bez čísel. */
  .lp-tiles {
    background: var(--bg);
    padding: var(--space-6) 0 var(--space-7);
    border-bottom: 1px solid var(--border-muted);
    scroll-margin-top: 80px;
  }
  /* Mobile: ribbon wave nad první sekcí dělá visual break sám,
   * 1px linka pod ní vypadá redundantně. Desktop ji drží jako jemný rule. */
  @media (max-width: 540px) {
    .lp-tiles { border-bottom: 0; }
  }
  .lp-tiles__grid {
    /* Stejný width pattern jako zbytek obsahu webu (header bar, lp-section,
       footer): container-wide se 2× gutter padding. Tile karty mírně užší
       díky větší mezeře v gridu. */
    width: calc(100% - 2 * var(--gutter));
    max-width: var(--container-wide);
    margin: 0 auto;
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: clamp(16px, 2.4vw, 32px);
  }

  /* Tile, mirror cross-link card: 1fr auto grid (text left, arrow circle right),
     align-items end, min-height clamp, padding clamp, border-radius input, ribbon
     arc v pozadí z-index 0, isolation isolate pro bezpečný stacking context. */
  .lp-tile {
    position: relative;
    display: grid;
    grid-template-columns: 1fr auto;
    gap: clamp(16px, 2vw, 24px);
    align-items: end;
    min-height: clamp(140px, 16vw, 200px);
    padding: clamp(20px, 2.4vw, 28px) clamp(22px, 2.4vw, 32px);
    border-radius: var(--radius-input);
    text-decoration: none !important;
    overflow: hidden;
    isolation: isolate;
    transition:
      transform 320ms var(--ease-quart),
      box-shadow 320ms var(--ease-quart);
  }

  /* Varianty zrcadlí cross-link: deep (plum bg + bílý text), cream (kremový bg
     s tenkým accent borderem), rose (rose bg + plum text), ink (plum bg + cream
     text). Eyebrow color + ribbon stroke per varianta. */
  .lp-tile--deep  { background: var(--plum-deep); color: #fff; }
  .lp-tile--cream { background: var(--cream); color: var(--fg); border: 1px solid var(--accent-rule); }
  .lp-tile--rose  { background: var(--rose); color: var(--plum-deep); }
  .lp-tile--ink   { background: var(--plum-deep); color: var(--cream); }
  /* Rezervace tile: CTA varianta s gradient pozadím (plum-deep → rose tint),
     výraznější titulkem a pulse dot indikátorem. Vizuálně nejnápadnější
     ze všech 6 tilů, je to primární konverze celé landing. */
  .lp-tile--reserve {
    background:
      radial-gradient(circle at 90% 110%, hsl(calc(var(--hue) + 44) 30% 70% / 0.32) 0%, transparent 55%),
      linear-gradient(135deg, hsl(var(--hue) 41% 13%) 0%, hsl(var(--hue) 36% 22%) 100%);
    color: #fff;
    box-shadow: 0 6px 24px hsl(var(--hue) 41% 13% / 0.18);
  }
  .lp-tile--reserve .lp-tile__eyebrow { color: var(--rose); }
  /* Title font-size dědí ze .lp-tile__title (sjednocený s ostatními tily),
   * jen color override na bílou pro kontrast s plum-deep bg. */
  .lp-tile--reserve .lp-tile__title { color: #fff; }
  .lp-tile--reserve .lp-tile__ribbon path { stroke: var(--rose); stroke-width: 28; }
  /* Pulse dot, 8 px vlevo nahoře, jemný breathing pulse pro „live" cue. */
  .lp-tile__pulse {
    position: absolute;
    top: clamp(16px, 2vw, 22px);
    right: clamp(16px, 2vw, 22px);
    width: 10px;
    height: 10px;
    border-radius: 999px;
    background: var(--rose);
    z-index: 2;
    box-shadow: 0 0 0 0 hsl(calc(var(--hue) + 44) 30% 70% / 0.7);
    animation: lp-tile-pulse 2.4s ease-out infinite;
  }
  @keyframes lp-tile-pulse {
    0%   { box-shadow: 0 0 0 0 hsl(calc(var(--hue) + 44) 30% 70% / 0.6); }
    70%  { box-shadow: 0 0 0 12px hsl(calc(var(--hue) + 44) 30% 70% / 0); }
    100% { box-shadow: 0 0 0 0 hsl(calc(var(--hue) + 44) 30% 70% / 0); }
  }
  /* Arrow filled: na rezervace tile už defaultně vyplněný kruh rose s plum-deep
     ikonou. Hover: scale + slide right. */
  .lp-tile__arrow--filled {
    background: var(--rose);
    border-color: var(--rose);
    opacity: 1;
    color: var(--plum-deep);
  }
  .lp-tile__arrow--filled :global(svg) { color: var(--plum-deep); }
  .lp-tile--reserve:hover .lp-tile__arrow--filled,
  .lp-tile--reserve:focus-visible .lp-tile__arrow--filled {
    background: #fff;
    border-color: #fff;
    transform: translateX(4px) scale(1.05);
  }
  @media (prefers-reduced-motion: reduce) {
    .lp-tile__pulse { animation: none; }
  }

  /* Type stack vlevo, bottom-aligned (grid align-items end). */
  .lp-tile__type {
    position: relative;
    z-index: 2;
    display: flex;
    flex-direction: column;
    gap: 6px;
    max-width: 28ch;
    min-width: 0;
  }
  .lp-tile__eyebrow {
    font: 500 var(--text-2xs) / 1 var(--font-sans);
    letter-spacing: var(--tracking-wider);
    text-transform: uppercase;
  }
  .lp-tile--deep .lp-tile__eyebrow  { color: var(--rose); }
  .lp-tile--cream .lp-tile__eyebrow { color: var(--accent); }
  .lp-tile--rose .lp-tile__eyebrow  { color: var(--plum-deep); }
  .lp-tile--ink .lp-tile__eyebrow   { color: var(--rose); }
  .lp-tile__title {
    font: 700 clamp(1.125rem, 1.8vw, 1.5rem) / 1.1 var(--font-sans);
    letter-spacing: var(--tracking-tight);
    color: inherit;
    text-wrap: balance;
  }

  /* Arrow: 36×36 kruh, 1px border currentColor, opacity 0.7 idle.
     Na hover currentColor fill + svg flip na bg barvu karty. */
  .lp-tile__arrow {
    position: relative;
    z-index: 2;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    border-radius: 999px;
    border: 1px solid currentColor;
    opacity: 0.7;
    color: inherit;
    transition:
      opacity 220ms var(--ease-quart),
      transform 220ms var(--ease-quart),
      background 220ms var(--ease-quart);
  }
  .lp-tile__arrow :global(svg) { display: block; }

  /* Ribbon: background arc, position absolute inset 0, z-index 0, opacity 0.92,
     stejné snake-draw + breathing chování jako cross-link. */
  .lp-tile__ribbon {
    position: absolute;
    inset: 0;
    z-index: 0;
    pointer-events: none;
    opacity: 0.92;
    transition: transform 700ms var(--ease-quart);
  }
  .lp-tile__ribbon svg {
    width: 100%;
    height: 100%;
    overflow: visible;
    display: block;
  }
  .lp-tile__ribbon path {
    fill: none;
    stroke-width: 32;
    stroke-linecap: round;
    stroke-linejoin: round;
  }
  /* Ribbon stroke per varianta, sjednoceno s cross-link. */
  .lp-tile--deep  .lp-tile__ribbon path { stroke: var(--accent); stroke-width: 38; }
  .lp-tile--cream .lp-tile__ribbon path { stroke: var(--accent); stroke-width: 32; }
  .lp-tile--rose  .lp-tile__ribbon path { stroke: var(--plum-deep); stroke-width: 12; }
  .lp-tile--ink   .lp-tile__ribbon path { stroke: var(--rose); stroke-width: 28; }

  .lp-tile__ribbon[data-ribbon-reveal] path {
    stroke-dasharray: 1;
    stroke-dashoffset: 1;
    pathLength: 1;
  }
  .lp-tile__ribbon[data-ribbon-reveal].is-revealed path {
    animation:
      ribbon-snake-draw 2.6s var(--ease-snake) forwards,
      ribbon-breathe 7s ease-in-out 2.6s infinite;
  }

  /* Hover, mirror cross-link: lift translateY -3px + plum shadow + arrow becomes
     filled (background = currentColor, svg color flips to tile bg). Ribbon slide
     14 px + pause breathing. */
  .lp-tile:hover,
  .lp-tile:focus-visible {
    transform: translateY(-3px);
    box-shadow: 0 18px 40px hsl(var(--hue) 41% 13% / 0.22);
    outline: none;
  }
  .lp-tile:hover .lp-tile__ribbon {
    transform: translateX(14px);
  }
  .lp-tile:hover .lp-tile__ribbon path {
    animation-play-state: paused;
    opacity: 0.85;
  }
  .lp-tile:hover .lp-tile__arrow,
  .lp-tile:focus-visible .lp-tile__arrow {
    opacity: 1;
    transform: translateX(3px);
    background: currentColor;
  }
  /* Šipka flip: svg color = bg color karty. */
  .lp-tile--deep:hover .lp-tile__arrow :global(svg),
  .lp-tile--deep:focus-visible .lp-tile__arrow :global(svg)  { color: var(--plum-deep); }
  .lp-tile--cream:hover .lp-tile__arrow :global(svg),
  .lp-tile--cream:focus-visible .lp-tile__arrow :global(svg) { color: var(--cream); }
  .lp-tile--rose:hover .lp-tile__arrow :global(svg),
  .lp-tile--rose:focus-visible .lp-tile__arrow :global(svg)  { color: var(--rose); }
  .lp-tile--ink:hover .lp-tile__arrow :global(svg),
  .lp-tile--ink:focus-visible .lp-tile__arrow :global(svg)   { color: var(--plum-deep); }

  .lp-tile:focus-visible {
    outline: 2px solid var(--rose);
    outline-offset: 3px;
  }
  .lp-tile--cream:focus-visible { outline-color: var(--accent); }
  .lp-tile--rose:focus-visible  { outline-color: var(--plum-deep); }

  @media (max-width: 760px) {
    .lp-hero {
      /* +100 px proti 70dvh (~586 → ~686 px na 812 viewportu) per klientovu
         žádost; větší plocha pro hero foto, lepší dojem na 6.1" displejích.
         Horizontální padding ponechán na 0, .lp-hero__inner si bere gutter
         přes width: calc(100% , 2*gutter), aby content alignoval s tile gridem
         a zbytkem stránky (jinak by byl double-guttered). */
      min-height: 85vh;
      min-height: 85dvh;
      padding: var(--space-7) 0;
    }
    .lp-tiles { padding: var(--space-5) 0 var(--space-6); }
    /* Mobile: 2 sloupce (3×2 → 2×3) aby každý tile měl dost šířky pro cross-link
       layout (1fr auto), tj. text vlevo + 32 px arrow kruh vpravo bez overlapu. */
    .lp-tiles__grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 10px;
    }
    .lp-tile {
      min-height: 108px;
      padding: 14px 16px;
      gap: 12px;
    }
    .lp-tile__type { max-width: none; gap: 4px; min-width: 0; }
    .lp-tile__title {
      font-size: 0.9375rem;
      line-height: 1.2;
      text-wrap: pretty;
    }
    /* Eyebrows na telefonu skryté, titul stačí jako label. */
    .lp-tile__eyebrow {
      display: none;
    }
    .lp-tile__arrow {
      width: 32px;
      height: 32px;
      flex-shrink: 0;
    }
    .lp-tile__ribbon path { stroke-width: 32; }
    .lp-tile--rose .lp-tile__ribbon path  { stroke-width: 14; }
    .lp-tile--deep .lp-tile__ribbon path  { stroke-width: 38; }
    .lp-tile--ink .lp-tile__ribbon path   { stroke-width: 30; }

    /* Telefonní šachovnice: prohozená barevnost Komunitní zázemí (3.)
       a Stipendijní programy (4.) oproti desktopu, aby v 2-col mobile
       gridu vznikla cross diagonal cream/ink, ne sloupcový blok cream
       vlevo + ink vpravo. */
    .lp-tiles__grid > .lp-tile:nth-child(3) {
      background: var(--plum-deep);
      color: var(--cream);
    }
    .lp-tiles__grid > .lp-tile:nth-child(3) .lp-tile__title { color: var(--cream); }
    .lp-tiles__grid > .lp-tile:nth-child(3) .lp-tile__ribbon path { stroke: var(--rose); }
    .lp-tiles__grid > .lp-tile:nth-child(4) {
      background: var(--cream);
      color: var(--fg);
      border: 1px solid var(--accent-rule);
    }
    .lp-tiles__grid > .lp-tile:nth-child(4) .lp-tile__title { color: var(--fg); }
    .lp-tiles__grid > .lp-tile:nth-child(4) .lp-tile__ribbon path { stroke: var(--accent); }
    /* Arrow hover/idle flip: na cream → cream svg po vyplnění,
       na ink → plum-deep svg po vyplnění. */
    .lp-tiles__grid > .lp-tile:nth-child(3):hover .lp-tile__arrow :global(svg),
    .lp-tiles__grid > .lp-tile:nth-child(3):focus-visible .lp-tile__arrow :global(svg) {
      color: var(--plum-deep);
    }
    .lp-tiles__grid > .lp-tile:nth-child(4):hover .lp-tile__arrow :global(svg),
    .lp-tiles__grid > .lp-tile:nth-child(4):focus-visible .lp-tile__arrow :global(svg) {
      color: var(--cream);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .lp-tile, .lp-tile__ribbon, .lp-tile__arrow { transition: none; }
    .lp-tile__ribbon[data-ribbon-reveal] path,
    .lp-tile__ribbon[data-ribbon-reveal].is-revealed path {
      stroke-dashoffset: 0;
      animation: none;
    }
    .lp-tile:hover .lp-tile__ribbon { transform: none; }
  }

  /* ============ ZIG-ZAG SEKCE (one-pager) ============ */
  .lp-sections {
    background: var(--bg);
    color: var(--fg);
  }
  .lp-section {
    position: relative;
    padding: var(--space-8) 0;
    scroll-margin-top: 80px;
    border-bottom: 1px solid var(--border-muted);
    overflow: hidden;
  }
  .lp-section:last-child { border-bottom: 0; }
  .lp-section:nth-of-type(even) {
    background: var(--bg-muted);
  }

  /* Section ribbon: thin Bezier curve as background ornament, fills negative
     space opposite the photo + peeká z pod fotky (Z-layer). Sudé sekce dostanou
     scaleX(-1) takže ribbon přejde na druhou stranu. */
  .lp-section__ribbon {
    position: absolute;
    inset: 0;
    z-index: 0;
    pointer-events: none;
    opacity: 0.32;
    transition: transform 600ms var(--ease-quart);
  }
  /* Hover CTA tlačítek lehce posune ribbon doprava (na sudých sekcích doleva
     díky scaleX(-1) flipu). Pohyb je decentní (12 px), dává sekci „dech". */
  .lp-section:has(.lp-section__cta:hover) .lp-section__ribbon,
  .lp-section:has(.lp-section__cta:focus-visible) .lp-section__ribbon {
    transform: translateX(12px);
  }
  .lp-section:nth-of-type(even):has(.lp-section__cta:hover) .lp-section__ribbon,
  .lp-section:nth-of-type(even):has(.lp-section__cta:focus-visible) .lp-section__ribbon {
    transform: scaleX(-1) translateX(12px);
  }
  .lp-section__ribbon svg {
    width: 100%;
    height: 100%;
    display: block;
    overflow: visible;
  }
  .lp-section__ribbon path {
    fill: none;
    stroke: var(--accent);
    stroke-width: 36;
    stroke-linecap: round;
    stroke-linejoin: round;
  }
  .lp-section__ribbon[data-ribbon-reveal] path {
    stroke-dasharray: 1;
    stroke-dashoffset: 1;
    pathLength: 1;
  }
  /* Reveal + idle breathing. Sekce není klikatelná, takže žádný hover. */
  .lp-section__ribbon[data-ribbon-reveal].is-revealed path {
    animation:
      ribbon-snake-draw 3.2s var(--ease-snake) forwards,
      ribbon-breathe 7s ease-in-out 3.2s infinite;
  }
  .lp-section:nth-of-type(even) .lp-section__ribbon { transform: scaleX(-1); }

  .lp-section__inner {
    position: relative;
    z-index: 2;
    /* Width pattern: content edge se zarovná s tile grid (1480 max,
       gutter-aware na menších viewportech). Žádný vlastní padding-x. */
    width: calc(100% - 2 * var(--gutter));
    max-width: var(--container-wide);
    margin: 0 auto;
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
    gap: clamp(32px, 5vw, 80px);
    align-items: center;
  }
  /* Sudé sekce: flipnout media doleva, text doprava. */
  .lp-section:nth-of-type(even) .lp-section__media { order: -1; }

  .lp-section__text {
    min-width: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    max-width: 52ch;
  }
  .lp-section__eyebrow {
    font: 600 var(--text-2xs) / 1 var(--font-sans);
    color: var(--accent);
    letter-spacing: var(--tracking-wider);
    text-transform: uppercase;
    margin: 0;
  }
  .lp-section__title {
    font: 600 clamp(1.875rem, 3.5vw, 2.75rem) / 1.15 var(--font-sans);
    letter-spacing: var(--tracking-tight);
    margin: 0;
    max-width: 22ch;
  }
  .lp-section__lede {
    font: 400 var(--text-md) / 1.6 var(--font-sans);
    color: var(--fg-soft, var(--fg));
    margin: 0;
  }
  .lp-section__ctas {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3);
    margin-top: var(--space-2);
  }
  /* Sekce CTA, jednotný outline tón napříč zigzagem (plum border + plum text,
     transparentní pozadí, hover swap na solid plum fill).
     Desktop: row layout (arrow vpravo přes flex order vede z následující řádky).
     Mobile (≤ 760): column layout, arrow nad textem, top-left, menší font. */
  .lp-section__cta {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 12px 22px;
    font: 600 var(--text-sm) / 1 var(--font-sans);
    letter-spacing: var(--tracking-wide);
    border-radius: var(--radius-input);
    text-decoration: none;
    transition: background 200ms ease, color 200ms ease, border-color 200ms ease, transform 200ms ease;
    border: 1px solid var(--accent);
    color: var(--accent);
    background: transparent;
  }
  .lp-section__cta:hover,
  .lp-section__cta:focus-visible {
    background: var(--accent);
    color: var(--accent-on);
    outline: none;
  }
  .lp-section__cta-arrow {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-size: 1.05em;
    line-height: 1;
    transition: transform 220ms ease;
  }
  .lp-section__cta-label { line-height: 1; }
  .lp-section__cta:hover .lp-section__cta-arrow,
  .lp-section__cta:focus-visible .lp-section__cta-arrow {
    transform: translateX(2px);
  }
  .lp-section__media { min-width: 0; }

  @media (max-width: 760px) {
    /* Na mobilu uvolnit overflow, aby mobile section divider (z kit.css)
       mohl přesahovat hranici sekce. Ribbon-clipping přesouváme na vnitřní
       wrapper, kde to potřebuje zůstat. Border-bottom přebíjíme, divider
       z kit.css ::before slouží jako hranice mezi sekcemi a 1 px ruler by
       se s ním vizuálně bil. */
    .lp-section {
      padding: var(--space-7) 0;
      overflow: visible;
      border-bottom: 0;
    }
    .lp-section__ribbon { overflow: hidden; opacity: 0.32; }
    .lp-section__inner {
      grid-template-columns: 1fr;
      gap: var(--space-5);
    }
    /* Na mobilu vždy text první, pak média (žádný flip). */
    .lp-section:nth-of-type(even) .lp-section__media { order: 0; }
    .lp-section__ribbon path { stroke-width: 32; }

    /* CTA na mobilu: arrow + label v jednom inline rowu, menší font. */
    .lp-section__ctas { flex-direction: column; align-items: flex-start; }
    .lp-section__cta {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      padding: 12px 16px;
      font-size: 13px;
      letter-spacing: 0;
    }
    .lp-section__cta-arrow {
      font-size: 16px;
      line-height: 1;
    }
    .lp-section__cta-label { line-height: 1; }
  }

  @media (prefers-reduced-motion: reduce) {
    .lp-section__ribbon[data-ribbon-reveal] path,
    .lp-section__ribbon[data-ribbon-reveal].is-revealed path {
      stroke-dashoffset: 0;
      animation: none;
    }
  }

  /* ============ SUMMARY CARDS (pod Ubytováním) ============ */
  /* Dvě karty vedle sebe, krátký souhrn dvou produktových košů (Co-living
     vlevo, Privátní apartmány vpravo). Jednoduchá konverzní karta, ne
     per-varianta breakdown. Subtle 2-layer drop shadow, padding, dl s
     uppercase eyebrow labely a tabular-nums na řádku ceny. Mobile stack.
     Stacking fix: position relative + z-index 2 + isolation isolate aby karty
     sedly nad .lp-section__ribbon (který má z-index 0). */
  /* Width + gap přesně match .lp-section__inner (text + gallery), aby
     karty Co-living + Privátní apartmány měly stejnou šířku jako gallery
     foto nahoře. Předchozí gap clamp(20, 2.4vw, 32) byl menší než inner
     clamp(32, 5vw, 80), karty tak vycházely širší než foto vedle. */
  .lp-summary {
    position: relative;
    z-index: 2;
    isolation: isolate;
    width: calc(100% - 2 * var(--gutter));
    max-width: var(--container-wide);
    margin: var(--space-7) auto 0;
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: clamp(32px, 5vw, 80px);
  }
  /* ResidentBenefits pruh pod lp-summary uvnitř ubytovani sekce. Vlastní
     padding má ResidentBenefits sám (var(--space-6) var(--gutter)), wrap
     jen přidává margin-top kvůli oddělení od lp-summary karet.
     Background transparent override: defaultně má .rb solid bg, který by
     vizuálně oddělil benefit pruh od ribbonu sekce nahoře , uvnitř landingu
     chceme aby ribbon protékal i pod chip karty. */
  .lp-section__benefits {
    position: relative;
    z-index: 2;
    margin-top: var(--space-5);
  }
  .lp-section__benefits :global(.rb) {
    background: transparent;
    padding-top: 0;
    padding-bottom: 0;
  }
  /* Desktop: celá karta klikatelná, link wrapper přenese hover styly. */
  .lp-summary__card-link {
    display: block;
    text-decoration: none !important;
    color: inherit;
  }
  .lp-summary__card {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    height: 100%;
    background: var(--bg);
    border: 1px solid var(--border-muted);
    border-radius: var(--radius-input);
    padding: clamp(28px, 3vw, 40px);
    box-shadow:
      0 4px 16px hsl(var(--hue) 41% 13% / 0.06),
      0 12px 32px hsl(var(--hue) 41% 13% / 0.08);
    transition: transform 240ms var(--ease-standard),
                box-shadow 240ms var(--ease-standard),
                border-color 240ms var(--ease-standard);
  }
  /* Hover na celé kartě (via wrapper link) lift + shadow + accent border + CTA fill. */
  .lp-summary__card-link:hover .lp-summary__card,
  .lp-summary__card-link:focus-visible .lp-summary__card {
    transform: translateY(-3px);
    border-color: var(--accent);
    box-shadow:
      0 6px 20px hsl(var(--hue) 41% 13% / 0.08),
      0 18px 44px hsl(var(--hue) 41% 13% / 0.12);
  }
  .lp-summary__card-link:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 3px;
    border-radius: var(--radius-input);
  }
  .lp-summary__card-link:hover .lp-summary__cta,
  .lp-summary__card-link:focus-visible .lp-summary__cta {
    background: var(--accent);
    color: var(--accent-on);
  }
  .lp-summary__card-link:hover .lp-summary__cta-arrow,
  .lp-summary__card-link:focus-visible .lp-summary__cta-arrow {
    transform: translateX(2px);
  }
  .lp-summary__head {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .lp-summary__h {
    font: 700 clamp(1.75rem, 3vw, 2.5rem) / 1.05 var(--font-sans);
    letter-spacing: var(--tracking-tight);
    color: var(--accent);
    margin: 0;
    max-width: 22ch;
  }
  /* Variantní akcenty pro vizuální odlišení karet. */
  .lp-summary__card--coliving .lp-summary__h { color: var(--accent); }
  .lp-summary__card--coliving .lp-summary__dt { color: var(--accent); opacity: 0.85; }
  .lp-summary__card--coliving .lp-summary__dd--price { color: var(--accent); }
  .lp-summary__card--coliving .lp-summary__cta { color: var(--accent); border-color: var(--accent); }
  .lp-summary__card-link--coliving:hover .lp-summary__cta,
  .lp-summary__card-link--coliving:focus-visible .lp-summary__cta {
    background: var(--accent); color: var(--accent-on); border-color: var(--accent);
  }
  .lp-summary__card--privatni .lp-summary__h { color: var(--accent); }
  .lp-summary__card--privatni .lp-summary__dt { color: var(--accent); opacity: 0.85; }
  .lp-summary__card--privatni .lp-summary__dd--price { color: var(--accent); }
  .lp-summary__card--privatni .lp-summary__cta { color: var(--accent); border-color: var(--accent); }
  .lp-summary__card-link--privatni:hover .lp-summary__cta,
  .lp-summary__card-link--privatni:focus-visible .lp-summary__cta {
    background: var(--accent); color: var(--accent-on); border-color: var(--accent);
  }
  /* Facts list sjednocen s .apt-spec na detail stránkách: 2-col layout
     1fr / 1.4fr, hairline mezi rows, dt uppercase tiny, dd text-sm.
     Stejný kompakt styling na desktopu i mobilu, žádný stacking. */
  .lp-summary__facts {
    margin: 0;
    display: grid;
    gap: 0;
  }
  .lp-summary__row {
    display: grid;
    grid-template-columns: 1fr 1.4fr;
    gap: var(--space-3);
    padding: var(--space-3) 0;
    align-items: baseline;
    border-top: 1px solid var(--border-muted);
  }
  .lp-summary__row:first-child { border-top: 0; padding-top: 0; }
  .lp-summary__dt {
    font: 600 var(--text-2xs) / 1.3 var(--font-sans);
    letter-spacing: var(--tracking-wider);
    text-transform: uppercase;
    color: var(--fg-subtle);
    margin: 0;
  }
  .lp-summary__dd {
    font: 500 var(--text-sm) / 1.5 var(--font-sans);
    color: var(--fg);
    margin: 0;
  }
  .lp-summary__dd--price {
    font-variant-numeric: tabular-nums;
    font-weight: 600;
  }
  /* CTA mirror outline tónu sekce CTA tlačítka. margin-top auto tlačí CTA na
     spodek karty pro vyrovnanou baseline napříč oběma kartami. */
  .lp-summary__cta {
    align-self: flex-start;
    margin-top: auto;
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 12px 22px;
    font: 600 var(--text-sm) / 1 var(--font-sans);
    letter-spacing: var(--tracking-wide);
    border-radius: var(--radius-input);
    text-decoration: none;
    border: 1px solid var(--accent);
    color: var(--accent);
    background: transparent;
    transition: background 200ms ease, color 200ms ease, border-color 200ms ease, transform 200ms ease;
  }
  .lp-summary__cta-arrow {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-size: 1.05em;
    line-height: 1;
    transition: transform 220ms ease;
  }
  .lp-summary__cta-label { line-height: 1; }

  @media (max-width: 760px) {
    .lp-summary {
      grid-template-columns: minmax(0, 1fr);
      gap: var(--space-5);
      margin-top: var(--space-6);
    }
    /* Mobile: link wrapper se chová jako passive container, klikatelné zůstává
       jen CTA tlačítko vespod. */
    .lp-summary__card-link {
      pointer-events: none;
    }
    .lp-summary__card {
      padding: clamp(16px, 4vw, 22px);
    }
    .lp-summary__h {
      font-size: clamp(1.4rem, 6vw, 1.75rem);
    }
    /* CTA: inline arrow + label, klikatelné aktivní jako jediné. */
    .lp-summary__cta {
      pointer-events: auto;
      display: inline-flex;
      align-items: center;
      gap: 8px;
      padding: 12px 16px;
      font-size: 13px;
      letter-spacing: 0;
    }
    .lp-summary__cta-arrow {
      font-size: 16px;
      line-height: 1;
    }
    .lp-summary__cta-label { line-height: 1; }
  }

  @media (prefers-reduced-motion: reduce) {
    .lp-summary__card,
    .lp-summary__cta { transition: none; }
    .lp-summary__card-link:hover .lp-summary__card { transform: none; }
  }


  /* ============ FINÁLNÍ CTA BANNER (SH/07 styling, contained) ============ */
  .lp-cta-wrap {
    padding: var(--space-7) var(--gutter) var(--space-8);
    background: var(--bg);
  }
  .lp-cta-banner {
    position: relative;
    display: grid;
    grid-template-columns: 1fr auto;
    gap: clamp(20px, 4vw, 56px);
    align-items: center;
    max-width: var(--container-wide);
    margin: 0 auto;
    padding: clamp(32px, 4vw, 48px) clamp(28px, 4vw, 52px);
    background: var(--plum-deep);
    color: #fff;
    border-radius: var(--radius-input);
    text-decoration: none !important;
    overflow: hidden;
    transition: transform 240ms var(--ease-standard), box-shadow 240ms var(--ease-standard);
  }
  .lp-cta-banner__bg {
    position: absolute;
    inset: 0;
    pointer-events: none;
    opacity: 0.92;
    transition: transform 700ms var(--ease-quart);
  }
  .lp-cta-banner__bg svg {
    width: 100%;
    height: 100%;
    display: block;
    overflow: visible;
  }
  .lp-cta-banner__bg path {
    fill: none;
    stroke: var(--accent);
    stroke-width: 22;
    stroke-linecap: round;
    stroke-linejoin: round;
  }
  .lp-cta-banner[data-ribbon-reveal] .lp-cta-banner__bg path {
    stroke-dasharray: 1;
    stroke-dashoffset: 1;
    pathLength: 1;
  }
  .lp-cta-banner[data-ribbon-reveal].is-revealed .lp-cta-banner__bg path {
    animation:
      ribbon-snake-draw 2.6s var(--ease-snake) forwards,
      ribbon-breathe 7s ease-in-out 2.6s infinite;
  }
  .lp-cta-banner__type {
    position: relative;
    z-index: 2;
    display: flex;
    flex-direction: column;
    gap: 10px;
    max-width: 52ch;
  }
  .lp-cta-banner__eyebrow {
    font: 500 var(--text-2xs) / 1 var(--font-sans);
    letter-spacing: var(--tracking-wider);
    text-transform: uppercase;
    color: var(--rose);
  }
  .lp-cta-banner__h {
    font: 700 clamp(1.875rem, 3.2vw, 2.625rem) / 1.05 var(--font-sans);
    letter-spacing: var(--tracking-tight);
  }
  .lp-cta-banner__h em {
    font-style: italic;
    font-weight: 500;
    color: var(--rose);
  }
  .lp-cta-banner__lede {
    font: 500 var(--text-md) / 1.55 var(--font-sans);
    color: rgba(255, 255, 255, 0.82);
    max-width: 48ch;
  }
  .lp-cta-banner__cta {
    position: relative;
    z-index: 2;
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 14px 26px;
    background: var(--cream);
    color: var(--plum-deep);
    font: 700 var(--text-md) / 1 var(--font-sans);
    border-radius: var(--radius-input);
    white-space: nowrap;
    transition: background 200ms ease, transform 200ms var(--ease-standard);
  }
  .lp-cta-banner:hover,
  .lp-cta-banner:focus-visible {
    transform: translateY(-3px);
    box-shadow: 0 24px 56px hsl(var(--hue) 41% 13% / 0.40);
    outline: none;
  }
  .lp-cta-banner:hover .lp-cta-banner__bg,
  .lp-cta-banner:focus-visible .lp-cta-banner__bg {
    transform: translateX(14px);
  }
  .lp-cta-banner:hover .lp-cta-banner__bg path,
  .lp-cta-banner:focus-visible .lp-cta-banner__bg path {
    animation-play-state: paused;
    opacity: 0.85;
