---
import Base from '../layouts/Base.astro';
import Icon from '../components/Icon.astro';
import Gallery from '../components/Gallery.astro';
import { withBase } from '../utils/url';
import { getEntry } from 'astro:content';

// Hero rotation — 4 background images sliding horizontally on a 20s loop.
const heroImages = [
  withBase('/images/hub/hero/hero-1.jpg'),
  withBase('/images/hub/hero/hero-2.jpg'),
  withBase('/images/hub/hero/hero-3.jpg'),
  withBase('/images/hub/hero/hero-4.jpg'),
];

// Living formats — tři formáty postavené na fresh vizualizacích z public/images/hub/.
// Kapsle = sdílený kapsulový hotel; jednolůžko a dvoulůžko jsou obě varianty 1+kk
// podle počtu obyvatel a velikosti pokoje.
const formats = [
  {
    name: 'Kapsle',
    src: withBase('/images/hub/interior/kapsle-horizontal.jpg'),
    alt: 'Kapsulová jednotka v Hubu: dřevěné spací moduly s integrovaným osvětlením, číslované pody, sdílený lounge na chodbě.',
    body: 'Spací modul ve sdílené jednotce. Premium kapsulový design: dřevo, tlumené světlo, vlastní zámek a nabíjení. Na chodbě sdílený lounge a společné sociální zázemí. Pro krátké pobyty a pro lidi, kterým rozhoduje cena.',
  },
  {
    name: 'Jednolůžko',
    src: withBase('/images/hub/interior/1kk-a4-a6.jpg'),
    alt: 'Jednolůžkový mikroapartmán v budovách A4–A6: postel u okna, integrovaná knihovna, pracovní stůl, dřevěná podlaha, vlastní koupelna.',
    body: 'Privátní 1+kk pro 1 osobu. Velká postel, integrovaná knihovna, TV, jídelní stolek pro dva u okna, vlastní sociální zázemí. Sdílená kuchyň s pár sousedy. Pro delší pobyty a klid na práci nebo studium.',
  },
  {
    name: 'Dvoulůžko',
    src: withBase('/images/hub/interior/vetsi-pokoj-a.jpg'),
    alt: 'Větší 1+kk byt v budovách A pro dvě osoby: kuchyňský kout, jídelní stůl, postel uprostřed, propojený obývací prostor.',
    body: 'Privátní 1+kk pro dva. Vlastní kuchyňka (dřez, sporák, mikrovlnka), pracovní a jídelní kout, postel ve středu, propojený obývací prostor. Sociální zázemí v jednotce. Pro páry, sourozence nebo dvě OSVČ s podobným rytmem.',
  },
];

// Provozy a služby — 14 sdílených tile s Lucide ikonkami. Některé linkují na
// detailní sub-projekt page (parent-link), zbylé jsou stand-alone (parent:
// null). Strukturalní cíl: na landingu jediná koncepce „co tu funguje", která
// zároveň slouží jako vstupní brána do detailních /projekty/ stránek.
//
// `icon` odpovídá souboru v node_modules/lucide-static/icons/<name>.svg.
const provozyServices = [
  { title: 'Kavárna',                 body: 'V přízemí budovy B otevírá v 7 ráno. Specialty káva, ranní pečivo z vlastní pekárny, klidné koutky pro práci s laptopem.', icon: 'coffee',       parent: 'komunitni-centrum' },
  { title: 'Pekárna',                 body: 'Vedle kavárny v budově B. Bochník chleba, croissanty, sezónní pečivo, od 6 ráno čerstvě upečené.',                        icon: 'croissant',    parent: 'komunitni-centrum' },
  { title: 'Coworkingový sál',        body: 'Devět pevných stolů, dva soft koutky, projektor, kávovar v rohu. Přízemí budovy C.',                                       icon: 'monitor',      parent: 'coworking-centrum' },
  { title: 'Studovny',                body: 'Tři tiché čítárny v patrech budov A. Pro studium, čtení, klidné hovory přes sluchátka. Knihovní polic na zdi.',           icon: 'book-open',    parent: 'coworking-centrum' },
  { title: 'Zasedací místnosti',      body: 'Dvě uzavíratelné místnosti pro 4–8 lidí. Bílá tabule, projektor, video hovor. Rezervace přes sdílený kalendář.',           icon: 'presentation', parent: 'coworking-centrum' },
  { title: 'Ateliéry',                body: 'Otevřené prostory pro malíře, sochaře, krejčí, designéry. Dlouhé stoly, světlo z velkých oken, sdílené nářadí.',           icon: 'palette',      parent: 'coworking-centrum' },
  { title: 'Sdílené dílny',           body: 'Dřevodílna, kovodílna, oprava kol. Hoblíky, frézky, brusky. Vše značené, vše s návodem. Kdo umí, učí ostatní.',             icon: 'wrench',       parent: 'komunitni-centrum' },
  { title: 'Nahrávací studia',        body: 'Dvě akusticky tlumené místnosti pro podcast, hudbu, voiceover. Mikrofony, mixovací pult, monitory.',                       icon: 'mic',          parent: 'coworking-centrum' },
  { title: 'Sauna',                   body: 'V objektu E. Topí dvakrát týdně po práci, plus víkendová ranní směna. Outdoor cool-down deck pro letní i zimní sezónu.',   icon: 'flame',        parent: 'sauna-bazen' },
  { title: 'Bazén',                   body: 'Před objektem D. V létě venkovní koupání, mimo sezónu zazimovaný a slouží jako požární nádrž areálu.',                     icon: 'waves',        parent: 'sauna-bazen' },
  { title: 'Minipivovar',             body: 'Malý nezávislý pivovar v objektu B. Vaří se v pondělí, rozlévá se v pátek v sousední hospodě.',                            icon: 'beer',         parent: 'komunitni-pivovar' },
  { title: 'Sportoviště a park',      body: 'Komunitní park před objektem B: grilovací místa, ping-pong, dětské hřiště, telocvična na vzduchu (calisthenics).',          icon: 'dumbbell',     parent: 'sportoviste-park' },
  { title: 'Kontejnerové sklady',     body: 'Pro horská kola, lyže, sezónní krámy, archiv. Uzamykatelné boxy s přístupem 24/7.',                                       icon: 'warehouse',    parent: null },
  { title: 'Kyvadlový bus na metro',  body: 'Přes ranní a odpolední špičku jezdí areálový minibus na metro Kobylisy. Cesta 15 minut, bez přesedání.',                  icon: 'bus',          parent: null },
];

// Four-claim grid — short, parallel, scannable. Replaces the prior prose
// sections (koncept / pro koho / sdílené prostory) with a unified 2×2.
const claims = [
  {
    eyebrow: 'Koncept',
    title: 'Sedm budov, ~331 jednotek 1+kk.',
    body: 'Rekonstrukce A1–A6 a budovy C v centru areálu Horních kasáren. Privátní jednotky 1+kk se sklopnou postelí a vlastním sociálním zázemím.',
  },
  {
    eyebrow: 'Pro koho',
    title: 'Lidé, kteří startují.',
    body: 'Pracující studenti, OSVČ na začátku, mladí kreativci, začínající podnikatelé. Hub dává smysl tomu, kdo hledá flexibilní bydlení blízko Prahy.',
  },
  {
    eyebrow: 'Sdílené prostory',
    title: 'Privátní jednotka, sdílený zbytek.',
    body: 'Coworking, sauna, bazén, kavárna, pekárna, minipivovar, ateliéry, dílny, studovny, zasedačky, nahrávací studia, sportoviště s telocvičnou na vzduchu. Vše v rámci areálu.',
  },
  {
    eyebrow: 'Stipendium',
    title: 'Výběr podle záměru, ne sleva.',
    body: 'Pro lidi, kteří by Hubu dávali smysl, ale bez podpory by si pobyt nemohli dovolit. Vedle stipendia jsou paralelní role: správce (work-trade) a rezident-tvůrce. Cestu si vyberete ve formuláři.',
  },
];

// Editorial zigzag — 5 rows alternating ltr/rtl. Each row teď renderuje
// inline horizontální galerii (mobile swipe / desktop arrows + dots) místo
// jediného obrázku, takže každá kapitola má víc snímků k prolistování.
const zigzag = [
  {
    dir: 'ltr',
    eyebrow: 'Místo',
    title: 'Areál Horních kasáren · 12 km od Prahy.',
    body: 'Klecany leží těsně za hranicí Prahy. Areál sedí na trase plánované tramvajové zastávky Výzkumný ústav I. (vydáno stavební povolení) a navrhované cyklostezky podél Vltavy. Přes špičku jezdí kyvadlový bus na metro Kobylisy.',
    eager: true,
    images: [
      { src: withBase('/images/hub/aerial/buildings-a-c.jpg'), alt: 'Letecký pohled na centrální dvůr Startovacího Hubu — budovy A1–A6 a C kolem komunitního parku.' },
      { src: withBase('/images/hub/aerial/areal-entry.jpg'),   alt: 'Letecký pohled na vstup do areálu Horních kasáren — historická brána a centrální dvůr s rekonstruovanými budovami.' },
      { src: withBase('/images/hub/aerial/buildings-a.jpg'),   alt: 'Letecký pohled na rekonstruované budovy A1–A6 v Startovacím Hubu.' },
    ],
  },
  {
    dir: 'rtl',
    eyebrow: 'Komunita',
    title: 'Tržnice, kavárna, pekárna a minipivovar v objektu B.',
    body: 'V budově B funguje tržnice s lokálními producenty, kavárna, pekárna, minipivovar a venkovní zázemí pro food-trucky. V přízemí budovy C je coworkingový sál s pódiem pro přednášky a kapely.',
    images: [
      { src: withBase('/images/hub/interior/b-jidelna.jpg'),          alt: 'Jídelní a sezení v objektu B — dřevěné stoly, lavice, večerní osvětlení nad tržnicí a kavárnou.' },
      { src: withBase('/images/hub/exterior/trznice-pivovar.jpg'),    alt: 'Tržnice s minipivovarem v objektu B — venkovní zázemí pro food-trucky.' },
      { src: withBase('/images/hub/interior/hub-market-evening.jpg'), alt: 'Tržnice za soumraku v objektu B s prosvícenými okny.' },
      { src: withBase('/images/hub/interior/hub-market-daytime.jpg'), alt: 'Tržnice v objektu B přes den — stánky lokálních producentů.' },
      { src: withBase('/images/hub/exterior/cowork.jpg'),             alt: 'Coworkingový sál v přízemí budovy C — pevné stoly, projektor, kávovar v rohu.' },
    ],
  },
  {
    dir: 'ltr',
    eyebrow: 'Bydlení',
    title: '~331 privátních jednotek 1+kk.',
    body: 'Každá jednotka má vlastní sociální zázemí: sprchu, umyvadlo a toaletu. Sklopná postel uvolní obytný prostor přes den. Členové přípravného družstva mají navíc právo na luxusní stavební buňku 1+kk se zvýšeným standardem výbavy.',
    images: [
      { src: withBase('/images/hub/interior/1kk-1.jpg'),            alt: 'Vizualizace privátní jednotky 1+kk — sklopná postel, kuchyňský kout, pracovní stůl, vlastní koupelna.' },
      { src: withBase('/images/hub/interior/1kk-a4-a6.jpg'),        alt: 'Luxusní stavební buňka 1+kk v budovách A4–A6 pro členy přípravného družstva — vyšší standard výbavy.' },
      { src: withBase('/images/hub/interior/kapsle-horizontal.jpg'),alt: 'Kapsulová jednotka v Hubu — dřevěné spací moduly s integrovaným osvětlením a sdíleným loungem na chodbě.' },
      { src: withBase('/images/hub/interior/vetsi-pokoj-a.jpg'),    alt: 'Větší pokoj v budovách A pro dvě osoby — kuchyňský kout, jídelní stůl, postel uprostřed.' },
      { src: withBase('/images/hub/interior/1kk-2.jpg'),            alt: 'Privátní jednotka 1+kk varianta 2 — alternativní řešení obytného prostoru.' },
      { src: withBase('/images/hub/interior/1kk-3.jpg'),            alt: 'Privátní jednotka 1+kk varianta 3 — kompaktní layout s vlastní koupelnou.' },
      { src: withBase('/images/hub/interior/koupelna-a.jpg'),       alt: 'Koupelna v jednotce 1+kk v budovách A — sprcha, umyvadlo, toaleta.' },
    ],
  },
  {
    dir: 'rtl',
    eyebrow: 'Areál',
    title: 'Vnitřní dvůr a zázemí.',
    body: 'Sedm rekonstruovaných budov (A1–A6 + C) na ~6 700 m² čistých podlahových ploch. Mezi nimi sauna v objektu E, venkovní bazén před objektem D, komunitní park s grilovacími místy a telocvična na vzduchu.',
    images: [
      { src: withBase('/images/hub/aerial/areal-bazen.jpg'),         alt: 'Letecký pohled na vnitřní dvůr s venkovním bazénem před objektem D a saunou v objektu E.' },
      { src: withBase('/images/hub/exterior/sport.jpg'),             alt: 'Sportoviště v komunitním parku před objektem B — telocvična na vzduchu a calisthenics.' },
      { src: withBase('/images/hub/exterior/hub-courtyard-trees.jpg'),alt: 'Vnitřní dvůr s břízami, lavicemi a večerním osvětlením.' },
      { src: withBase('/images/hub/exterior/hub-courtyard-night.jpg'),alt: 'Vnitřní dvůr Startovacího Hubu za soumraku — atmosféra po setmění.' },
      { src: withBase('/images/hub/exterior/building-e-f.jpg'),      alt: 'Vizualizace objektů E a F Startovacího Hubu — wellness zóna se saunou.' },
    ],
  },
  {
    dir: 'ltr',
    eyebrow: 'Pro koho',
    title: 'Pracující studenty, OSVČ a mladí kreativci.',
    body: 'Hub je dělaný pro lidi, kteří startují: začínající podnikatele, studenty na bakalářce nebo diplomce, OSVČ na začátku kariéry. Pro někoho je to startovní bydlení, pro jiného přechodný mezikrok.',
    images: [
      { src: withBase('/images/hub/interior/window-view-a.jpg'),     alt: 'Pohled z okna pokoje v budovách A1–A3 — pracovní zóna s laptopem a knihovnou nad vnitřním dvorem.' },
      { src: withBase('/images/hub/interior/hub-market-people.jpg'), alt: 'Skupinka lidí na tržnici v objektu B Startovacího Hubu.' },
      { src: withBase('/images/hub/exterior/hub-courtyard-night.jpg'),alt: 'Lidé na vnitřním dvoře areálu za soumraku.' },
      { src: withBase('/images/hub/exterior/trznice-pivovar.jpg'),   alt: 'Lidé před tržnicí a minipivovarem v objektu B.' },
      { src: withBase('/images/hub/exterior/hub-courtyard-trees.jpg'),alt: 'Lidé na vnitřním dvoře areálu mezi břízami.' },
    ],
  },
];
---
<Base
  title="Startovací Hub"
  description="Nájemní bydlení blízko Prahy s coworkingem, saunou, bazénem, kavárnou a kyvadlovým busem na metro. Areál Horních kasáren v Klecanech. Pro pracující studenty, OSVČ na začátku a mladé kreativce."
  headerVariant="dark"
  ogImage={withBase('/og/default.png')}
>
  <section class="hub-hero osa-dark">
    <div class="hub-hero__bg-stack" aria-hidden="true">
      {heroImages.map((src, i) => (
        <img
          class={`hub-hero__bg hub-hero__bg--${i}`}
          src={src}
          alt=""
          loading={i === 0 ? 'eager' : 'lazy'}
          decoding="async"
          fetchpriority={i === 0 ? 'high' : 'auto'}
        />
      ))}
    </div>
    <div class="hub-hero__scrim" aria-hidden="true"></div>
    <div class="hub-hero__inner">
      <div class="hub-hero__kicker-row">
        <span class="osa-eyebrow hub-hero__kicker">Areál Horních kasáren · Klecany</span>
        <a class="osa-eyebrow hub-hero__kicker-out" href="https://keiaiendiel.github.io/vpd-web/vpd1/" rel="noopener">Záměr VPD1 →</a>
      </div>
      <h1 class="hub-hero__title">Startovací Hub.</h1>
      <p class="hub-hero__lede">Nájemní bydlení blízko Prahy v areálu Horních kasáren. Coworking, sauna, bazén, kavárna, ateliéry, dílny. K tomu kyvadlový bus na metro Kobylisy. Pro pracující studenty, OSVČ na začátku a mladé kreativce.</p>
      <a class="hub-hero__cta" href={withBase('/rezervace/')}>Rezervace →</a>
    </div>
  </section>

  <section class="hub-section hub-formats">
    <header class="osa-sub-head">
      <span class="osa-eyebrow">Jak v Hubu bydlíte</span>
      <h2 class="hub-section__heading">Tři způsoby, jak v Hubu bydlet.</h2>
    </header>
    <div class="hub-formats__grid">
      {formats.map((f) => (
        <article class="hub-format-card">
          <figure class="hub-format-card__media">
            <img src={f.src} alt={f.alt} loading="lazy" />
          </figure>
          <h3>{f.name}</h3>
          <p>{f.body}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="hub-section hub-amenities">
    <header class="osa-sub-head">
      <span class="osa-eyebrow">Provozy a služby</span>
      <h2 class="hub-section__heading">Co tu funguje.</h2>
    </header>
    <div class="hub-amenities__grid">
      {provozyServices.map((a) => {
        const Tag = a.parent ? 'a' : 'div';
        const props = a.parent ? { href: withBase(`/projekty/${a.parent}/`) } : {};
        return (
          <Tag class:list={['hub-amenity-card', a.parent && 'hub-amenity-card--linked']} {...props}>
            <span class="hub-amenity-card__icon" aria-hidden="true"><Icon name={a.icon} /></span>
            <h3 class="hub-amenity-card__title">{a.title}</h3>
            <p class="hub-amenity-card__body">{a.body}</p>
            {a.parent && (
              <span class="hub-amenity-card__cta">
                <span class="hub-amenity-card__cta-text">Detail </span>
                <span aria-hidden="true">→</span>
              </span>
            )}
          </Tag>
        );
      })}
    </div>
    <p class="hub-amenities__more"><a href={withBase('/projekty/')}>Detailní popisy šesti hlavních provozů →</a></p>
  </section>

  <section class="hub-claims-section">
    <div class="hub-claims" role="list">
      {claims.map((c) => (
        <article class="hub-claims__item" role="listitem">
          <span class="osa-eyebrow hub-claims__eyebrow">{c.eyebrow}</span>
          <h3 class="hub-claims__title">{c.title}</h3>
          <p class="hub-claims__body">{c.body}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="hub-druzstvo">
    <article class="hub-druzstvo__card">
      <span class="osa-eyebrow hub-druzstvo__eyebrow">Přípravné družstvo</span>
      <h2 class="hub-druzstvo__title">Kdo přichází první, určuje pravidla.</h2>
      <p class="hub-druzstvo__lede">První kohorta cca 50 rezidentů. Domlouváte <strong>denní rytmus, nájemní řád a provozní pravidla</strong>; za to získáváte <strong>garantované právo bydlet v luxusní stavební buňce 1+kk</strong> s cenovou stabilitou na první období. Druhá kohorta otevírá později pro ty, kdo přijdou do hotového rámce.</p>
      <a class="hub-druzstvo__cta" href={withBase('/projekty/bytove-druzstvo/')}>Detail přípravného družstva →</a>
    </article>
  </section>

  <section class="hub-zigzag">
    <header class="osa-sub-head hub-zigzag__head">
      <span class="osa-eyebrow">Areál</span>
      <h2 class="hub-section__heading">Jak to tu vypadá.</h2>
    </header>
    {zigzag.map((row, i) => (
      <div
        class:list={['hub-zigzag__row', `hub-zigzag__row--${row.dir}`]}
        data-row={i}
        data-zigzag-reveal>
        <div class="hub-zigzag__media">
          <Gallery images={row.images} ariaLabel={row.eyebrow} eager={row.eager} aspectRatio="4 / 3" />
        </div>
        <div class="hub-zigzag__copy">
          <span class="osa-eyebrow">{row.eyebrow}</span>
          <h3>{row.title}</h3>
          <p>{row.body}</p>
        </div>
      </div>
    ))}
  </section>

  <section class="hub-cta-pair">
    <div class="hub-cta-pair__grid">
      <article class="hub-cta-card hub-cta-card--primary">
        <div class="hub-cta-card__content">
          <span class="osa-eyebrow hub-cta-card__kicker">Chci tu bydlet</span>
          <p class="hub-cta-card__lede">Přidejte se k první kohortě přípravného družstva. Z vašich odpovědí ve formuláři skládáme provozní pravidla a domlouváme nájemní rámec.</p>
          <a class="hub-cta-card__btn hub-cta-card__btn--primary" href={withBase('/rezervace/')}>Rezervace →</a>
        </div>
      </article>

      <article class="hub-cta-card hub-cta-card--secondary">
        <div class="hub-cta-card__content">
          <span class="osa-eyebrow hub-cta-card__kicker">Investice do záměru</span>
          <p class="hub-cta-card__lede">Zajímá vás víc revitalizace areálu než vlastní bydlení? Záměr VPD1 mluví ke strategickým a finančním partnerům.</p>
          <a class="hub-cta-card__btn hub-cta-card__btn--secondary" href="https://keiaiendiel.github.io/vpd-web/vpd1/" rel="noopener">Záměr VPD1 →</a>
        </div>
      </article>
    </div>
  </section>

  <section class="hub-section hub-place">
    <div class="hub-place__grid">
      <div>
        <header class="osa-sub-head">
          <span class="osa-eyebrow">Místo</span>
          <h2 class="hub-section__heading">Kde to je.</h2>
        </header>
        <p>Klecany leží severně od Prahy, 12 km od centra. Přes ranní a odpolední špičku k metru Kobylisy jezdí kyvadlový bus areálu (15 minut), mimo špičku příměstská linka PID (~25 minut). Areál sedí na trase plánované tramvajové zastávky Výzkumný ústav I. Stavební povolení už máme, stojí na hranici Klecany / Zdiby. V plánu je také cyklolávka Roztoky–Klecany.</p>
        <a class="hub-place__cta" href={withBase('/o-arealu/#misto')}>O areálu a kontextu →</a>
      </div>
      <figure class="hub-place__map">
        <button
          type="button"
          class="hub-place__map-trigger"
          data-zoom-open
          data-zoom-src={withBase('/images/hub/masterplan_fotoreal.jpg')}
