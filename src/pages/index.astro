---
import Base from '../layouts/Base.astro';
import Gallery from '../components/Gallery.astro';
import Icon from '../components/Icon.astro';
import { withBase } from '../utils/url';

/* Phase 2 landing per SH_Web_Site_Copy.md § 0.1 + SH_Web_Visualization_List
   § 1.1 + 1.2. Hero rotace 5 záběrů (Foto se připravuje, zatím placeholdery),
   „Co Hub nabízí" 4 karty s horizontal scroll-snap gallery, section teasery
   pro 8 sekcí, masterplan, finální CTA panel.

   Hero rotace: cross-fade přes všech 5 slidů, 5 s na slide, 25 s celkový cyklus.
   `prefers-reduced-motion: reduce` zastaví na slide 1. */

/* === HERO ROTACE (5 záběrů) === */
/* Per Visualization_List_Cleanup.md § Landing/Hero h01-h05:
   h01 Budova C zvenku · h02 Vnitřní dvůr · h03 Pokoj 2+kk s pracujícím ·
   h04 Kapsle interiér · h05 Areál Klecany aerial. Nové Tier A rendery z
   vault Visualizations/h*. */
const heroSlides = [
  {
    src: withBase('/images/hub/hero/h01.jpg'),
    alt: 'Budova C (coworking + komunita) v parteru, hlavní vstup v odpoledním podvětí, 20 až 30 lidí v záběru: někteří vchází, někdo telefonuje, někdo na kole.',
  },
  {
    src: withBase('/images/hub/hero/h02.jpg'),
    alt: 'Vnitřní dvůr areálu za modré hodiny, lidé u stolu venku, světla v oknech budov.',
  },
  {
    src: withBase('/images/hub/hero/h03.jpg'),
    alt: 'Privátní apartmán 2+kk: jeden člověk u laptopu u okna s denním světlem, káva na stole, klidná pracovní atmosféra.',
  },
  {
    src: withBase('/images/hub/hero/h04.jpg'),
    alt: 'Velký pokoj s privátními kapslemi v rohu, „obývák s pody" se sedáky, knihami a převlékací kabinkou v pozadí.',
  },
  {
    src: withBase('/images/hub/hero/h05.jpg'),
    alt: 'Letecký pohled na horní kasárny Klecan v ranní mlze, krajinný kontext nad Vltavou.',
  },
];

/* === AMENITY ZIG-ZAG (4 řady) === */
/* Zig-zag layout per Visualization_List_Cleanup.md § Landing/Co Hub nabízí.
   Galerie reálných záběrů per řada (Gallery komponenta: dot pagination +
   chevron buttons + scroll-snap), kde vault folder zatím nemá záběr, slot
   nese placeholder s krátkou poznámkou, co tam bude. Copy per Site_Copy
   § 0.4.1. */
type GalleryItem =
  | { src: string; alt: string }
  | { placeholder: string; alt: string };
type AmenityRow = {
  eyebrow: string;
  lede: string;
  href: string;
  detailLabel: string;
  gallery: GalleryItem[];
};

const amenityRows: AmenityRow[] = [
  {
    eyebrow: 'Ubytování',
    lede: 'Devět typů, od privátní kapsle pro jednoho po byt 5+kk pro skupinu.',
    href: '/ubytovani/',
    detailLabel: 'Možnosti ubytování',
    /* Vault neukládá samostatné Ubytování záběry pro landing, recyklujeme
       z konkrétních ubytovacích sekcí (ks, kd, lj, lp, p1k a další zatím
       empty), držíme aktuální mix. */
    gallery: [
      { src: withBase('/images/hub/interior/1kk-a4-a6.jpg'), alt: '1+kk ranní rituál: káva u okna, denní světlo, postel ustlaná v pozadí.' },
      { src: withBase('/images/hub/interior/vetsi-pokoj-a.jpg'), alt: 'Větší privátní apartmán pro skupinu: jídelní stůl, kuchyňský kout, postel.' },
      { src: withBase('/images/hub/amenities/kapsle-horizontal-2.jpg'), alt: 'Kapsle ve společném pokoji s knihovnou a rostlinou.' },
      { src: withBase('/images/hub/amenities/1kk-2.jpg'), alt: '1+kk varianta s manželskou postelí a pracovním stolem u okna.' },
    ],
  },
  {
    eyebrow: 'Coworking',
    lede: 'Volný stůl v sále zdarma pro rezidenty. Fixní stůl, ateliéry, dílny s těžkými stroji za hodinovou sazbu.',
    href: '/coworking/',
    detailLabel: 'Coworking, dílny a ateliéry',
    /* Vault cw01-cw04 folders zatím empty (úplně nové vizualizace per
       Marek + Scott Weber / Impact Hub reference). Placeholder slots. */
    gallery: [
      { placeholder: 'cw01 Volný stůl v sále, hot-desking, 6 až 8 lidí ve flow', alt: 'Coworkingový sál v 1. NP budovy C, flexibilní hot-desking.' },
      { placeholder: 'cw02 Fixní stůl personalizovaný, monitory, klávesnice, rostlina', alt: 'Detail dedicated desku s monitory a osobními věcmi.' },
      { placeholder: 'cw03 Zasedací místnost s týmem 4 až 6 lidí, prezentace na obrazovku', alt: 'Zasedací místnost v budově C v plné akci.' },
      { placeholder: 'cw04 Ateliér nebo dílna v D1 nebo H1 až H3, hardware a nářadí', alt: 'Ateliér nebo dílna s fyzickou prací mimo office.' },
    ],
  },
  {
    eyebrow: 'Komunita',
    lede: 'Wellness, sport, gastro, kultura. Bazén, sauna, kantýna v budově B, klubovna, komunitní zahrádky.',
    href: '/komunita/',
    detailLabel: 'Komunitní program',
    /* Vault ko02-ko04 nové (Bazén, Kantýna, Klubovna). ko01 Grilovací
       místo zatím chybí. */
    gallery: [
      { src: withBase('/images/hub/amenities/ko02-bazen.jpg'), alt: 'Bazén v centrálním objektu areálu, letní odpoledne, sluneční terasa, relax po práci.' },
      { src: withBase('/images/hub/amenities/ko04-klubovna.jpg'), alt: 'Klubovna v budově C s eventem, lidé u stolů, kulturní život uvnitř Hubu.' },
      { src: withBase('/images/hub/exterior/trznice-pivovar.jpg'), alt: 'Tržnice s minipivovarem v budově B, večerní zázemí pro gastronomii.' },
      { placeholder: 'ko01 Grilovací místo, rodinné grilování v sobotu poledne, 8 až 12 lidí', alt: 'Grilovací místo v komunitním parku v sobotní poledne.' },
    ],
  },
  {
    eyebrow: 'Doprava',
    lede: 'Hub-shuttle do metra Kobylisy, 5 jízd v ceně. Bus 374 a Hub-taxi. Cyklostezka EuroVelo 7 podél Vltavy.',
    href: '/doprava/',
    detailLabel: 'Jak se sem dostanete',
    /* Vault dp02 nový (cyklostezka). dp01 Hub-shuttle a dp03 zastávka
       autobusu zatím chybí. */
    gallery: [
      { src: withBase('/images/hub/amenities/dp02-cyklostezka.jpg'), alt: 'Cyklista v motion bluru na cyklostezce Praha až Klecany, alternativa pro tělo a klima.' },
      { src: withBase('/images/hub/amenities/doprava-tram.jpg'), alt: 'Plánovaná tramvajová zastávka Výzkumný ústav I poblíž areálu (2029 až 2030).' },
      { placeholder: 'dp01 Hub-shuttle dodávka před hlavním vstupem, 3 až 4 rezidenti nastupují', alt: 'Hub-shuttle dodávka před hlavním vstupem do Hubu, ranní mlha.' },
      { placeholder: 'dp03 Zastávka autobusu 374 v Klecanech, U hřbitova', alt: 'Zastávka autobusu 374 jako záložní spoj na Kobylisy.' },
    ],
  },
];

/* === SEKCE LIST (6 sekcí jako icon karty) === */
const sections = [
  { path: '/ubytovani/', label: 'Ubytování',  icon: 'bed-double',    hint: '9 typů pokojů a apartmánů' },
  { path: '/coworking/', label: 'Coworking',  icon: 'briefcase',     hint: '5 tarifů od volného stolu po dílnu' },
  { path: '/komunita/',  label: 'Komunita',   icon: 'users',         hint: 'Wellness, sport, gastro, kultura' },
  { path: '/okoli/',     label: 'Okolí',      icon: 'map-pin',       hint: 'Klecany, 15 km severně od Prahy' },
  { path: '/doprava/',   label: 'Doprava',    icon: 'bus',           hint: 'Hub-shuttle, bus 374, Hub-taxi' },
  { path: '/stipendia/', label: 'Stipendia',  icon: 'sparkles',      hint: 'Pobytové stipendium, 4 role' },
];
---
<Base
  title="Bydlení v Klecanech, 15 minut autobusem z Prahy · Hub"
  description="Horní kasárny Klecan, otevřené pro bydlení a práci. Devět typů pokojů a apartmánů, coworking, dílny, sauna, společná kuchyně, kavárna. Bývalé vojenské kasárny nad Vltavou, patnáct kilometrů severně od centra Prahy. Areál se otevírá postupně od roku 2026."
  headerVariant="dark">

  {/* ============ HERO ROTATION ============ */}
  <section class="lp-hero" aria-label="Startovací Hub Klecany, hero galerie">
    <div class="lp-hero__rotation" aria-hidden="true">
      {heroSlides.map((slide, i) => (
        <div class="lp-hero__slide" data-slide={i} style={`animation-delay: ${i * 5 - 1}s`}>
          <img class="lp-hero__bg" src={slide.src} alt={slide.alt} loading={i === 0 ? 'eager' : 'lazy'} decoding="async" />
        </div>
      ))}
    </div>
    <div class="lp-hero__scrim" aria-hidden="true"></div>

    <div class="lp-hero__inner">
      <p class="lp-hero__eyebrow">Areál Horních kasáren · Klecany</p>
      <h1 class="lp-hero__title">Startovací Hub.</h1>
      <p class="lp-hero__lede">
        Prostor pro život a tvorbu. Devět možností ubytování, od privátních kapslí
        po 5+kk apartmány. Coworking, dílny a ateliéry pro práci. Sauna, kavárna
        a společná kuchyně pro každodenní život. Patnáct minut autobusem do metra
        Kobylisy. Komunita a možnost pobytového stipendia.
      </p>
      <div class="lp-hero__cta-row">
        <a class="lp-hero__cta lp-hero__cta--primary" href={withBase('/rezervace/')}>Rezervace</a>
        <a class="lp-hero__cta" href={withBase('/ubytovani/')}>Možnosti ubytování</a>
      </div>
    </div>
  </section>

  {/* ============ CO HUB NABÍZÍ (zig-zag, 4 řady) ============ */}
  <section class="lp-amenities" aria-label="Co Hub nabízí">
    <div class="lp-amenities__inner">
      <header class="lp-amenities__head">
        <h2 class="lp-amenities__title">Co Hub nabízí</h2>
      </header>
      <div class="lp-zigzag">
        {amenityRows.map((row, i) => (
          <div class:list={['lp-zigzag__row', i % 2 === 1 && 'lp-zigzag__row--rtl']}>
            <div class="lp-zigzag__media">
              <Gallery images={row.gallery} ariaLabel={row.eyebrow} aspectRatio="4 / 3" />
            </div>
            <div class="lp-zigzag__copy">
              <p class="lp-zigzag__eyebrow">{row.eyebrow}</p>
              <h3 class="lp-zigzag__headline">{row.lede}</h3>
              <a class="lp-zigzag__cta" href={withBase(row.href)}>
                {row.detailLabel}
                <span aria-hidden="true"> →</span>
              </a>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  {/* ============ SECTION TEASERY (8 sekcí) ============ */}
  <section class="lp-grid" aria-label="Sekce webu">
    <div class="lp-grid__inner">
      <ul class="lp-grid__list">
        {sections.map((s) => (
          <li class="lp-grid__item">
            <a class="lp-grid__link" href={withBase(s.path)}>
              <span class="lp-grid__icon" aria-hidden="true"><Icon name={s.icon} size={26} strokeWidth={1.75} /></span>
              <div class="lp-grid__body">
                <span class="lp-grid__label">{s.label}</span>
                <span class="lp-grid__hint">{s.hint}</span>
              </div>
              <span class="lp-grid__arrow" aria-hidden="true">→</span>
            </a>
          </li>
        ))}
      </ul>
    </div>
  </section>

  {/* ============ MÍSTO / MASTERPLAN ============ */}
  <section class="lp-place" aria-label="Místo, kde Hub stojí">
    <div class="lp-place__inner">
      <div class="lp-place__text">
        <p class="lp-place__eyebrow">Místo</p>
        <h2 class="lp-place__title">Horní kasárny, 15 km severně od centra Prahy.</h2>
        <p>
          Areál horních kasáren v Klecanech leží nad pravým břehem Vltavy. Patnáct kilometrů
          severně od Václavského náměstí, dvanáct minut autobusem 374 od metra Kobylisy.
        </p>
        <p>
          Bývalý vojenský areál, který otevíráme po etapách od roku 2026. Hub je první obyvatelná
          fáze záměru VPD1.
        </p>
        <p class="lp-place__links">
          <a href={withBase('/okoli/')}>Co je v okolí →</a>
          <a href={withBase('/doprava/')}>Jak se sem dostanete →</a>
        </p>
      </div>
      <figure class="lp-place__map">
        <img
          src={withBase('/images/hub/masterplan_fotoreal.jpg')}
          alt="Fotorealistický masterplan areálu Horních kasáren, popisky budov A1 až A6, B, C, D, E, F, P, S a venkovního bazénu."
          loading="lazy"
          decoding="async" />
        <figcaption>Masterplan areálu, stav 2026</figcaption>
      </figure>
    </div>
  </section>

  {/* ============ FINÁLNÍ CTA PANEL ============ */}
  <section class="lp-cta" aria-label="Závěrečná výzva k registraci">
    <div class="lp-cta__inner">
      <p class="lp-cta__eyebrow">Rezervujte si místo</p>
      <h2 class="lp-cta__title">Bydlete tady měsíc, nebo rok.</h2>
      <p class="lp-cta__lede">
        Rezervace je nezávazná. Vyplníte konfiguraci pokoje, datum nástupu a kontakt.
        Z rezervačního oddělení vám zavoláme do 24 hodin s detailem dostupnosti a ceny.
      </p>
      <a class="lp-cta__button" href={withBase('/rezervace/')}>Rezervace</a>
    </div>
  </section>
</Base>

<style>
  /* ============ HERO ROTATION ============ */
  /* 5 slides absolutely overlapped, 25 s cyklus, 5 s na slide,
     cross-fade 1 s. animation-delay posunuje každý slide v cyklu. */
  .lp-hero {
    position: relative;
    isolation: isolate;
    min-height: 64vh;
    display: grid;
    align-items: end;
    padding: var(--space-8) var(--gutter) var(--space-7);
    color: #fff;
    background: var(--k-100);
    overflow: hidden;
  }
  .lp-hero__rotation {
    position: absolute;
    inset: 0;
    z-index: -2;
  }
  /* 5 slidů jako horizontal carousel: 4 s nehybný hold, pak 1 s swipe
     celé fotky doleva. Sousední slide zároveň zprava vplouvá dovnitř,
     takže přechod je jeden plynulý sweep bez cross-fade.
     Slide N animation-delay = N × 5 s − 1 s (pre-roll, aby slide 0 byl
     hned na svém místě při page loadu). */
  .lp-hero__slide {
    position: absolute;
    inset: 0;
    transform: translateX(100%);
    animation: lp-hero-swipe 25s cubic-bezier(0.65, 0, 0.35, 1) infinite;
    will-change: transform;
  }

  @keyframes lp-hero-swipe {
    /* 25 s smyčka = 100 %. 0-4 % (1 s): swipe-in zprava. 4-20 % (4 s):
       hold na středu. 20-24 % (1 s): swipe-out doleva. 24-100 %: hidden
       off-screen vlevo dokud se animace neresetuje. Boundary teleport
       z -100 % zpět na 100 % se děje off-screen, uživatel ho nevidí. */
    0%   { transform: translateX(100%); }
    4%   { transform: translateX(0); }
    20%  { transform: translateX(0); }
    24%  { transform: translateX(-100%); }
    100% { transform: translateX(-100%); }
  }

  .lp-hero__bg {
    position: absolute;
    inset: 0;
    width: 100%; height: 100%;
    object-fit: cover;
    filter: brightness(0.88);
  }
  .lp-hero__scrim {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to top,
      rgba(0,0,0,0.75) 0%,
      rgba(0,0,0,0.45) 35%,
      rgba(0,0,0,0.05) 75%
    );
    z-index: -1;
  }
  .lp-hero__inner {
    max-width: var(--container);
    margin: 0 auto;
    width: 100%;
  }
  .lp-hero__eyebrow {
    font: 600 var(--text-2xs) / 1 var(--font-sans);
    color: rgba(255,255,255,0.85);
    letter-spacing: var(--tracking-wider);
    text-transform: uppercase;
    margin: 0 0 var(--space-4);
  }
  .lp-hero__title {
    font: 600 clamp(2.5rem, 6vw, 4.75rem) / 1.05 var(--font-sans);
    letter-spacing: var(--tracking-tight);
    margin: 0 0 var(--space-5);
    max-width: 18ch;
  }
  .lp-hero__lede {
    font-size: clamp(1.05rem, 1.5vw, 1.25rem);
    line-height: 1.45;
    margin: 0 0 var(--space-6);
    max-width: 52ch;
    color: rgba(255,255,255,0.95);
  }
  .lp-hero__cta-row {
    display: flex;
    gap: var(--space-3);
    flex-wrap: wrap;
  }
  .lp-hero__cta {
    display: inline-flex;
    align-items: center;
    padding: 12px 22px;
    font: 600 var(--text-sm) / 1 var(--font-sans);
    color: #fff;
    border: 1px solid rgba(255,255,255,0.4);
    border-radius: var(--radius-input);
    text-decoration: none;
    transition: background 200ms ease, color 200ms ease, border-color 200ms ease;
  }
  .lp-hero__cta:hover {
    background: #fff;
    color: var(--k-100);
    border-color: #fff;
  }
  .lp-hero__cta--primary {
    background: var(--accent);
    border-color: var(--accent);
  }
  .lp-hero__cta--primary:hover {
    background: #fff;
    color: var(--accent);
  }

  /* reduced-motion: freeze on slide 0 */
  @media (prefers-reduced-motion: reduce) {
    .lp-hero__slide { animation: none; transform: translateX(-100%); }
    .lp-hero__slide[data-slide="0"] { transform: translateX(0); }
  }

  /* ============ AMENITY ZIG-ZAG ============ */
  .lp-amenities {
    padding: var(--space-9) var(--gutter);
    background: var(--bg);
    color: var(--fg);
  }
  .lp-amenities__inner {
    max-width: var(--container-wide);
    margin: 0 auto;
  }
  .lp-amenities__head {
    margin: 0 0 var(--space-8);
    max-width: 36ch;
  }
  .lp-amenities__eyebrow {
    font: 600 var(--text-2xs) / 1 var(--font-sans);
    color: var(--accent);
    letter-spacing: var(--tracking-wider);
    text-transform: uppercase;
    margin: 0 0 var(--space-3);
  }
  .lp-amenities__title {
    font: 600 clamp(2rem, 4vw, 3rem) / 1.1 var(--font-sans);
    letter-spacing: var(--tracking-tight);
    margin: 0;
  }

  /* Zig-zag rows: alternující foto + text. Lichá řada (i % 2 === 1) má
     media v pravém sloupci, copy v levém. */
  .lp-zigzag {
    display: grid;
    gap: clamp(56px, 9vw, 112px);
  }
  .lp-zigzag__row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: clamp(32px, 5vw, 72px);
    align-items: center;
  }
  .lp-zigzag__row--rtl .lp-zigzag__media { order: 2; }
  .lp-zigzag__row--rtl .lp-zigzag__copy  { order: 1; }

  .lp-zigzag__copy { max-width: 48ch; }
  .lp-zigzag__eyebrow {
    font: 600 var(--text-2xs) / 1 var(--font-sans);
    color: var(--accent);
    letter-spacing: var(--tracking-wider);
    text-transform: uppercase;
    margin: 0 0 var(--space-3);
  }
  .lp-zigzag__headline {
    font: 600 clamp(1.625rem, 2.6vw, 2.25rem) / 1.25 var(--font-sans);
    letter-spacing: var(--tracking-tight);
    margin: 0 0 var(--space-5);
    text-wrap: balance;
  }
  .lp-zigzag__cta {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 10px 20px;
    font: 600 var(--text-sm) / 1 var(--font-sans);
    color: var(--accent);
    border: 1px solid var(--accent);
    border-radius: var(--radius-input);
    text-decoration: none;
    transition: background 200ms ease, color 200ms ease;
  }
  .lp-zigzag__cta:hover,
  .lp-zigzag__cta:focus-visible {
    background: var(--accent);
    color: var(--accent-on);
    outline: none;
  }

  @media (max-width: 760px) {
    .lp-zigzag__row {
      grid-template-columns: 1fr;
      gap: var(--space-5);
    }
    .lp-zigzag__row--rtl .lp-zigzag__media,
    .lp-zigzag__row--rtl .lp-zigzag__copy { order: 0; }
  }

  /* ============ SEKCE ICON CARDS (6 sekcí) ============ */
  .lp-grid {
    padding: var(--space-8) var(--gutter);
    background: var(--bg-muted, var(--bg));
    color: var(--fg);
  }
  .lp-grid__inner {
    max-width: var(--container);
    margin: 0 auto;
  }
  .lp-grid__list {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: var(--space-4);
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .lp-grid__item { display: block; }
  .lp-grid__link {
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: center;
    gap: var(--space-4);
    padding: var(--space-4) var(--space-5);
    background: var(--bg);
    border: 1px solid var(--border-muted);
    border-radius: var(--radius-input);
    color: inherit;
    text-decoration: none;
    transition: border-color 220ms ease, transform 220ms ease, box-shadow 220ms ease;
  }
  .lp-grid__link:hover,
  .lp-grid__link:focus-visible {
    border-color: var(--accent);
    transform: translateY(-2px);
    box-shadow: 0 6px 22px rgba(0, 0, 0, 0.06);
    outline: none;
  }
  .lp-grid__icon {
    display: grid;
    place-items: center;
    width: 56px;
    height: 56px;
    background: var(--accent-soft);
    color: var(--accent);
    border-radius: 12px;
    transition: background 220ms ease;
  }
