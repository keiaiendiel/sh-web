    }
    .lp-jumps--mobile .lp-jumps__item--primary :global(svg) {
      color: var(--accent-on);
    }
    .lp-jumps--mobile .lp-jumps__item--primary:hover,
    .lp-jumps--mobile .lp-jumps__item--primary:focus-visible {
      background: transparent;
      color: var(--accent);
      border-color: var(--accent);
    }
    .lp-jumps--mobile .lp-jumps__item--primary:hover :global(svg),
    .lp-jumps--mobile .lp-jumps__item--primary:focus-visible :global(svg) {
      color: var(--accent);
    }
  }

  /* ============ ZIG-ZAG SEKCE (one-pager) ============ */
  .lp-sections {
    background: var(--bg);
    color: var(--fg);
  }
  .lp-section {
    padding: var(--space-8) var(--gutter);
    scroll-margin-top: 80px;
    border-bottom: 1px solid var(--border-muted);
  }
  .lp-section:last-child { border-bottom: 0; }
  .lp-section:nth-of-type(even) {
    background: var(--bg-muted);
  }
  .lp-section__inner {
    max-width: var(--container-wide);
    margin: 0 auto;
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
    gap: clamp(32px, 5vw, 80px);
    align-items: center;
  }
  /* Sudé sekce: flipnout media doleva, text doprava. */
  .lp-section:nth-of-type(even) .lp-section__media { order: -1; }

  .lp-section__text {
    min-width: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    max-width: 52ch;
  }
  .lp-section__eyebrow {
    font: 600 var(--text-2xs) / 1 var(--font-sans);
    color: var(--accent);
    letter-spacing: var(--tracking-wider);
    text-transform: uppercase;
    margin: 0;
  }
  .lp-section__title {
    font: 600 clamp(1.875rem, 3.5vw, 2.75rem) / 1.15 var(--font-sans);
    letter-spacing: var(--tracking-tight);
    margin: 0;
    max-width: 22ch;
  }
  .lp-section__lede {
    font: 400 var(--text-md) / 1.6 var(--font-sans);
    color: var(--fg-soft, var(--fg));
    margin: 0;
  }
  .lp-section__cta {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    margin-top: var(--space-2);
    padding: 12px 22px;
    font: 600 var(--text-sm) / 1 var(--font-sans);
    letter-spacing: var(--tracking-wide);
    color: var(--accent);
    background: transparent;
    border: 1px solid var(--accent);
    border-radius: var(--radius-input);
    text-decoration: none;
    width: fit-content;
    transition: background 200ms ease, color 200ms ease;
  }
  .lp-section__cta:hover,
  .lp-section__cta:focus-visible {
    background: var(--accent);
    color: var(--accent-on);
    outline: none;
  }
  .lp-section__media { min-width: 0; }

  @media (max-width: 760px) {
    .lp-section { padding: var(--space-7) var(--gutter); }
    .lp-section__inner {
      grid-template-columns: 1fr;
      gap: var(--space-5);
    }
    /* Na mobilu vždy text první, pak média (žádný flip). */
    .lp-section:nth-of-type(even) .lp-section__media { order: 0; }
  }

  /* ============ ROOM PICKER (pod Ubytováním) ============ */
  /* 2 sloupce, Co-living a Privátní apartmány. Každý sloupec je
     horizontálně scrollovatelný snap-strip kartiček (jeden picker
     analogický mobilní verzi /ubytovani/). Na mobilu 1 sloupec pod
     druhým. */
  .lp-rooms {
    max-width: var(--container-wide);
    margin: var(--space-7) auto 0;
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
    gap: clamp(24px, 4vw, 56px);
  }
  .lp-rooms__group {
    min-width: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }
  .lp-rooms__eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    font: 600 var(--text-2xs) / 1 var(--font-sans);
    color: var(--accent);
    letter-spacing: var(--tracking-wider);
    text-transform: uppercase;
    margin: 0;
    width: fit-content;
    text-decoration: none;
    padding-bottom: 2px;
    border-bottom: 1px solid transparent;
    transition: border-color 160ms ease, color 160ms ease;
  }
  .lp-rooms__eyebrow:hover,
  .lp-rooms__eyebrow:focus-visible {
    border-bottom-color: var(--accent);
    outline: none;
  }

  /* Card picker: full-width karta, jeden snímek = jedna karta. Gallery
     JS overuje data-gallery atributy (scroll-snap + dot indicator +
     chevron buttons), takže stejné UX jako u obrazové galerie. */
  .lp-rooms__picker {
    position: relative;
    min-width: 0;
  }
  .lp-rooms__strip {
    display: flex;
    overflow-x: auto;
    overflow-y: hidden;
    scroll-snap-type: x mandatory;
    scroll-behavior: smooth;
    scrollbar-width: none;
    -ms-overflow-style: none;
  }
  .lp-rooms__strip::-webkit-scrollbar { display: none; }
  .lp-rooms__strip:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 4px;
    border-radius: var(--radius-input);
  }
  .lp-rooms__slide {
    flex: 0 0 100%;
    min-width: 0;
    scroll-snap-align: start;
    scroll-snap-stop: always;
  }
  .lp-rooms__controls {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 12px;
    margin-top: 14px;
  }
  .lp-rooms__nav {
    width: 32px;
    height: 32px;
    border-radius: 999px;
    border: 1px solid var(--accent-rule);
    background: transparent;
    color: var(--accent);
    cursor: pointer;
    display: grid;
    place-items: center;
    flex-shrink: 0;
    transition: background 220ms cubic-bezier(0.2, 0, 0, 1),
                border-color 220ms cubic-bezier(0.2, 0, 0, 1),
                transform 220ms cubic-bezier(0.2, 0, 0, 1);
  }
  .lp-rooms__nav :global(svg) { display: block; stroke: currentColor; transition: transform 220ms cubic-bezier(0.2, 0, 0, 1); }
  .lp-rooms__nav--prev :global(svg) { transform: translateX(-1px); }
  .lp-rooms__nav--next :global(svg) { transform: translateX(1px); }
  .lp-rooms__nav:hover {
    background: var(--accent-soft);
    border-color: var(--accent);
    transform: scale(1.06);
  }
  .lp-rooms__nav--prev:hover :global(svg) { transform: translateX(-3px); }
  .lp-rooms__nav--next:hover :global(svg) { transform: translateX(3px); }
  .lp-rooms__nav:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 3px;
  }
  .lp-rooms__nav:disabled {
    opacity: 0.25;
    cursor: default;
    pointer-events: none;
    transform: none;
  }
  .lp-rooms__dots {
    display: flex;
    align-items: center;
    gap: 6px;
  }
  .lp-rooms__dot {
    width: 6px;
    height: 6px;
    border-radius: 999px;
    border: 0;
    padding: 0;
    background: var(--border-muted);
    cursor: pointer;
    transition: background 320ms cubic-bezier(0.2, 0, 0, 1),
                width 360ms cubic-bezier(0.2, 0, 0, 1),
                transform 220ms cubic-bezier(0.2, 0, 0, 1);
  }
  .lp-rooms__dot:hover { background: var(--accent-rule); transform: scale(1.4); }
  .lp-rooms__dot.is-active {
    background: var(--accent);
    width: 28px;
    animation: lp-rooms-dot-pulse 480ms cubic-bezier(0.2, 0, 0, 1);
  }
  .lp-rooms__dot.is-active:hover { transform: scale(1.05); }
  .lp-rooms__dot:focus-visible { outline: 2px solid var(--accent); outline-offset: 3px; }
  @keyframes lp-rooms-dot-pulse {
    0%   { transform: scale(0.6); }
    50%  { transform: scale(1.15); }
    100% { transform: scale(1); }
  }

  @media (max-width: 900px) {
    .lp-rooms {
      grid-template-columns: 1fr;
      gap: var(--space-6);
    }
  }
  @media (max-width: 760px) {
    .lp-rooms__nav { display: none; }
  }

  /* ============ FEATURE CHIPS (Coworking + Komunita) ============ */
  /* Kompaktní řada kliknutelných chipů pod zigzagem, ilustruje hlavní
     pod-sekce. Hover dostane plum outline + jemný lift. */
  .lp-features {
    max-width: var(--container-wide);
    margin: var(--space-6) auto 0;
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
  }
  .lp-feature {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 10px 16px;
    font: 600 var(--text-sm) / 1 var(--font-sans);
    color: var(--fg);
    background: var(--bg);
    border: 1px solid var(--border-muted);
    border-radius: var(--radius-input);
    text-decoration: none;
    transition: border-color 180ms ease, color 180ms ease, background 180ms ease, transform 180ms ease;
  }
  .lp-feature__icon {
    color: var(--accent);
    display: inline-flex;
  }
  .lp-feature__icon :global(svg) { display: block; }
  .lp-feature:hover,
  .lp-feature:focus-visible {
    border-color: var(--accent);
    background: var(--accent-soft);
    color: var(--fg);
    transform: translateY(-1px);
    outline: none;
  }
  .lp-section:nth-of-type(even) .lp-feature { background: var(--bg); }

  @media (max-width: 760px) {
    .lp-features { gap: 8px; }
    .lp-feature { padding: 8px 12px; font-size: var(--text-xs); }
  }

  /* ============ OKOLÍ EMBED MAPA ============ */
  /* Pod zigzagem okolí, jako jeden šedý frame s Leaflet mapou + adresa. */
  .lp-okoli-map {
    max-width: var(--container-wide);
    margin: var(--space-7) auto 0;
  }
  .lp-okoli-map__frame {
    width: 100%;
    height: clamp(280px, 42vw, 480px);
    border-radius: var(--radius-input);
    overflow: hidden;
    background: var(--bg-muted);
    border: 1px solid var(--border-muted);
  }
  .lp-okoli-map__address {
    margin: var(--space-3) 0 0;
    font: 500 var(--text-sm) / 1.5 var(--font-sans);
    color: var(--fg-soft, var(--fg));
    display: flex;
    align-items: baseline;
    gap: var(--space-3);
    flex-wrap: wrap;
  }
  .lp-okoli-map__address strong { color: var(--fg); }
  .lp-okoli-map__address a {
    color: var(--accent);
    text-decoration: none;
    border-bottom: 1px solid var(--accent-rule);
    padding-bottom: 1px;
  }
  .lp-okoli-map__address a:hover { border-bottom-color: var(--accent); }

  /* ============ FINÁLNÍ CTA ============ */
  .lp-cta {
    padding: var(--space-8) var(--gutter);
    background: var(--accent);
    color: #fff;
    text-align: center;
  }
  .lp-cta__inner {
    max-width: 640px;
    margin: 0 auto;
  }
  .lp-cta__eyebrow {
    font: 600 var(--text-2xs) / 1 var(--font-sans);
    color: rgba(255,255,255,0.85);
    letter-spacing: var(--tracking-wider);
    text-transform: uppercase;
    margin: 0 0 var(--space-3);
  }
  .lp-cta__title {
    font: 600 clamp(1.75rem, 3.5vw, 2.5rem) / 1.15 var(--font-sans);
    letter-spacing: var(--tracking-tight);
    margin: 0 0 var(--space-4);
  }
  .lp-cta__lede {
    font-size: var(--text-md);
    line-height: 1.5;
    margin: 0 0 var(--space-6);
    opacity: 0.92;
  }
  .lp-cta__button {
    display: inline-block;
    padding: 14px 32px;
    font: 700 var(--text-md) / 1 var(--font-sans);
