---
import Base from '../layouts/Base.astro';
import Gallery from '../components/Gallery.astro';
import Icon from '../components/Icon.astro';
import { withBase } from '../utils/url';

/* Phase 2 landing per SH_Web_Site_Copy.md § 0.1 + SH_Web_Visualization_List
   § 1.1 + 1.2. Hero rotace 4 záběrů (Tier A rendery z vault hero-update),
   „Co Hub nabízí" 4 karty s horizontal scroll-snap gallery, section teasery
   pro 8 sekcí, masterplan, finální CTA panel.

   Hero rotace: swipe přes 4 slidy, 5 s na slide, 20 s celkový cyklus.
   `prefers-reduced-motion: reduce` zastaví na slide 1. */

/* === HERO ROTACE (4 záběry) === */
/* Tier A rendery z vault Visualizations/h - Hero/hero-update.
   Každý slide má desktop (landscape) a phone (portrait) variantu,
   <picture> přepíná v zlomu 768 px. */
const heroSlides = [
  {
    desktop: withBase('/images/hub/hero/h01.jpg'),
    phone:   withBase('/images/hub/hero/h01-phone.jpg'),
    alt: 'Privátní apartmány v parteru po setmění, lidé před vstupem mezi břízami, teplá světla v oknech.',
  },
  {
    desktop: withBase('/images/hub/hero/h02.jpg'),
    phone:   withBase('/images/hub/hero/h02-phone.jpg'),
    alt: 'Chodba s privátními kapslemi v dřevěném obložení, lavice a rostlina v lounge, tlumené ambientní světlo.',
  },
  {
    desktop: withBase('/images/hub/hero/h03.jpg'),
    phone:   withBase('/images/hub/hero/h03-phone.jpg'),
    alt: 'Vnitřní dvůr areálu za modré hodiny, lidé u dlouhého stolu venku, světla v oknech renovovaných budov.',
  },
  {
    desktop: withBase('/images/hub/hero/h04.jpg'),
    phone:   withBase('/images/hub/hero/h04-phone.jpg'),
    alt: 'Privátní apartmán 1+kk: žena vaří v kuchyni, muž čte u stolu, postel u okna, teplé večerní světlo.',
  },
];

/* === SEKCE ZIG-ZAG (5 řad, one-pager) === */
/* Každá sekce má anchor id pro scroll z tile gridu pod hero. Eyebrow + title +
   lede + CTAs do detail page na jedné straně, gallery na druhé. Sudé řady mají
   gallery vlevo přes :nth-of-type(even) flip. Okolí + Doprava merged do jedné
   sekce s 2 CTAs. */
type GalleryItem =
  | { src: string; alt: string }
  | { placeholder: string; alt: string };
type SectionCta = { href: string; label: string };
type Section = {
  id: string;
  eyebrow: string;
  title: string;
  lede: string;
  ctas: SectionCta[];
  gallery: GalleryItem[];
  /* Bezier d-form pro section ribbon pozadí, viewBox 0 0 1600 600.
     Sudé sekce dostanou scaleX(-1) takže path se zrcadlí, navrhuj path
     s důrazem v levé spodní třetině (negativní prostor pod textem). */
  ribbonPath: string;
};

const sections: Section[] = [
  {
    id: 'ubytovani',
    eyebrow: 'Ubytovací služby',
    title: 'Vlastní apartmán, nebo místo v co-livingu?',
    lede: 'Devět typů ubytování. Privátní apartmány 1+kk až 5+kk, kapsle pro jednoho nebo dva, lůžka ve sdílených pokojích. V ceně energie, internet, pět jízd Hub-shuttle a týdenní poukaz do sauny.',
    ctas: [{ href: '/ubytovani/', label: 'Možnosti ubytování' }],
    ribbonPath: 'M -80 480 C 120 320, 320 240, 540 360 S 940 520, 1120 380 S 1400 280, 1560 360',
    gallery: [
      { src: withBase('/images/hub/ubytovani/landing-window-dusk.jpg'), alt: 'Privátní apartmán zvenku za soumraku, osoba u okna pracuje u stolu při svitu lampy.' },
      { src: withBase('/images/hub/ubytovani/landing-1kk-wide.jpg'), alt: 'Privátní apartmán 1+kk: žena vaří v kuchyni, muž čte u stolu, postel u okna, teplé večerní světlo.' },
      { src: withBase('/images/hub/ubytovani/landing-capsules.jpg'), alt: 'Privátní kapsle ve dvou patrech, dřevěná obložení a tlumené ambientní světlo.' },
      { src: withBase('/images/hub/ubytovani/landing-1kk-small.jpg'), alt: 'Privátní apartmán 1+kk se sníženými proporcemi, postel u okna, kuchyňský kout a jídelní stůl.' },
      { src: withBase('/images/hub/ubytovani/landing-exterior.jpg'), alt: 'Privátní apartmány v parteru po setmění, lidé před vstupem mezi břízami, teplá světla v oknech.' },
    ],
  },
  {
    id: 'coworking',
    eyebrow: 'Coworking',
    title: 'Sál, fixní stůl, ateliér nebo dílna.',
    lede: 'Volný stůl v sále 24/7, fixní stůl s vlastní skříňkou, sdílená kancelář pro čtyři, zasedací místnost na hodinu. K tomu ateliéry a dílny s těžkými stroji v sousedních budovách. Coworkingový sál mají rezidenti v ceně bydlení.',
    ctas: [{ href: '/coworking/', label: 'Coworking a dílny' }],
    ribbonPath: 'M -60 380 C 180 460, 360 220, 580 380 S 960 540, 1140 360 S 1380 220, 1560 360',
    gallery: [
      { src: withBase('/images/hub/coworking/budova-c-exterior.jpg'), alt: 'Budova C zvenku, parter s hlavním vstupem do coworkingu a komunitního zázemí.' },
      { src: withBase('/images/hub/coworking/budova-c-interior.jpg'), alt: 'Interiér budovy C, společný prostor pro coworking a komunitní akce.' },
      { placeholder: 'cw03 Zasedací místnost s týmem 4 až 6 lidí, prezentace na obrazovku', alt: 'Zasedací místnost v budově C v plné akci.' },
      { placeholder: 'cw04 Ateliér nebo dílna v D1 nebo H1 až H3, hardware a nářadí', alt: 'Ateliér nebo dílna s fyzickou prací mimo office.' },
    ],
  },
  {
    id: 'komunita',
    eyebrow: 'Komunitní zázemí',
    title: 'Bazén, sauna, jídelna, klubovna.',
    lede: 'Vlastní bazén a sauna v jádře areálu, jídelna s minipivovarem v budově B, klubovna v budově C, komunitní park s grilem. Týdenní vstup do sauny mají v ceně všichni rezidenti.',
    ctas: [{ href: '/komunita/', label: 'Komunitní program' }],
    ribbonPath: 'M -80 520 C 140 360, 360 480, 580 340 S 940 460, 1140 380 S 1380 280, 1560 360',
    gallery: [
      { src: withBase('/images/hub/komunita/bazen.jpg'), alt: 'Bazén v centrálním objektu areálu, letní odpoledne, sluneční terasa, relax po práci.' },
      { src: withBase('/images/hub/komunita/restaurant.jpg'), alt: 'Komunitní restaurace v budově B v plném provozu, dlouhé stoly, otevřená kuchyně, lidé u oběda.' },
      { src: withBase('/images/hub/komunita/courtyard.jpg'), alt: 'Vnitřní dvůr areálu za modré hodiny, lidé u dlouhého stolu venku, světla v oknech renovovaných budov.' },
      { src: withBase('/images/hub/komunita/klubovna.jpg'), alt: 'Klubovna v budově C s eventem, lidé u stolů, kulturní život uvnitř Hubu.' },
      { src: withBase('/images/hub/komunita/04.jpg'), alt: 'Vnitřní dvůr za soumraku, lidé procházejí mezi rozsvícenými budovami, kola u stojanu, atmosféra komunitního večera.' },
      { placeholder: 'ko01 Grilovací místo, rodinné grilování v sobotu poledne, 8 až 12 lidí', alt: 'Grilovací místo v komunitním parku v sobotní poledne.' },
    ],
  },
  {
    id: 'stipendia',
    eyebrow: 'Stipendijní programy',
    title: 'Pobytové stipendium pro lidi s projektem.',
    lede: 'Čtyři role: rezident-tvůrce, work-trade správce, stavitel-rezident, rezident-programátor. Bydlení nebo zvýhodněná cena za konkrétní vstup do života Hubu (dílny, péče o areál, vlastní projekt). Při registraci zaškrtněte zájem, ozveme se s podmínkami.',
    ctas: [{ href: '/stipendia/', label: 'Pobytová stipendia' }],
    ribbonPath: 'M -60 420 C 160 540, 380 260, 600 400 S 960 520, 1140 380 S 1380 240, 1560 380',
    gallery: [
      { placeholder: 'Ateliér s rezidentem-tvůrcem v práci, denní světlo, velký stůl', alt: 'Ateliér s rezidentem-tvůrcem v práci.' },
      { placeholder: 'Skupinový moment u stolu, společné plánování nebo večeře rezidentů', alt: 'Skupinový moment u stolu, společné plánování rezidentů.' },
      { placeholder: 'Rezident se stará o pozemek areálu', alt: 'Rezident se stará o pozemek areálu.' },
      { placeholder: 'Rezident-programátor u stolu s monitorem, kód na obrazovce', alt: 'Rezident-programátor u stolu s monitorem.' },
    ],
  },
  {
    id: 'okoli',
    eyebrow: 'Okolí a dostupnost',
    title: 'Klecany, 15 km od Prahy. Patnáct minut autobusem na metro.',
    lede: 'Bývalý vojenský areál nad pravým břehem Vltavy. V docházkové vzdálenosti školka Astra, praktický lékař, lékárna, pošta. Pět jízd Hub-shuttle do metra Kobylis měsíčně v ceně, bus 374 PID a Hub-taxi jako záloha. Cyklostezka EuroVelo 7 podél Vltavy deset minut na kole.',
    ctas: [
      { href: '/okoli/',   label: 'Co je v okolí' },
      { href: '/doprava/', label: 'Jak se sem dostanete' },
    ],
    ribbonPath: 'M -80 460 C 180 300, 380 460, 600 340 S 980 460, 1160 380 S 1380 280, 1560 380',
    gallery: [
      { src: withBase('/images/hub/areal/masterplan_fotoreal.jpg'), alt: 'Fotorealistický masterplan areálu Horních kasáren, popisky budov A1 až A6, B, C, D, E, F, P, S a venkovního bazénu.' },
      { src: withBase('/images/hub/areal/topview.jpg'), alt: 'Letecký pohled na areál horních kasáren a obec Klecany v širším krajinném kontextu.' },
      { src: withBase('/images/hub/doprava/tram.jpg'), alt: 'Plánovaná tramvajová zastávka Výzkumný ústav I poblíž areálu (2029 až 2030).' },
      { src: withBase('/images/hub/doprava/cyklostezka.jpg'), alt: 'Cyklista na cyklostezce Praha až Klecany podél Vltavy.' },
      { src: withBase('/images/hub/areal/building-a-1.jpg'), alt: 'Privátní apartmány A1 zvenku, dřevěný obklad, čistý parter, alej bříz podél cesty.' },
      { src: withBase('/images/hub/areal/building-b.jpg'), alt: 'Budova B, komunitní gastro blok, exteriér z hlavní cesty areálu.' },
      { placeholder: 'dp01 Hub-shuttle dodávka před hlavním vstupem, 3 až 4 rezidenti nastupují', alt: 'Hub-shuttle dodávka před hlavním vstupem do Hubu, ranní mlha.' },
    ],
  },
];

/* === RIBBON TILES (pod hero) ===
   Pět scroll dlaždic + Rezervace tile (6 celkem, 3×2 grid). Per spec § 04
   banner influence: bez čísel, větší typo, větší ribbon arc jako pozadí,
   plakátovější. Pět variant rotuje (cream / rose / plum-soft / sand / soft)
   pro vizuální rozmanitost napříč grídem, žádné dva sousedy nejsou stejné.
   Plnější colorize přijde až do subpage hero sekcí. */
const tiles = [
  { label: 'Ubytovací služby', sub: 'Apartmány, kapsle, lůžka',  href: '#ubytovani', variant: 'cream',
    path: 'M 60 240 C 220 100, 380 320, 540 200 C 660 100, 720 260, 760 340' },
  { label: 'Coworking',         sub: 'Sál, ateliér, dílna',      href: '#coworking', variant: 'rose',
    path: 'M 80 120 C 240 280, 400 80, 560 240 C 680 360, 740 200, 760 320' },
  { label: 'Komunitní zázemí',  sub: 'Bazén, sauna, jídelna',    href: '#komunita',  variant: 'plum-soft',
    path: 'M 80 200 C 240 80, 420 280, 580 160 C 700 80, 740 240, 760 320' },
  { label: 'Stipendijní programy', sub: 'Pobyt zdarma za projekt', href: '#stipendia', variant: 'sand',
    path: 'M 60 240 C 200 100, 380 320, 520 200 C 660 80, 740 240, 760 360' },
  { label: 'Okolí a dostupnost', sub: 'Vltava, bus, cyklostezka', href: '#okoli',    variant: 'soft',
    path: 'M 80 320 C 200 480, 420 200, 580 360 C 700 480, 740 320, 760 220' },
];
---
<Base
  title="Startovací Hub Klecany · Bydlení a coworking 15 min od Prahy"
  description="Devět typů bydlení od kapsle po byt 5+kk, coworking, dílny, sauna a kavárna. Horní kasárna Klecany, patnáct minut autobusem od metra Kobylisy. Od 3 000 Kč měsíčně, energie a internet v ceně."
  headerVariant="overlay">

  {/* ============ HERO ROTATION ============ */}
  <section class="lp-hero" aria-label="Startovací Hub Klecany, hero galerie">
    <div class="lp-hero__rotation" aria-hidden="true">
      {heroSlides.map((slide, i) => (
        <div class="lp-hero__slide" data-slide={i} style={`animation-delay: ${i * 5 - 1}s`}>
          <picture>
            <source media="(max-width: 768px)" srcset={slide.phone} />
            <img class="lp-hero__bg" src={slide.desktop} alt={slide.alt} loading={i === 0 ? 'eager' : 'lazy'} decoding="async" />
          </picture>
        </div>
      ))}
    </div>
    <div class="lp-hero__scrim" aria-hidden="true"></div>

    <div class="lp-hero__inner">
      <h1 class="lp-hero__title">Bydlení a&nbsp;coworking na&nbsp;prahu metropole.</h1>
      <p class="lp-hero__lede">Devět typů ubytování od&nbsp;3&nbsp;000&nbsp;Kč měsíčně. Energie a&nbsp;internet v&nbsp;ceně.</p>
    </div>

    {/* Scroll cue: kruhový button s chevron-down, jemně poskakuje + pulsing ring,
        klik smooth-scrolluje na jump strip pod hero. */}
    <a class="lp-hero__scroll-cue osa-nolink" href="#lp-jumps" aria-label="Skrolovat na možnosti">
      <Icon name="chevron-down" size={24} strokeWidth={2} />
    </a>
  </section>

  {/* Tile grid POD hero (3×2). Pět scroll-anchor dlaždic + Rezervace tile
      jako šestá. Každá dlaždice má velký ribbon arc jako pozadí (peeká z
      pod typo), per spec § 04 banner influence (plakátovější vibe). */}
  <section class="lp-tiles" id="lp-jumps" aria-label="Skok do sekcí">
    <div class="lp-tiles__grid">
      {tiles.map((t) => (
        <a class={`lp-tile lp-tile--${t.variant} osa-nolink`} href={t.href}>
          <span class="lp-tile__ribbon" aria-hidden="true" data-ribbon-reveal>
            <svg viewBox="0 0 800 600" preserveAspectRatio="xMidYMid slice">
              <path d={t.path} />
            </svg>
          </span>
          <span class="lp-tile__type">
            <span class="lp-tile__label">{t.label}</span>
            <span class="lp-tile__sub">{t.sub}</span>
          </span>
          {/* Corner šipka dolů = scroll v rámci stránky. Liší se od Rezervace
              tile, kde je arrow-up-right (= odkaz pryč na jinou stránku). */}
          <span class="lp-tile__arrow lp-tile__arrow--scroll" aria-hidden="true">
            <Icon name="chevron-down" size={18} strokeWidth={2} />
          </span>
        </a>
      ))}

      <a class="lp-tile lp-tile--reserve osa-nolink" href={withBase('/rezervace/')}>
        <span class="lp-tile__ribbon" aria-hidden="true" data-ribbon-reveal>
          <svg viewBox="0 0 800 600" preserveAspectRatio="xMidYMid slice">
            <path d="M 540 80 C 720 100, 760 240, 600 320 C 460 400, 380 280, 540 200" />
          </svg>
        </span>
        <span class="lp-tile__type">
          <span class="lp-tile__label">Rezervujte si <em>místo</em></span>
          <span class="lp-tile__sub">Nezávazná, ozveme se do 24 h.</span>
        </span>
        <span class="lp-tile__arrow lp-tile__arrow--cross" aria-hidden="true">
          <Icon name="arrow-up-right" size={18} strokeWidth={2} />
        </span>
      </a>
    </div>
  </section>

  {/* ============ ZIG-ZAG SEKCE (5 řad, one-pager) ============ */}
  <div class="lp-sections">
    {sections.map((sec) => (
      <>
        <section class="lp-section" id={sec.id} aria-labelledby={`${sec.id}-title`}>
          <span class="lp-section__ribbon" aria-hidden="true" data-ribbon-reveal>
            <svg viewBox="0 0 1600 600" preserveAspectRatio="none">
              <path d={sec.ribbonPath} vector-effect="non-scaling-stroke" />
            </svg>
          </span>
          <div class="lp-section__inner">
            <div class="lp-section__text">
              <p class="lp-section__eyebrow">{sec.eyebrow}</p>
              <h2 class="lp-section__title" id={`${sec.id}-title`}>{sec.title}</h2>
              <p class="lp-section__lede">{sec.lede}</p>
              <div class="lp-section__ctas">
                {sec.ctas.map((cta) => (
                  <a class="lp-section__cta osa-nolink" href={withBase(cta.href)}>
                    <span class="lp-section__cta-arrow" aria-hidden="true">↗</span>
                    <span class="lp-section__cta-label">{cta.label}</span>
                  </a>
                ))}
              </div>
            </div>
            <div class="lp-section__media">
              <Gallery images={sec.gallery} ariaLabel={sec.eyebrow} aspectRatio="4 / 3" />
            </div>
          </div>

          {sec.id === 'ubytovani' && (
            <div class="lp-summary">
              {/* === Karta 1: Co-living (krátký souhrn, ne per-varianta breakdown) === */}
              <article class="lp-summary__card" aria-labelledby="lp-summary-coliving-h">
                <header class="lp-summary__head">
                  <h3 class="lp-summary__h" id="lp-summary-coliving-h">Co-living</h3>
                  <p class="lp-summary__sub">Kapsle a&nbsp;lůžka ve&nbsp;sdílených pokojích.</p>
                </header>
                <dl class="lp-summary__facts">
                  <div class="lp-summary__row">
                    <dt class="lp-summary__dt">Počet variant</dt>
                    <dd class="lp-summary__dd">4 (jednolůžková a&nbsp;dvoulůžková kapsle, jednolůžko a&nbsp;dvoulůžko)</dd>
                  </div>
                  <div class="lp-summary__row">
                    <dt class="lp-summary__dt">Pro koho</dt>
                    <dd class="lp-summary__dd">1 osoba nebo pár</dd>
                  </div>
                  <div class="lp-summary__row">
                    <dt class="lp-summary__dt">Plocha</dt>
                    <dd class="lp-summary__dd">matrace 200×80 cm až 230×240 cm</dd>
                  </div>
                  <div class="lp-summary__row">
                    <dt class="lp-summary__dt">Soukromí</dt>
                    <dd class="lp-summary__dd">uzamykatelný modul nebo vlastní postel v&nbsp;pokoji</dd>
                  </div>
                  <div class="lp-summary__row">
                    <dt class="lp-summary__dt">Cena od</dt>
                    <dd class="lp-summary__dd lp-summary__dd--price">3&nbsp;000&nbsp;Kč/měsíc · od 2&nbsp;250&nbsp;Kč při roční smlouvě</dd>
                  </div>
                </dl>
                <a class="lp-summary__cta osa-nolink" href={withBase('/ubytovani/#ub-coliving-title')}>
                  <span class="lp-summary__cta-arrow" aria-hidden="true">↗</span>
                  <span class="lp-summary__cta-label">Zobrazit kapsle a&nbsp;lůžka</span>
                </a>
              </article>

              {/* === Karta 2: Privátní apartmány (krátký souhrn) === */}
              <article class="lp-summary__card" aria-labelledby="lp-summary-privatni-h">
                <header class="lp-summary__head">
                  <h3 class="lp-summary__h" id="lp-summary-privatni-h">Privátní apartmány</h3>
                  <p class="lp-summary__sub">Vlastní byt, kuchyň, koupelna.</p>
                </header>
                <dl class="lp-summary__facts">
                  <div class="lp-summary__row">
                    <dt class="lp-summary__dt">Počet velikostí</dt>
                    <dd class="lp-summary__dd">5 (1+kk až 5+kk)</dd>
                  </div>
                  <div class="lp-summary__row">
                    <dt class="lp-summary__dt">Pro koho</dt>
                    <dd class="lp-summary__dd">2 až 10 osob</dd>
                  </div>
                  <div class="lp-summary__row">
                    <dt class="lp-summary__dt">Plocha</dt>
                    <dd class="lp-summary__dd">21 až 105 m²</dd>
                  </div>
                  <div class="lp-summary__row">
                    <dt class="lp-summary__dt">Soukromí</dt>
                    <dd class="lp-summary__dd">vlastní vchod, koupelna a&nbsp;kuchyň</dd>
                  </div>
                  <div class="lp-summary__row">
                    <dt class="lp-summary__dt">Cena od</dt>
                    <dd class="lp-summary__dd lp-summary__dd--price">9&nbsp;500&nbsp;Kč/měsíc · od 7&nbsp;600&nbsp;Kč při roční smlouvě</dd>
                  </div>
                </dl>
                <a class="lp-summary__cta osa-nolink" href={withBase('/ubytovani/#ub-privatni-title')}>
                  <span class="lp-summary__cta-arrow" aria-hidden="true">↗</span>
                  <span class="lp-summary__cta-label">Zobrazit apartmány</span>
                </a>
              </article>
            </div>
          )}

        </section>
      </>
    ))}
  </div>

  {/* ============ FINÁLNÍ CTA BANNER ============
       SH/07 ribbon banner styling (plum-deep + plum stroke). Contained,
       ne full-bleed, žije uvnitř container-wide stejně jako landing sekce.
       Pod ním footer (plum-deep), čímž celý spodek zaplaví plum. */}
  <section class="lp-cta-wrap" aria-label="Závěrečná výzva k registraci">
    <a class="lp-cta-banner osa-nolink" href={withBase('/rezervace/')} data-ribbon-reveal>
      <span class="lp-cta-banner__bg" aria-hidden="true">
        <svg viewBox="0 0 2100 700" preserveAspectRatio="xMidYMid slice">
          <path d="M 1280 80 C 1580 140, 1900 320, 1920 520 C 1940 680, 1600 720, 1460 540" />
        </svg>
      </span>
      <span class="lp-cta-banner__type">
        <span class="lp-cta-banner__eyebrow">Rezervace</span>
        <span class="lp-cta-banner__h">Rezervujte si <em>místo</em>.</span>
        <span class="lp-cta-banner__lede">
          Vyberete pokoj, termín a způsob kontaktu. Z rezervačního oddělení vám zavoláme do 24 hodin.
        </span>
      </span>
      <span class="lp-cta-banner__cta">
        Nezávazná rezervace<span aria-hidden="true"> →</span>
      </span>
