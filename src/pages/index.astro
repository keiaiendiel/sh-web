<script is:inline>
  document.addEventListener('astro:page-load', () => {
    // Reveal-on-scroll for zigzag rows. Element-level idempotency so re-runs
    // on view-transition navigation only bind freshly-rendered rows. Two
    // safety nets so rows never get stuck invisible: (1) any row already in
    // viewport gets revealed synchronously after observer setup, (2) a
    // 1.2 s timeout reveals all remaining rows as a fallback if IO misses.
    const rows = Array.from(document.querySelectorAll('[data-zigzag-reveal]:not([data-zigzag-bound])'));
    rows.forEach((r) => { r.dataset.zigzagBound = '1'; });
    if (rows.length) {
      if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
        rows.forEach((r) => r.classList.add('is-revealed'));
      } else {
        const io = new IntersectionObserver((entries) => {
          entries.forEach((e) => {
            if (e.isIntersecting) {
              e.target.classList.add('is-revealed');
              io.unobserve(e.target);
            }
          });
        }, { rootMargin: '0px 0px -8% 0px', threshold: 0.05 });
        rows.forEach((r) => io.observe(r));
        // Synchronous reveal pass for rows already in viewport at bind time.
        requestAnimationFrame(() => {
          const vh = window.innerHeight || document.documentElement.clientHeight;
          rows.forEach((r) => {
            const rect = r.getBoundingClientRect();
            if (rect.top < vh && rect.bottom > 0) {
              r.classList.add('is-revealed');
              io.unobserve(r);
            }
          });
        });
        // Fallback: if anything is still hidden after 1.2 s, show it anyway.
        setTimeout(() => {
          rows.forEach((r) => r.classList.add('is-revealed'));
        }, 1200);
      }
    }

    // Image lightbox — opens on click of [data-zoom-open], closes on ESC,
    // backdrop click or close button. Reusable for any single-image trigger.
    const zoom = document.getElementById('hub-zoom');
    const zoomTriggers = document.querySelectorAll('[data-zoom-open]:not([data-zoom-bound])');
    if (zoom && zoomTriggers.length) {
      zoomTriggers.forEach((t) => { t.dataset.zoomBound = '1'; });
      const zoomImg = zoom.querySelector('.hub-zoom__img');
      const openZoom = (src, alt) => {
        zoomImg.src = src;
        zoomImg.alt = alt || '';
        zoom.hidden = false;
        requestAnimationFrame(() => zoom.classList.add('is-open'));
        document.documentElement.classList.add('osa-nav-lock');
      };
      const closeZoom = () => {
        zoom.classList.remove('is-open');
        document.documentElement.classList.remove('osa-nav-lock');
        setTimeout(() => { zoom.hidden = true; zoomImg.src = ''; }, 220);
      };
      zoomTriggers.forEach((t) => {
        t.addEventListener('click', () => {
          openZoom(t.dataset.zoomSrc || t.querySelector('img')?.src, t.dataset.zoomAlt);
        });
      });
      zoom.querySelector('.hub-zoom__close').addEventListener('click', closeZoom);
      zoom.addEventListener('click', (e) => { if (e.target === zoom) closeZoom(); });
      document.addEventListener('keydown', (e) => {
        if (!zoom.hidden && e.key === 'Escape') closeZoom();
      });
    }

    // Leaflet map under "Místo" — same pattern as /o-arealu/.
    const mapEl = document.getElementById('hub-landing-map');
    if (mapEl && !mapEl.dataset.mapBound && typeof L !== 'undefined') {
      mapEl.dataset.mapBound = '1';
      const center = [50.181447059112294, 14.424094125168379];
      const map = L.map(mapEl, {
        center, zoom: 16,
        zoomControl: false, attributionControl: false,
        scrollWheelZoom: false,
      });
      L.tileLayer('https://{s}.basemaps.cartocdn.com/rastertiles/voyager_nolabels/{z}/{x}/{y}{r}.png', {
        attribution: '&copy; <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a> &copy; <a href="https://carto.com/">CARTO</a>',
        subdomains: 'abcd', maxZoom: 19,
      }).addTo(map);
      const icon = L.divIcon({
        html:
          '<svg width="30" height="40" viewBox="0 0 28 36" fill="none" xmlns="http://www.w3.org/2000/svg">' +
          '<path d="M14 0C6.27 0 0 6.27 0 14c0 9.33 14 22 14 22S28 23.33 28 14C28 6.27 21.73 0 14 0z" fill="#5A2A5F"/>' +
          '<circle cx="14" cy="14" r="5" fill="#ffffff"/>' +
          '</svg>',
        className: '', iconSize: [30, 40], iconAnchor: [15, 40], popupAnchor: [0, -42],
      });
      const gmaps = 'https://maps.app.goo.gl/vCF6VbW7Z49sggau6';
      const popupHtml =
        '<a href="' + gmaps + '" target="_blank" rel="noopener" class="op-map-popup">' +
          '<strong>Horní kasárna Klecany</strong>' +
          '<span class="op-map-popup__cta">Otevřít v Mapách →</span>' +
        '</a>';
      L.marker(center, { icon })
        .addTo(map)
        .bindPopup(popupHtml, { className: 'op-map-popup-wrap' })
        .openPopup()
        .on('click', () => window.open(gmaps, '_blank'));
      L.control.attribution({ prefix: false }).addTo(map);
      L.control.zoom({ position: 'bottomright' }).addTo(map);
      mapEl.addEventListener('click', () => map.scrollWheelZoom.enable(), { once: true });
    }
  });
</script>

<style>
  /* HERO -- full-bleed slide carousel + scrim, content above. */
  .hub-hero {
    position: relative;
    isolation: isolate;
    min-height: clamp(560px, 88vh, 820px);
    display: flex;
    align-items: flex-end;
    background: var(--k-100);
    color: #fff;
    overflow: hidden;
  }
  .hub-hero__bg-stack { position: absolute; inset: 0; z-index: 1; overflow: hidden; }
  .hub-hero__bg {
    position: absolute; inset: 0;
    width: 100%; height: 100%;
    object-fit: cover;
    filter: brightness(0.7) saturate(0.92);
    transform: translateX(100%);
    will-change: transform;
    animation-name: hub-hero-slide;
    animation-duration: 20s;
    animation-iteration-count: infinite;
    animation-timing-function: cubic-bezier(0.5, 0, 0.2, 1);
  }
  /* Negative delay on image 0 so it starts already on-screen at 5% of cycle. */
  .hub-hero__bg--0 { animation-delay: -1s; }
  .hub-hero__bg--1 { animation-delay: 4s;  }
  .hub-hero__bg--2 { animation-delay: 9s;  }
  .hub-hero__bg--3 { animation-delay: 14s; }

  @keyframes hub-hero-slide {
    0%      { transform: translateX(100%); }
    5%      { transform: translateX(0); }
    25%     { transform: translateX(0); }
    30%     { transform: translateX(-100%); }
    100%    { transform: translateX(-100%); }
  }
  @media (prefers-reduced-motion: reduce) {
    .hub-hero__bg                        { animation: none; transform: translateX(100%); }
    .hub-hero__bg--0                     { transform: translateX(0); }
  }
  .hub-hero__scrim {
    position: absolute; inset: 0; z-index: 2;
    background: linear-gradient(180deg, rgba(0,0,0,0.30) 0%, rgba(0,0,0,0.18) 38%, rgba(0,0,0,0.72) 100%);
    pointer-events: none;
  }
  .hub-hero__inner {
    position: relative; z-index: 3;
    padding: clamp(72px, 10vw, 112px) var(--gutter) clamp(56px, 8vw, 88px);
    max-width: var(--container-wide); margin: 0 auto; width: 100%;
    display: grid; gap: clamp(24px, 3vw, 36px);
  }
  /* Entrance cascade — each hero child lifts and fades in with a 90ms step.
     Runs once per element instantiation (fresh on cold load AND after every
     view-transition arrival, since main is replaced). Reduced-motion below
     skips the keyframes entirely. */
  .hub-hero__inner > * {
    animation: hub-hero-enter 720ms cubic-bezier(0.16, 1, 0.3, 1) both;
  }
  .hub-hero__inner > *:nth-child(1) { animation-delay:  60ms; }
  .hub-hero__inner > *:nth-child(2) { animation-delay: 150ms; }
  .hub-hero__inner > *:nth-child(3) { animation-delay: 240ms; }
  .hub-hero__inner > *:nth-child(4) { animation-delay: 330ms; }
  @keyframes hub-hero-enter {
    from { opacity: 0; transform: translateY(14px); }
    to   { opacity: 1; transform: translateY(0); }
  }
  @media (prefers-reduced-motion: reduce) {
    .hub-hero__inner > * { animation: none; }
  }
  .hub-hero__kicker-row {
    display: flex; align-items: baseline; justify-content: space-between;
    gap: 24px; flex-wrap: wrap;
    /* Match the visible width of "Startovací hub." H1 so the right kicker
       lines up just beyond the end of the word "hub.". */
    max-width: clamp(320px, 48vw, 660px);
  }
  .hub-hero__kicker     { color: rgba(255,255,255,0.78); }
  .hub-hero__kicker-out {
    color: rgba(255,255,255,0.78);
    text-decoration: underline;
    text-decoration-thickness: 1px;
    text-underline-offset: 4px;
    text-decoration-color: rgba(255,255,255,0.4);
    transition:
      color var(--dur-fast) linear,
      text-decoration-color var(--dur-fast) linear;
  }
  .hub-hero__kicker-out:hover {
    color: #fff;
    text-decoration-color: #fff;
  }
  .hub-hero__title {
    font-family: var(--font-sans); font-weight: 600;
    font-size: clamp(48px, 7vw, 96px);
    line-height: 1.0; letter-spacing: -0.025em;
    margin: 0; max-width: 14ch;
  }
  .hub-hero__lede {
    font-size: clamp(16px, 1.35vw, 19px);
    line-height: 1.55;
    /* Lede max-width škáluje s H1 (clamp(48px, 7vw, 96px) × 14ch ≈ width)
       takže pravý okraj řádku lede sedí přibližně na konci „Startovací Hub.". */
    max-width: clamp(20em, 36vw, 32em);
    color: rgba(255,255,255,0.88);
    margin: 0;
  }
  /* Hero CTA — outline at rest, white wipe fills from bottom on hover.
     Pattern A (outline → fill): default white border + white text;
     on hover the white fill rises from the bottom, text turns black. */
  .hub-hero__cta {
    position: relative;
    isolation: isolate;
    overflow: hidden;
    justify-self: start;
    display: inline-flex; align-items: center; gap: 8px;
    padding: 16px 32px;
    background: transparent;
    color: #fff;
    border: 1px solid #fff;
    border-radius: var(--radius-input);
    font: 600 17px / 1 var(--font-sans);
    text-decoration: none;
    margin-top: 8px;
    transition: color 160ms cubic-bezier(0.65, 0, 0.35, 1);
  }
  .hub-hero__cta::after {
    content: "";
    position: absolute;
    inset: 0;
    background: #fff;
    z-index: -1;
    clip-path: inset(100% 0 0 0);
    transition: clip-path 220ms cubic-bezier(0.65, 0, 0.35, 1);
  }
  .hub-hero__cta:hover::after,
  .hub-hero__cta:focus-visible::after {
    clip-path: inset(0 0 0 0);
  }
  .hub-hero__cta:hover,
  .hub-hero__cta:focus-visible { color: var(--k-100); }
  .hub-hero__cta:focus-visible {
    outline: 2px solid #fff;
    outline-offset: 3px;
  }
  .hub-hero__cta:active { transform: translateY(1px); }
  @media (prefers-reduced-motion: reduce) {
    .hub-hero__cta,
    .hub-hero__cta::after { transition: none; }
  }
  @media (max-width: 720px) {
    .hub-hero__kicker-out { display: none; }
  }

  /* SECTION SHELL */
  .hub-section {
    padding: clamp(48px, 6vw, 72px) var(--gutter);
    max-width: var(--container-wide);
    margin: 0 auto;
  }
  .hub-section__heading {
    font-family: var(--font-sans);
    font-size: clamp(28px, 3vw, 44px);
    font-weight: 600;
    margin: 0;
    letter-spacing: var(--tracking-tight);
    line-height: 1.1;
    text-wrap: balance;
  }
  .hub-section__intro {
    font-size: 18px;
    color: var(--fg-muted);
    margin: 0 0 32px;
    max-width: 720px;
    line-height: 1.55;
  }
  .osa-sub-head { margin-bottom: 32px; }
  .osa-sub-head .osa-eyebrow { color: var(--fg-subtle); display: block; margin-bottom: 8px; }

  /* FORMATS GRID — 3-up cards under hero. */
  .hub-formats__grid {
    display: grid; gap: 24px;
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }
  @media (max-width: 960px) { .hub-formats__grid { grid-template-columns: 1fr; gap: 20px; } }
  .hub-format-card {
    display: grid; gap: 12px;
    border: 1px solid var(--border-muted);
    border-radius: var(--radius-input);
    background: var(--bg);
    padding: 0 0 20px;
    transition: border-color var(--dur-base) var(--ease-decel);
  }
  .hub-format-card:hover { border-color: var(--accent); }
  .hub-format-card__media {
    margin: 0;
    border-radius: var(--radius-input) var(--radius-input) 0 0;
    overflow: hidden;
    aspect-ratio: 4/3;
  }
  .hub-format-card__media img {
    width: 100%; height: 100%;
    object-fit: cover; display: block;
  }
  .hub-format-card h3 {
    font-size: 17px; font-weight: 600;
    margin: 4px 20px 0; line-height: 1.3;
  }
  .hub-format-card p {
    font-size: 14px; line-height: 1.55;
    color: var(--fg-muted); margin: 0 20px;
  }
  .hub-formats__note {
    margin-top: 32px;
    font-size: 14px; line-height: 1.55;
    color: var(--fg-muted);
    max-width: 880px;
  }

  /* AMENITY GRID — 14 sdílených provozů s ikonkami. Stejný rámeček jako
     hub-claims pod ní: outer border + radius, vnitřní hairlines per-cell
     border-right / border-bottom s edge stripping, žádný gap+bg trik (ten
     šedil prázdné cells v poslední row). */
  .hub-amenities__grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    border: 1px solid var(--border-muted);
    border-radius: var(--radius-input);
    overflow: hidden;
    background: var(--bg);
    padding: 0 !important;
  }
  @media (max-width: 960px) { .hub-amenities__grid { grid-template-columns: repeat(2, minmax(0, 1fr)); } }
  @media (max-width: 560px) { .hub-amenities__grid { grid-template-columns: 1fr; } }
  .hub-amenity-card {
    /* Padding-bottom rezervuje vždy místo pro „Detail →" CTA, který je
       absolutně pozicovaný — díky tomu se layout nemění mezi linked a
       non-linked kartami a hover nepřesouvá obsah okolních dlaždic. */
    display: grid; gap: 8px;
    padding: 28px 24px 52px;
    background: var(--bg);
    align-content: start;
    color: inherit;
    text-decoration: none;
    position: relative;
    border-right: 1px solid var(--border-muted);
    border-bottom: 1px solid var(--border-muted);
    transition: box-shadow 320ms var(--ease-decel);
  }
  /* Edge stripping — předpokládá 14 položek (poslední row má 2 karty na
     desktop+tablet, 1 na mobilu). Pokud se počet změní, přepočítat selectory. */
  .hub-amenity-card:nth-child(4n) { border-right: none; }
  .hub-amenity-card:nth-last-child(-n+2) { border-bottom: none; }
  @media (max-width: 960px) {
    .hub-amenity-card { border-right: 1px solid var(--border-muted); }
    .hub-amenity-card:nth-child(4n) { border-right: 1px solid var(--border-muted); }
    .hub-amenity-card:nth-child(2n) { border-right: none; }
  }
  @media (max-width: 560px) {
    /* Mobile = compact list. Karta = jeden řádek: ikonka + nadpis vedle sebe,
       bez body textu, bez CTA. Klikatelný cíl zůstává linked sub-projekt page. */
    .hub-amenity-card,
    .hub-amenity-card:nth-child(2n) { border-right: none; }
    .hub-amenity-card:nth-last-child(-n+2) { border-bottom: 1px solid var(--border-muted); }
    .hub-amenity-card:last-child { border-bottom: none; }
    .hub-amenity-card {
      grid-template-columns: auto 1fr auto;
      align-items: center;
      gap: 14px;
      padding: 14px 16px;
    }
    .hub-amenity-card__icon {
      width: 32px;
      height: 32px;
      border-radius: 8px;
    }
    .hub-amenity-card__icon :global(svg) {
      width: 18px;
      height: 18px;
    }
    .hub-amenity-card__title {
      font-size: 15px;
      line-height: 1.3;
      margin: 0;
    }
    .hub-amenity-card__body { display: none; }
    /* Detail → padá zarovnaný do třetí grid kolonky (auto), zrcadlový
       protějšek ikonky vlevo. Class-chain selektor (.x.x) bumpne specificity
       nad desktop base rule, který je v zdrojáku níž a má position:absolute
       + left:24px (jinak by šipka spadla absolutně přes ikonu). */
    .hub-amenity-card.hub-amenity-card .hub-amenity-card__cta {
      position: static;
      inset: auto;
      opacity: 1;
      font-size: 20px;
      line-height: 1;
      color: var(--accent);
      font-weight: 600;
      display: inline-flex;
      align-items: center;
      justify-self: end;
      transform: translateY(-1px);
    }
    .hub-amenity-card__cta-text { display: none; }
  }
  .hub-amenity-card--linked { cursor: pointer; }
  /* Hover signál: 2px plumový tah uvnitř karty (inset). Hairlines zůstávají,
     přidává se jen accent stroke + delights na ikonu a CTA. Non-linked
     dlaždice hover state nemají — nikam nevedou. */
  .hub-amenity-card--linked:hover,
  .hub-amenity-card--linked:focus-visible {
    box-shadow: inset 0 0 0 2px var(--accent);
    outline: none;
  }
  .hub-amenity-card__cta {
    position: absolute;
    bottom: 22px;
    left: 24px;
    font-size: 12px; font-weight: 600;
    color: var(--accent);
    letter-spacing: 0.02em;
    opacity: 0;
    transition: opacity 320ms var(--ease-decel);
  }
  .hub-amenity-card--linked:hover .hub-amenity-card__cta,
  .hub-amenity-card--linked:focus-visible .hub-amenity-card__cta {
    opacity: 1;
  }
  .hub-amenities__more {
    margin: 28px auto 0;
    max-width: var(--container-wide);
    padding: 0 var(--gutter);
    font-size: 14px;
  }
  .hub-amenities__more a {
    color: var(--accent); font-weight: 600;
    text-decoration: none;
  }
  .hub-amenities__more a:hover { text-decoration: underline; }
  /* Lucide ikonku rendrujeme jako inline SVG (přes Icon.astro). Tile drží
     ikonku v plumovém rámečku se soft accent pozadím — uniformní pro
     všech 14 amenit, žádné per-icon CSS bloky. Změna ikonky = jen
     `icon: 'name'` v provozyServices. */
  .hub-amenity-card__icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 40px; height: 40px;
    background: var(--accent-soft);
    color: var(--accent);
    border-radius: 10px;
    flex-shrink: 0;
  }
  .hub-amenity-card__icon :global(svg) {
    width: 22px; height: 22px;
    stroke: currentColor;
  }
  .hub-amenity-card__title {
    font-family: var(--font-sans);
    font-size: 17px; font-weight: 600;
    margin: 4px 0 0;
    line-height: 1.3;
    letter-spacing: var(--tracking-tight);
    /* Title zůstává černý i na hover — plum barva by snížila kontrast a
       celá karta by působila „šedivěji". Hover signál nese stroke + Detail. */
  }
  .hub-amenity-card__body {
    font-size: 14px; line-height: 1.55;
    color: var(--fg-muted);
    margin: 0;
  }

  /* PŘÍPRAVNÉ DRUŽSTVO — full-width prominent card. Plum frame + accent emphasis. */
  .hub-druzstvo {
    padding: clamp(40px, 5vw, 64px) var(--gutter);
