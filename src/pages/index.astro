---
import Base from '../layouts/Base.astro';
import Gallery from '../components/Gallery.astro';
import Icon from '../components/Icon.astro';
import RoomCard from '../components/RoomCard.astro';
import { getCollection } from 'astro:content';
import { withBase } from '../utils/url';

/* Room collections pro 2-sloupcový picker pod Ubytováním sekcí. */
const apartmany = (await getCollection('apartmany')).sort((a, b) => a.data.order - b.data.order);
const coliving = (await getCollection('coliving')).sort((a, b) => a.data.order - b.data.order);
const coligvingVelikost: Record<string, string> = {
  'kapsle-single': 'kapsle ve sdíleném pokoji',
  'jedno-luzko':   'lůžko ve sdíleném pokoji',
  'kapsle-double': 'kapsle ve sdíleném pokoji',
  'dvouluzko':     'celý pokoj v patrovém bytě',
};
const colivingKapacita: Record<string, string> = {
  'kapsle-single': '1 osoba',
  'jedno-luzko':   '1 osoba',
  'kapsle-double': '1-2 osoby',
  'dvouluzko':     '1-2 osoby',
};

/* Phase 2 landing per SH_Web_Site_Copy.md § 0.1 + SH_Web_Visualization_List
   § 1.1 + 1.2. Hero rotace 4 záběrů (Tier A rendery z vault hero-update),
   „Co Hub nabízí" 4 karty s horizontal scroll-snap gallery, section teasery
   pro 8 sekcí, masterplan, finální CTA panel.

   Hero rotace: swipe přes 4 slidy, 5 s na slide, 20 s celkový cyklus.
   `prefers-reduced-motion: reduce` zastaví na slide 1. */

/* === HERO ROTACE (4 záběry) === */
/* Tier A rendery z vault Visualizations/h - Hero/hero-update.
   Každý slide má desktop (landscape) a phone (portrait) variantu,
   <picture> přepíná v zlomu 768 px. */
const heroSlides = [
  {
    desktop: withBase('/images/hub/hero/h01.jpg'),
    phone:   withBase('/images/hub/hero/h01-phone.jpg'),
    alt: 'Privátní apartmány v parteru po setmění, lidé před vstupem mezi břízami, teplá světla v oknech.',
  },
  {
    desktop: withBase('/images/hub/hero/h02.jpg'),
    phone:   withBase('/images/hub/hero/h02-phone.jpg'),
    alt: 'Chodba s privátními kapslemi v dřevěném obložení, lavice a rostlina v lounge, tlumené ambientní světlo.',
  },
  {
    desktop: withBase('/images/hub/hero/h03.jpg'),
    phone:   withBase('/images/hub/hero/h03-phone.jpg'),
    alt: 'Vnitřní dvůr areálu za modré hodiny, lidé u dlouhého stolu venku, světla v oknech renovovaných budov.',
  },
  {
    desktop: withBase('/images/hub/hero/h04.jpg'),
    phone:   withBase('/images/hub/hero/h04-phone.jpg'),
    alt: 'Privátní apartmán 1+kk: žena vaří v kuchyni, muž čte u stolu, postel u okna, teplé večerní světlo.',
  },
];

/* === SEKCE ZIG-ZAG (6 řad, one-pager) === */
/* Každá sekce má anchor id pro scroll z jump strip pod hero. Eyebrow +
   title + lede + CTA do detail page na jedné straně, gallery (chevron +
   dot pagination, scroll-snap) na druhé. Sudé řady mají gallery vlevo
   přes :nth-of-type(even) flip. Copy per Site_Copy § 0.4.1 a sekční
   intra § 1-6. */
type GalleryItem =
  | { src: string; alt: string }
  | { placeholder: string; alt: string };
type Section = {
  id: string;
  eyebrow: string;
  title: string;
  lede: string;
  href: string;
  detailLabel: string;
  gallery: GalleryItem[];
};

const sections: Section[] = [
  {
    id: 'ubytovani',
    eyebrow: 'Ubytování',
    title: 'Devět typů, od kapsle po byt 5+kk.',
    lede: 'Privátní apartmány 1+kk až 5+kk, dvě kapsle a dva sdílené pokoje. Energie, internet, úklid společných prostor, pět jízd Hub-shuttle do metra Kobylis měsíčně a poukaz do sauny týdně v ceně.',
    href: '/ubytovani/',
    detailLabel: 'Možnosti ubytování',
    gallery: [
      { src: withBase('/images/hub/ubytovani/landing-window-dusk.jpg'), alt: 'Privátní apartmán zvenku za soumraku, osoba u okna pracuje u stolu při svitu lampy.' },
      { src: withBase('/images/hub/ubytovani/landing-1kk-wide.jpg'), alt: 'Privátní apartmán 1+kk: žena vaří v kuchyni, muž čte u stolu, postel u okna, teplé večerní světlo.' },
      { src: withBase('/images/hub/ubytovani/landing-capsules.jpg'), alt: 'Privátní kapsle ve dvou patrech, dřevěná obložení a tlumené ambientní světlo.' },
      { src: withBase('/images/hub/ubytovani/landing-1kk-small.jpg'), alt: 'Privátní apartmán 1+kk se sníženými proporcemi, postel u okna, kuchyňský kout a jídelní stůl.' },
      { src: withBase('/images/hub/ubytovani/landing-exterior.jpg'), alt: 'Privátní apartmány v parteru po setmění, lidé před vstupem mezi břízami, teplá světla v oknech.' },
    ],
  },
  {
    id: 'coworking',
    eyebrow: 'Coworking',
    title: 'Sál, fixní stůl, ateliér nebo dílna.',
    lede: 'Pět typů pracovních prostor v budově C: volný stůl v sále 24/7, fixní stůl s vlastní skříňkou, sdílená kancelář pro čtyři, zasedací místnost na hodinovou rezervaci. Ateliéry a dílny s těžkými stroji v samostatných objektech.',
    href: '/coworking/',
    detailLabel: 'Coworking, dílny a ateliéry',
    gallery: [
      { src: withBase('/images/hub/coworking/budova-c-exterior.jpg'), alt: 'Budova C zvenku, parter s hlavním vstupem do coworkingu a komunitního zázemí.' },
      { src: withBase('/images/hub/coworking/budova-c-interior.jpg'), alt: 'Interiér budovy C, společný prostor pro coworking a komunitní akce.' },
      { placeholder: 'cw03 Zasedací místnost s týmem 4 až 6 lidí, prezentace na obrazovku', alt: 'Zasedací místnost v budově C v plné akci.' },
      { placeholder: 'cw04 Ateliér nebo dílna v D1 nebo H1 až H3, hardware a nářadí', alt: 'Ateliér nebo dílna s fyzickou prací mimo office.' },
    ],
  },
  {
    id: 'komunita',
    eyebrow: 'Komunita',
    title: 'Wellness, gastro, kultura, sport.',
    lede: 'Vlastní bazén a sauna v jádře areálu, jídelna s minipivovarem v budově B, klubovna v budově C, komunitní park s grilem. Pro rezidenty s dlouhým pobytem poukaz do sauny týdně v ceně.',
    href: '/komunita/',
    detailLabel: 'Komunitní program',
    gallery: [
      { src: withBase('/images/hub/komunita/bazen.jpg'), alt: 'Bazén v centrálním objektu areálu, letní odpoledne, sluneční terasa, relax po práci.' },
      { src: withBase('/images/hub/komunita/restaurant.jpg'), alt: 'Komunitní restaurace v budově B v plném provozu, dlouhé stoly, otevřená kuchyně, lidé u oběda.' },
      { src: withBase('/images/hub/komunita/courtyard.jpg'), alt: 'Vnitřní dvůr areálu za modré hodiny, lidé u dlouhého stolu venku, světla v oknech renovovaných budov.' },
      { src: withBase('/images/hub/komunita/klubovna.jpg'), alt: 'Klubovna v budově C s eventem, lidé u stolů, kulturní život uvnitř Hubu.' },
      { src: withBase('/images/hub/komunita/04.jpg'), alt: 'Vnitřní dvůr za soumraku, lidé procházejí mezi rozsvícenými budovami, kola u stojanu, atmosféra komunitního večera.' },
      { placeholder: 'ko01 Grilovací místo, rodinné grilování v sobotu poledne, 8 až 12 lidí', alt: 'Grilovací místo v komunitním parku v sobotní poledne.' },
    ],
  },
  {
    id: 'okoli',
    eyebrow: 'Místo a okolí',
    title: 'Horní kasárny v Klecanech, 15 km severně od Prahy.',
    lede: 'Bývalý vojenský areál nad pravým břehem Vltavy, který otevíráme po etapách od roku 2026. V docházkové vzdálenosti Montessori školka Astra (přímo v areálu), praktický lékař, lékárna, pošta a balíkomaty. Skate hala v sousedním areálu, cyklostezka EuroVelo 7 podél Vltavy deset minut na kole.',
    href: '/okoli/',
    detailLabel: 'Co je v okolí',
    gallery: [
      { src: withBase('/images/hub/areal/masterplan_fotoreal.jpg'), alt: 'Fotorealistický masterplan areálu Horních kasáren, popisky budov A1 až A6, B, C, D, E, F, P, S a venkovního bazénu.' },
      { src: withBase('/images/hub/areal/topview.jpg'), alt: 'Letecký pohled na areál horních kasáren a obec Klecany v širším krajinném kontextu.' },
      { src: withBase('/images/hub/areal/building-a-1.jpg'), alt: 'Privátní apartmány A1 zvenku, dřevěný obklad, čistý parter, alej bříz podél cesty.' },
      { src: withBase('/images/hub/areal/building-a-2.jpg'), alt: 'Privátní apartmány A2, fasáda s pravidelnými okny, denní světlo a zeleň v popředí.' },
      { src: withBase('/images/hub/areal/building-b.jpg'), alt: 'Budova B, komunitní gastro blok, exteriér z hlavní cesty areálu.' },
      { src: withBase('/images/hub/areal/building-b-2.jpg'), alt: 'Budova B z druhého úhlu, vstup do tržnice a minipivovaru.' },
      { src: withBase('/images/hub/areal/building-d1.jpg'), alt: 'Budova D1 s ateliéry a dílnami pro tvořivou práci.' },
      { src: withBase('/images/hub/areal/building-e-f.jpg'), alt: 'Budovy E a F v zadní části areálu, doplňková infrastruktura Hubu.' },
      { src: withBase('/images/hub/areal/building-p.jpg'), alt: 'Budova P, technické zázemí v okrajové části areálu.' },
    ],
  },
  {
    id: 'doprava',
    eyebrow: 'Doprava',
    title: 'Patnáct minut autobusem na metro.',
    lede: 'Hub-shuttle do metra Kobylisy v ceně, pět jízd měsíčně. Bus 374 PID a Hub-taxi jako záloha. Cyklostezka EuroVelo 7 podél Vltavy, plánovaná tramvaj Kobylisy-Sedlec do roku 2030.',
    href: '/doprava/',
    detailLabel: 'Jak se sem dostanete',
    gallery: [
      { src: withBase('/images/hub/doprava/tram.jpg'), alt: 'Plánovaná tramvajová zastávka Výzkumný ústav I poblíž areálu (2029 až 2030).' },
      { src: withBase('/images/hub/doprava/cyklostezka.jpg'), alt: 'Cyklista na cyklostezce Praha až Klecany podél Vltavy.' },
      { placeholder: 'dp01 Hub-shuttle dodávka před hlavním vstupem, 3 až 4 rezidenti nastupují', alt: 'Hub-shuttle dodávka před hlavním vstupem do Hubu, ranní mlha.' },
      { placeholder: 'dp03 Zastávka autobusu 374 v Klecanech, U hřbitova', alt: 'Zastávka autobusu 374 jako záložní spoj na Kobylisy.' },
    ],
  },
  {
    id: 'stipendia',
    eyebrow: 'Stipendia',
    title: 'Pobytové stipendium.',
    lede: 'Rezident-tvůrce, work-trade správce, stavitel-rezident, rezident-programátor. Bydlení nebo zvýhodněná cena výměnou za hmatatelný vstup do života Hubu. Při registraci stačí zaškrtnout zájem, ozveme se s podmínkami a termíny.',
    href: '/stipendia/',
    detailLabel: 'Pobytová stipendia',
    gallery: [
      { placeholder: 'Ateliér s rezidentem-tvůrcem v práci, denní světlo, velký stůl', alt: 'Ateliér s rezidentem-tvůrcem v práci.' },
      { placeholder: 'Skupinový moment u stolu, společné plánování nebo večeře rezidentů', alt: 'Skupinový moment u stolu, společné plánování rezidentů.' },
      { placeholder: 'Rezident se stará o pozemek areálu', alt: 'Rezident se stará o pozemek areálu.' },
      { placeholder: 'Rezident-programátor u stolu s monitorem, kód na obrazovce', alt: 'Rezident-programátor u stolu s monitorem.' },
    ],
  },
];

/* === FEATURE CHIPS pod Coworking a Komunita ===
   Kompaktní řada kliknutelných chipů s Lucide ikonkou + label, pod
   zigzagem dané sekce. Každý chip linkuje na anchor v detail page. */
type Feature = { label: string; icon: string; href: string };
const coworkingFeatures: Feature[] = [
  { label: 'Coworkingový sál',  icon: 'laptop',       href: '/coworking/#cw-sal' },
  { label: 'Sdílená kancelář',  icon: 'users',        href: '/coworking/#cw-shared' },
  { label: 'Zasedací místnost', icon: 'presentation', href: '/coworking/#cw-zasedacka' },
  { label: 'Ateliéry a dílny',  icon: 'palette',      href: '/coworking/#cw-ateliery-dilny' },
];
const komunitaFeatures: Feature[] = [
  { label: 'Wellness',         icon: 'waves',            href: '/komunita/#km-wellness' },
  { label: 'Komunitní park',   icon: 'trees',            href: '/komunita/#km-park' },
  { label: 'Gastro',           icon: 'utensils-crossed', href: '/komunita/#km-gastro' },
  { label: 'Klubovna',         icon: 'party-popper',     href: '/komunita/#km-klubovna' },
];

/* === JUMP STRIP (pod hero) === */
/* Šest scroll anchorů na sekce níže + Rezervace odkaz na detail page.
   Anchor links využívají globální scroll-padding-top: 80px ze Base.astro. */
const navItems = [
  { href: '#ubytovani',   label: 'Ubytování',  icon: 'bed-double' },
  { href: '#coworking',   label: 'Coworking',  icon: 'briefcase' },
  { href: '#komunita',    label: 'Komunita',   icon: 'users' },
  { href: '#okoli',       label: 'Okolí',      icon: 'map-pin' },
  { href: '#doprava',     label: 'Doprava',    icon: 'bus' },
  { href: '#stipendia',   label: 'Stipendia',  icon: 'sparkles' },
  { href: withBase('/rezervace/'), label: 'Rezervace', icon: 'calendar-check', primary: true },
];
---
<Base
  title="Startovací Hub Klecany · Bydlení a coworking 15 min od Prahy"
  description="Devět typů bydlení od kapsle po byt 5+kk, coworking, dílny, sauna a kavárna. Horní kasárna Klecany, patnáct minut autobusem od metra Kobylisy. Od 3 000 Kč měsíčně, energie a internet v ceně."
  headerVariant="overlay">

  {/* ============ HERO ROTATION ============ */}
  <section class="lp-hero" aria-label="Startovací Hub Klecany, hero galerie">
    <div class="lp-hero__rotation" aria-hidden="true">
      {heroSlides.map((slide, i) => (
        <div class="lp-hero__slide" data-slide={i} style={`animation-delay: ${i * 5 - 1}s`}>
          <picture>
            <source media="(max-width: 768px)" srcset={slide.phone} />
            <img class="lp-hero__bg" src={slide.desktop} alt={slide.alt} loading={i === 0 ? 'eager' : 'lazy'} decoding="async" />
          </picture>
        </div>
      ))}
    </div>
    <div class="lp-hero__scrim" aria-hidden="true"></div>

    <div class="lp-hero__inner">
      <h1 class="lp-hero__title">Startovací Hub.</h1>
      <p class="lp-hero__lede">Na prahu metropole · Praha-sever</p>
    </div>

    {/* Jump strip uvnitř hero (desktop only). Bílé outline buttony + Rezervace white-fill. */}
    <nav class="lp-jumps lp-jumps--desktop" aria-label="Skok do sekcí">
      <div class="lp-jumps__inner">
        {navItems.map((item) => (
          <a class:list={['lp-jumps__item osa-nolink', item.primary && 'lp-jumps__item--primary']} href={item.href}>
            <Icon name={item.icon} size={16} strokeWidth={1.75} />
            {item.label}
          </a>
        ))}
      </div>
    </nav>
  </section>

  {/* Jump strip POD hero (mobile only). 3-col grid, čtvercové buttony s ikonkou nahoře a labelem dole. Rezervace přes celou šířku. */}
  <nav class="lp-jumps lp-jumps--mobile" aria-label="Skok do sekcí">
    <div class="lp-jumps__inner">
      {navItems.map((item) => (
        <a class:list={['lp-jumps__item osa-nolink', item.primary && 'lp-jumps__item--primary']} href={item.href}>
          <Icon name={item.icon} size={22} strokeWidth={1.75} />
          <span class="lp-jumps__label">{item.label}</span>
        </a>
      ))}
    </div>
  </nav>

  {/* ============ ZIG-ZAG SEKCE (6 řad, one-pager) ============ */}
  <div class="lp-sections">
    {sections.map((sec) => (
      <>
        <section class="lp-section" id={sec.id} aria-labelledby={`${sec.id}-title`}>
          <div class="lp-section__inner">
            <div class="lp-section__text">
              <p class="lp-section__eyebrow">{sec.eyebrow}</p>
              <h2 class="lp-section__title" id={`${sec.id}-title`}>{sec.title}</h2>
              <p class="lp-section__lede">{sec.lede}</p>
              <a class="lp-section__cta osa-nolink" href={withBase(sec.href)}>
                {sec.detailLabel}<span aria-hidden="true"> →</span>
              </a>
            </div>
            <div class="lp-section__media">
              <Gallery images={sec.gallery} ariaLabel={sec.eyebrow} aspectRatio="4 / 3" />
            </div>
          </div>

          {sec.id === 'ubytovani' && (
            <div class="lp-rooms">
              <div class="lp-rooms__group">
                <a class="lp-rooms__eyebrow osa-nolink" href={withBase('/ubytovani/#ub-coliving-title')}>
                  Co-living<span aria-hidden="true"> →</span>
                </a>
                <div class="lp-rooms__picker" data-gallery role="region" aria-roledescription="carousel" aria-label="Karty co-living variant">
                  <div class="lp-rooms__strip" data-gallery-viewport tabindex="0">
                    {coliving.map((c) => (
                      <div class="lp-rooms__slide" data-gallery-slide>
                        <RoomCard
                          eyebrow={c.data.shortName}
                          name={c.data.name}
                          velikost={coligvingVelikost[c.data.slug] ?? 've sdíleném pokoji'}
                          kapacita={colivingKapacita[c.data.slug] ?? '1 osoba'}
                          popis={c.data.popis}
                          cenaAnchor={c.data.cena.anchor}
                          perOsoba={c.data.cena.perOsoba}
                          thumbnail={c.data.thumbnail}
                          detailHref={withBase(`/ubytovani/co-living/${c.data.slug}/`)}
                          reserveHref={withBase(`/rezervace/?typ=${c.data.slug}`)}
                        />
                      </div>
                    ))}
                  </div>
                  <div class="lp-rooms__controls" role="group" aria-label="Ovládání karet co-living">
                    <button type="button" class="lp-rooms__nav lp-rooms__nav--prev" data-gallery-prev aria-label="Předchozí karta">
                      <Icon name="chevron-left" size={18} strokeWidth={2} />
                    </button>
                    <div class="lp-rooms__dots" role="tablist" aria-label="Pozice v co-living kartách">
                      {coliving.map((_, i) => (
                        <button type="button" class="lp-rooms__dot" data-gallery-dot={i} aria-label={`Karta ${i + 1} z ${coliving.length}`}></button>
                      ))}
                    </div>
                    <button type="button" class="lp-rooms__nav lp-rooms__nav--next" data-gallery-next aria-label="Další karta">
                      <Icon name="chevron-right" size={18} strokeWidth={2} />
                    </button>
                  </div>
                </div>
              </div>
              <div class="lp-rooms__group">
                <a class="lp-rooms__eyebrow osa-nolink" href={withBase('/ubytovani/#ub-privatni-title')}>
                  Privátní apartmány<span aria-hidden="true"> →</span>
                </a>
                <div class="lp-rooms__picker" data-gallery role="region" aria-roledescription="carousel" aria-label="Karty privátních apartmánů">
                  <div class="lp-rooms__strip" data-gallery-viewport tabindex="0">
                    {apartmany.map((a) => (
                      <div class="lp-rooms__slide" data-gallery-slide>
                        <RoomCard
                          eyebrow={a.data.shortName}
                          name={a.data.name}
                          velikost={a.data.plocha}
                          kapacita={`${a.data.kapacita} lůžek`}
                          popis={a.data.popis}
                          cenaAnchor={a.data.cena.anchor}
                          perOsoba={a.data.cena.perOsoba}
                          thumbnail={a.data.thumbnail}
                          detailHref={withBase(`/ubytovani/privatni/${a.data.slug}/`)}
                          reserveHref={withBase(`/rezervace/?typ=${a.data.slug}`)}
                        />
                      </div>
                    ))}
                  </div>
                  <div class="lp-rooms__controls" role="group" aria-label="Ovládání karet privátních apartmánů">
                    <button type="button" class="lp-rooms__nav lp-rooms__nav--prev" data-gallery-prev aria-label="Předchozí karta">
                      <Icon name="chevron-left" size={18} strokeWidth={2} />
                    </button>
                    <div class="lp-rooms__dots" role="tablist" aria-label="Pozice v kartách privátních apartmánů">
                      {apartmany.map((_, i) => (
                        <button type="button" class="lp-rooms__dot" data-gallery-dot={i} aria-label={`Karta ${i + 1} z ${apartmany.length}`}></button>
                      ))}
                    </div>
                    <button type="button" class="lp-rooms__nav lp-rooms__nav--next" data-gallery-next aria-label="Další karta">
                      <Icon name="chevron-right" size={18} strokeWidth={2} />
                    </button>
                  </div>
                </div>
              </div>
            </div>
          )}

          {sec.id === 'coworking' && (
            <div class="lp-features" aria-label="Hlavní typy coworkingu">
              {coworkingFeatures.map((f) => (
                <a class="lp-feature osa-nolink" href={withBase(f.href)}>
                  <span class="lp-feature__icon" aria-hidden="true"><Icon name={f.icon} size={18} strokeWidth={1.75} /></span>
                  <span class="lp-feature__label">{f.label}</span>
                </a>
              ))}
            </div>
          )}

          {sec.id === 'komunita' && (
            <div class="lp-features" aria-label="Hlavní komunitní zázemí">
              {komunitaFeatures.map((f) => (
                <a class="lp-feature osa-nolink" href={withBase(f.href)}>
                  <span class="lp-feature__icon" aria-hidden="true"><Icon name={f.icon} size={18} strokeWidth={1.75} /></span>
                  <span class="lp-feature__label">{f.label}</span>
                </a>
              ))}
            </div>
          )}

          {sec.id === 'okoli' && (
            <div class="lp-okoli-map" aria-label="Poloha areálu na mapě">
