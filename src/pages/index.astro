<style>
  /* ============ HERO ROTATION ============ */
  /* 4 slides absolutely overlapped, 20 s cyklus, 5 s na slide,
     swipe 1 s. animation-delay posunuje každý slide v cyklu. */
  .lp-hero {
    position: relative;
    isolation: isolate;
    /* Full-screen na desktop i mobile. dvh = dynamic viewport height,
       řeší iOS Safari URL bar bez jumping při scrollu. Fallback vh pro
       starší prohlížeče. Header je position: fixed (overlay variant),
       takže hero může jít plně pod něj. Horizontální gutter je na
       __inner aby content alignoval s header bar pattern (max-width +
       padding-x + margin auto). */
    min-height: 100vh;
    min-height: 100dvh;
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: var(--space-9) 0;
    color: #fff;
    background: var(--plum-deep);
    overflow: hidden;
  }
  .lp-hero__rotation {
    position: absolute;
    inset: 0;
    z-index: -2;
  }
  /* 4 slidy jako horizontal carousel: 4 s nehybný hold, pak 1 s swipe
     celé fotky doleva. Sousední slide zároveň zprava vplouvá dovnitř,
     takže přechod je jeden plynulý sweep bez cross-fade.
     Slide N animation-delay = N × 5 s − 1 s (pre-roll, aby slide 0 byl
     hned na svém místě při page loadu). */
  .lp-hero__slide {
    position: absolute;
    inset: 0;
    transform: translateX(100%);
    animation: lp-hero-swipe 20s cubic-bezier(0.65, 0, 0.35, 1) infinite;
    will-change: transform;
  }

  @keyframes lp-hero-swipe {
    /* 20 s smyčka = 100 %. 0-5 % (1 s): swipe-in zprava. 5-25 % (4 s):
       hold na středu. 25-30 % (1 s): swipe-out doleva. 30-100 %: hidden
       off-screen vlevo dokud se animace neresetuje. Boundary teleport
       z -100 % zpět na 100 % se děje off-screen, uživatel ho nevidí. */
    0%   { transform: translateX(100%); }
    5%   { transform: translateX(0); }
    25%  { transform: translateX(0); }
    30%  { transform: translateX(-100%); }
    100% { transform: translateX(-100%); }
  }

  .lp-hero__bg {
    position: absolute;
    inset: 0;
    width: 100%; height: 100%;
    object-fit: cover;
    filter: brightness(0.88);
  }
  .lp-hero__scrim {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to top,
      rgba(0,0,0,0.75) 0%,
      rgba(0,0,0,0.45) 35%,
      rgba(0,0,0,0.05) 75%
    );
    z-index: -1;
  }
  .lp-hero__inner {
    /* Width pattern: matches tile grid edge (1480 max, gutter-aware). */
    width: calc(100% - 2 * var(--gutter));
    max-width: var(--container-wide);
    margin: 0 auto;
    text-align: left;
  }
  .lp-hero__title {
    font: 600 clamp(1.625rem, 4.2vw, 2.875rem) / 1.18 var(--font-sans);
    letter-spacing: var(--tracking-tight);
    margin: 0 0 var(--space-4);
    max-width: 22ch;
    text-wrap: balance;
  }
  .lp-hero__lede {
    font: 600 clamp(1rem, 1.25vw, 1.25rem) / 1.45 var(--font-sans);
    letter-spacing: var(--tracking-wide);
    margin: 0;
    color: rgba(255,255,255,0.92);
    max-width: 36ch;
  }

  /* === SCROLL CUE === */
  /* Kruhový button dole na hero, který smooth-scrolluje na jump strip.
     Glass-morph styling (blur + transparent), uvnitř bouncing chevron,
     kolem subtle pulsing ring jako delight cue. */
  .lp-hero__scroll-cue {
    position: absolute;
    bottom: clamp(20px, 4vh, 36px);
    left: 50%;
    transform: translateX(-50%);
    width: 48px;
    height: 48px;
    border-radius: 999px;
    border: 1.5px solid rgba(255, 255, 255, 0.55);
    background: rgba(0, 0, 0, 0.22);
    color: #fff;
    display: grid;
    place-items: center;
    text-decoration: none;
    cursor: pointer;
    backdrop-filter: blur(6px);
    -webkit-backdrop-filter: blur(6px);
    transition: border-color 220ms ease, background 220ms ease, transform 220ms cubic-bezier(0.2, 0, 0, 1);
    z-index: 1;
  }
  .lp-hero__scroll-cue::before {
    /* Subtle pulse ring, drží rytmus s bounce uvnitř. */
