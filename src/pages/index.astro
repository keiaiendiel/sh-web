  /* Variant fills, light enough na landing ale rozlišitelné mezi sebou.
     Soft / plum-soft jsou solid lavender (ne accent-soft alpha) protože tiles
     přečnívají nad hero a transparent variant by ho prosvítal. Rose a sand
     dodávají teplo do studené plum škály, držíme všechny v light tonalitě. */
  .lp-tile--cream { background: var(--cream); }
  .lp-tile--soft  { background: hsl(var(--hue) 28% 93%); }
  .lp-tile--rose {
    background: var(--rose);
    color: var(--plum-deep);
    border-color: transparent;
  }
  .lp-tile--plum-soft {
    background: hsl(var(--hue) 28% 88%);
    color: var(--plum-deep);
    border-color: transparent;
  }
  .lp-tile--sand {
    background: #EFE9E0;
    color: var(--plum-deep);
    border-color: transparent;
  }
  /* Sub-label drží legibilní fg-subtle tón i na barevných variantách. */
  .lp-tile--rose .lp-tile__sub,
  .lp-tile--plum-soft .lp-tile__sub,
  .lp-tile--sand .lp-tile__sub {
    color: var(--fg-subtle);
  }
  .lp-tile--reserve {
    background: var(--plum-deep);
    color: #fff;
    border-color: var(--plum-deep);
  }

  /* Type stack: bottom-left, fills negative space next to ribbon */
  .lp-tile__type {
    position: relative;
    z-index: 2;
    display: flex;
    flex-direction: column;
    gap: 4px;
    max-width: 22ch;
  }
  .lp-tile__label {
    font: 700 clamp(1.125rem, 1.55vw, 1.5rem) / 1.05 var(--font-sans);
    letter-spacing: var(--tracking-tight);
    color: inherit;
    white-space: nowrap;
    text-overflow: ellipsis;
    overflow: hidden;
  }
  .lp-tile__label em {
    font-style: italic;
    font-weight: 500;
    color: var(--accent);
  }
  .lp-tile--reserve .lp-tile__label em { color: var(--rose); }
  .lp-tile__sub {
    font: 500 var(--text-sm) / 1.35 var(--font-sans);
    color: var(--fg-subtle);
    white-space: nowrap;
    text-overflow: ellipsis;
    overflow: hidden;
  }
  .lp-tile--reserve .lp-tile__sub { color: rgba(255, 255, 255, 0.72); }

  /* Corner šipka v pravém dolním rohu .lp-tile. chevron-down = scroll,
