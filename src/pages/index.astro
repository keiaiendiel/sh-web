---
import Base from '../layouts/Base.astro';
import { withBase } from '../utils/url';
import Gallery from '../components/Gallery.astro';
import { getCollection, getEntry } from 'astro:content';

const subProjects = (await getCollection('subProjects')).sort((a, b) => a.data.order - b.data.order);
const heroImage = withBase('/images/hub/exterior/hub-courtyard-trees.jpg');
---
<Base
  title="Startovací Hub Klecany"
  description="Startovací bydlení s komunitním a coworkingovým zázemím v areálu horních kasáren, deset minut od Prahy. Přijímáme nezávazné před-rezervace."
  headerVariant="dark"
  ogImage={withBase('/og/default.png')}
>
  <section class="hub-hero" style={`background-image: url('${heroImage}');`}>
    <div class="hub-hero__inner">
      <h1 class="hub-hero__title">Startovací Hub Klecany</h1>
      <p class="hub-hero__sub">Nájemní bydlení s komunitním a coworkingovým zázemím v areálu horních kasáren, deset minut od Prahy. Přijímáme nezávazné před-rezervace.</p>
    </div>
  </section>

  <section class="hub-paths">
    <div class="hub-paths__single">
      <a class="hub-path-card hub-path-card--primary" href={withBase('/obyvatele/')}>
        <h2>Chci tu bydlet</h2>
        <p>Sdílené bydlení, kapsle, klidnější uzavíratelná místa, jednolůžkové pokoje, nebo stipendijní režim. Otevřeli jsme nezávazné před-rezervace.</p>
        <span class="hub-path-card__cta">Vyplnit před-rezervaci →</span>
      </a>
    </div>
  </section>

  <section class="hub-section hub-prose">
    <p>Startovací Hub je obyvatelná část areálu, kterou rozjedeme jako první. Nájemní bydlení v různých formátech: levné kapsle pro krátkodobé pobyty, klidnější uzavíratelná místa pro delší stay, jednolůžkové i sdílené pokoje. K tomu sdílené sociální zázemí, společná kuchyň, prostor pro práci a tichý prostor pro studium.</p>
    <p>Hub kombinuje různé režimy: platící rezidenti, stipendijní místa pro lidi, kteří by se sem jinak nedostali, a komunitní rovinu se sdílenou kuchyní, coworkingem a tichým prostorem. To je kombinace, která v okolí Prahy chybí.</p>
    <p>Záměr nekončí u Hubu. Areál horních kasáren má potenciál na 1500+ bytových jednotek a postupné dotvoření celé městské vrstvy v souladu s cíli VPD. Hub je první krok, ze kterého rosteme.</p>
  </section>

  <section class="hub-section">
    <h2 class="hub-section__heading">Vizualizace záměru</h2>
    <h3 class="hub-section__subheading">Exteriér</h3>
    <Gallery title={null} images={[
      withBase('/images/hub/exterior/hub-courtyard-trees.jpg'),
      withBase('/images/hub/exterior/hub-courtyard-night.jpg'),
      withBase('/images/hub/exterior/hub-renovated-building.jpg'),
      withBase('/images/hub/exterior/hub-street-daytime.jpg'),
      withBase('/images/hub/exterior/hub-street-sunset.jpg'),
      withBase('/images/hub/exterior/exterior-01.jpg'),
      withBase('/images/hub/exterior/exterior-02.jpg'),
    ]} />
    <h3 class="hub-section__subheading">Interiér / společné prostory</h3>
    <Gallery title={null} images={[
      withBase('/images/hub/interior/hub-market-evening.jpg'),
      withBase('/images/hub/interior/hub-market-daytime.jpg'),
      withBase('/images/hub/interior/hub-market-people.jpg'),
      withBase('/images/hub/interior/interior-01.jpg'),
      withBase('/images/hub/interior/interior-02.jpg'),
      withBase('/images/hub/interior/interior-03.jpg'),
    ]} />
  </section>

  <section class="hub-section">
    <h2 class="hub-section__heading">Co Hub obsahuje</h2>
    <p class="hub-section__intro">Hub není jeden objekt. Skládá se z propojených provozů, které vznikají postupně.</p>
    <div class="hub-projects-teaser">
      {subProjects.map((p) => (
        <a class="hub-teaser-card" href={withBase(`/projekty/${p.id}/`)}>
          <h3>{p.data.name}</h3>
          <p>{p.data.role}</p>
          <span class="hub-teaser-card__cta">Detail →</span>
        </a>
      ))}
      <a class="hub-teaser-card hub-teaser-card--more" href={withBase('/projekty/')}>
        <h3>Další projekty</h3>
        <p>Hub se rozrůstá. Podívejte se na všechny provozy.</p>
        <span class="hub-teaser-card__cta">Projekty →</span>
      </a>
    </div>
  </section>

  <section class="hub-section hub-place">
    <div class="hub-place__grid">
      <div>
        <h2 class="hub-section__heading">Kde to je</h2>
        <p>Areál horní kasárny Klecany leží severně od Prahy, 12 km od centra. Areál je na trase plánované tramvajové linky z Kobylis a na navrhované cyklostezce do Prahy. Detail dopravy, rozlohy a smluvních práv najdete v sekci O projektu.</p>
        <a class="hub-place__cta" href={withBase('/o-projektu/#misto')}>O místě a kontextu →</a>
      </div>
      <figure class="hub-place__map">
        <img src={withBase('/images/hub/masterplan.jpg')} alt="Masterplan areálu horních kasáren Klecany." loading="lazy" />
        <figcaption>Areál horních kasáren — masterplan.</figcaption>
      </figure>
    </div>
  </section>

  <section class="hub-section hub-status">
    <p>Otevřeli jsme nezávazné před-rezervace. Vyplnění formuláře vám nezávazně rezervuje místo v okruhu, se kterým postupně komunikujeme detail nabídky. Nejde o smlouvu, neúčtujeme nic. Reálný start první etapy proběhne, jakmile budou potvrzeny tři podmínky: kapitálová struktura, provozní připravenost areálu a právní rámec provozu.</p>
  </section>

  <section class="hub-section">
    <h2 class="hub-section__heading">Časté otázky</h2>
    {await Promise.all(['q1', 'q5', 'q7'].map(async (id) => {
      const entry = await getEntry('faq', id);
      return entry ? (
        <details class="hub-faq-mini">
          <summary>{entry.data.question}</summary>
          <p>{entry.data.answer}</p>
        </details>
      ) : null;
    }))}
    <p class="hub-faq-mini__more"><a href={withBase('/faq/')}>Všechny otázky →</a></p>
  </section>
</Base>

<style>
  .hub-hero { min-height: 80vh; background-size: cover; background-position: center; color: #fff; display: flex; align-items: flex-end; padding: 96px 24px 64px; position: relative; }
  .hub-hero::after { content: ''; position: absolute; inset: 0; background: linear-gradient(180deg, rgba(0,0,0,0.15) 0%, rgba(0,0,0,0.6) 100%); pointer-events: none; }
  .hub-hero__inner { position: relative; z-index: 1; max-width: 1440px; margin: 0 auto; width: 100%; }
  .hub-hero__title { font-size: clamp(48px, 6vw, 100px); font-weight: 700; line-height: 1.05; margin: 0 0 16px; letter-spacing: -0.02em; }
  .hub-hero__sub { font-size: clamp(18px, 1.6vw, 26px); max-width: 640px; line-height: 1.4; opacity: 0.92; margin: 0; }
  .hub-paths { padding: 96px 24px; max-width: 1440px; margin: 0 auto; }
  .hub-paths__single { max-width: 640px; margin: 0 auto; }
  .hub-path-card { display: block; padding: 40px 32px; border: 1px solid var(--k-30); text-decoration: none; color: inherit; transition: border-color 200ms cubic-bezier(0.16,1,0.3,1); }
  .hub-path-card:hover { border-color: var(--accent); }
  .hub-path-card h2 { font-size: 32px; margin: 0 0 12px; }
  .hub-path-card p { color: var(--k-70); margin: 0 0 24px; }
  .hub-path-card__cta { color: var(--accent); font-weight: 600; }
  .hub-path-card--primary { border-width: 2px; }

  .hub-section { padding: 80px 24px; max-width: 1440px; margin: 0 auto; }
  .hub-section__heading { font-size: clamp(28px, 3vw, 48px); font-weight: 700; margin: 0 0 32px; letter-spacing: -0.01em; }
  .hub-section__subheading { font-size: 18px; font-weight: 600; margin: 24px 0 12px; opacity: 0.7; }
  .hub-prose { max-width: 720px; }
  .hub-prose p { font-size: 18px; line-height: 1.65; margin: 0 0 18px; color: var(--k-90, #1a1a1a); }

  .hub-section__intro { font-size: 18px; color: var(--k-70, #4a4a4a); margin: -16px 0 32px; max-width: 720px; line-height: 1.55; }
  .hub-projects-teaser { display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap: 16px; }
  @media (max-width: 960px) { .hub-projects-teaser { grid-template-columns: repeat(2, minmax(0, 1fr)); } }
  @media (max-width: 600px) { .hub-projects-teaser { grid-template-columns: 1fr; } }
  .hub-teaser-card { display: block; padding: 24px 20px; border: 1px solid var(--k-30); text-decoration: none; color: inherit; transition: border-color 200ms cubic-bezier(0.16,1,0.3,1); }
  .hub-teaser-card:hover { border-color: var(--accent); }
  .hub-teaser-card h3 { font-size: 18px; margin: 0 0 8px; }
  .hub-teaser-card p { font-size: 14px; line-height: 1.5; color: var(--k-70, #4a4a4a); margin: 0 0 12px; }
  .hub-teaser-card__cta { font-size: 13px; color: var(--accent); font-weight: 600; }
  .hub-teaser-card--more { background: var(--k-05, #f6f6f6); }

  .hub-place__grid { display: grid; grid-template-columns: 1fr 1.4fr; gap: 32px; align-items: center; }
  @media (max-width: 720px) { .hub-place__grid { grid-template-columns: 1fr; } }
  .hub-place p { font-size: 17px; line-height: 1.65; max-width: 540px; margin: 0 0 24px; color: var(--k-90); }
  .hub-place__cta { color: var(--accent); font-weight: 600; text-decoration: none; }
  .hub-place__cta:hover { text-decoration: underline; }
  .hub-place__map img { width: 100%; height: auto; border: 1px solid var(--k-20, #d4d4d4); display: block; }
  .hub-place__map figcaption { font-size: 13px; color: var(--k-60, #6a6a6a); margin-top: 8px; }

  .hub-status p { font-size: 16px; line-height: 1.65; max-width: 880px; padding: 24px 28px; background: var(--k-05, #f6f6f6); border-left: 3px solid var(--accent); margin: 0; }

  .hub-faq-mini { padding: 16px 0; border-bottom: 1px solid var(--k-20, #d4d4d4); }
  .hub-faq-mini summary { font-weight: 600; cursor: pointer; padding: 8px 0; list-style: none; font-size: 17px; }
  .hub-faq-mini summary::-webkit-details-marker { display: none; }
  .hub-faq-mini summary::before { content: '+'; display: inline-block; margin-right: 12px; transition: transform 200ms; }
  .hub-faq-mini[open] summary::before { transform: rotate(45deg); }
  .hub-faq-mini p { padding: 0 0 8px 24px; line-height: 1.6; color: var(--k-80, #2a2a2a); }
  .hub-faq-mini__more { margin: 24px 0 0; }
  .hub-faq-mini__more a { color: var(--accent); font-weight: 600; text-decoration: none; }
</style>
