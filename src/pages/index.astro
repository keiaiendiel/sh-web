      color: var(--fg);
      background: var(--bg);
      border: 1px solid var(--border-muted);
      backdrop-filter: none;
      white-space: normal;
      text-align: center;
      line-height: 1.25;
    }
    .lp-jumps--mobile .lp-jumps__item :global(svg) {
      color: var(--accent);
