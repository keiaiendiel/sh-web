---
import Base from '../layouts/Base.astro';
import Gallery from '../components/Gallery.astro';
import Icon from '../components/Icon.astro';
import RoomCard from '../components/RoomCard.astro';
import { getCollection } from 'astro:content';
import { withBase } from '../utils/url';

/* Room collections pro 2-sloupcový picker pod Ubytováním sekcí. */
const apartmany = (await getCollection('apartmany')).sort((a, b) => a.data.order - b.data.order);
const coliving = (await getCollection('coliving')).sort((a, b) => a.data.order - b.data.order);
const coligvingVelikost: Record<string, string> = {
  'kapsle-single': 'kapsle ve sdíleném pokoji',
  'jedno-luzko':   'lůžko ve sdíleném pokoji',
  'kapsle-double': 'kapsle ve sdíleném pokoji',
  'dvouluzko':     'celý pokoj v patrovém bytě',
};
const colivingKapacita: Record<string, string> = {
  'kapsle-single': '1 osoba',
  'jedno-luzko':   '1 osoba',
  'kapsle-double': '1-2 osoby',
  'dvouluzko':     '1-2 osoby',
};

/* Phase 2 landing per SH_Web_Site_Copy.md § 0.1 + SH_Web_Visualization_List
   § 1.1 + 1.2. Hero rotace 4 záběrů (Tier A rendery z vault hero-update),
   „Co Hub nabízí" 4 karty s horizontal scroll-snap gallery, section teasery
   pro 8 sekcí, masterplan, finální CTA panel.

   Hero rotace: swipe přes 4 slidy, 5 s na slide, 20 s celkový cyklus.
   `prefers-reduced-motion: reduce` zastaví na slide 1. */

/* === HERO ROTACE (4 záběry) === */
/* Tier A rendery z vault Visualizations/h - Hero/hero-update.
   Každý slide má desktop (landscape) a phone (portrait) variantu,
   <picture> přepíná v zlomu 768 px. */
const heroSlides = [
  {
    desktop: withBase('/images/hub/hero/h01.jpg'),
    phone:   withBase('/images/hub/hero/h01-phone.jpg'),
    alt: 'Privátní apartmány v parteru po setmění, lidé před vstupem mezi břízami, teplá světla v oknech.',
  },
  {
    desktop: withBase('/images/hub/hero/h02.jpg'),
    phone:   withBase('/images/hub/hero/h02-phone.jpg'),
    alt: 'Chodba s privátními kapslemi v dřevěném obložení, lavice a rostlina v lounge, tlumené ambientní světlo.',
  },
  {
    desktop: withBase('/images/hub/hero/h03.jpg'),
    phone:   withBase('/images/hub/hero/h03-phone.jpg'),
    alt: 'Vnitřní dvůr areálu za modré hodiny, lidé u dlouhého stolu venku, světla v oknech renovovaných budov.',
  },
  {
    desktop: withBase('/images/hub/hero/h04.jpg'),
    phone:   withBase('/images/hub/hero/h04-phone.jpg'),
    alt: 'Privátní apartmán 1+kk: žena vaří v kuchyni, muž čte u stolu, postel u okna, teplé večerní světlo.',
  },
];

/* === SEKCE ZIG-ZAG (5 řad, one-pager) === */
/* Každá sekce má anchor id pro scroll z tile gridu pod hero. Eyebrow + title +
   lede + CTAs do detail page na jedné straně, gallery na druhé. Sudé řady mají
   gallery vlevo přes :nth-of-type(even) flip. Okolí + Doprava merged do jedné
   sekce s 2 CTAs. */
type GalleryItem =
  | { src: string; alt: string }
  | { placeholder: string; alt: string };
type SectionCta = { href: string; label: string };
type Section = {
  id: string;
  eyebrow: string;
  title: string;
  lede: string;
  ctas: SectionCta[];
  gallery: GalleryItem[];
  /* Bezier d-form pro section ribbon pozadí, viewBox 0 0 1600 600.
     Sudé sekce dostanou scaleX(-1) takže path se zrcadlí, navrhuj path
     s důrazem v levé spodní třetině (negativní prostor pod textem). */
  ribbonPath: string;
};

const sections: Section[] = [
  {
    id: 'ubytovani',
    eyebrow: 'Ubytovací služby',
    title: 'Vlastní apartmán, nebo místo v co-livingu?',
    lede: 'Devět typů ubytování. Privátní apartmány 1+kk až 5+kk, kapsle pro jednoho nebo dva, lůžka ve sdílených pokojích. V ceně energie, internet, pět jízd Hub-shuttle a týdenní poukaz do sauny.',
    ctas: [{ href: '/ubytovani/', label: 'Možnosti ubytování' }],
    ribbonPath: 'M -80 480 C 120 320, 320 240, 540 360 S 940 520, 1120 380 S 1400 280, 1560 360',
    gallery: [
      { src: withBase('/images/hub/ubytovani/landing-window-dusk.jpg'), alt: 'Privátní apartmán zvenku za soumraku, osoba u okna pracuje u stolu při svitu lampy.' },
      { src: withBase('/images/hub/ubytovani/landing-1kk-wide.jpg'), alt: 'Privátní apartmán 1+kk: žena vaří v kuchyni, muž čte u stolu, postel u okna, teplé večerní světlo.' },
      { src: withBase('/images/hub/ubytovani/landing-capsules.jpg'), alt: 'Privátní kapsle ve dvou patrech, dřevěná obložení a tlumené ambientní světlo.' },
      { src: withBase('/images/hub/ubytovani/landing-1kk-small.jpg'), alt: 'Privátní apartmán 1+kk se sníženými proporcemi, postel u okna, kuchyňský kout a jídelní stůl.' },
      { src: withBase('/images/hub/ubytovani/landing-exterior.jpg'), alt: 'Privátní apartmány v parteru po setmění, lidé před vstupem mezi břízami, teplá světla v oknech.' },
    ],
  },
  {
    id: 'coworking',
    eyebrow: 'Coworking',
    title: 'Sál, fixní stůl, ateliér nebo dílna.',
    lede: 'Volný stůl v sále 24/7, fixní stůl s vlastní skříňkou, sdílená kancelář pro čtyři, zasedací místnost na hodinu. K tomu ateliéry a dílny s těžkými stroji v sousedních budovách. Coworkingový sál mají rezidenti v ceně bydlení.',
    ctas: [{ href: '/coworking/', label: 'Coworking a dílny' }],
    ribbonPath: 'M -60 380 C 180 460, 360 220, 580 380 S 960 540, 1140 360 S 1380 220, 1560 360',
    gallery: [
      { src: withBase('/images/hub/coworking/budova-c-exterior.jpg'), alt: 'Budova C zvenku, parter s hlavním vstupem do coworkingu a komunitního zázemí.' },
      { src: withBase('/images/hub/coworking/budova-c-interior.jpg'), alt: 'Interiér budovy C, společný prostor pro coworking a komunitní akce.' },
      { placeholder: 'cw03 Zasedací místnost s týmem 4 až 6 lidí, prezentace na obrazovku', alt: 'Zasedací místnost v budově C v plné akci.' },
      { placeholder: 'cw04 Ateliér nebo dílna v D1 nebo H1 až H3, hardware a nářadí', alt: 'Ateliér nebo dílna s fyzickou prací mimo office.' },
    ],
  },
  {
    id: 'komunita',
    eyebrow: 'Komunitní zázemí',
    title: 'Bazén, sauna, jídelna, klubovna.',
    lede: 'Vlastní bazén a sauna v jádře areálu, jídelna s minipivovarem v budově B, klubovna v budově C, komunitní park s grilem. Týdenní vstup do sauny mají v ceně všichni rezidenti.',
    ctas: [{ href: '/komunita/', label: 'Komunitní program' }],
    ribbonPath: 'M -80 520 C 140 360, 360 480, 580 340 S 940 460, 1140 380 S 1380 280, 1560 360',
    gallery: [
      { src: withBase('/images/hub/komunita/bazen.jpg'), alt: 'Bazén v centrálním objektu areálu, letní odpoledne, sluneční terasa, relax po práci.' },
      { src: withBase('/images/hub/komunita/restaurant.jpg'), alt: 'Komunitní restaurace v budově B v plném provozu, dlouhé stoly, otevřená kuchyně, lidé u oběda.' },
      { src: withBase('/images/hub/komunita/courtyard.jpg'), alt: 'Vnitřní dvůr areálu za modré hodiny, lidé u dlouhého stolu venku, světla v oknech renovovaných budov.' },
      { src: withBase('/images/hub/komunita/klubovna.jpg'), alt: 'Klubovna v budově C s eventem, lidé u stolů, kulturní život uvnitř Hubu.' },
      { src: withBase('/images/hub/komunita/04.jpg'), alt: 'Vnitřní dvůr za soumraku, lidé procházejí mezi rozsvícenými budovami, kola u stojanu, atmosféra komunitního večera.' },
      { placeholder: 'ko01 Grilovací místo, rodinné grilování v sobotu poledne, 8 až 12 lidí', alt: 'Grilovací místo v komunitním parku v sobotní poledne.' },
    ],
  },
  {
    id: 'stipendia',
    eyebrow: 'Stipendijní programy',
    title: 'Pobytové stipendium pro lidi s projektem.',
    lede: 'Čtyři role: rezident-tvůrce, work-trade správce, stavitel-rezident, rezident-programátor. Bydlení nebo zvýhodněná cena za konkrétní vstup do života Hubu (dílny, péče o areál, vlastní projekt). Při registraci zaškrtněte zájem, ozveme se s podmínkami.',
    ctas: [{ href: '/stipendia/', label: 'Pobytová stipendia' }],
    ribbonPath: 'M -60 420 C 160 540, 380 260, 600 400 S 960 520, 1140 380 S 1380 240, 1560 380',
    gallery: [
      { placeholder: 'Ateliér s rezidentem-tvůrcem v práci, denní světlo, velký stůl', alt: 'Ateliér s rezidentem-tvůrcem v práci.' },
      { placeholder: 'Skupinový moment u stolu, společné plánování nebo večeře rezidentů', alt: 'Skupinový moment u stolu, společné plánování rezidentů.' },
      { placeholder: 'Rezident se stará o pozemek areálu', alt: 'Rezident se stará o pozemek areálu.' },
      { placeholder: 'Rezident-programátor u stolu s monitorem, kód na obrazovce', alt: 'Rezident-programátor u stolu s monitorem.' },
    ],
  },
  {
    id: 'okoli',
    eyebrow: 'Okolí a dostupnost',
    title: 'Klecany, 15 km od Prahy. Patnáct minut autobusem na metro.',
    lede: 'Bývalý vojenský areál nad pravým břehem Vltavy. V docházkové vzdálenosti školka Astra, praktický lékař, lékárna, pošta. Pět jízd Hub-shuttle do metra Kobylis měsíčně v ceně, bus 374 PID a Hub-taxi jako záloha. Cyklostezka EuroVelo 7 podél Vltavy deset minut na kole.',
    ctas: [
      { href: '/okoli/',   label: 'Co je v okolí' },
      { href: '/doprava/', label: 'Jak se sem dostanete' },
    ],
    ribbonPath: 'M -80 460 C 180 300, 380 460, 600 340 S 980 460, 1160 380 S 1380 280, 1560 380',
    gallery: [
      { src: withBase('/images/hub/areal/masterplan_fotoreal.jpg'), alt: 'Fotorealistický masterplan areálu Horních kasáren, popisky budov A1 až A6, B, C, D, E, F, P, S a venkovního bazénu.' },
      { src: withBase('/images/hub/areal/topview.jpg'), alt: 'Letecký pohled na areál horních kasáren a obec Klecany v širším krajinném kontextu.' },
      { src: withBase('/images/hub/doprava/tram.jpg'), alt: 'Plánovaná tramvajová zastávka Výzkumný ústav I poblíž areálu (2029 až 2030).' },
      { src: withBase('/images/hub/doprava/cyklostezka.jpg'), alt: 'Cyklista na cyklostezce Praha až Klecany podél Vltavy.' },
      { src: withBase('/images/hub/areal/building-a-1.jpg'), alt: 'Privátní apartmány A1 zvenku, dřevěný obklad, čistý parter, alej bříz podél cesty.' },
      { src: withBase('/images/hub/areal/building-b.jpg'), alt: 'Budova B, komunitní gastro blok, exteriér z hlavní cesty areálu.' },
      { placeholder: 'dp01 Hub-shuttle dodávka před hlavním vstupem, 3 až 4 rezidenti nastupují', alt: 'Hub-shuttle dodávka před hlavním vstupem do Hubu, ranní mlha.' },
    ],
  },
];

/* === RIBBON TILES (pod hero) ===
   Pět scroll dlaždic + Rezervace tile (6 celkem, 3×2 grid). Per spec § 04
   banner influence: bez čísel, větší typo, větší ribbon arc jako pozadí,
   plakátovější. Variant per tile (cream / cream-warm / soft) drží content
   light aby přilehlé landing fotky vynikly. Plnější colorize přijde až do
   subpage hero sekcí. */
const tiles = [
  { label: 'Ubytovací služby', sub: 'Apartmány, kapsle, lůžka',  href: '#ubytovani', variant: 'cream',
    path: 'M 60 240 C 220 100, 380 320, 540 200 C 660 100, 720 260, 760 340' },
  { label: 'Coworking',         sub: 'Sál, ateliér, dílna',      href: '#coworking', variant: 'soft',
    path: 'M 80 120 C 240 280, 400 80, 560 240 C 680 360, 740 200, 760 320' },
  { label: 'Komunitní zázemí',  sub: 'Bazén, sauna, jídelna',    href: '#komunita',  variant: 'cream',
    path: 'M 80 200 C 240 80, 420 280, 580 160 C 700 80, 740 240, 760 320' },
  { label: 'Stipendijní programy', sub: 'Pobyt zdarma za projekt', href: '#stipendia', variant: 'soft',
    path: 'M 60 240 C 200 100, 380 320, 520 200 C 660 80, 740 240, 760 360' },
  { label: 'Okolí a dostupnost', sub: 'Vltava, bus, cyklostezka', href: '#okoli',    variant: 'cream',
    path: 'M 80 320 C 200 480, 420 200, 580 360 C 700 480, 740 320, 760 220' },
];
---
<Base
  title="Startovací Hub Klecany · Bydlení a coworking 15 min od Prahy"
  description="Devět typů bydlení od kapsle po byt 5+kk, coworking, dílny, sauna a kavárna. Horní kasárna Klecany, patnáct minut autobusem od metra Kobylisy. Od 3 000 Kč měsíčně, energie a internet v ceně."
  headerVariant="overlay">

  {/* ============ HERO ROTATION ============ */}
  <section class="lp-hero" aria-label="Startovací Hub Klecany, hero galerie">
    <div class="lp-hero__rotation" aria-hidden="true">
      {heroSlides.map((slide, i) => (
        <div class="lp-hero__slide" data-slide={i} style={`animation-delay: ${i * 5 - 1}s`}>
          <picture>
            <source media="(max-width: 768px)" srcset={slide.phone} />
            <img class="lp-hero__bg" src={slide.desktop} alt={slide.alt} loading={i === 0 ? 'eager' : 'lazy'} decoding="async" />
          </picture>
        </div>
      ))}
    </div>
    <div class="lp-hero__scrim" aria-hidden="true"></div>

    <div class="lp-hero__inner">
      <h1 class="lp-hero__title">Bydlení, coworking, dílny a&nbsp;sauna. 15&nbsp;minut od&nbsp;metra.</h1>
      <p class="lp-hero__lede">Devět typů ubytování od&nbsp;kapsle po&nbsp;5+kk apartmán. Od&nbsp;3&nbsp;000&nbsp;Kč měsíčně, energie a&nbsp;internet v&nbsp;ceně.</p>
    </div>

    {/* Scroll cue: kruhový button s chevron-down, jemně poskakuje + pulsing ring,
        klik smooth-scrolluje na jump strip pod hero. */}
    <a class="lp-hero__scroll-cue osa-nolink" href="#lp-jumps" aria-label="Skrolovat na možnosti">
      <Icon name="chevron-down" size={24} strokeWidth={2} />
    </a>
  </section>

  {/* Tile grid POD hero (3×2). Pět scroll-anchor dlaždic + Rezervace tile
      jako šestá. Každá dlaždice má velký ribbon arc jako pozadí (peeká z
      pod typo), per spec § 04 banner influence (plakátovější vibe). */}
  <section class="lp-tiles" id="lp-jumps" aria-label="Skok do sekcí">
    <div class="lp-tiles__grid">
      {tiles.map((t) => (
        <a class={`lp-tile lp-tile--${t.variant} osa-nolink`} href={t.href}>
          <span class="lp-tile__ribbon" aria-hidden="true" data-ribbon-reveal>
            <svg viewBox="0 0 800 600" preserveAspectRatio="xMidYMid slice">
              <path d={t.path} />
            </svg>
          </span>
          <span class="lp-tile__type">
            <span class="lp-tile__label">{t.label}</span>
            <span class="lp-tile__sub">{t.sub}</span>
          </span>
        </a>
      ))}

      <a class="lp-tile lp-tile--reserve osa-nolink" href={withBase('/rezervace/')}>
        <span class="lp-tile__ribbon" aria-hidden="true" data-ribbon-reveal>
          <svg viewBox="0 0 800 600" preserveAspectRatio="xMidYMid slice">
            <path d="M 540 80 C 720 100, 760 240, 600 320 C 460 400, 380 280, 540 200" />
          </svg>
        </span>
        <span class="lp-tile__type">
          <span class="lp-tile__label">Rezervujte si <em>místo</em></span>
          <span class="lp-tile__sub">Nezávazná. Ozveme se do 24 hodin.</span>
        </span>
      </a>
    </div>
  </section>

  {/* ============ ZIG-ZAG SEKCE (5 řad, one-pager) ============ */}
  <div class="lp-sections">
    {sections.map((sec) => (
      <>
        <section class="lp-section" id={sec.id} aria-labelledby={`${sec.id}-title`}>
          <span class="lp-section__ribbon" aria-hidden="true" data-ribbon-reveal>
            <svg viewBox="0 0 1600 600" preserveAspectRatio="none">
              <path d={sec.ribbonPath} vector-effect="non-scaling-stroke" />
            </svg>
          </span>
          <div class="lp-section__inner">
            <div class="lp-section__text">
              <p class="lp-section__eyebrow">{sec.eyebrow}</p>
              <h2 class="lp-section__title" id={`${sec.id}-title`}>{sec.title}</h2>
              <p class="lp-section__lede">{sec.lede}</p>
              <div class="lp-section__ctas">
                {sec.ctas.map((cta) => (
                  <a class="lp-section__cta osa-nolink" href={withBase(cta.href)}>
                    {cta.label}<span aria-hidden="true"> →</span>
                  </a>
                ))}
              </div>
            </div>
            <div class="lp-section__media">
              <Gallery images={sec.gallery} ariaLabel={sec.eyebrow} aspectRatio="4 / 3" />
            </div>
          </div>

          {sec.id === 'ubytovani' && (
            <div class="lp-rooms">
              <div class="lp-rooms__group">
                <a class="lp-rooms__eyebrow osa-nolink" href={withBase('/ubytovani/#ub-coliving-title')}>
                  Co-living<span aria-hidden="true"> →</span>
                </a>
                <div class="lp-rooms__picker" data-gallery role="region" aria-roledescription="carousel" aria-label="Karty co-living variant">
                  <div class="lp-rooms__strip" data-gallery-viewport tabindex="0">
                    {coliving.map((c) => (
                      <div class="lp-rooms__slide" data-gallery-slide>
                        <RoomCard
                          eyebrow={c.data.shortName}
                          name={c.data.name}
                          velikost={coligvingVelikost[c.data.slug] ?? 've sdíleném pokoji'}
                          kapacita={colivingKapacita[c.data.slug] ?? '1 osoba'}
                          popis={c.data.popis}
                          cenaAnchor={c.data.cena.anchor}
                          perOsoba={c.data.cena.perOsoba}
                          thumbnail={c.data.thumbnail}
                          detailHref={withBase(`/ubytovani/co-living/${c.data.slug}/`)}
                          reserveHref={withBase(`/rezervace/?typ=${c.data.slug}`)}
                        />
                      </div>
                    ))}
                  </div>
                  <div class="lp-rooms__controls" role="group" aria-label="Ovládání karet co-living">
                    <button type="button" class="lp-rooms__nav lp-rooms__nav--prev" data-gallery-prev aria-label="Předchozí karta">
                      <Icon name="chevron-left" size={18} strokeWidth={2} />
                    </button>
                    <div class="lp-rooms__dots" role="tablist" aria-label="Pozice v co-living kartách">
                      {coliving.map((_, i) => (
                        <button type="button" class="lp-rooms__dot" data-gallery-dot={i} aria-label={`Karta ${i + 1} z ${coliving.length}`}></button>
                      ))}
                    </div>
                    <button type="button" class="lp-rooms__nav lp-rooms__nav--next" data-gallery-next aria-label="Další karta">
                      <Icon name="chevron-right" size={18} strokeWidth={2} />
                    </button>
                  </div>
                </div>
              </div>
              <div class="lp-rooms__group">
                <a class="lp-rooms__eyebrow osa-nolink" href={withBase('/ubytovani/#ub-privatni-title')}>
                  Privátní apartmány<span aria-hidden="true"> →</span>
                </a>
                <div class="lp-rooms__picker" data-gallery role="region" aria-roledescription="carousel" aria-label="Karty privátních apartmánů">
                  <div class="lp-rooms__strip" data-gallery-viewport tabindex="0">
                    {apartmany.map((a) => (
                      <div class="lp-rooms__slide" data-gallery-slide>
                        <RoomCard
                          eyebrow={a.data.shortName}
                          name={a.data.name}
                          velikost={a.data.plocha}
                          kapacita={`${a.data.kapacita} lůžek`}
                          popis={a.data.popis}
                          cenaAnchor={a.data.cena.anchor}
                          perOsoba={a.data.cena.perOsoba}
                          thumbnail={a.data.thumbnail}
                          detailHref={withBase(`/ubytovani/privatni/${a.data.slug}/`)}
                          reserveHref={withBase(`/rezervace/?typ=${a.data.slug}`)}
                        />
                      </div>
                    ))}
                  </div>
                  <div class="lp-rooms__controls" role="group" aria-label="Ovládání karet privátních apartmánů">
                    <button type="button" class="lp-rooms__nav lp-rooms__nav--prev" data-gallery-prev aria-label="Předchozí karta">
                      <Icon name="chevron-left" size={18} strokeWidth={2} />
                    </button>
                    <div class="lp-rooms__dots" role="tablist" aria-label="Pozice v kartách privátních apartmánů">
                      {apartmany.map((_, i) => (
                        <button type="button" class="lp-rooms__dot" data-gallery-dot={i} aria-label={`Karta ${i + 1} z ${apartmany.length}`}></button>
                      ))}
                    </div>
                    <button type="button" class="lp-rooms__nav lp-rooms__nav--next" data-gallery-next aria-label="Další karta">
                      <Icon name="chevron-right" size={18} strokeWidth={2} />
                    </button>
                  </div>
                </div>
              </div>
            </div>
          )}

        </section>
      </>
    ))}
  </div>

  {/* ============ FINÁLNÍ CTA BANNER ============
       SH/07 ribbon banner styling (plum-deep + plum stroke). Contained,
       ne full-bleed, žije uvnitř container-wide stejně jako landing sekce.
       Pod ním footer (plum-deep), čímž celý spodek zaplaví plum. */}
  <section class="lp-cta-wrap" aria-label="Závěrečná výzva k registraci">
    <a class="lp-cta-banner osa-nolink" href={withBase('/rezervace/')} data-ribbon-reveal>
      <span class="lp-cta-banner__bg" aria-hidden="true">
        <svg viewBox="0 0 2100 700" preserveAspectRatio="xMidYMid slice">
          <path d="M 1280 80 C 1580 140, 1900 320, 1920 520 C 1940 680, 1600 720, 1460 540" />
        </svg>
      </span>
      <span class="lp-cta-banner__type">
        <span class="lp-cta-banner__eyebrow">Rezervace</span>
        <span class="lp-cta-banner__h">Rezervujte si <em>místo</em>.</span>
        <span class="lp-cta-banner__lede">
          Vyberete pokoj, termín a způsob kontaktu. Z rezervačního oddělení vám zavoláme do 24 hodin.
        </span>
      </span>
      <span class="lp-cta-banner__cta">
        Nezávazná rezervace<span aria-hidden="true"> →</span>
      </span>
    </a>
  </section>
</Base>

<style>
  /* ============ HERO ROTATION ============ */
  /* 4 slides absolutely overlapped, 20 s cyklus, 5 s na slide,
     swipe 1 s. animation-delay posunuje každý slide v cyklu. */
  .lp-hero {
    position: relative;
    isolation: isolate;
    /* Full-screen na desktop i mobile. dvh = dynamic viewport height,
       řeší iOS Safari URL bar bez jumping při scrollu. Fallback vh pro
       starší prohlížeče. Header je position: fixed (overlay variant),
       takže hero může jít plně pod něj. Horizontální gutter je na
       __inner aby content alignoval s header bar pattern (max-width +
       padding-x + margin auto). */
    min-height: 100vh;
    min-height: 100dvh;
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: var(--space-9) 0;
    color: #fff;
    background: var(--k-100);
    overflow: hidden;
  }
  .lp-hero__rotation {
    position: absolute;
    inset: 0;
    z-index: -2;
  }
  /* 4 slidy jako horizontal carousel: 4 s nehybný hold, pak 1 s swipe
     celé fotky doleva. Sousední slide zároveň zprava vplouvá dovnitř,
     takže přechod je jeden plynulý sweep bez cross-fade.
     Slide N animation-delay = N × 5 s − 1 s (pre-roll, aby slide 0 byl
     hned na svém místě při page loadu). */
  .lp-hero__slide {
    position: absolute;
    inset: 0;
    transform: translateX(100%);
    animation: lp-hero-swipe 20s cubic-bezier(0.65, 0, 0.35, 1) infinite;
    will-change: transform;
  }

  @keyframes lp-hero-swipe {
    /* 20 s smyčka = 100 %. 0-5 % (1 s): swipe-in zprava. 5-25 % (4 s):
       hold na středu. 25-30 % (1 s): swipe-out doleva. 30-100 %: hidden
       off-screen vlevo dokud se animace neresetuje. Boundary teleport
       z -100 % zpět na 100 % se děje off-screen, uživatel ho nevidí. */
    0%   { transform: translateX(100%); }
    5%   { transform: translateX(0); }
    25%  { transform: translateX(0); }
    30%  { transform: translateX(-100%); }
    100% { transform: translateX(-100%); }
  }

  .lp-hero__bg {
    position: absolute;
    inset: 0;
    width: 100%; height: 100%;
    object-fit: cover;
    filter: brightness(0.88);
  }
  .lp-hero__scrim {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to top,
      rgba(0,0,0,0.75) 0%,
      rgba(0,0,0,0.45) 35%,
      rgba(0,0,0,0.05) 75%
    );
    z-index: -1;
  }
  .lp-hero__inner {
    /* Width pattern: matches tile grid edge (1480 max, gutter-aware). */
    width: calc(100% - 2 * var(--gutter));
    max-width: var(--container-wide);
    margin: 0 auto;
    text-align: left;
  }
  .lp-hero__title {
    font: 600 clamp(1.625rem, 4.2vw, 2.875rem) / 1.18 var(--font-sans);
    letter-spacing: var(--tracking-tight);
    margin: 0 0 var(--space-4);
    max-width: 22ch;
    text-wrap: balance;
  }
  .lp-hero__lede {
    font: 600 clamp(1rem, 1.25vw, 1.25rem) / 1.45 var(--font-sans);
    letter-spacing: var(--tracking-wide);
    margin: 0;
    color: rgba(255,255,255,0.92);
    max-width: 36ch;
  }

  /* === SCROLL CUE === */
  /* Kruhový button dole na hero, který smooth-scrolluje na jump strip.
     Glass-morph styling (blur + transparent), uvnitř bouncing chevron,
     kolem subtle pulsing ring jako delight cue. */
  .lp-hero__scroll-cue {
    position: absolute;
    bottom: clamp(20px, 4vh, 36px);
    left: 50%;
    transform: translateX(-50%);
    width: 48px;
    height: 48px;
    border-radius: 999px;
    border: 1.5px solid rgba(255, 255, 255, 0.55);
    background: rgba(0, 0, 0, 0.22);
    color: #fff;
    display: grid;
    place-items: center;
    text-decoration: none;
    cursor: pointer;
    backdrop-filter: blur(6px);
    -webkit-backdrop-filter: blur(6px);
    transition: border-color 220ms ease, background 220ms ease, transform 220ms cubic-bezier(0.2, 0, 0, 1);
    z-index: 1;
  }
  .lp-hero__scroll-cue::before {
    /* Subtle pulse ring, drží rytmus s bounce uvnitř. */
    content: '';
    position: absolute;
    inset: -6px;
    border-radius: 999px;
    border: 1px solid rgba(255, 255, 255, 0.45);
    opacity: 0;
    animation: lp-hero-cue-ping 2.6s cubic-bezier(0.4, 0, 0.2, 1) infinite;
    pointer-events: none;
  }
  .lp-hero__scroll-cue :global(svg) {
    display: block;
    animation: lp-hero-cue-bounce 2.6s cubic-bezier(0.4, 0, 0.2, 1) infinite;
  }
  .lp-hero__scroll-cue:hover,
  .lp-hero__scroll-cue:focus-visible {
    border-color: #fff;
    background: rgba(255, 255, 255, 0.18);
    transform: translateX(-50%) translateY(2px);
    outline: none;
  }
  .lp-hero__scroll-cue:hover :global(svg),
  .lp-hero__scroll-cue:focus-visible :global(svg) {
    animation-play-state: paused;
  }
  @keyframes lp-hero-cue-bounce {
    0%, 20%, 100% { transform: translateY(0); }
    50%          { transform: translateY(5px); }
    70%          { transform: translateY(0); }
  }
  @keyframes lp-hero-cue-ping {
    0%   { opacity: 0.7; transform: scale(1); }
    70%  { opacity: 0;   transform: scale(1.45); }
    100% { opacity: 0;   transform: scale(1.45); }
  }

  /* reduced-motion: freeze on slide 0, vypnout cue animace */
  @media (prefers-reduced-motion: reduce) {
    .lp-hero__slide { animation: none; transform: translateX(-100%); }
    .lp-hero__slide[data-slide="0"] { transform: translateX(0); }
    .lp-hero__scroll-cue :global(svg),
    .lp-hero__scroll-cue::before { animation: none; }
    .lp-hero__scroll-cue::before { opacity: 0; }
  }

  /* ============ TILE GRID (3×2, pod hero) ============
     Pět scroll-anchor dlaždic + Rezervace tile jako šestá. Velký ribbon arc
     na pozadí (z-index 0, peeká z pod typo), typo zaplňuje plochu. Variant
     fill drží light na landingu (cream/soft) protože foto v sekcích níže
     potřebují bílé pozadí, výraznější colorize jde do subpage hero.
     Per spec § 04 banner influence, plakátový styl bez čísel. */
  .lp-tiles {
    background: var(--bg);
    padding: var(--space-6) 0 var(--space-7);
    border-bottom: 1px solid var(--border-muted);
    scroll-margin-top: 80px;
  }
  .lp-tiles__grid {
    width: calc(100% - 2 * var(--gutter));
    max-width: var(--container-wide);
    margin: 0 auto;
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: clamp(12px, 1.6vw, 20px);
  }

  .lp-tile {
    position: relative;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    aspect-ratio: 1.7 / 1;
    padding: clamp(20px, 2.4vw, 32px);
    border: 1px solid var(--accent-rule);
    border-radius: var(--radius-input);
    text-decoration: none !important;
    color: var(--fg);
    overflow: hidden;
    transition: transform 240ms var(--ease-standard),
                border-color 240ms var(--ease-standard),
                box-shadow 240ms var(--ease-standard);
  }
  /* Variant fills, light enough na landing ale rozlišitelné mezi sebou */
  .lp-tile--cream { background: var(--cream); }
  .lp-tile--soft  { background: var(--accent-soft); }
  .lp-tile--reserve {
    background: var(--plum-deep);
    color: #fff;
    border-color: var(--plum-deep);
  }

  /* Type stack: bottom-left, fills negative space next to ribbon */
  .lp-tile__type {
    position: relative;
    z-index: 2;
    display: flex;
    flex-direction: column;
    gap: 4px;
    max-width: 22ch;
  }
  .lp-tile__label {
    font: 700 clamp(1.25rem, 1.7vw, 1.625rem) / 1.05 var(--font-sans);
    letter-spacing: var(--tracking-tight);
    color: inherit;
    text-wrap: balance;
  }
  .lp-tile__label em {
    font-style: italic;
    font-weight: 500;
    color: var(--accent);
  }
  .lp-tile--reserve .lp-tile__label em { color: var(--rose); }
  .lp-tile__sub {
    font: 500 var(--text-sm) / 1.35 var(--font-sans);
    color: var(--fg-subtle);
  }
  .lp-tile--reserve .lp-tile__sub { color: rgba(255, 255, 255, 0.72); }

  /* Ribbon: big background arc, peeká z pod typo (z-index 0) */
  .lp-tile__ribbon {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 0;
    opacity: 0.55;
    transition: opacity 240ms var(--ease-standard), transform 360ms var(--ease-standard);
  }
  .lp-tile__ribbon svg {
    width: 100%;
    height: 100%;
    overflow: visible;
    display: block;
  }
  .lp-tile__ribbon path {
    fill: none;
    stroke: var(--accent);
    stroke-width: 36;
    stroke-linecap: round;
    stroke-linejoin: round;
  }
  .lp-tile--reserve .lp-tile__ribbon path {
    stroke: var(--rose);
    stroke-width: 44;
  }
  .lp-tile--reserve .lp-tile__ribbon { opacity: 0.85; }
  .lp-tile__ribbon[data-ribbon-reveal] path {
    stroke-dasharray: 1;
    stroke-dashoffset: 1;
    pathLength: 1;
  }
  .lp-tile__ribbon[data-ribbon-reveal].is-revealed path {
    animation: ribbon-snake-draw 2.6s var(--ease-snake) forwards;
  }

  /* Hover: lift + ribbon nice */
  .lp-tile:hover,
  .lp-tile:focus-visible {
    transform: translateY(-2px);
    border-color: var(--accent);
    box-shadow: 0 1px 2px rgba(0,0,0,0.04), 0 12px 32px rgba(90, 42, 95, 0.14);
    outline: none;
  }
  .lp-tile--reserve:hover,
  .lp-tile--reserve:focus-visible {
    border-color: var(--rose);
    box-shadow: 0 18px 48px rgba(45, 20, 48, 0.34);
  }
  .lp-tile:hover .lp-tile__ribbon,
  .lp-tile:focus-visible .lp-tile__ribbon {
    opacity: 0.85;
    transform: translateX(8px);
  }
  .lp-tile--reserve:hover .lp-tile__ribbon,
  .lp-tile--reserve:focus-visible .lp-tile__ribbon {
    opacity: 1;
  }
  .lp-tile:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
  }
  .lp-tile--reserve:focus-visible {
    outline: 2px solid var(--rose);
  }

  @media (max-width: 760px) {
    .lp-hero {
      min-height: 70vh;
      min-height: 70dvh;
      padding: var(--space-7) var(--gutter);
    }
    .lp-tiles { padding: var(--space-5) 0 var(--space-6); }
    .lp-tiles__grid {
      gap: 10px;
    }
    .lp-tile {
      aspect-ratio: 1 / 1.05;
      padding: 14px 12px;
    }
    .lp-tile__type { max-width: none; gap: 2px; }
    .lp-tile__label { font-size: 0.9375rem; line-height: 1.1; }
    .lp-tile__sub { font-size: 11px; line-height: 1.2; }
    .lp-tile__ribbon path { stroke-width: 44; }
    .lp-tile--reserve .lp-tile__ribbon path { stroke-width: 52; }
  }
  @media (max-width: 420px) {
    .lp-tile__sub { display: none; }
  }

  @media (prefers-reduced-motion: reduce) {
    .lp-tile, .lp-tile__ribbon { transition: none; }
    .lp-tile__ribbon[data-ribbon-reveal] path,
    .lp-tile__ribbon[data-ribbon-reveal].is-revealed path {
      stroke-dashoffset: 0;
      animation: none;
    }
  }

  /* ============ ZIG-ZAG SEKCE (one-pager) ============ */
  .lp-sections {
    background: var(--bg);
    color: var(--fg);
  }
  .lp-section {
    position: relative;
    padding: var(--space-8) 0;
    scroll-margin-top: 80px;
    border-bottom: 1px solid var(--border-muted);
    overflow: hidden;
  }
  .lp-section:last-child { border-bottom: 0; }
  .lp-section:nth-of-type(even) {
    background: var(--bg-muted);
  }

  /* Section ribbon: thin Bezier curve as background ornament, fills negative
     space opposite the photo + peeká z pod fotky (Z-layer). Sudé sekce dostanou
     scaleX(-1) takže ribbon přejde na druhou stranu. */
  .lp-section__ribbon {
    position: absolute;
    inset: 0;
    z-index: 0;
    pointer-events: none;
    opacity: 0.32;
  }
  .lp-section__ribbon svg {
    width: 100%;
    height: 100%;
    display: block;
    overflow: visible;
  }
  .lp-section__ribbon path {
    fill: none;
    stroke: var(--accent);
    stroke-width: 36;
    stroke-linecap: round;
    stroke-linejoin: round;
  }
  .lp-section__ribbon[data-ribbon-reveal] path {
    stroke-dasharray: 1;
    stroke-dashoffset: 1;
    pathLength: 1;
  }
  .lp-section__ribbon[data-ribbon-reveal].is-revealed path {
    animation: ribbon-snake-draw 3.2s var(--ease-snake) forwards;
  }
  .lp-section:nth-of-type(even) .lp-section__ribbon { transform: scaleX(-1); }

  .lp-section__inner {
    position: relative;
    z-index: 2;
    /* Width pattern: content edge se zarovná s tile grid (1480 max,
       gutter-aware na menších viewportech). Žádný vlastní padding-x. */
    width: calc(100% - 2 * var(--gutter));
    max-width: var(--container-wide);
    margin: 0 auto;
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
    gap: clamp(32px, 5vw, 80px);
    align-items: center;
  }
  /* Sudé sekce: flipnout media doleva, text doprava. */
  .lp-section:nth-of-type(even) .lp-section__media { order: -1; }

  .lp-section__text {
    min-width: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    max-width: 52ch;
  }
  .lp-section__eyebrow {
    font: 600 var(--text-2xs) / 1 var(--font-sans);
    color: var(--accent);
    letter-spacing: var(--tracking-wider);
    text-transform: uppercase;
    margin: 0;
  }
  .lp-section__title {
    font: 600 clamp(1.875rem, 3.5vw, 2.75rem) / 1.15 var(--font-sans);
    letter-spacing: var(--tracking-tight);
    margin: 0;
    max-width: 22ch;
  }
  .lp-section__lede {
    font: 400 var(--text-md) / 1.6 var(--font-sans);
    color: var(--fg-soft, var(--fg));
    margin: 0;
  }
  .lp-section__ctas {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3);
    margin-top: var(--space-2);
  }
  .lp-section__cta {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 12px 22px;
    font: 600 var(--text-sm) / 1 var(--font-sans);
    letter-spacing: var(--tracking-wide);
    color: var(--accent);
    background: transparent;
    border: 1px solid var(--accent);
    border-radius: var(--radius-input);
    text-decoration: none;
    transition: background 200ms ease, color 200ms ease;
  }
  .lp-section__cta:hover,
  .lp-section__cta:focus-visible {
    background: var(--accent);
    color: var(--accent-on);
    outline: none;
  }
  .lp-section__media { min-width: 0; }

  @media (max-width: 760px) {
    .lp-section { padding: var(--space-7) 0; }
    .lp-section__inner {
      grid-template-columns: 1fr;
      gap: var(--space-5);
    }
    /* Na mobilu vždy text první, pak média (žádný flip). */
    .lp-section:nth-of-type(even) .lp-section__media { order: 0; }
    .lp-section__ribbon { opacity: 0.32; }
    .lp-section__ribbon path { stroke-width: 32; }
  }

  @media (prefers-reduced-motion: reduce) {
    .lp-section__ribbon[data-ribbon-reveal] path,
    .lp-section__ribbon[data-ribbon-reveal].is-revealed path {
      stroke-dashoffset: 0;
      animation: none;
    }
  }

  /* ============ ROOM PICKER (pod Ubytováním) ============ */
  /* 2 sloupce, Co-living a Privátní apartmány. Každý sloupec je
     horizontálně scrollovatelný snap-strip kartiček (jeden picker
     analogický mobilní verzi /ubytovani/). Na mobilu 1 sloupec pod
     druhým. */
  .lp-rooms {
    /* Width pattern: matches tile grid edge. */
    width: calc(100% - 2 * var(--gutter));
    max-width: var(--container-wide);
    margin: var(--space-7) auto 0;
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
    gap: clamp(24px, 4vw, 56px);
  }
  .lp-rooms__group {
    min-width: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }
  .lp-rooms__eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    font: 600 var(--text-2xs) / 1 var(--font-sans);
    color: var(--accent);
    letter-spacing: var(--tracking-wider);
    text-transform: uppercase;
    margin: 0;
    width: fit-content;
    text-decoration: none;
    padding-bottom: 2px;
    border-bottom: 1px solid transparent;
    transition: border-color 160ms ease, color 160ms ease;
  }
  .lp-rooms__eyebrow:hover,
  .lp-rooms__eyebrow:focus-visible {
    border-bottom-color: var(--accent);
    outline: none;
  }

  /* Card picker: full-width karta, jeden snímek = jedna karta. Gallery
     JS overuje data-gallery atributy (scroll-snap + dot indicator +
     chevron buttons), takže stejné UX jako u obrazové galerie. */
  .lp-rooms__picker {
    position: relative;
    min-width: 0;
  }
  .lp-rooms__strip {
    display: flex;
    overflow-x: auto;
    overflow-y: hidden;
    scroll-snap-type: x mandatory;
    scroll-behavior: smooth;
    scrollbar-width: none;
    -ms-overflow-style: none;
  }
  .lp-rooms__strip::-webkit-scrollbar { display: none; }
  .lp-rooms__strip:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 4px;
    border-radius: var(--radius-input);
  }
  .lp-rooms__slide {
    flex: 0 0 100%;
    min-width: 0;
    scroll-snap-align: start;
    scroll-snap-stop: always;
  }
  .lp-rooms__controls {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 12px;
    margin-top: 14px;
  }
  .lp-rooms__nav {
    width: 32px;
    height: 32px;
    border-radius: 999px;
    border: 1px solid var(--accent-rule);
    background: transparent;
    color: var(--accent);
    cursor: pointer;
    display: grid;
    place-items: center;
    flex-shrink: 0;
    transition: background 220ms cubic-bezier(0.2, 0, 0, 1),
                border-color 220ms cubic-bezier(0.2, 0, 0, 1),
                transform 220ms cubic-bezier(0.2, 0, 0, 1);
  }
  .lp-rooms__nav :global(svg) { display: block; stroke: currentColor; transition: transform 220ms cubic-bezier(0.2, 0, 0, 1); }
  .lp-rooms__nav--prev :global(svg) { transform: translateX(-1px); }
  .lp-rooms__nav--next :global(svg) { transform: translateX(1px); }
  .lp-rooms__nav:hover {
    background: var(--accent-soft);
    border-color: var(--accent);
    transform: scale(1.06);
  }
  .lp-rooms__nav--prev:hover :global(svg) { transform: translateX(-3px); }
  .lp-rooms__nav--next:hover :global(svg) { transform: translateX(3px); }
  .lp-rooms__nav:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 3px;
  }
  .lp-rooms__nav:disabled {
    opacity: 0.25;
    cursor: default;
    pointer-events: none;
    transform: none;
  }
  .lp-rooms__dots {
    display: flex;
    align-items: center;
    gap: 6px;
  }
  .lp-rooms__dot {
    width: 6px;
    height: 6px;
    border-radius: 999px;
    border: 0;
    padding: 0;
    background: var(--border-muted);
    cursor: pointer;
    transition: background 320ms cubic-bezier(0.2, 0, 0, 1),
                width 360ms cubic-bezier(0.2, 0, 0, 1),
                transform 220ms cubic-bezier(0.2, 0, 0, 1);
  }
  .lp-rooms__dot:hover { background: var(--accent-rule); transform: scale(1.4); }
  .lp-rooms__dot.is-active {
    background: var(--accent);
    width: 28px;
    animation: lp-rooms-dot-pulse 480ms cubic-bezier(0.2, 0, 0, 1);
  }
  .lp-rooms__dot.is-active:hover { transform: scale(1.05); }
  .lp-rooms__dot:focus-visible { outline: 2px solid var(--accent); outline-offset: 3px; }
  @keyframes lp-rooms-dot-pulse {
    0%   { transform: scale(0.6); }
    50%  { transform: scale(1.15); }
    100% { transform: scale(1); }
  }

  @media (max-width: 900px) {
    .lp-rooms {
      grid-template-columns: 1fr;
      gap: var(--space-6);
    }
  }
  @media (max-width: 760px) {
    .lp-rooms__nav { display: none; }
  }


  /* ============ FINÁLNÍ CTA BANNER (SH/07 styling, contained) ============ */
  .lp-cta-wrap {
    padding: var(--space-7) var(--gutter) var(--space-8);
