---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import FilterBar from '../../components/FilterBar.astro';
import ProjectCard from '../../components/ProjectCard.astro';
import SVGPattern from '../../components/SVGPattern.astro';

const all = await getCollection('subProjects', e => e.data.status !== 'draft');
const sorted = all.sort((a, b) => (a.data.order ?? 999) - (b.data.order ?? 999));
---
<Base title="Projekty - Občanské sdružení Alternativa II">
  <Header variant="dark" />
  <main class="osa-projekty">
    {/*
     * Dark hero: same shape as Úvod, O spolku, VPD and aktuality/[slug].
     * The user asked for the top banner on Úvod, O spolku and Projekty to feel
     * like a single family - same black frame, left-aligned title and
     * sub-line, same vertical rhythm. Projekty has the filter bar inside the
     * frame, which is allowed: the frame is a bit taller than the others
     * because of the filters, but the top portion (crumbs, H1, lede) follows
     * the shared contract byte-for-byte.
     */}
    <section class="osa-projekty__hero osa-dark">
      <SVGPattern variant="dark" opacity={0.14}>
        <div class="container-wide osa-projekty__hero-inner">
          <header class="osa-projekty__head" data-reveal>
            <span class="osa-eyebrow">Autonomní projekty</span>
            <h1 class="osa-projekty__h1">
              Pod hlavičkou OSA působí desítky autonomních projektů.
              <span class="osa-projekty__h1-sub">
                Každý si vede vlastní prostor, web, členskou základnu a hospodaření. Spolek poskytuje právní a organizační zázemí.
              </span>
            </h1>
          </header>
          <div class="osa-projekty__filters" data-reveal data-reveal-delay="1">
            <FilterBar />
          </div>
        </div>
      </SVGPattern>
    </section>

    <section class="section">
      <div class="container-wide">
        <ul class="osa-projekty__grid" role="list" data-filter-target>
          {sorted.map((p, i) => (
            <li data-filter-item data-reveal data-reveal-delay={String((i % 3) + 1)}><ProjectCard
              slug={p.id}
              name={p.data.name}
              description={p.data.description}
              accent={p.data.accent}
              relationship={p.data.relationship}
              status={p.data.status}
              topic={p.data.topic}
              external_url={p.data.external_url}
              filterable={true}
            /></li>
          ))}
        </ul>
      </div>
    </section>
  </main>
  <Footer />
</Base>

<style>
  /* ---------- Dark hero frame ---------- */

  .osa-projekty__hero {
    border-bottom: 1px solid var(--rule);
  }
  .osa-projekty__hero-inner {
    /* Same contract as .osa-about__hero-inner and .osa-vpd__hero-inner. Split
       padding preserves .container-wide's horizontal gutter. */
    padding-top: clamp(var(--space-7), 8vw, var(--space-9));
    padding-bottom: var(--space-9);
    display: grid;
    gap: var(--space-6);
  }

  .osa-projekty__head {
    display: grid;
    gap: var(--space-3);
    max-width: 72ch;
  }
  .osa-projekty__h1 {
    font-family: var(--font-sans);
    font-weight: 600;
    font-size: clamp(2.25rem, 5vw + 0.5rem, 4rem);
    line-height: 1.05;
    letter-spacing: var(--tracking-tight);
    color: var(--fg);
    margin: 0;
    max-width: 22ch;
    text-wrap: balance;
  }
  .osa-projekty__h1-sub {
    display: block;
    color: var(--fg-muted);
    font-weight: 500;
    font-size: clamp(1.25rem, 1.8vw + 0.5rem, 1.75rem);
    margin-top: var(--space-3);
    max-width: 34ch;
  }

  /* ---------- FilterBar inside the dark hero ----------
   *
   * FilterBar uses var(--fg), var(--bg) and var(--rule) so the osa-dark scope
   * flips its palette automatically. The default rule color on dark is K0
   * (pure white) which reads too hot as hairlines, so we soften it to K70
   * locally. We also zero out the component's bottom margin because the hero
   * frame already provides its own padding-bottom.
   */
  .osa-projekty__filters {
    --rule: var(--k-70);
  }
  .osa-projekty__filters :global(.osa-filter) {
    margin-bottom: 0;
  }

  /* ---------- Grid ---------- */

  .osa-projekty__grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    grid-auto-rows: 1fr;
    gap: 0;
    border-top: 1px solid var(--rule);
    border-left: 1px solid var(--rule);
  }
  .osa-projekty__grid > li {
    display: flex;
    opacity: 1;
    transform: translateY(0);
    clip-path: inset(0 0 0 0);
    transition:
      opacity 380ms cubic-bezier(0.16, 1, 0.3, 1),
      transform 380ms cubic-bezier(0.16, 1, 0.3, 1),
      clip-path 380ms cubic-bezier(0.16, 1, 0.3, 1);
  }
  .osa-projekty__grid > li > * { flex: 1; }
  .osa-projekty__grid > li[data-filter-out] {
    opacity: 0;
    transform: translateY(12px);
    clip-path: inset(0 0 100% 0);
    pointer-events: none;
  }
  .osa-projekty__grid > li[hidden] { display: none; }
  @media (prefers-reduced-motion: reduce) {
    .osa-projekty__grid > li { transition: none; }
    .osa-projekty__grid > li[data-filter-out] { transform: none; clip-path: none; }
  }
</style>
