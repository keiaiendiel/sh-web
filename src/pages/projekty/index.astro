---
import Base from '../../layouts/Base.astro';
import { withBase } from '../../utils/url';
import { getCollection } from 'astro:content';

const cards = (await getCollection('subProjects')).sort((a, b) => a.data.order - b.data.order);
---
<Base
  title="Projekty Startovacího Hubu"
  description="Komunitní centrum, coworking, pivovar, bytové družstvo, tržnice a další provozy."
>
  <section class="hub-page-hero">
    <h1>Projekty Startovacího Hubu</h1>
    <p class="hub-lead">Startovací Hub Klecany se skládá z propojených provozů. Některé jsou v aktivní přípravě, jiné teprve dolaďujeme. Tady je přehled toho, co Hub obsahuje a kam se rozrůstá.</p>
  </section>

  <section class="hub-section">
    <div class="hub-projects-grid">
      {cards.map((p) => (
        <a class="hub-project-card" href={withBase(`/projekty/${p.id}/`)}>
          <div class="hub-project-card__thumb" aria-hidden="true">
            {p.data.thumbnail
              ? <img src={p.data.thumbnail} alt="" loading="lazy" width="600" height="450" />
              : <span class="hub-project-card__todo">Vizualizaci doplníme.</span>
            }
          </div>
          <h2>{p.data.name}</h2>
          <p>{p.data.role}</p>
          <span class="hub-project-card__status">V přípravě</span>
        </a>
      ))}
      <div class="hub-project-card hub-project-card--placeholder">
        <div class="hub-project-card__thumb" aria-hidden="true">
          <span class="hub-project-card__todo">+</span>
        </div>
        <h2>Další projekty</h2>
        <p>Hub se rozrůstá. Další provozy a iniciativy doplníme, jakmile budou konkrétně definované.</p>
        <span class="hub-project-card__status hub-project-card__status--soft">Bude doplněno</span>
      </div>
    </div>
    <p class="hub-foot-note">Pokud vás zajímá konkrétní projekt nebo byste se rád(a) zapojil(a), ozvěte se na <a href="mailto:vpd@osa2.cz">vpd@osa2.cz</a>.</p>
  </section>
</Base>

<style>
  .hub-page-hero { padding: 96px 24px 48px; max-width: 1440px; margin: 0 auto; }
  .hub-page-hero h1 { font-size: clamp(40px, 5vw, 80px); font-weight: 700; margin: 0 0 24px; letter-spacing: -0.02em; }
  .hub-lead { font-size: 20px; line-height: 1.5; max-width: 720px; color: var(--k-90); margin: 0; }

  .hub-section { padding: 64px 24px; max-width: 1440px; margin: 0 auto; }

  .hub-projects-grid { display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap: 24px; }
  @media (max-width: 960px) { .hub-projects-grid { grid-template-columns: repeat(2, minmax(0, 1fr)); } }
  @media (max-width: 600px) { .hub-projects-grid { grid-template-columns: 1fr; } }

  .hub-project-card { display: grid; gap: 12px; padding: 0; text-decoration: none; color: inherit; border: 1px solid var(--k-30); transition: border-color 200ms cubic-bezier(0.16,1,0.3,1); }
  a.hub-project-card:hover { border-color: var(--accent); }
  .hub-project-card__thumb { aspect-ratio: 4/3; background: var(--k-05, #f6f6f6); display: grid; place-items: center; overflow: hidden; }
  .hub-project-card__thumb img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .hub-project-card__todo { font-size: 12px; color: var(--k-60, #6a6a6a); letter-spacing: 0.05em; }
  .hub-project-card h2 { font-size: 18px; margin: 0; padding: 0 16px; }
  .hub-project-card p { font-size: 14px; line-height: 1.55; color: var(--k-70, #4a4a4a); margin: 0; padding: 0 16px; }
  .hub-project-card__status { font-size: 12px; color: var(--accent); font-weight: 600; letter-spacing: 0.05em; padding: 0 16px 16px; }
  .hub-project-card__status--soft { color: var(--k-60, #6a6a6a); }
  .hub-project-card--placeholder { background: var(--k-05, #f6f6f6); border-style: dashed; }

  .hub-foot-note { margin: 40px 0 0; font-size: 14px; color: var(--k-70, #4a4a4a); }
  .hub-foot-note a { color: var(--accent); }
</style>
