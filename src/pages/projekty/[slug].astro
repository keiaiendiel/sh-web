---
import Base from '../../layouts/Base.astro';
import { getCollection, render } from 'astro:content';
import { withBase } from '../../utils/url';

export async function getStaticPaths() {
  const all = await getCollection('subProjects');
  return all.map((p) => ({ params: { slug: p.id }, props: { project: p } }));
}

const { project } = Astro.props;
const { Content } = await render(project);

const buildingLabel = (id: string) => {
  switch (id) {
    case 'komunitni-centrum':  return 'Objekt B';
    case 'coworking-centrum':  return 'Přízemí budovy C';
    case 'komunitni-pivovar':  return 'Objekt B';
    case 'bytove-druzstvo':    return 'Vlastnické vehikl';
    case 'sauna-bazen':        return 'Objekty D + E';
    case 'sportoviste-park':   return 'Park před objektem B';
    default:                   return 'Areál';
  }
};

const statusLabel = (s: string) =>
  s === 'realizujeme' ? 'Realizujeme' : 'V přípravě';
---
<Base
  title={`${project.data.name} — Startovací Hub Klecany`}
  description={project.data.role}
  headerVariant="light"
>
  <section class="pjd-hero">
    <div class="pjd-hero__inner">
      <a class="pjd-hero__back" href={withBase('/projekty/')}>← Všechny provozy</a>
      <span class="osa-eyebrow pjd-hero__building">{buildingLabel(project.id)}</span>
      <h1 class="pjd-hero__title">{project.data.name}</h1>
      <p class="pjd-hero__lede">{project.data.role}</p>
      <span class="pjd-hero__status">{statusLabel(project.data.status)}</span>
    </div>
  </section>

  <section class="pjd-body">
    <div class="pjd-body__inner">
      <Content />
    </div>
  </section>

  <section class="pjd-cta">
    <div class="pjd-cta__inner">
      <p class="pjd-cta__lede">Pokud Hub vidíte jako reálnou možnost bydlení, vyplňte před-rezervaci. Na otázky k jednotlivým provozům odpovíme e-mailem.</p>
      <div class="pjd-cta__btns">
        <a class="pjd-cta__btn pjd-cta__btn--primary" href={withBase('/rezervace/')}>Vyplnit před-rezervaci →</a>
        <a class="pjd-cta__btn pjd-cta__btn--ghost" href="mailto:vpd@osa2.cz">vpd@osa2.cz</a>
      </div>
    </div>
  </section>
</Base>

<style>
  .pjd-hero {
    padding: clamp(48px, 8vw, 96px) var(--gutter) clamp(32px, 5vw, 48px);
    max-width: var(--container-wide); margin: 0 auto;
    border-bottom: 1px solid var(--k-20);
  }
  .pjd-hero__inner {
    max-width: 760px;
    display: grid;
    gap: 14px;
  }
  .pjd-hero__back {
    font-family: var(--font-sans);
    font-size: 14px;
    color: var(--k-70);
    text-decoration: none;
    letter-spacing: var(--tracking-tight);
    transition: color var(--dur-fast) linear;
  }
  .pjd-hero__back:hover { color: var(--accent); }
  .pjd-hero__building { color: var(--accent); }
  .pjd-hero__title {
    font-family: var(--font-sans);
    font-size: clamp(36px, 5vw, 64px);
    font-weight: 600;
    line-height: 1.05;
    letter-spacing: var(--tracking-tight);
    margin: 4px 0 0;
    text-wrap: balance;
  }
  .pjd-hero__lede {
    font-size: clamp(17px, 1.5vw, 20px);
    line-height: 1.55;
    color: var(--k-90);
    margin: 8px 0 0;
    max-width: 60ch;
  }
  .pjd-hero__status {
    justify-self: start;
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    padding: 4px 12px;
    background: var(--k-10);
    color: var(--k-70);
    border-radius: 999px;
    margin-top: 8px;
  }

  .pjd-body {
    padding: clamp(48px, 6vw, 80px) var(--gutter);
    max-width: var(--container-wide); margin: 0 auto;
  }
  .pjd-body__inner {
    max-width: 720px;
  }
  .pjd-body__inner :global(h2) {
    font-family: var(--font-sans);
    font-size: clamp(22px, 2.4vw, 30px);
    font-weight: 600;
    margin: 32px 0 12px;
    line-height: 1.2;
    letter-spacing: var(--tracking-tight);
    text-wrap: balance;
  }
  .pjd-body__inner :global(h2:first-child) { margin-top: 0; }
  .pjd-body__inner :global(h3) {
    font-family: var(--font-sans);
    font-size: 18px;
    font-weight: 600;
    margin: 24px 0 8px;
    line-height: 1.3;
  }
  .pjd-body__inner :global(p) {
    font-size: clamp(16px, 1.4vw, 18px);
    line-height: 1.65;
    color: var(--k-90);
    margin: 0 0 16px;
    max-width: 64ch;
  }
  .pjd-body__inner :global(ul),
  .pjd-body__inner :global(ol) {
    font-size: clamp(16px, 1.4vw, 18px);
    line-height: 1.65;
    color: var(--k-90);
    margin: 0 0 16px;
    padding-left: 22px;
    max-width: 64ch;
  }
  .pjd-body__inner :global(li) { margin: 0 0 6px; }
  .pjd-body__inner :global(a) {
    color: var(--accent);
    text-decoration: underline;
    text-underline-offset: 3px;
  }
  .pjd-body__inner :global(strong) { font-weight: 600; }

  .pjd-cta {
    padding: clamp(48px, 6vw, 80px) var(--gutter);
    max-width: var(--container-wide); margin: 0 auto;
    border-top: 1px solid var(--k-20);
  }
  .pjd-cta__inner {
    max-width: 720px; margin: 0 auto; text-align: center;
    display: grid; gap: 20px;
    padding: clamp(32px, 4vw, 48px);
    border: 1px solid var(--k-30);
    border-radius: var(--radius-input);
  }
  .pjd-cta__lede {
    font-size: clamp(16px, 1.35vw, 18px);
    line-height: 1.55;
    color: var(--k-90);
    margin: 0;
  }
  .pjd-cta__btns {
    display: flex; gap: 12px;
    justify-content: center; flex-wrap: wrap;
  }
  .pjd-cta__btn {
    display: inline-flex; align-items: center; gap: 8px;
    padding: 14px 24px;
    border-radius: var(--radius-input);
    font-weight: 600; font-size: 15px;
    text-decoration: none;
    transition:
      transform var(--dur-base) var(--ease-decel),
      box-shadow var(--dur-base) var(--ease-decel),
      background var(--dur-base) var(--ease-decel);
  }
  .pjd-cta__btn--primary {
    background: var(--accent); color: var(--accent-on);
    border: 1px solid var(--accent);
  }
  .pjd-cta__btn--primary:hover {
    transform: translateY(-2px);
    box-shadow: 0 12px 28px rgba(90, 42, 95, 0.32);
  }
  .pjd-cta__btn--ghost {
    color: var(--k-100);
    border: 1px solid var(--k-30);
    background: var(--bg);
  }
  .pjd-cta__btn--ghost:hover { border-color: var(--accent); color: var(--accent); }
</style>
