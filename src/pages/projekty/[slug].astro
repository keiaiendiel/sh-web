---
import Base from '../../layouts/Base.astro';
import Icon from '../../components/Icon.astro';
import { getCollection, render } from 'astro:content';
import { withBase } from '../../utils/url';

export async function getStaticPaths() {
  const all = await getCollection('subProjects');
  return all.map((p) => ({ params: { slug: p.id }, props: { project: p } }));
}

const { project } = Astro.props;
const { Content } = await render(project);

const buildingLabel = (id: string) => {
  switch (id) {
    case 'komunitni-centrum':  return 'Objekt B';
    case 'coworking-centrum':  return 'Přízemí budovy C';
    case 'komunitni-pivovar':  return 'Objekt B';
    case 'bytove-druzstvo':    return 'Přípravné družstvo';
    case 'sauna-bazen':        return 'Objekty D + E';
    case 'sportoviste-park':   return 'Park před objektem B';
    default:                   return 'Areál';
  }
};

const statusLabel = (s: string) =>
  s === 'realizujeme' ? 'Realizujeme' : 'Aktivní';

const hasHero = !!project.data.heroImage;
const heroVariant = hasHero ? 'dark' : 'light';
---
<Base
  title={`${project.data.name} · Startovací Hub Klecany`}
  description={project.data.role}
  headerVariant={heroVariant}
>
  {hasHero ? (
    <section class="pjd-hero pjd-hero--image osa-dark">
      <img class="pjd-hero__bg" src={project.data.heroImage} alt={project.data.heroImageAlt ?? ''} aria-hidden={project.data.heroImageAlt ? undefined : 'true'} loading="eager" decoding="async" />
      <div class="pjd-hero__scrim" aria-hidden="true"></div>
      <div class="pjd-hero__inner pjd-hero__inner--over">
        <a class="pjd-hero__back" href={withBase('/projekty/')}>← Všechny provozy</a>
        <span class="osa-eyebrow pjd-hero__building">{buildingLabel(project.id)}</span>
        <h1 class="pjd-hero__title">{project.data.name}</h1>
        <p class="pjd-hero__lede">{project.data.role}</p>
        <div class="pjd-hero__meta">
          <span class="pjd-hero__status">{statusLabel(project.data.status)}</span>
          {project.data.provozy && project.data.provozy.length > 0 && (
            <ul class="pjd-hero__provozy" aria-label="Provozy a služby v tomto celku">
              {project.data.provozy.map((p) => (
                <li class="pjd-hero__provoz">
                  <span class="pjd-hero__provoz-icon" aria-hidden="true"><Icon name={p.icon} size={16} /></span>
                  <span>{p.label}</span>
                </li>
              ))}
            </ul>
          )}
        </div>
      </div>
    </section>
  ) : (
    <section class="pjd-hero">
      <div class="pjd-hero__inner">
        <a class="pjd-hero__back" href={withBase('/projekty/')}>← Všechny provozy</a>
        <span class="osa-eyebrow pjd-hero__building">{buildingLabel(project.id)}</span>
        <h1 class="pjd-hero__title">{project.data.name}</h1>
        <p class="pjd-hero__lede">{project.data.role}</p>
        <div class="pjd-hero__meta">
          <span class="pjd-hero__status">{statusLabel(project.data.status)}</span>
          {project.data.provozy && project.data.provozy.length > 0 && (
            <ul class="pjd-hero__provozy" aria-label="Provozy a služby v tomto celku">
              {project.data.provozy.map((p) => (
                <li class="pjd-hero__provoz">
                  <span class="pjd-hero__provoz-icon" aria-hidden="true"><Icon name={p.icon} size={16} /></span>
                  <span>{p.label}</span>
                </li>
              ))}
            </ul>
          )}
        </div>
      </div>
    </section>
  )}

  <section class="pjd-body">
    <div class="pjd-body__inner">
      <Content />
    </div>
  </section>

  <section class="pjd-cta">
    <div class="pjd-cta__inner">
      <p class="pjd-cta__lede">Pokud vás Hub zajímá jako možné bydlení, vyplňte nezávazný zájem. Vyplněním se přidáváte k přípravnému družstvu. Na otázky k jednotlivým provozům odpovíme e-mailem.</p>
      <div class="pjd-cta__btns">
        <a class="pjd-cta__btn pjd-cta__btn--primary" href={withBase('/rezervace/')}>Rezervace →</a>
        <a class="pjd-cta__btn pjd-cta__btn--ghost" href="mailto:info@startovacihub.cz">info@startovacihub.cz</a>
      </div>
    </div>
  </section>
</Base>

<style>
  .pjd-hero {
    padding: clamp(48px, 8vw, 96px) var(--gutter) clamp(32px, 5vw, 48px);
    max-width: var(--container-wide); margin: 0 auto;
    border-bottom: 1px solid var(--border-muted);
  }
  .pjd-hero__inner {
    max-width: 760px;
    display: grid;
    gap: 14px;
  }
  /* Image hero — bg vizualizace + scrim + text on top, ladí s ostatními
     dark hero sekcemi (rezervace, projekty, o-arealu). Building image
     dělá pages osobnější a vyplňuje předtím prázdnou hlavičku. */
  .pjd-hero--image {
    position: relative;
    isolation: isolate;
    min-height: clamp(360px, 50vh, 520px);
    padding: clamp(56px, 8vw, 112px) var(--gutter) clamp(40px, 5vw, 64px);
    max-width: none;
    margin: 0;
    border-bottom: none;
    color: #fff;
    overflow: hidden;
    display: grid;
    align-items: end;
  }
  .pjd-hero__bg {
    position: absolute; inset: 0;
    width: 100%; height: 100%;
    object-fit: cover;
    z-index: -2;
  }
  .pjd-hero__scrim {
    position: absolute; inset: 0;
    background:
      linear-gradient(180deg, rgba(0,0,0,0) 0%, rgba(0,0,0,0.20) 55%, rgba(0,0,0,0.50) 100%);
    z-index: -1;
  }
  .pjd-hero__inner--over {
    max-width: var(--container-wide);
    margin: 0 auto;
    width: 100%;
  }
  .pjd-hero--image .pjd-hero__back { color: rgba(255,255,255,0.78); }
  .pjd-hero--image .pjd-hero__back:hover { color: #fff; }
  .pjd-hero--image .pjd-hero__building { color: #fff; opacity: 0.85; }
  .pjd-hero--image .pjd-hero__title { color: #fff; }
  .pjd-hero--image .pjd-hero__lede { color: rgba(255,255,255,0.92); }
  .pjd-hero--image .pjd-hero__status {
    background: rgba(255,255,255,0.12);
    border-color: rgba(255,255,255,0.55);
    color: #fff;
    backdrop-filter: blur(2px);
  }
  .pjd-hero__back {
    font-family: var(--font-sans);
    font-size: 14px;
    color: var(--fg-muted);
    text-decoration: none;
    letter-spacing: var(--tracking-tight);
    transition: color var(--dur-fast) linear;
  }
  .pjd-hero__back:hover { color: var(--accent); }
  .pjd-hero__building { color: var(--accent); }
  .pjd-hero__title {
    font-family: var(--font-sans);
    font-size: clamp(36px, 5vw, 64px);
    font-weight: 600;
    line-height: 1.05;
    letter-spacing: var(--tracking-tight);
    margin: 4px 0 0;
    text-wrap: balance;
  }
  .pjd-hero__lede {
    font-size: clamp(17px, 1.5vw, 20px);
    line-height: 1.55;
    color: var(--fg);
    margin: 8px 0 0;
    max-width: 60ch;
  }
  .pjd-hero__status {
    justify-self: start;
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    padding: 4px 12px;
    background: var(--accent-soft);
    color: var(--accent);
    border: 1px solid var(--accent);
    border-radius: 999px;
  }
  /* Meta row pod hero textem — status pill + řádek provoz chipů (icon +
     label), jeden flexbox. Wrap na úzkých breakpointech. */
  .pjd-hero__meta {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    align-items: center;
    margin-top: 12px;
  }
  .pjd-hero__provozy {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
  }
  .pjd-hero__provoz {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 4px 10px 4px 8px;
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 0.01em;
    background: var(--accent-soft);
    color: var(--accent);
    border: 1px solid var(--accent-rule);
    border-radius: 999px;
    line-height: 1.4;
  }
  .pjd-hero__provoz-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    color: var(--accent);
  }
  .pjd-hero__provoz-icon :global(svg) {
    width: 14px;
    height: 14px;
    stroke: currentColor;
  }
  /* Image hero variant: bílé chipy s podsvícením, ladí se scrimovaným bg. */
  .pjd-hero--image .pjd-hero__provoz {
    background: rgba(255, 255, 255, 0.14);
    border-color: rgba(255, 255, 255, 0.45);
    color: #fff;
    backdrop-filter: blur(2px);
  }
  .pjd-hero--image .pjd-hero__provoz-icon { color: #fff; }

  .pjd-body {
    padding: clamp(48px, 6vw, 80px) var(--gutter);
    max-width: var(--container-wide); margin: 0 auto;
  }
  .pjd-body__inner {
    max-width: 720px;
  }
  .pjd-body__inner :global(h2) {
    font-family: var(--font-sans);
    font-size: clamp(22px, 2.4vw, 30px);
    font-weight: 600;
    margin: 32px 0 12px;
    line-height: 1.2;
    letter-spacing: var(--tracking-tight);
    text-wrap: balance;
  }
  .pjd-body__inner :global(h2:first-child) { margin-top: 0; }
  .pjd-body__inner :global(h3) {
    font-family: var(--font-sans);
    font-size: 18px;
    font-weight: 600;
    margin: 24px 0 8px;
    line-height: 1.3;
  }
  .pjd-body__inner :global(p) {
    font-size: clamp(16px, 1.4vw, 18px);
    line-height: 1.65;
    color: var(--fg);
    margin: 0 0 16px;
    max-width: 64ch;
  }
  .pjd-body__inner :global(ul),
  .pjd-body__inner :global(ol) {
    font-size: clamp(16px, 1.4vw, 18px);
    line-height: 1.65;
    color: var(--fg);
    margin: 0 0 16px;
    padding-left: 22px;
    max-width: 64ch;
  }
  .pjd-body__inner :global(li) { margin: 0 0 6px; }
  .pjd-body__inner :global(a) {
    color: var(--accent);
    text-decoration: underline;
    text-underline-offset: 3px;
  }
  .pjd-body__inner :global(strong) { font-weight: 600; }

  .pjd-cta {
    padding: clamp(48px, 6vw, 80px) var(--gutter);
    max-width: var(--container-wide); margin: 0 auto;
    border-top: 1px solid var(--border-muted);
  }
  .pjd-cta__inner {
    max-width: 720px; margin: 0 auto; text-align: center;
    display: grid; gap: 20px;
    padding: clamp(32px, 4vw, 48px);
    border: 1px solid var(--accent-rule);
    border-radius: var(--radius-input);
  }
  .pjd-cta__lede {
    font-size: clamp(16px, 1.35vw, 18px);
    line-height: 1.55;
    color: var(--fg);
    margin: 0;
  }
  .pjd-cta__btns {
    display: flex; gap: 12px;
    justify-content: center; flex-wrap: wrap;
  }
  /* Detail-page CTAs — wipe pattern. Primary plum retracts on hover;
     ghost is black outline that fills on hover. */
  .pjd-cta__btn {
    position: relative;
    isolation: isolate;
    overflow: hidden;
    display: inline-flex; align-items: center; gap: 8px;
    padding: 14px 24px;
    border-radius: var(--radius-input);
    font-weight: 600; font-size: 15px;
    text-decoration: none;
    transition: color 160ms cubic-bezier(0.65, 0, 0.35, 1);
  }
  .pjd-cta__btn::after {
    content: "";
    position: absolute;
    inset: 0;
    z-index: -1;
    transition: clip-path 220ms cubic-bezier(0.65, 0, 0.35, 1);
  }
  .pjd-cta__btn--primary {
    color: #fff;
    border: 1px solid var(--accent);
  }
  .pjd-cta__btn--primary::after {
    background: var(--accent);
    clip-path: inset(0 0 0 0);
  }
  .pjd-cta__btn--primary:hover,
  .pjd-cta__btn--primary:focus-visible { color: var(--accent); }
  .pjd-cta__btn--primary:hover::after,
  .pjd-cta__btn--primary:focus-visible::after {
    clip-path: inset(100% 0 0 0);
  }
  .pjd-cta__btn--ghost {
    color: var(--k-100);
    border: 1px solid var(--k-100);
  }
  .pjd-cta__btn--ghost::after {
    background: var(--k-100);
    clip-path: inset(100% 0 0 0);
  }
  .pjd-cta__btn--ghost:hover,
  .pjd-cta__btn--ghost:focus-visible { color: #fff; }
  .pjd-cta__btn--ghost:hover::after,
  .pjd-cta__btn--ghost:focus-visible::after {
    clip-path: inset(0 0 0 0);
  }
  @media (prefers-reduced-motion: reduce) {
    .pjd-cta__btn,
    .pjd-cta__btn::after { transition: none; }
  }
</style>
