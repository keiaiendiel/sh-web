---
import Base from '../../layouts/Base.astro';
import CrossLinkPair from '../../components/CrossLinkPair.astro';
import Icon from '../../components/Icon.astro';
import Arrow from '../../components/Arrow.astro';
import { getCollection } from 'astro:content';
import { withBase } from '../../utils/url';

/* Sekundární rozcestník: vše ostatní rezervovatelné (zázemí + doprava, kompletní
   výčet dle klientské tabulky Koncept webu). Zatím jen pro přihlášené (přihlášení
   + rezervace zázemí teprve připravujeme), klik sbírá zájem. Hue z locked paletky
   25/50/130/200/240 (stejný recept jako ResidentBenefits chipy). */
type Reservable = { slug: string; label: string; icon: string; hue: 25 | 50 | 130 | 200 | 240 };
const reservableGroups: { title: string; items: Reservable[] }[] = [
  {
    title: 'Zázemí',
    items: [
      { slug: 'zasedaci-mistnost',  label: 'Zasedací místnost', icon: 'users',          hue: 240 },
      { slug: 'coworkingovy-sal',   label: 'Coworkingový sál',  icon: 'laptop',         hue: 240 },
      { slug: 'fixni-stul',         label: 'Fixní stůl',        icon: 'briefcase',      hue: 240 },
      { slug: 'kancelar',           label: 'Kancelář pro tým',  icon: 'monitor',        hue: 240 },
      { slug: 'atelier',            label: 'Ateliér',           icon: 'palette',        hue: 25 },
      { slug: 'dilna',              label: 'Dílna',             icon: 'hammer',         hue: 25 },
      { slug: 'zkusebna',           label: 'Zkušebna',          icon: 'guitar',         hue: 25 },
      { slug: 'podcastove-studio',  label: 'Podcastové studio', icon: 'mic',            hue: 25 },
      { slug: 'strihove-studio',    label: 'Střihové studio',   icon: 'scissors',       hue: 25 },
      { slug: 'filmove-studio',     label: 'Filmové studio',    icon: 'clapperboard',   hue: 25 },
      { slug: 'sauna',              label: 'Sauna a wellness',  icon: 'thermometer',    hue: 200 },
      { slug: 'privatni-koupelna',  label: 'Privátní koupelna', icon: 'bath',           hue: 200 },
      { slug: 'salonek',            label: 'Salonek',           icon: 'armchair',       hue: 50 },
      { slug: 'sdilena-kuchyne',    label: 'Sdílená kuchyně',   icon: 'utensils',       hue: 50 },
      { slug: 'grilovaci-misto',    label: 'Grilovací místo',   icon: 'flame',          hue: 50 },
      { slug: 'spolecensky-sal',    label: 'Společenský sál',   icon: 'party-popper',   hue: 130 },
      { slug: 'podium',             label: 'Pódium',            icon: 'speaker',        hue: 130 },
      { slug: 'zahradka',           label: 'Komunitní zahrádka', icon: 'flower-2',      hue: 130 },
      { slug: 'sklad',              label: 'Sklad a kóje',      icon: 'container',      hue: 130 },
    ],
  },
  {
    title: 'Doprava',
    items: [
      { slug: 'kyvadlovka-myshelter', label: 'Místo v kyvadlovém spoji', icon: 'bus',       hue: 240 },
      { slug: 'sdilene-taxi',         label: 'Sdílené taxi',             icon: 'car-front', hue: 240 },
      { slug: 'elektroauto',          label: 'Elektroauto',              icon: 'zap',       hue: 130 },
      { slug: 'elektrokolo',          label: 'Elektrokolo',              icon: 'bike',      hue: 130 },
      { slug: 'elektrokolobezka',     label: 'Elektrokoloběžka',         icon: 'scooter',    hue: 130 },
      { slug: 'elektrolongboard',     label: 'Elektrolongboard',         icon: 'circle-dot', hue: 130 },
      { slug: 'onewheel',             label: 'Onewheel',                 icon: 'circle-gauge', hue: 130 },
      { slug: 'pujcovna',             label: 'Celá půjčovna',            icon: 'key-round', hue: 50 },
      { slug: 'parking',              label: 'Parkovací místo',          icon: 'parking-circle', hue: 50 },
    ],
  },
];

/* Post-submit dotazník: jedna otázka na obrazovku, živý součet orientační ceny.
   Renderováno staticky (scoped styles), JS jen přepíná a sčítá. */
type SurveyOption = { v: string; label: string; price: number; note?: string; desc?: string };
type SurveyQuestion = { id: string; q: string; hint?: string; options: SurveyOption[] };
const surveyQuestions: SurveyQuestion[] = [
  {
    id: 'uklid',
    q: 'Chcete pravidelný úklid pokoje?',
    hint: 'Úklid vašeho pokoje nebo bytu nad rámec společných prostor.',
    options: [
      { v: 'ne', label: 'Ne, uklidím si sám', price: 0 },
      { v: 'mesicne', label: '1× měsíčně', price: 300 },
      { v: 'tydne', label: '1× týdně', price: 800 },
      { v: '2tydne', label: '2× týdně', price: 1400 },
    ],
  },
  {
    id: 'pradlo',
    q: 'Výměna ložního prádla?',
    hint: 'Povlečení a ručníky vyměníme za čerstvé.',
    options: [
      { v: 'ne', label: 'Ne, vyřeším v prádelně', price: 0 },
      { v: '14dni', label: '1× za 14 dní', price: 200 },
      { v: 'tydne', label: '1× týdně', price: 350 },
    ],
  },
  {
    id: 'prani',
    q: 'Praní a žehlení osobního prádla?',
    options: [
      { v: 'ne', label: 'Ne', price: 0 },
      { v: 'balicek', label: 'Měsíční balíček', price: 600, desc: 'Vypereme, vyžehlíme a vrátíme připravené.' },
    ],
  },
  {
    id: 'donaska',
    q: 'Donáška jídla na pokoj?',
    hint: 'Z kantýny přímo k vám, korespondenci a balíčky nosíme všem.',
    options: [
      { v: 'ne', label: 'Ne, dojdu si', price: 0 },
      { v: 'snidane', label: 'Snídaně', price: 500 },
      { v: 'snidane-vecere', label: 'Snídaně a večeře', price: 900 },
    ],
  },
  {
    id: 'zahradka',
    q: 'Komunitní zahrádka?',
    hint: 'Voda, kompost a nářadí v ceně, sezóna duben až říjen.',
    options: [
      { v: 'ne', label: 'Ne', price: 0 },
      { v: 'maly', label: 'Malý záhon', price: 150 },
      { v: 'velky', label: 'Velký záhon', price: 300 },
    ],
  },
  {
    id: 'stul',
    q: 'Pracovní místo navíc?',
    hint: 'Volný stůl v coworkingovém sále máte v ceně bydlení.',
    options: [
      { v: 'ne', label: 'Stačí volný stůl', price: 0, note: 'v ceně' },
      { v: 'fixni', label: 'Fixní stůl s technikou', price: 4200, desc: 'Dva monitory, ergonomická židle, uzamykatelná skříňka.' },
    ],
  },
  {
    id: 'sklad',
    q: 'Sklad navíc?',
    options: [
      { v: 'ne', label: 'Ne', price: 0 },
      { v: 'koje', label: 'Sklepní kóje', price: 400 },
      { v: 'kontejner', label: 'Kontejnerový sklad', price: 900 },
    ],
  },
  {
    id: 'parkovani',
    q: 'Parkovací místo?',
    options: [
      { v: 'ne', label: 'Ne, jezdím bez auta', price: 0 },
      { v: 'ano', label: 'Ano, vyhrazené stání', price: 0, note: 'v ceně bydlení' },
    ],
  },
  {
    id: 'mobilita',
    q: 'Jízdy kyvadlovkou MyShelter navíc?',
    hint: 'Pět jízd měsíčně máte v ceně bydlení.',
    options: [
      { v: 'ne', label: 'Pět jízd mi stačí', price: 0, note: 'v ceně' },
      { v: 'balicek10', label: 'Balíček 10 jízd navíc', price: 500 },
      { v: 'neomezene', label: 'Neomezené jízdy', price: 900 },
    ],
  },
  {
    id: 'mazlicek',
    q: 'Přivezete si mazlíčka?',
    options: [
      { v: 'ne', label: 'Ne', price: 0 },
      { v: 'ano', label: 'Ano', price: 0, note: 'podmínky domluvíme', desc: 'Napište nám pak do poznámky, jakého mazlíčka máte.' },
    ],
  },
];

/*
 * Rezervace , Typeform-style single-question flow.
 *
 * Cíle (per /loop conversation 2026-05-20):
 *   1. Mobile-first, žádná sidebar co kanibalizuje viewport.
 *   2. Jedna otázka per obrazovka, auto-advance po výběru.
 *   3. Smart pre-fill z ?typ=<slug>, skip až 2 kroky.
 *   4. Progress bar (single 1px ruler), ne 4 step chips.
 *   5. Sticky trust bar dole („Nezávazné · 0 spam · do 24h").
 *   6. Success state s CrossLinkPair odkazujícím na další podstránky.
 *
 * Backend: console.log payload + success UI. Worker scaffold v worker/
 * deploy pending, frontend bude napojen v Phase 5b.
 */

const apartmany = (await getCollection('apartmany'))
  .filter((a) => !a.data.hidden)
  .sort((a, b) => a.data.order - b.data.order);
const coliving = (await getCollection('sdilenePokoje'))
  .filter((c) => !c.data.hidden)
  .sort((a, b) => a.data.order - b.data.order);
const fmt = (n: number) => `${n.toLocaleString('cs-CZ')} Kč`;
---
<Base
  title="Registrace zájmu o bydlení · Startovací Hub Klecany"
  description="Vyberte typ bydlení, termín a způsob kontaktu. Do 24 hodin se vám ozveme z rezervačního oddělení. Registrace je nezávazná."
  headerVariant="overlay">

  <main class="rez" id="rez" data-rez-root>
    <header class="rez__head">
      <p class="rez__step-counter" aria-live="polite">
        <span data-step-current>1</span><span class="rez__step-sep">/</span><span data-step-total>3</span>
      </p>
      <div class="rez__progress" aria-hidden="true">
        <span class="rez__progress-fill" data-progress-fill></span>
      </div>
    </header>

    <form id="rez-form" class="rez__form" novalidate>
      {/* === KROK: Koncept === */}
      <section class="rez__panel is-current" data-panel="koncept" data-panel-index="0">
        <div class="rez__panel-intro">
          <h1 class="rez__q">Jak chcete v&nbsp;Hubu bydlet?</h1>
          <p class="rez__q-hint">Doporučíme nejvhodnější formát. Volba není závazná.</p>
        </div>
        <div class="rez__choices rez__choices--3 rez__choices--main">
          <label class="rez__choice">
            <input type="radio" name="koncept" value="privatni" data-auto-next />
            <span class="rez__choice-body">
              <span class="rez__choice-title">Privátní apartmán</span>
              <span class="rez__choice-meta">Vlastní byt, kuchyň, koupelna. Pět velikostí 1+kk až 5+kk.</span>
              <span class="rez__choice-price">od&nbsp;10 000&nbsp;Kč<span class="rez__choice-price-unit">/měs</span></span>
            </span>
          </label>
          <label class="rez__choice">
            <input type="radio" name="koncept" value="co-living" data-auto-next />
            <span class="rez__choice-body">
              <span class="rez__choice-title">Sdílené pokoje</span>
              <span class="rez__choice-meta">Vlastní lůžko, box nebo kapsle, sdílená kuchyň a koupelna.</span>
              <span class="rez__choice-price">od&nbsp;3 000&nbsp;Kč<span class="rez__choice-price-unit">/měs</span></span>
            </span>
          </label>
          <label class="rez__choice">
            <input type="radio" name="koncept" value="stipendium" data-auto-next />
            <span class="rez__choice-body">
              <span class="rez__choice-title">Žádost o&nbsp;stipendium</span>
              <span class="rez__choice-meta">Pobytové (slevy na&nbsp;bydlení za&nbsp;přínos) nebo projektové (úhrada materiálu a&nbsp;dílen).</span>
              <span class="rez__choice-price">Nadace&nbsp;VPD</span>
            </span>
          </label>
        </div>

        <div class="rez__more" data-reserve-section>
          <p class="rez__more-head">Nebo si rovnou rezervujte konkrétní zázemí a dopravu</p>
          {reservableGroups.map((g) => (
            <div class="rez__more-group">
              <p class="rez__more-group-title">{g.title}</p>
              <div class="rez__more-grid">
                {g.items.map((r) => (
                  <button type="button" class="rez__more-item" data-reserve-locked data-zazemi={r.slug} style={`--tile-hue: ${r.hue};`} aria-label={`Rezervovat ${r.label}, zatím jen pro přihlášené`}>
                    <span class="rez__more-icon" aria-hidden="true"><Icon name={r.icon} size={22} /></span>
                    <span class="rez__more-label">{r.label}</span>
                  </button>
                ))}
              </div>
            </div>
          ))}
          <p class="rez__more-msg" data-reserve-msg hidden role="status">
            Rezervace konkrétního zázemí je zatím jen pro přihlášené uživatele. Přihlášení i rezervaci zázemí teprve připravujeme, zatím sbíráme zájem o bydlení výše.
          </p>
        </div>

        <div class="rez__actions" data-actions>
          <button type="button" class="rez__back" data-prev hidden aria-label="Předchozí krok">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true">
              <path d="M19 12H5m0 0l6-6m-6 6l6 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
            <span>Zpět</span>
          </button>
          <span class="rez__actions-spacer"></span>
          <span class="rez__actions-counter" aria-hidden="true">
            <span data-step-current-mini>1</span><span class="rez__step-sep">/</span><span data-step-total-mini>3</span>
          </span>
          <button type="button" class="rez__cta rez__cta--compact" data-next>
            Pokračovat <Arrow dir="right" variant="chevron" size={15} weight={2.4} />
          </button>
        </div>
      </section>

      {/* === KROK: Formát (privátní) === */}
      <section class="rez__panel" data-panel="format-privatni" data-panel-index="1" data-show-for="privatni" hidden>
        <div class="rez__panel-intro">
          <h1 class="rez__q">Jaký apartmán?</h1>
          <p class="rez__q-hint">Pět privátních jednotek 1+kk až 5+kk. Cena za celý byt.</p>
        </div>
        <div class="rez__choices rez__choices--cards rez__choices--3">
          {apartmany.map((a) => (
            <label class="rez__choice rez__choice--card" data-format-slug={a.data.slug}>
              <input type="radio" name="format" value={a.data.slug} data-auto-next />
              {a.data.thumbnail && (
                <span class="rez__choice-thumb" aria-hidden="true">
                  <img src={withBase(a.data.thumbnail)} alt="" loading="lazy" decoding="async" />
                </span>
              )}
              <span class="rez__choice-body">
                <span class="rez__choice-head">
                  <span class="rez__choice-title">{a.data.shortName}</span>
                  <span class="rez__choice-price">od&nbsp;{a.data.cena.anchor.toLocaleString('cs-CZ')}<span class="rez__choice-price-unit">&nbsp;Kč/měs</span></span>
                </span>
                <span class="rez__choice-meta">{a.data.plocha} · {a.data.kapacita} lůžek</span>
                <span class="rez__choice-desc">{a.data.popis}</span>
              </span>
            </label>
          ))}
        </div>
        <div class="rez__actions" data-actions>
          <button type="button" class="rez__back" data-prev hidden aria-label="Předchozí krok">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true">
              <path d="M19 12H5m0 0l6-6m-6 6l6 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
            <span>Zpět</span>
          </button>
          <span class="rez__actions-spacer"></span>
          <span class="rez__actions-counter" aria-hidden="true">
            <span data-step-current-mini>2</span><span class="rez__step-sep">/</span><span data-step-total-mini>3</span>
          </span>
          <button type="button" class="rez__cta rez__cta--compact" data-next>
            Pokračovat <Arrow dir="right" variant="chevron" size={15} weight={2.4} />
          </button>
        </div>
      </section>

      {/* === KROK: Formát (co-living) === */}
      <section class="rez__panel" data-panel="format-coliving" data-panel-index="1" data-show-for="co-living" hidden>
        <div class="rez__panel-intro">
          <h1 class="rez__q">Jaké sdílené ubytování?</h1>
          <p class="rez__q-hint">Šest variant podle míry soukromí, od otevřeného lůžka po kapslové dvojlůžko.</p>
        </div>
        <div class="rez__choices rez__choices--cards rez__choices--2">
          {coliving.map((c) => (
            <label class="rez__choice rez__choice--card" data-format-slug={c.data.slug}>
              <input type="radio" name="format" value={c.data.slug} data-auto-next />
              {c.data.thumbnail && (
                <span class="rez__choice-thumb" aria-hidden="true">
                  <img src={withBase(c.data.thumbnail)} alt="" loading="lazy" decoding="async" />
                </span>
              )}
              <span class="rez__choice-body">
                <span class="rez__choice-head">
                  <span class="rez__choice-title">{c.data.shortName}</span>
                  <span class="rez__choice-price">od&nbsp;{c.data.cena.anchor.toLocaleString('cs-CZ')}<span class="rez__choice-price-unit">&nbsp;Kč/měs</span></span>
                </span>
                <span class="rez__choice-meta">Matrace {c.data.matrace.join(' / ')}</span>
                <span class="rez__choice-desc">{c.data.popis}</span>
              </span>
            </label>
          ))}
        </div>
        <div class="rez__actions" data-actions>
          <button type="button" class="rez__back" data-prev hidden aria-label="Předchozí krok">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true">
              <path d="M19 12H5m0 0l6-6m-6 6l6 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
            <span>Zpět</span>
          </button>
          <span class="rez__actions-spacer"></span>
          <span class="rez__actions-counter" aria-hidden="true">
            <span data-step-current-mini>2</span><span class="rez__step-sep">/</span><span data-step-total-mini>3</span>
          </span>
          <button type="button" class="rez__cta rez__cta--compact" data-next>
            Pokračovat <Arrow dir="right" variant="chevron" size={15} weight={2.4} />
          </button>
        </div>
      </section>

      {/* === KROK: Stipendium (typ + krátký popis) === */}
      <section class="rez__panel" data-panel="format-stipendium" data-panel-index="1" data-show-for="stipendium" hidden>
        <div class="rez__panel-intro">
          <h1 class="rez__q">Jaké stipendium vás zajímá?</h1>
          <p class="rez__q-hint">Dvě hlavní kategorie. Můžete žádat o&nbsp;obě zároveň, pokud váš projekt zapadá.</p>
        </div>
        <div class="rez__choices rez__choices--2 rez__choices--main">
          <label class="rez__choice">
            <input type="radio" name="stipendium-typ" value="pobytove" />
            <span class="rez__choice-body">
              <span class="rez__choice-title">Pobytové stipendium</span>
              <span class="rez__choice-meta">Nadace pokryje část nebo celé bydlení v&nbsp;Hubu výměnou za&nbsp;přínos komunitě: dílny, workshopy, péče o&nbsp;areál nebo vlastní projekt s&nbsp;veřejným výstupem.</span>
            </span>
          </label>
          <label class="rez__choice">
            <input type="radio" name="stipendium-typ" value="projektove" />
            <span class="rez__choice-body">
              <span class="rez__choice-title">Projektové stipendium</span>
              <span class="rez__choice-meta">Nadace proplatí konkrétní náklady projektu: materiál, ateliérový nájem, CNC strojochodiny, dílenský čas. Bydlení žadatel řeší samostatně.</span>
            </span>
          </label>
          <label class="rez__choice">
            <input type="radio" name="stipendium-typ" value="oboji" />
            <span class="rez__choice-body">
              <span class="rez__choice-title">Obě kategorie</span>
              <span class="rez__choice-meta">Bydlení i&nbsp;náklady projektu. Probereme s&nbsp;vámi, co dává smysl.</span>
            </span>
          </label>
        </div>
        <div class="rez__field">
          <label for="stipendium-zamer">Pár vět o&nbsp;záměru</label>
          <textarea id="stipendium-zamer" name="stipendium-zamer" rows="3" maxlength="500" placeholder="Krátký popis projektu nebo přínosu pro komunitu. Detail probereme telefonicky."></textarea>
        </div>
        <div class="rez__actions" data-actions>
          <button type="button" class="rez__back" data-prev hidden aria-label="Předchozí krok">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true">
              <path d="M19 12H5m0 0l6-6m-6 6l6 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
            <span>Zpět</span>
          </button>
          <span class="rez__actions-spacer"></span>
          <span class="rez__actions-counter" aria-hidden="true">
            <span data-step-current-mini>2</span><span class="rez__step-sep">/</span><span data-step-total-mini>3</span>
          </span>
          <button type="button" class="rez__cta rez__cta--compact" data-next>
            Pokračovat <Arrow dir="right" variant="chevron" size={15} weight={2.4} />
          </button>
        </div>
      </section>

      {/* === KROK: Termín === */}
      <section class="rez__panel" data-panel="termin" data-panel-index="2" hidden>
        <div class="rez__panel-intro">
          <h1 class="rez__q">Kdy chcete nastoupit?</h1>
          <p class="rez__q-hint">Hub je v projektové přípravě. Termín potvrdíme telefonicky.</p>
        </div>
        <div class="rez__grid-2">
          <div class="rez__field">
            <label for="mesic">Měsíc nástupu</label>
            <select id="mesic" name="mesic" required>
              <option value="">Vyberte měsíc</option>
              <option value="2026-09">09 / 2026</option>
              <option value="2026-10">10 / 2026</option>
              <option value="2026-11">11 / 2026</option>
              <option value="2026-12">12 / 2026</option>
              <option value="2027-01">01 / 2027</option>
              <option value="2027-02">02 / 2027</option>
              <option value="2027-03">03 / 2027</option>
              <option value="2027-Q2">Q2 / 2027</option>
