    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(190px, 1fr));
    gap: var(--space-2);
  }
  /* Větší barevné dlaždice s ikonou v hue pill (recept ResidentBenefits).
     --tile-hue přichází per item z locked paletky 25/50/130/200/240. */
