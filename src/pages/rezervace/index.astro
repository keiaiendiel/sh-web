<script is:inline>
  /* Sekundární rozcestník: slepá tlačítka rezervace zázemí , zatím jen pro
     přihlášené. Klik odhalí zprávu, žádná navigace. Re-bind na page-load.
     ?zazemi=<slug> prefill: zvýrazní cílovou dlaždici a ukáže zprávu (CTA
     z dopravních a zázemních stránek sem vedou s tímto parametrem). */
  (function () {
    function bind() {
      var btns = document.querySelectorAll('[data-reserve-locked]:not([data-locked-bound])');
      btns.forEach(function (b) {
        b.dataset.lockedBound = '1';
        b.addEventListener('click', function () {
          var section = b.closest('[data-reserve-section]');
          var msg = section ? section.querySelector('[data-reserve-msg]') : document.querySelector('[data-reserve-msg]');
          if (msg) { msg.hidden = false; }
          b.classList.add('is-poked');
          setTimeout(function () { b.classList.remove('is-poked'); }, 400);
        });
      });

      var zazemi = new URL(window.location.href).searchParams.get('zazemi');
      if (zazemi && !document.body.dataset.zazemiPrefill) {
        document.body.dataset.zazemiPrefill = '1';
        var section = document.querySelector('[data-reserve-section]:not([hidden])');
        if (section) {
          var tile = section.querySelector('[data-zazemi="' + zazemi + '"]');
          if (tile) tile.classList.add('is-hot');
          var msg = section.querySelector('[data-reserve-msg]');
          if (msg) msg.hidden = false;
          setTimeout(function () {
            (tile || section).scrollIntoView({ behavior: 'smooth', block: 'center' });
          }, 350);
        }
      }
    }
    document.addEventListener('astro:page-load', bind);
  }());
</script>

<script is:inline>
  /* Post-submit dotazník: jedna otázka na obrazovku, živý součet orientační
     ceny doplňků. Otázky jsou vyrenderované staticky (fieldsety), JS jen
     přepíná, sčítá a na konci sestaví shrnutí. */
  (function () {
    function bind() {
      var panel = document.querySelector('.rez__panel--success');
      if (!panel || panel.dataset.svBound === '1') return;
      panel.dataset.svBound = '1';

      var startBox = panel.querySelector('[data-survey-start]');
      var survey = panel.querySelector('[data-survey]');
      var done = panel.querySelector('[data-survey-done]');
      var after = panel.querySelector('[data-survey-after]');
      var qs = Array.prototype.slice.call(panel.querySelectorAll('.rez-survey__q'));
      var stepEl = panel.querySelector('[data-sv-step]');
      var fill = panel.querySelector('[data-sv-fill]');
      var ticker = panel.querySelector('[data-sv-ticker]');
      var summaryEl = panel.querySelector('[data-sv-summary]');
      if (!survey || !qs.length) return;

      var idx = 0;
      var timer = null;

      function fmtKc(n) {
        return n.toLocaleString('cs-CZ') + ' Kč';
      }
      function total() {
        var sum = 0;
        panel.querySelectorAll('.rez-survey__q input:checked').forEach(function (i) {
          sum += parseInt(i.dataset.svPrice || '0', 10) || 0;
        });
        return sum;
      }
      function updateTicker() {
        if (ticker) ticker.textContent = 'Vybrané doplňky: +' + fmtKc(total()) + ' měsíčně (orientačně)';
      }
      function show(i) {
        idx = i;
        qs.forEach(function (q, j) { q.hidden = j !== i; });
        if (stepEl) stepEl.textContent = String(i + 1);
        if (fill) fill.style.transform = 'scaleX(' + ((i + 1) / qs.length) + ')';
        updateTicker();
      }
      function finish() {
        survey.hidden = true;
        if (done) {
          var picks = [];
          panel.querySelectorAll('.rez-survey__q input:checked').forEach(function (i) {
            if (i.dataset.svPick) picks.push(i.dataset.svPick);
          });
          var sum = total();
          var text;
          if (picks.length) {
            text = 'Poznamenali jsme si: ' + picks.join(', ') + '.';
            if (sum > 0) text += ' Dohromady zhruba +' + fmtKc(sum) + ' měsíčně k ceně bydlení.';
          } else {
            text = 'Žádné doplňky zatím nechcete, to je v pořádku. Vše jde přidat kdykoli později.';
          }
          if (summaryEl) summaryEl.textContent = text;
          done.hidden = false;
        }
        if (after) after.hidden = false;
      }
      function next() {
        if (idx + 1 >= qs.length) { finish(); return; }
        show(idx + 1);
      }

      panel.addEventListener('click', function (e) {
        if (e.target.closest('[data-sv-start]')) {
          startBox.hidden = true;
          survey.hidden = false;
          show(0);
        }
        if (e.target.closest('[data-sv-later]')) {
          startBox.hidden = true;
          if (after) after.hidden = false;
        }
        if (e.target.closest('[data-sv-skip]')) {
          clearTimeout(timer);
          next();
        }
        if (e.target.closest('[data-sv-back]')) {
          clearTimeout(timer);
          if (idx > 0) show(idx - 1);
        }
      });

      panel.addEventListener('change', function (e) {
        if (e.target.closest('.rez-survey__q')) {
          updateTicker();
          clearTimeout(timer);
          timer = setTimeout(next, 320);
        }
      });
    }
    document.addEventListener('astro:page-load', bind);
  }());
</script>

<style>
