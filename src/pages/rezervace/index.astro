---
import Base from '../../layouts/Base.astro';
import CrossLinkPair from '../../components/CrossLinkPair.astro';
import { getCollection } from 'astro:content';
import { withBase } from '../../utils/url';

/*
 * Rezervace , Typeform-style single-question flow.
 *
 * Cíle (per /loop conversation 2026-05-20):
 *   1. Mobile-first, žádná sidebar co kanibalizuje viewport.
 *   2. Jedna otázka per obrazovka, auto-advance po výběru.
 *   3. Smart pre-fill z ?typ=<slug>, skip až 2 kroky.
 *   4. Progress bar (single 1px ruler), ne 4 step chips.
 *   5. Sticky trust bar dole („Nezávazné · 0 spam · do 24h").
 *   6. Success state s CrossLinkPair odkazujícím na další podstránky.
 *
 * Backend: console.log payload + success UI. Worker scaffold v worker/
 * deploy pending, frontend bude napojen v Phase 5b.
 */

const apartmany = (await getCollection('apartmany'))
  .filter((a) => !a.data.hidden)
  .sort((a, b) => a.data.order - b.data.order);
const coliving = (await getCollection('coliving'))
  .filter((c) => !c.data.hidden)
  .sort((a, b) => a.data.order - b.data.order);
const fmt = (n: number) => `${n.toLocaleString('cs-CZ')} Kč`;
---
<Base
  title="Registrace zájmu o bydlení · Startovací Hub Klecany"
  description="Vyberte typ bydlení, termín a způsob kontaktu. Do 24 hodin se vám ozveme z rezervačního oddělení. Registrace je nezávazná."
  headerVariant="overlay">

  <main class="rez" id="rez" data-rez-root>
    <header class="rez__head">
      <p class="rez__step-counter" aria-live="polite">
        <span data-step-current>1</span><span class="rez__step-sep">/</span><span data-step-total>3</span>
      </p>
      <div class="rez__progress" aria-hidden="true">
        <span class="rez__progress-fill" data-progress-fill></span>
      </div>
    </header>

    <form id="rez-form" class="rez__form" novalidate>
      {/* === KROK: Koncept === */}
      <section class="rez__panel is-current" data-panel="koncept" data-panel-index="0">
        <div class="rez__panel-intro">
          <h1 class="rez__q">Jak chcete v&nbsp;Hubu bydlet?</h1>
          <p class="rez__q-hint">Doporučíme nejvhodnější formát. Volba není závazná.</p>
        </div>
        <div class="rez__choices rez__choices--3">
          <label class="rez__choice">
            <input type="radio" name="koncept" value="privatni" data-auto-next />
            <span class="rez__choice-body">
              <span class="rez__choice-title">Privátní apartmán</span>
              <span class="rez__choice-meta">Vlastní byt, kuchyň, koupelna. Od&nbsp;9 500&nbsp;Kč&nbsp;/&nbsp;měsíc.</span>
            </span>
          </label>
          <label class="rez__choice">
            <input type="radio" name="koncept" value="co-living" data-auto-next />
            <span class="rez__choice-body">
              <span class="rez__choice-title">Co-living</span>
              <span class="rez__choice-meta">Vlastní lůžko nebo kapsle, sdílená kuchyň. Od&nbsp;3 000&nbsp;Kč&nbsp;/&nbsp;měsíc.</span>
            </span>
          </label>
          <label class="rez__choice">
            <input type="radio" name="koncept" value="stipendium" data-auto-next />
            <span class="rez__choice-body">
              <span class="rez__choice-title">Žádost o&nbsp;stipendium</span>
              <span class="rez__choice-meta">Pobytové (slevy na&nbsp;bydlení za&nbsp;přínos) nebo projektové (úhrada materiálu a&nbsp;dílen).</span>
            </span>
          </label>
        </div>
        <div class="rez__actions" data-actions>
          <button type="button" class="rez__back" data-prev hidden aria-label="Předchozí krok">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true">
              <path d="M19 12H5m0 0l6-6m-6 6l6 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
            <span>Zpět</span>
          </button>
          <span class="rez__actions-spacer"></span>
          <span class="rez__actions-counter" aria-hidden="true">
            <span data-step-current-mini>1</span><span class="rez__step-sep">/</span><span data-step-total-mini>3</span>
          </span>
          <button type="button" class="rez__cta rez__cta--compact" data-next>
            Pokračovat <span aria-hidden="true">→</span>
          </button>
        </div>
      </section>

      {/* === KROK: Formát (privátní) === */}
      <section class="rez__panel" data-panel="format-privatni" data-panel-index="1" data-show-for="privatni" hidden>
        <div class="rez__panel-intro">
          <h1 class="rez__q">Jaký apartmán?</h1>
          <p class="rez__q-hint">Pět privátních jednotek 1+kk až 5+kk. Cena za celý byt.</p>
        </div>
        <div class="rez__choices rez__choices--cards rez__choices--3">
          {apartmany.map((a) => (
            <label class="rez__choice rez__choice--card" data-format-slug={a.data.slug}>
              <input type="radio" name="format" value={a.data.slug} data-auto-next />
              {a.data.thumbnail && (
                <span class="rez__choice-thumb" aria-hidden="true">
                  <img src={withBase(a.data.thumbnail)} alt="" loading="lazy" decoding="async" />
                </span>
              )}
              <span class="rez__choice-body">
                <span class="rez__choice-head">
                  <span class="rez__choice-title">{a.data.shortName}</span>
                  <span class="rez__choice-price">od&nbsp;{a.data.cena.anchor.toLocaleString('cs-CZ')}<span class="rez__choice-price-unit">&nbsp;Kč/měs</span></span>
                </span>
                <span class="rez__choice-meta">{a.data.plocha} · {a.data.kapacita} lůžek</span>
                <span class="rez__choice-desc">{a.data.popis}</span>
              </span>
            </label>
          ))}
        </div>
        <div class="rez__actions" data-actions>
          <button type="button" class="rez__back" data-prev hidden aria-label="Předchozí krok">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true">
              <path d="M19 12H5m0 0l6-6m-6 6l6 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
            <span>Zpět</span>
          </button>
          <span class="rez__actions-spacer"></span>
          <span class="rez__actions-counter" aria-hidden="true">
            <span data-step-current-mini>2</span><span class="rez__step-sep">/</span><span data-step-total-mini>3</span>
          </span>
          <button type="button" class="rez__cta rez__cta--compact" data-next>
            Pokračovat <span aria-hidden="true">→</span>
          </button>
        </div>
      </section>

      {/* === KROK: Formát (co-living) === */}
      <section class="rez__panel" data-panel="format-coliving" data-panel-index="1" data-show-for="co-living" hidden>
        <div class="rez__panel-intro">
          <h1 class="rez__q">Jaká varianta co-livingu?</h1>
          <p class="rez__q-hint">Čtyři formáty od jednolůžkové kapsle po dvoulůžko ve sdíleném bytě.</p>
        </div>
        <div class="rez__choices rez__choices--cards rez__choices--2">
          {coliving.map((c) => (
            <label class="rez__choice rez__choice--card" data-format-slug={c.data.slug}>
              <input type="radio" name="format" value={c.data.slug} data-auto-next />
              {c.data.thumbnail && (
                <span class="rez__choice-thumb" aria-hidden="true">
                  <img src={withBase(c.data.thumbnail)} alt="" loading="lazy" decoding="async" />
                </span>
              )}
              <span class="rez__choice-body">
                <span class="rez__choice-head">
                  <span class="rez__choice-title">{c.data.shortName}</span>
                  <span class="rez__choice-price">od&nbsp;{c.data.cena.anchor.toLocaleString('cs-CZ')}<span class="rez__choice-price-unit">&nbsp;Kč/měs</span></span>
                </span>
                <span class="rez__choice-meta">Matrace {c.data.matrace.join(' / ')}</span>
                <span class="rez__choice-desc">{c.data.popis}</span>
              </span>
            </label>
          ))}
        </div>
        <div class="rez__actions" data-actions>
          <button type="button" class="rez__back" data-prev hidden aria-label="Předchozí krok">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true">
              <path d="M19 12H5m0 0l6-6m-6 6l6 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
            <span>Zpět</span>
          </button>
          <span class="rez__actions-spacer"></span>
          <span class="rez__actions-counter" aria-hidden="true">
            <span data-step-current-mini>2</span><span class="rez__step-sep">/</span><span data-step-total-mini>3</span>
          </span>
          <button type="button" class="rez__cta rez__cta--compact" data-next>
            Pokračovat <span aria-hidden="true">→</span>
          </button>
        </div>
      </section>

      {/* === KROK: Stipendium (typ + krátký popis) === */}
      <section class="rez__panel" data-panel="format-stipendium" data-panel-index="1" data-show-for="stipendium" hidden>
        <div class="rez__panel-intro">
          <h1 class="rez__q">Jaké stipendium vás zajímá?</h1>
          <p class="rez__q-hint">Dvě hlavní kategorie. Můžete žádat o&nbsp;obě zároveň, pokud váš projekt zapadá.</p>
        </div>
        <div class="rez__choices rez__choices--2">
          <label class="rez__choice">
            <input type="radio" name="stipendium-typ" value="pobytove" />
            <span class="rez__choice-body">
              <span class="rez__choice-title">Pobytové stipendium</span>
              <span class="rez__choice-meta">Nadace pokryje část nebo celé bydlení v&nbsp;Hubu výměnou za&nbsp;přínos komunitě: dílny, workshopy, péče o&nbsp;areál nebo vlastní projekt s&nbsp;veřejným výstupem.</span>
            </span>
          </label>
          <label class="rez__choice">
            <input type="radio" name="stipendium-typ" value="projektove" />
            <span class="rez__choice-body">
              <span class="rez__choice-title">Projektové stipendium</span>
              <span class="rez__choice-meta">Nadace proplatí konkrétní náklady projektu: materiál, ateliérový nájem, CNC strojochodiny, dílenský čas. Bydlení žadatel řeší samostatně.</span>
            </span>
          </label>
          <label class="rez__choice">
            <input type="radio" name="stipendium-typ" value="oboji" />
            <span class="rez__choice-body">
              <span class="rez__choice-title">Obě kategorie</span>
              <span class="rez__choice-meta">Bydlení i&nbsp;náklady projektu. Probereme s&nbsp;vámi, co dává smysl.</span>
            </span>
          </label>
        </div>
        <div class="rez__field">
          <label for="stipendium-zamer">Pár vět o&nbsp;záměru</label>
          <textarea id="stipendium-zamer" name="stipendium-zamer" rows="3" maxlength="500" placeholder="Krátký popis projektu nebo přínosu pro komunitu. Detail probereme telefonicky."></textarea>
        </div>
        <div class="rez__actions" data-actions>
          <button type="button" class="rez__back" data-prev hidden aria-label="Předchozí krok">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true">
              <path d="M19 12H5m0 0l6-6m-6 6l6 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
            <span>Zpět</span>
          </button>
          <span class="rez__actions-spacer"></span>
          <span class="rez__actions-counter" aria-hidden="true">
            <span data-step-current-mini>2</span><span class="rez__step-sep">/</span><span data-step-total-mini>3</span>
          </span>
          <button type="button" class="rez__cta rez__cta--compact" data-next>
            Pokračovat <span aria-hidden="true">→</span>
          </button>
        </div>
      </section>

      {/* === KROK: Termín === */}
      <section class="rez__panel" data-panel="termin" data-panel-index="2" hidden>
        <div class="rez__panel-intro">
          <h1 class="rez__q">Kdy chcete nastoupit?</h1>
          <p class="rez__q-hint">Hub je v projektové přípravě. Termín potvrdíme telefonicky.</p>
        </div>
        <div class="rez__grid-2">
          <div class="rez__field">
            <label for="mesic">Měsíc nástupu</label>
            <select id="mesic" name="mesic" required>
              <option value="">Vyberte měsíc</option>
              <option value="2026-09">09 / 2026</option>
              <option value="2026-10">10 / 2026</option>
              <option value="2026-11">11 / 2026</option>
              <option value="2026-12">12 / 2026</option>
              <option value="2027-01">01 / 2027</option>
              <option value="2027-02">02 / 2027</option>
              <option value="2027-03">03 / 2027</option>
              <option value="2027-Q2">Q2 / 2027</option>
              <option value="2027-Q3">Q3 / 2027</option>
              <option value="2027-Q4">Q4 / 2027</option>
            </select>
          </div>
          <div class="rez__field">
            <label>Délka pobytu</label>
            <div class="rez__pills">
              <label class="rez__pill"><input type="radio" name="delka" value="1-2" required /><span>1&ndash;2&nbsp;měs</span></label>
              <label class="rez__pill"><input type="radio" name="delka" value="3-5" /><span>3&ndash;5&nbsp;měs</span></label>
              <label class="rez__pill"><input type="radio" name="delka" value="6-11" /><span>6&ndash;11&nbsp;měs</span></label>
              <label class="rez__pill"><input type="radio" name="delka" value="12+" /><span>12+&nbsp;měs</span></label>
            </div>
          </div>
        </div>
        <div class="rez__addons">
          <label class="rez__addon">
            <input type="checkbox" name="prodlouzeni" value="ano" />
            <span class="rez__addon-body">
              <strong>Právo prodloužit pobyt</strong>
              <small>Přibližně +5 až 10 % k základní ceně.</small>
            </span>
          </label>
          <label class="rez__addon">
            <input type="checkbox" name="stipendium" value="ano" />
            <span class="rez__addon-body">
              <strong>Mám zájem o pobytové stipendium</strong>
              <small>Oznámíme vám příští výzvu.</small>
            </span>
          </label>
        </div>
        <div class="rez__actions" data-actions>
          <button type="button" class="rez__back" data-prev hidden aria-label="Předchozí krok">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true">
              <path d="M19 12H5m0 0l6-6m-6 6l6 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
            <span>Zpět</span>
          </button>
          <span class="rez__actions-spacer"></span>
          <span class="rez__actions-counter" aria-hidden="true">
            <span data-step-current-mini>3</span><span class="rez__step-sep">/</span><span data-step-total-mini>4</span>
          </span>
          <button type="button" class="rez__cta rez__cta--compact" data-next>
            Pokračovat <span aria-hidden="true">→</span>
          </button>
        </div>
      </section>

      {/* === KROK: Kontakt === */}
      <section class="rez__panel" data-panel="kontakt" data-panel-index="3" hidden>
        <div class="rez__panel-intro">
          <h1 class="rez__q">Kam vám zavoláme?</h1>
          <p class="rez__q-hint">Voláme z rezervačního oddělení do 24 hodin.</p>
        </div>
        <div class="rez__grid-2">
          <div class="rez__field">
            <label for="jmeno">Křestní jméno</label>
            <input type="text" id="jmeno" name="jmeno" required autocomplete="given-name" />
          </div>
          <div class="rez__field">
            <label for="prijmeni">Příjmení</label>
            <input type="text" id="prijmeni" name="prijmeni" required autocomplete="family-name" />
          </div>
        </div>
        <div class="rez__field">
          <label for="telefon">Telefon</label>
          <input type="tel" id="telefon" name="telefon" required autocomplete="tel" inputmode="tel" placeholder="+420" />
        </div>
        <div class="rez__field">
          <label for="email">E-mail</label>
          <input type="email" id="email" name="email" required autocomplete="email" placeholder="vy@example.cz" />
        </div>
        <div class="rez__field">
          <label for="poznamka">Poznámka (volitelné)</label>
          <textarea id="poznamka" name="poznamka" rows="3" maxlength="500" placeholder="Mazlíček, partner, preference spolubydlícího"></textarea>
        </div>
        <label class="rez__gdpr">
          <input type="checkbox" name="gdpr" value="ano" required />
          <span>Souhlasím se zpracováním osobních údajů. <a href={withBase('/gdpr/')}>Zásady</a>.</span>
        </label>
        <div class="rez__actions rez__actions--submit" data-actions>
          <button type="button" class="rez__back" data-prev hidden aria-label="Předchozí krok">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true">
              <path d="M19 12H5m0 0l6-6m-6 6l6 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
            <span>Zpět</span>
          </button>
          <span class="rez__actions-spacer"></span>
          <span class="rez__actions-counter" aria-hidden="true">
            <span data-step-current-mini>4</span><span class="rez__step-sep">/</span><span data-step-total-mini>4</span>
          </span>
          <button type="submit" class="rez__cta rez__cta--primary" id="rez-submit">
            Odeslat nezávaznou registraci <span aria-hidden="true">→</span>
          </button>
        </div>
      </section>

      {/* === SUCCESS === */}
      <section class="rez__panel rez__panel--success" data-panel="success" data-panel-index="4" hidden>
        <div class="rez__success-mark" aria-hidden="true">
          <svg width="56" height="56" viewBox="0 0 24 24" fill="none">
            <path d="M5 12.5l4.5 4.5L19 7.5" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" />
          </svg>
        </div>
        <div class="rez__panel-intro">
          <h1 class="rez__q">Dorazilo. Zavoláme do&nbsp;24&nbsp;hodin.</h1>
          <p class="rez__q-hint">Probereme termín, detaily nástupu a&nbsp;co dál. Pořád je to nezávazná registrace, žádný závazek.</p>
        </div>
      </section>
    </form>

    <footer class="rez__trust" aria-label="Naše záruky">
      <span class="rez__trust-item">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" aria-hidden="true">
          <path d="M9 11l3 3L22 4" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
          <path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
        </svg>
        Nezávazné
      </span>
      <span class="rez__trust-item">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" aria-hidden="true">
          <circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="2" />
          <path d="M12 6v6l4 2" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
        </svg>
        Odpověď do 24&nbsp;hodin
      </span>
      <span class="rez__trust-item">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" aria-hidden="true">
          <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" stroke="currentColor" stroke-width="2" stroke-linejoin="round" />
        </svg>
        Bez spamu, bez závazku
      </span>
    </footer>
  </main>

  {/* CrossLinkPair zobrazený pouze v success state (toggle přes class) */}
  <div class="rez-after" data-rez-after hidden>
    <CrossLinkPair
      sectionLabel="Než se vám ozveme"
      items={[
        { eyebrow: 'Komunita',  title: 'Bazén, <em>sauna</em>, jídelna a&nbsp;klubovna.', href: '/komunita/', variant: 'ink' },
        { eyebrow: 'Okolí',     title: 'Klecany, <em>15&nbsp;km</em> od&nbsp;Prahy.',     href: '/okoli/',    variant: 'cream' },
      ]}
    />
  </div>
</Base>

<script is:inline define:vars={{
  apartmanySlug: apartmany.map((a) => a.data.slug),
  colivingSlug: coliving.map((c) => c.data.slug),
}}>
  /* Typeform-style controller.
   *   - Steps: [koncept, format-<branch>, termin, kontakt, success]
   *   - Auto-advance: po radio change s data-auto-next → next() s 250ms delay
   *   - Smart pre-fill z ?typ=<slug>: skip koncept + format → start na termin
   *   - Animace: translateX slide-in z práva při forward, z leva při back
   */
  (function () {
    var root = document.querySelector('[data-rez-root]');
    if (!root) return;
    var form = document.getElementById('rez-form');
    var panels = form.querySelectorAll('.rez__panel');
    var counter = root.querySelector('[data-step-current]');
    var totalEl = root.querySelector('[data-step-total]');
    var progressFill = root.querySelector('[data-progress-fill]');
    var afterEl = document.querySelector('[data-rez-after]');

    /* State: history stack of panel names. Current panel = last item.
     * Routing rules:
     *   - koncept choice "privatni"   → format-privatni
     *   - koncept choice "co-living"  → format-coliving
     *   - koncept choice "stipendium" → format-stipendium
     *   - format-* → termin
     *   - termin → kontakt
     *   - kontakt submit → success
     */
    var history = ['koncept'];

    function panelByName(name) {
      return form.querySelector('.rez__panel[data-panel="' + name + '"]');
    }

    function totalSteps() {
      /* Length of remaining flow depends on how deep we entered the wizard:
       *   typ= deep-link        → history starts at 'termin'      → 2 (termin, kontakt)
       *   cesta= hero deep-link → history starts at 'format-*'    → 3 (format, termin, kontakt)
       *   default               → history starts at 'koncept'     → 4 (koncept, format, termin, kontakt) */
      var first = history[0];
      if (first === 'termin') return 2;
      if (first.indexOf('format-') === 0) return 3;
      return 4;
    }

    /* Pending hide timers per panel. Bez WeakMap by stale setTimeout
     * z předchozí showPanel volání mohl skrýt target panel poté co se k němu
     * uživatel vrátil přes Back (zde reprodukováno: koncept → privátní →
     * Back v 300ms → koncept zůstane is-current, ale hidden=true → Pokračovat
     * tlačítko nedostupné). Při každém showPanel zrušíme pending timer
     * pro target a odstraníme stale is-leaving-* třídy. */
    var pendingHide = new WeakMap();

    function showPanel(name, direction) {
      direction = direction || 'forward';
      var target = panelByName(name);
      if (!target) return;

      /* Cancel pending hide pro target (rapid back during transition fix) */
      var pendingId = pendingHide.get(target);
      if (pendingId) {
        clearTimeout(pendingId);
        pendingHide.delete(target);
      }
      /* Strip stale leaving classes , CSS source order by jinak nechal
       * .is-leaving-* override .is-current (opacity 0, pointer-events none). */
      target.classList.remove('is-leaving-left', 'is-leaving-right');

      panels.forEach(function (p) {
        if (p === target) return;
        if (p.classList.contains('is-current')) {
          p.classList.remove('is-current');
          p.classList.add(direction === 'forward' ? 'is-leaving-left' : 'is-leaving-right');
          var id = setTimeout(function () {
            p.hidden = true;
            p.classList.remove('is-leaving-left', 'is-leaving-right');
            pendingHide.delete(p);
          }, 320);
          pendingHide.set(p, id);
        }
      });
      target.hidden = false;
      target.classList.add(direction === 'forward' ? 'is-entering-right' : 'is-entering-left');
      requestAnimationFrame(function () {
        target.classList.add('is-current');
        target.classList.remove('is-entering-right', 'is-entering-left');
      });
      var firstInput = target.querySelector('input:not([type="radio"]):not([type="checkbox"]), select, textarea');
      if (firstInput && direction === 'forward') {
        setTimeout(function () { try { firstInput.focus(); } catch (e) {} }, 360);
      }
      updateProgress(name);
    }

    function updateProgress(name) {
      var stepNumber, total;
      total = totalSteps();
      var first = history[0];
      var formatEntered = first.indexOf('format-') === 0;
      if (name === 'koncept')          stepNumber = 1;
      else if (name.indexOf('format-') === 0) stepNumber = formatEntered ? 1 : 2;
      else if (name === 'termin')      stepNumber = first === 'termin' ? 1 : formatEntered ? 2 : 3;
      else if (name === 'kontakt')     stepNumber = first === 'termin' ? 2 : formatEntered ? 3 : 4;
      else if (name === 'success')     stepNumber = total;
      else stepNumber = 1;

      var shownStep = Math.min(stepNumber, total);
      counter.textContent = String(shownStep);
      totalEl.textContent = String(total);
      progressFill.style.transform = 'scaleX(' + (stepNumber / total) + ')';

      /* Sync per-panel mini counters (right of bottom action row). */
      var miniCurrent = form.querySelectorAll('[data-step-current-mini]');
      var miniTotal = form.querySelectorAll('[data-step-total-mini]');
      miniCurrent.forEach(function (el) { el.textContent = String(shownStep); });
      miniTotal.forEach(function (el) { el.textContent = String(total); });

      /* Hide Back button on first step or success across all panels. */
      var hideBack = history.length <= 1 || name === 'success';
      form.querySelectorAll('[data-prev]').forEach(function (b) {
        b.hidden = hideBack;
      });
    }

    function next() {
      /* Manual advance přebírá kontrolu , zruš případný auto-advance timer. */
      clearTimeout(autoNextTimer);
      var cur = history[history.length - 1];
      if (cur === 'koncept') {
        var koncept = form.querySelector('input[name="koncept"]:checked');
        if (!koncept) {
          flashInvalid(form.querySelector('input[name="koncept"]').closest('.rez__choices'));
          return;
        }
        var route = 'format-' + (koncept.value === 'co-living' ? 'coliving' : koncept.value);
        history.push(route);
        showPanel(route, 'forward');
      } else if (cur === 'format-stipendium') {
        var typ = form.querySelector('input[name="stipendium-typ"]:checked');
        if (!typ) {
          flashInvalid(form.querySelector('input[name="stipendium-typ"]').closest('.rez__choices'));
          return;
        }
        history.push('termin');
        showPanel('termin', 'forward');
      } else if (cur.indexOf('format-') === 0) {
        var format = form.querySelector('input[name="format"]:checked');
        if (!format) {
          flashInvalid(form.querySelector('input[name="format"]').closest('.rez__choices'));
          return;
        }
        history.push('termin');
        showPanel('termin', 'forward');
      } else if (cur === 'termin') {
        if (!validateTermin()) return;
        history.push('kontakt');
        showPanel('kontakt', 'forward');
      }
    }

    function back() {
      /* Zruš pending auto-advance , jinak by zombie next() override-oval naši back. */
      clearTimeout(autoNextTimer);
      if (history.length <= 1) return;
      history.pop();
      showPanel(history[history.length - 1], 'back');
    }

    function validateTermin() {
      var mesic = form.querySelector('select[name="mesic"]');
      var delka = form.querySelector('input[name="delka"]:checked');
      if (!mesic.value) { mesic.focus(); flashInvalid(mesic); return false; }
      if (!delka) { flashInvalid(form.querySelector('input[name="delka"]').closest('.rez__field')); return false; }
      return true;
    }

    function flashInvalid(el) {
      if (!el) return;
      el.classList.add('is-invalid');
      setTimeout(function () { el.classList.remove('is-invalid'); }, 800);
    }

    /* Auto-advance po radio výběru. Debounce 250ms tak aby user mohl změnit
     * volbu, než se přepneme. */
    var autoNextTimer = null;
    form.addEventListener('change', function (e) {
      var t = e.target;
      if (t.matches('input[data-auto-next]') && t.checked) {
        clearTimeout(autoNextTimer);
        autoNextTimer = setTimeout(next, 280);
      }
    });

    form.addEventListener('click', function (e) {
      if (e.target.closest('[data-next]')) { e.preventDefault(); next(); }
      if (e.target.closest('[data-prev]')) { e.preventDefault(); back(); }
    });

    /* Submit */
    form.addEventListener('submit', function (e) {
      e.preventDefault();
      var required = form.querySelectorAll('.rez__panel[data-panel="kontakt"] input[required]');
      var allOk = true;
      required.forEach(function (el) {
        if (el.type === 'checkbox') {
          if (!el.checked) { allOk = false; flashInvalid(el.closest('.rez__gdpr')); }
        } else if (!el.value) {
          allOk = false;
          flashInvalid(el);
          if (el === document.activeElement || !document.activeElement) el.focus();
        }
      });
      if (!allOk) return;
      var fd = new FormData(form);
      var payload = {};
      fd.forEach(function (v, k) { payload[k] = v; });
      console.log('[Hub Rezervace] payload:', payload);
      /* Cloudflare Worker endpoint (form.startovacihub.cz) deploy pending,
         Phase 5b. Pro teď success state + log. */
      history.push('success');
      showPanel('success', 'forward');
      if (afterEl) afterEl.removeAttribute('hidden');
      window.scrollTo({ top: 0, behavior: 'smooth' });
    });

    /* URL pre-fill:
     *   ?typ=<slug>      → preselect konkrétní format, skip rovnou na termin
     *   ?cesta=apartman  → preselect privátní koncept, skok na format-privatni
     *   ?cesta=luzko     → preselect co-living koncept, skok na format-coliving
     *   ?cesta=stipendium→ preselect stipendium, skok na format-stipendium
     */
    var url = new URL(window.location.href);
    var typ = url.searchParams.get('typ');
    var cesta = url.searchParams.get('cesta');
    var hideKonceptPanel = function () {
      var konceptPanel = panelByName('koncept');
      if (konceptPanel) {
        konceptPanel.hidden = true;
        konceptPanel.classList.remove('is-current');
      }
    };

    if (typ) {
      var isPrivatni = apartmanySlug.indexOf(typ) >= 0;
      var isColiving = colivingSlug.indexOf(typ) >= 0;
      if (isPrivatni || isColiving) {
        var konceptValue = isPrivatni ? 'privatni' : 'co-living';
        var konceptRadio = form.querySelector('input[name="koncept"][value="' + konceptValue + '"]');
        var formatRadio = form.querySelector('input[name="format"][value="' + typ + '"]');
        if (konceptRadio) konceptRadio.checked = true;
        if (formatRadio) formatRadio.checked = true;
        history = ['termin'];
        hideKonceptPanel();
        showPanel('termin', 'forward');
      } else {
        updateProgress('koncept');
      }
    } else if (cesta === 'apartman' || cesta === 'luzko' || cesta === 'stipendium') {
      var map = {
        apartman:   { konceptVal: 'privatni',   route: 'format-privatni'   },
        luzko:      { konceptVal: 'co-living',  route: 'format-coliving'   },
        stipendium: { konceptVal: 'stipendium', route: 'format-stipendium' },
      };
      var entry = map[cesta];
      var konceptRadio2 = form.querySelector('input[name="koncept"][value="' + entry.konceptVal + '"]');
      if (konceptRadio2) konceptRadio2.checked = true;
      history = [entry.route];
      hideKonceptPanel();
      showPanel(entry.route, 'forward');
    } else {
      updateProgress('koncept');
    }
  }());
</script>

<style>
  /* =========================================================================
     /rezervace/ Typeform-style flow
     Single column, mobile-first, animated slide transitions.
     ========================================================================= */

  .rez {
    /* Vyplnit prostor pod sticky header (80px), nechat trust footer dole. */
    min-height: calc(100vh - 64px);
    min-height: calc(100dvh - 64px);
    padding: clamp(80px, 14vh, 120px) var(--gutter) clamp(80px, 12vh, 100px);
    display: grid;
    grid-template-rows: auto 1fr auto;
    gap: var(--space-6);
    max-width: 720px;
    margin: 0 auto;
    width: 100%;
    color: var(--fg);
    transition: max-width 320ms cubic-bezier(0.32, 0.72, 0, 1);
  }
  /* Desktop: wider container + 2-col panel layout (intro left, body right).
     Mobile zůstává jednoduchý vertikální flow. Card-grid panely se ještě
     trochu rozšíří pro lepší dech 3-up / 2-up preview karet. */
  @media (min-width: 1024px) {
    .rez { max-width: 1180px; }
    .rez:has(.rez__panel.is-current .rez__choices--cards) {
      max-width: 1320px;
    }
  }

  /* ---------- Head: counter + progress bar ---------- */
  .rez__head {
    display: grid;
    grid-template-columns: auto 1fr;
    align-items: center;
    gap: var(--space-3);
  }
  .rez__step-counter {
    margin: 0;
    font: 600 var(--text-sm) / 1 var(--font-sans);
    color: var(--accent);
    letter-spacing: var(--tracking-wider);
    font-variant-numeric: tabular-nums;
    display: inline-flex;
    align-items: center;
    gap: 4px;
  }
  .rez__step-sep { color: var(--fg-subtle); opacity: 0.5; }
  .rez__step-counter [data-step-total] { color: var(--fg-subtle); }
  .rez__progress {
    height: 2px;
    background: var(--accent-rule);
    border-radius: 2px;
    overflow: hidden;
    position: relative;
  }
  .rez__progress-fill {
    position: absolute;
    inset: 0;
    background: var(--accent);
    transform-origin: left center;
    transform: scaleX(0.25);
    transition: transform 480ms cubic-bezier(0.32, 0.72, 0, 1);
  }
  .rez__back {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    height: 32px;
    padding: 0 12px;
    border-radius: var(--radius-input);
    border: 1px solid var(--accent-rule);
    background: transparent;
    color: var(--accent);
    font: 600 var(--text-xs) / 1 var(--font-sans);
    cursor: pointer;
    transition: background 180ms ease, border-color 180ms ease;
  }
  .rez__back:hover,
  .rez__back:focus-visible {
    background: var(--accent-soft);
    border-color: var(--accent);
    outline: none;
  }
  .rez__back svg { transform: translateX(0); transition: transform 180ms ease; }
  .rez__back:hover svg { transform: translateX(-2px); }
  .rez__back[hidden] { display: none; }

  /* ---------- Per-panel bottom action row ---------- */
  /* Layout: [Zpět]   ··· spacer ···   [stepN/total]   [Pokračovat] */
  .rez__actions {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 12px;
    margin-top: var(--space-3);
    padding-top: var(--space-4);
    border-top: 1px solid var(--accent-rule);
  }
  .rez__actions-spacer { flex: 1 1 auto; }
  .rez__actions-counter {
    font: 600 var(--text-xs) / 1 var(--font-sans);
    color: var(--fg-subtle);
    letter-spacing: var(--tracking-wider);
    font-variant-numeric: tabular-nums;
    display: inline-flex;
    align-items: center;
    gap: 3px;
    opacity: 0.7;
  }
  .rez__actions-counter [data-step-current-mini] { color: var(--accent); }
  .rez__actions .rez__back {
    /* Back button on the LEFT of the action row */
    order: 0;
  }
  .rez__actions .rez__cta--compact {
    /* Compact Continue button on the RIGHT */
    padding: 10px 20px;
    font-size: var(--text-sm);
  }
  /* Submit step: the primary CTA is larger and stretches on mobile */
  .rez__actions--submit .rez__cta--primary {
    align-self: auto;
    padding: 14px 26px;
    flex: 1 1 auto;
  }
  @media (min-width: 540px) {
    .rez__actions--submit .rez__cta--primary {
      flex: 0 0 auto;
    }
  }

  /* ---------- Panel + animovaný slide ---------- */
  /* Non-current panels mají transform: translateX(±40px) pro slide animaci.
     Bez clip-x by ±40px posun způsobil horizontální overflow viewportu na
     mobilu (375 + 40 = 415, vyjede scrollbar a obsah se vizuálně rozhodí).
     overflow-x: clip drží slide motion uvnitř form bounds, vertical zůstává
     visible aby grid auto-sizing fungoval pro nejvyšší panel. */
  .rez__form {
    position: relative;
    display: grid;
    min-width: 0;
    overflow-x: clip;
  }
  .rez__panel {
    grid-column: 1;
    grid-row: 1;
    display: flex;
    flex-direction: column;
    gap: var(--space-5);
    min-width: 0;
    opacity: 0;
    transform: translateX(40px);
    pointer-events: none;
    transition:
      opacity 320ms cubic-bezier(0.32, 0.72, 0, 1),
      transform 320ms cubic-bezier(0.32, 0.72, 0, 1);
  }
  .rez__panel > * { min-width: 0; }
  .rez__panel.is-current {
    opacity: 1;
    transform: translateX(0);
    pointer-events: auto;
  }
  .rez__panel.is-leaving-left {
    opacity: 0;
    transform: translateX(-40px);
    pointer-events: none;
  }
  .rez__panel.is-leaving-right {
    opacity: 0;
    transform: translateX(40px);
    pointer-events: none;
  }
  .rez__panel.is-entering-right {
    opacity: 0;
    transform: translateX(40px);
  }
  .rez__panel.is-entering-left {
    opacity: 0;
    transform: translateX(-40px);
  }

  .rez__q {
    font: 700 clamp(1.625rem, 3.5vw, 2.25rem) / 1.1 var(--font-sans);
    letter-spacing: var(--tracking-tight);
    margin: 0;
    text-wrap: balance;
    max-width: 22ch;
  }
  .rez__q-hint {
    font: 500 var(--text-md) / 1.55 var(--font-sans);
    color: var(--fg-muted);
    margin: 0;
    max-width: 48ch;
  }

  /* Intro wrapper, h1 + hint stack uvnitř jednoho gridového cellu. Na
     mobilu se chová jako běžný blok, na desktopu sedí v levém sloupci.
     min-width 0 zajistí, že wrapper nezachvátí víc než parent dovoluje
     (jinak by velmi dlouhý h1 mohl udělat horizontal overflow na úzkém
     viewportu). */
  .rez__panel-intro {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    min-width: 0;
  }
  .rez__panel-intro > * { min-width: 0; max-width: 100%; }

  /* ---------- Desktop 2-col panel: intro vlevo, body vpravo ---------- */
  /* Na širokém viewportu rozkládáme každý panel do gridu: rez__panel-intro
     drží levý sloupec (~320px), všechny choice cards / fields / addons
     padají do pravého sloupce a mají tak víc dechu. Action row překlene
     oba sloupce dole. Slide animace zůstává v platnosti díky původním
     transform/opacity pravidlům výš. */
  @media (min-width: 1024px) {
    .rez__panel {
      display: grid;
      grid-template-columns: minmax(280px, 360px) minmax(0, 1fr);
      column-gap: clamp(48px, 6vw, 96px);
      row-gap: var(--space-5);
      align-items: start;
    }
    .rez__panel-intro {
      grid-column: 1;
      position: sticky;
      top: 96px;
      gap: var(--space-3);
    }
    .rez__panel-intro .rez__q,
    .rez__panel-intro .rez__q-hint { max-width: none; }
    .rez__panel-intro .rez__q { font-size: clamp(2rem, 3vw, 2.625rem); }
    .rez__panel-intro .rez__q-hint { font-size: var(--text-md); }
    /* Vše ostatní (choice grid, single field, grid-2, addons, gdpr, range
       slider, pills wrapper) sedí v pravém sloupci. */
    .rez__panel > *:not(.rez__panel-intro):not(.rez__actions) {
      grid-column: 2;
    }
    .rez__actions {
      grid-column: 1 / -1;
    }
    /* Success panel: 1-col centered, žádný sidebar */
    .rez__panel--success {
      grid-template-columns: 1fr;
      text-align: left;
    }
    .rez__panel--success > * {
      grid-column: 1;
    }
    .rez__panel--success .rez__panel-intro {
      position: static;
    }
    /* Lehký vizuální oddělovač mezi sloupci, jen na panelech s body content */
    .rez__panel:not(.rez__panel--success) {
      position: relative;
    }
    .rez__panel:not(.rez__panel--success)::before {
      content: "";
      position: absolute;
      top: 8px;
      bottom: 64px;
      left: calc(min(360px, 33%) + clamp(20px, 3vw, 44px));
      width: 1px;
      background: linear-gradient(to bottom,
        transparent 0%,
        var(--accent-rule) 12%,
        var(--accent-rule) 88%,
        transparent 100%);
      pointer-events: none;
      opacity: 0.5;
    }
  }
  @media (min-width: 1280px) {
    .rez__panel-intro .rez__q { font-size: 2.75rem; line-height: 1.05; }
  }

  /* ---------- Choice cards ---------- */
  .rez__choices {
    display: grid;
    gap: var(--space-3);
  }
  /* Non-card volby (koncept + stipendium-typ) , vždy stackované vertikálně.
   * Důvod: na desktopu byly 3 úzké buňky a delší meta text se zbytečně
   * lámal. Vertikální stack s bohatším rytmem = lepší čitelnost + dýchání. */
  .rez__choices--2 { grid-template-columns: 1fr; }
  .rez__choices--3 { grid-template-columns: 1fr; }
  /* Card-style overrides , obnoví grid na desktopu pro format-* panely. */
  @media (min-width: 720px) {
    .rez__choices--cards.rez__choices--2 { grid-template-columns: 1fr 1fr; }
    .rez__choices--cards.rez__choices--3 { grid-template-columns: 1fr 1fr 1fr; }
  }
  .rez__choice {
    position: relative;
    display: block;
    padding: clamp(16px, 2.2vw, 24px) clamp(18px, 2.4vw, 28px);
    border: 1px solid var(--accent-rule);
    border-radius: var(--radius-input);
    background: var(--bg);
    cursor: pointer;
    transition: border-color 200ms ease, background 200ms ease, transform 200ms ease, box-shadow 200ms ease;
  }
  .rez__choice:hover {
    border-color: var(--accent);
    background: var(--accent-soft);
    transform: translateY(-1px);
  }
  .rez__choice input[type="radio"] {
    position: absolute;
    opacity: 0;
    pointer-events: none;
  }
  .rez__choice:has(input:checked) {
    border-color: var(--accent);
    background: var(--accent-soft);
    box-shadow: 0 0 0 1px var(--accent) inset;
  }
  .rez__choice:focus-within {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
  }
  .rez__choice-body {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }
  .rez__choice-title {
    font: 700 clamp(1rem, 1.5vw, 1.125rem) / 1.2 var(--font-sans);
    letter-spacing: var(--tracking-tight);
  }
  .rez__choice-meta {
    font: 500 var(--text-sm) / 1.4 var(--font-sans);
    color: var(--fg-muted);
  }

  /* Non-card volby na desktopu , dech a typografická hierarchie.
   * Title větší (vyšší vizuální váha jako tlačítko/CTA), meta s wide
   * max-width pro krásnou linkulinu. Padding bohatší aby řádek vypadal
   * jako proper card-row, ne button. Subtle arrow „>" v pravém horním
   * rohu pro affordance. */
  @media (min-width: 720px) {
    .rez__choices:not(.rez__choices--cards) {
      gap: 12px;
    }
    .rez__choices:not(.rez__choices--cards) .rez__choice {
      padding: 22px 28px;
    }
    .rez__choices:not(.rez__choices--cards) .rez__choice-body {
      gap: 6px;
      padding-right: 36px; /* room for arrow indicator */
    }
    .rez__choices:not(.rez__choices--cards) .rez__choice-title {
      font: 700 1.1875rem / 1.25 var(--font-sans);
    }
    .rez__choices:not(.rez__choices--cards) .rez__choice-meta {
      font: 500 0.9375rem / 1.5 var(--font-sans);
      max-width: 64ch;
    }
    .rez__choices:not(.rez__choices--cards) .rez__choice::after {
      content: '';
      position: absolute;
      top: 50%;
      right: 24px;
      width: 12px;
      height: 12px;
      border-top: 2px solid var(--fg-subtle);
      border-right: 2px solid var(--fg-subtle);
      transform: translateY(-50%) rotate(45deg);
      opacity: 0.5;
      transition: opacity 200ms ease, right 220ms cubic-bezier(0.32, 0.72, 0, 1), border-color 200ms ease;
    }
    .rez__choices:not(.rez__choices--cards) .rez__choice:hover::after,
    .rez__choices:not(.rez__choices--cards) .rez__choice:focus-within::after {
      opacity: 1;
      right: 20px;
      border-color: var(--accent);
    }
    .rez__choices:not(.rez__choices--cards) .rez__choice:has(input:checked)::after {
      opacity: 1;
      border-color: var(--accent);
    }
  }

  /* ---------- Card-style choices (format-privatni, format-coliving) ----------
   * Mobile: compact horizontal row (small thumb left + text right).
   * Desktop ≥ 900 px: full preview cards with photo on top + body below.
   */
  .rez__choices--cards {
    gap: var(--space-3);
  }
  .rez__choice--card {
    display: grid;
    grid-template-columns: 96px 1fr;
    gap: 14px;
    align-items: stretch;
    padding: 12px;
  }
  .rez__choice--card .rez__choice-thumb {
    display: block;
    overflow: hidden;
    border-radius: calc(var(--radius-input) - 2px);
    background: var(--accent-soft);
    aspect-ratio: 4 / 3;
    width: 100%;
  }
