---
import Base from '../../layouts/Base.astro';
import { withBase } from '../../utils/url';

/* Phase 1 stub. Plný 5-krokový wizard + Cloudflare Worker backend
   (Turnstile + Resend + D1 EU) přijde v Phase 5 per SH_Web_Plan.md
   sekce „Konfigurátor rezervace". H1, podtitulek a slug jsou už finální.

   Do té doby fungujeme přes e-mail. URL `/rezervace/?typ=<slug>` se
   v Phase 5 napojí na pre-fill prvního kroku wizardu. */
---
<Base
  title="Rezervace · Startovací Hub Klecany"
  description="Registrace zájmu o bydlení v Startovacím Hubu Klecany. Vyplníte konfiguraci pokoje, datum nástupu a kontakt. Není to závazek, jen vám zavoláme do 24 hodin.">
  <article class="page-stub">
    <p class="page-stub__eyebrow">Rezervace</p>
    <h1>Registrace zájmu o bydlení</h1>
    <p class="page-stub__lede">
      Vyplníte konfiguraci pokoje, datum nástupu a kontakt. Není to závazek, jen vám zavoláme.
      Plný formulář (5 kroků: koncept bydlení, konfigurace, termín, kontakt, souhlas) dokončujeme,
      backend napojený na Cloudflare D1 v EU jurisdikci připravujeme.
    </p>

    <div class="rez-fallback">
      <p class="rez-fallback__label">Mezitím napište e-mail</p>
      <p class="rez-fallback__email">
        <a href="mailto:vpd@osa2.cz?subject=Registrace zájmu o bydlení v Hubu">vpd@osa2.cz</a>
      </p>
      <p class="rez-fallback__hint">
        Stačí typ ubytování (kapsle, dvoulůžko, 1+kk, 2+kk, 3+kk, 4+kk nebo 5+kk),
        orientační termín nástupu a telefon. Ozveme se do 24 hodin.
      </p>
    </div>

    <p class="page-stub__note">Plný 5-krokový formulář v Phase 5</p>
    <p class="page-stub__links">
      <a href={withBase('/ubytovani/')}>9 typů ubytování</a>
      <a href={withBase('/stipendia/')}>Pobytové stipendium</a>
    </p>
  </article>
</Base>

<style>
  .rez-fallback {
    margin: var(--space-7) 0 var(--space-5);
    padding: var(--space-5) var(--space-6);
    background: var(--bg-muted);
    border: 1px solid var(--accent-rule);
    border-radius: var(--radius-input);
  }
  .rez-fallback__label {
    font: 600 var(--text-2xs) / 1 var(--font-sans);
    color: var(--accent);
    letter-spacing: var(--tracking-wider);
    text-transform: uppercase;
    margin: 0 0 var(--space-2);
  }
  .rez-fallback__email {
    font: 600 var(--text-2xl) / 1.1 var(--font-sans);
    margin: 0 0 var(--space-3);
  }
  .rez-fallback__email a {
    color: var(--accent);
    text-decoration: underline;
    text-decoration-color: var(--accent-rule);
    text-underline-offset: 4px;
  }
  .rez-fallback__email a:hover { text-decoration-color: var(--accent); }
  .rez-fallback__hint {
    font-size: var(--text-sm);
    color: var(--fg-muted);
    margin: 0;
    line-height: 1.5;
  }
</style>
