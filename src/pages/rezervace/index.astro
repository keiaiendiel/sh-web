    margin: var(--space-4) 0 0;
    padding: 12px 16px;
    border-radius: var(--radius-input);
    background: var(--accent-soft);
    color: var(--accent);
    font: 500 var(--text-sm) / 1.5 var(--font-sans);
  }
  .rez__more-msg[hidden] { display: none; }
  @media (max-width: 540px) {
    .rez__more-grid { grid-template-columns: repeat(2, minmax(0, 1fr)); }
    .rez__more-item { padding: 12px; gap: 10px; flex-direction: column; align-items: flex-start; }
  }

  /* ---------- Post-submit dotazník ---------- */
  .rez-survey__start { display: grid; gap: var(--space-3); }
  .rez-survey__pitch {
    font: 500 var(--text-md) / 1.55 var(--font-sans);
    color: var(--fg-muted);
    margin: 0;
    max-width: 56ch;
  }
  .rez-survey__start-row { display: flex; flex-wrap: wrap; gap: 10px; }
  .rez-survey[hidden], .rez-survey__start[hidden], .rez-survey__done[hidden], [data-survey-after][hidden] { display: none; }
  .rez-survey {
    display: grid;
    gap: var(--space-4);
    padding: clamp(20px, 2.5vw, 28px);
    border: 1px solid var(--accent-rule);
    border-radius: var(--radius-input);
    background: var(--bg);
  }
  .rez-survey__head {
    display: grid;
