---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';
import { withBase } from '../../utils/url';

/* Phase 5 wizard frontend. Pět kroků per SH_Web_Plan.md ř. 217-251
   a Site_Copy § 9.2:
     1. Koncept bydlení (3 karty)
     2. Konfigurace prostoru (podmínečně na kroku 1)
     3. Termín a stipendium
     4. Kontakt
     5. GDPR + rekapitulace + odeslat

   Stálý sidebar drží aktuální cenu a „vše v ceně" checklist (per Plan.md
   ř. 250). Po odeslání placeholder URL na Cloudflare Worker (form.startovacihub.cz),
   zatím console.log + success state. Backend scaffold v `worker/`. */

const apartmany = (await getCollection('apartmany')).sort((a, b) => a.data.order - b.data.order);
const coliving = (await getCollection('coliving')).sort((a, b) => a.data.order - b.data.order);
const fmt = (n: number) => `${n.toLocaleString('cs-CZ')} Kč`;
---
<Base
  title="Registrace zájmu o bydlení v Hubu Klecany"
  description="Sestavte si bydlení v Hubu. Vyberte typ, termín, délku pobytu a kontakt. Do 24 hodin se vám ozveme. Registrace je nezávazná, není to smlouva.">
  <section class="rez-hero">
    <div class="rez-hero__inner">
      <p class="rez-hero__eyebrow">Rezervace</p>
      <h1 class="rez-hero__title">Registrace zájmu o bydlení.</h1>
      <p class="rez-hero__lede">
        Vyplníte konfiguraci pokoje, datum a kontakt. Není to závazek, jen vám zavoláme.
        Do 24 hodin se ozve někdo z rezervačního oddělení s detailem dostupnosti a ceny.
      </p>
    </div>
  </section>

  <section class="rez-layout">
    <form id="rez-form" class="rez-form" novalidate>
      <ol class="rez-progress" aria-label="Postup průvodce">
        <li class="rez-progress__step is-active" data-step="1"><span>01</span>Koncept</li>
        <li class="rez-progress__step" data-step="2"><span>02</span>Konfigurace</li>
        <li class="rez-progress__step" data-step="3"><span>03</span>Termín</li>
        <li class="rez-progress__step" data-step="4"><span>04</span>Kontakt</li>
      </ol>

      {/* === KROK 1: Koncept === */}
      <fieldset class="rez-step is-current" data-step="1">
        <legend>
          <span class="rez-step__num">01</span>
          <span class="rez-step__title">Jak chcete v Hubu bydlet?</span>
        </legend>
        <div class="rez-cards rez-cards--3">
          <label class="rez-card">
            <input type="radio" name="koncept" value="privatni" required />
            <div class="rez-card__body">
              <h3>Privátní apartmán</h3>
              <p>Vlastní byt, vlastní koupelna a kuchyň. Od 9 500 Kč/měsíc.</p>
            </div>
          </label>
          <label class="rez-card">
            <input type="radio" name="koncept" value="co-living" required />
            <div class="rez-card__body">
              <h3>Co-living</h3>
              <p>Vlastní lůžko nebo kapsle, společná kuchyň. Od 2 250 Kč/měsíc při ročním závazku.</p>
            </div>
          </label>
          <label class="rez-card">
            <input type="radio" name="koncept" value="nevim" required />
            <div class="rez-card__body">
              <h3>Nevím, poradíme</h3>
              <p>Tři otázky, doporučíme variantu, ozveme se.</p>
            </div>
          </label>
        </div>
        <div class="rez-nav">
          <span></span>
          <button type="button" class="rez-btn" data-next>Pokračovat →</button>
        </div>
      </fieldset>

      {/* === KROK 2: Konfigurace (3 podstavy podle kroku 1) === */}
      <fieldset class="rez-step" data-step="2" hidden>
        <legend>
          <span class="rez-step__num">02</span>
          <span class="rez-step__title">Konkrétní formát</span>
        </legend>

        <div class="rez-sub" data-show-for="privatni" hidden>
          <p class="rez-sub__hint">Pět privátních apartmánů. Cena za celou jednotku.</p>
          <div class="rez-cards rez-cards--3">
            {apartmany.map((a) => (
              <div class="rez-card rez-card--media" data-card data-format={a.data.slug}>
                <input type="radio" name="format" value={a.data.slug} class="rez-card__radio" tabindex="-1" aria-hidden="true" />
                <div class="rez-card__thumb">
                  {a.data.thumbnail ? (
                    <img src={withBase(a.data.thumbnail)} alt="" loading="lazy" decoding="async" />
                  ) : (
                    <div class="rez-card__thumb-empty" aria-hidden="true">▢</div>
                  )}
                </div>
                <div class="rez-card__body">
                  <h3>{a.data.name}</h3>
                  <p>{a.data.plocha} · {a.data.kapacita} lůžek</p>
                  <p class="rez-card__price">od {fmt(a.data.cena.m12)}/měsíc<small> (12+ měs)</small></p>
                  <a class="rez-card__detail" href={withBase(`/ubytovani/privatni/${a.data.slug}/`)} target="_blank" rel="noopener" data-no-select>Detail →</a>
                </div>
              </div>
            ))}
          </div>
        </div>

        <div class="rez-sub" data-show-for="co-living" hidden>
          <p class="rez-sub__hint">Čtyři varianty co-livingu. Cena na osobu (kapsle pro 1), nebo na kapsli/pokoj (pro pár).</p>
          <div class="rez-cards rez-cards--2">
            {coliving.map((c) => (
              <div class="rez-card rez-card--media" data-card data-format={c.data.slug}>
                <input type="radio" name="format" value={c.data.slug} class="rez-card__radio" tabindex="-1" aria-hidden="true" />
                <div class="rez-card__thumb">
                  {c.data.thumbnail ? (
                    <img src={withBase(c.data.thumbnail)} alt="" loading="lazy" decoding="async" />
                  ) : (
                    <div class="rez-card__thumb-empty" aria-hidden="true">▢</div>
                  )}
                </div>
                <div class="rez-card__body">
                  <h3>{c.data.name}</h3>
                  <p>Matrace {c.data.matrace[0]}{c.data.matrace[1] && ` nebo ${c.data.matrace[1]}`}</p>
                  <p class="rez-card__price">od {fmt(c.data.cena.m12)}/měsíc<small> (12+ měs)</small></p>
                  <a class="rez-card__detail" href={withBase(`/ubytovani/co-living/${c.data.slug}/`)} target="_blank" rel="noopener" data-no-select>Detail →</a>
                </div>
              </div>
            ))}
          </div>
        </div>

        <div class="rez-sub" data-show-for="nevim" hidden>
          <p class="rez-sub__hint">Tři rychlé otázky, ozveme se s konkrétním návrhem.</p>
          <div class="rez-field">
            <label for="nevim-rozpocet">Rozpočet (Kč/měsíc)</label>
            <input type="range" id="nevim-rozpocet" name="nevim-rozpocet" min="3000" max="25000" step="500" value="9500" />
            <output for="nevim-rozpocet" id="nevim-rozpocet-out">9 500 Kč/měs</output>
          </div>
          <div class="rez-field">
            <label for="nevim-soukromi">Preferujete spíš:</label>
            <select id="nevim-soukromi" name="nevim-soukromi">
              <option value="soukromi">Soukromí (vlastní byt nebo pokoj)</option>
              <option value="komunita">Komunitu (sdílený byt, kapsle s ostatními)</option>
              <option value="balanc">Záleží na ceně</option>
            </select>
          </div>
          <div class="rez-field">
            <label for="nevim-uvazek">Jak budete v Hubu reálně být?</label>
            <select id="nevim-uvazek" name="nevim-uvazek">
              <option value="full-time">Full-time (bydlím a pracuji tady)</option>
              <option value="hybrid">Hybrid (pár dní v týdnu)</option>
              <option value="vikendy">Víkendy a krátké pobyty</option>
            </select>
          </div>
        </div>

        <div class="rez-nav">
          <button type="button" class="rez-btn rez-btn--ghost" data-prev>← Zpět</button>
          <button type="button" class="rez-btn" data-next>Pokračovat →</button>
        </div>
      </fieldset>

      {/* === KROK 3: Termín + stipendium === */}
      <fieldset class="rez-step" data-step="3" hidden>
        <legend>
          <span class="rez-step__num">03</span>
          <span class="rez-step__title">Termín nástupu a délka pobytu</span>
        </legend>

        <div class="rez-field">
          <label for="mesic">Měsíc nástupu</label>
          <select id="mesic" name="mesic" required>
            <option value="">Vyberte měsíc</option>
            <option value="2026-09">09/2026</option>
            <option value="2026-10">10/2026</option>
            <option value="2026-11">11/2026</option>
            <option value="2026-12">12/2026</option>
            <option value="2027-01">01/2027</option>
            <option value="2027-02">02/2027</option>
            <option value="2027-03">03/2027</option>
            <option value="2027-04">04/2027</option>
            <option value="2027-05">05/2027</option>
            <option value="2027-06">06/2027</option>
            <option value="2027-Q3">Q3 2027</option>
            <option value="2027-Q4">Q4 2027</option>
          </select>
        </div>

        <div class="rez-field">
          <label>Délka pobytu</label>
          <div class="rez-radio-row">
            <label class="rez-pill"><input type="radio" name="delka" value="1-2" required /><span>1 až 2 měsíce</span></label>
            <label class="rez-pill"><input type="radio" name="delka" value="3-5" /><span>3 až 5 měsíců</span></label>
            <label class="rez-pill"><input type="radio" name="delka" value="6-11" /><span>6 až 11 měsíců</span></label>
            <label class="rez-pill"><input type="radio" name="delka" value="12+" /><span>12+ měsíců</span></label>
          </div>
        </div>

        <div class="rez-field rez-field--check">
          <label class="rez-check">
            <input type="checkbox" name="stipendium" value="ano" />
            <span>Mám zájem o pobytové stipendium. Oznámíme vám příští výzvu.</span>
          </label>
        </div>

        <div class="rez-nav">
          <button type="button" class="rez-btn rez-btn--ghost" data-prev>← Zpět</button>
          <button type="button" class="rez-btn" data-next>Pokračovat →</button>
        </div>
      </fieldset>

      {/* === KROK 4: Kontakt === */}
      <fieldset class="rez-step" data-step="4" hidden>
        <legend>
          <span class="rez-step__num">04</span>
          <span class="rez-step__title">Kontakt</span>
        </legend>

        <div class="rez-grid-2">
          <div class="rez-field">
            <label for="jmeno">Křestní jméno <span aria-hidden="true">*</span></label>
            <input type="text" id="jmeno" name="jmeno" required autocomplete="given-name" />
          </div>
          <div class="rez-field">
            <label for="prijmeni">Příjmení <span aria-hidden="true">*</span></label>
            <input type="text" id="prijmeni" name="prijmeni" required autocomplete="family-name" />
          </div>
        </div>

        <div class="rez-field">
          <label for="telefon">Telefon <span aria-hidden="true">*</span></label>
          <input type="tel" id="telefon" name="telefon" required autocomplete="tel" inputmode="tel" placeholder="+420" />
          <p class="rez-field__hint">Zavoláme do 24 hodin pro potvrzení detailů. Nikomu jinému ho nepředáme.</p>
        </div>

        <div class="rez-field">
          <label for="email">E-mail <span aria-hidden="true">*</span></label>
          <input type="email" id="email" name="email" required autocomplete="email" placeholder="vy@example.cz" />
        </div>

        <div class="rez-field">
          <label for="poznamka">Poznámka (volitelné)</label>
          <textarea id="poznamka" name="poznamka" rows="4" maxlength="500" placeholder="Cokoli speciálního, co bychom měli vědět (mazlíček, partner, preference spolubydlícího, atd.)"></textarea>
        </div>

        <div class="rez-field rez-field--check">
          <label class="rez-check">
            <input type="checkbox" name="gdpr" value="ano" required />
            <span>Souhlasím se zpracováním osobních údajů pro účely vyřízení registrace zájmu. Viz <a href={withBase('/gdpr/')}>Zásady ochrany osobních údajů</a>.</span>
          </label>
        </div>

        <div class="rez-nav">
          <button type="button" class="rez-btn rez-btn--ghost" data-prev>← Zpět</button>
          <button type="submit" class="rez-btn rez-btn--primary">Odeslat nezávaznou rezervaci</button>
        </div>
      </fieldset>

      <div class="rez-success" id="rez-success" hidden>
        <h2>Děkujeme, dorazilo.</h2>
        <p>Zavoláme vám do 24 hodin. Někdo z rezervačního týmu se vám ozve telefonicky během příštího pracovního dne, většinou rychleji. Probereme, kdy chcete přijet na prohlídku, jaké jsou detaily kolem termínu nástupu a jak postupujeme dál.</p>
        <p>Toto je nezávazná registrace zájmu. Žádný závazek z vaší strany, žádný účet od nás. Pokud se rozhodnete jinak, prostě nám to dejte vědět nebo neodpovídejte, nic nezačne běžet.</p>
      </div>
    </form>

    {/* Stálý sidebar */}
    <aside class="rez-side">
      <div class="rez-side__inner">
        <p class="rez-side__eyebrow">Vaše konfigurace</p>
        <div class="rez-side__price" id="rez-side-price">
          <span class="rez-side__price-label">Předpokládaná cena</span>
          <span class="rez-side__price-value" id="rez-side-price-value">vyplníte v průvodci</span>
        </div>
        <div class="rez-side__check">
          <p class="rez-side__check-title">Vše v ceně bydlení</p>
          <ul>
            <li>Energie, internet, úklid společných prostor</li>
            <li>5 jízd Hub-shuttle do metra Kobylis měsíčně</li>
            <li>1 jízda Hub-taxi lokálně měsíčně</li>
            <li>Volný stůl v coworkingovém sále 24/7</li>
            <li>Poukaz do sauny 1× týdně</li>
          </ul>
        </div>
        <p class="rez-side__note">
          Cena se po odeslání upřesní podle aktuální dostupnosti a délky pobytu. Registrace je
          nezávazná, není to smlouva.
        </p>
      </div>
    </aside>
  </section>

  {/* Mini-FAQ pod formulářem */}
  <section class="sec-block sec-block--alt">
    <div class="sec-block__inner">
      <header class="sec-block__head">
        <p class="sec-block__eyebrow">Mini FAQ</p>
        <h2 class="sec-block__title">Časté otázky kolem registrace.</h2>
      </header>
      <details class="faq-mini">
        <summary>Co znamená „nezávazná registrace zájmu"?</summary>
        <p>K ničemu vás nezavazuje. Není to nájemní ani ubytovací smlouva. Jen nám říkáte, že vás formát zajímá a chcete podrobnosti. Pokud se rozhodnete nepokračovat, prostě neodpovíte při dalším kontaktu. Bez storno poplatku, bez zálohy.</p>
      </details>
      <details class="faq-mini">
        <summary>Kdy můžu reálně do Hubu nastoupit?</summary>
        <p>Hub je v projektové přípravě. Termíny otevření jednotlivých budov upřesňujeme s postupem rekonstrukce. V registraci vyberete měsíc, kdy byste chtěli nastoupit, a my vám při telefonu řekneme realisticky, jestli je to v té době možné. Pokud zatím není, navrhneme alternativy nebo se ozveme, až bude.</p>
      </details>
      <details class="faq-mini">
        <summary>Můžu napřed přijet a podívat se?</summary>
        <p>Ano, pravidelně otevíráme prohlídky areálu. V registraci zatím není ani prohlídka závazná, jen nám usnadní, abychom věděli, koho čekat. Pokud chcete přijet bez registrace, napište na vpd@osa2.cz nebo zavolejte, domluvíme termín.</p>
      </details>
    </div>
  </section>
</Base>

<script is:inline define:vars={{
  apartmanyData: apartmany.map((a) => ({ slug: a.data.slug, name: a.data.name, cena: a.data.cena })),
  colivingData: coliving.map((c) => ({ slug: c.data.slug, name: c.data.name, cena: c.data.cena })),
}}>
  /* Wizard state + step controller. State persists in form data
     (FormData API), no global mutable object. Sidebar se průběžně
     aktualizuje z form data při změnách. */
  (function () {
    var form = document.getElementById('rez-form');
    if (!form) return;

    var steps = form.querySelectorAll('.rez-step');
    var progressItems = form.querySelectorAll('.rez-progress__step');
    var sidePrice = document.getElementById('rez-side-price-value');
    var success = document.getElementById('rez-success');
    var TOTAL_STEPS = 4;

    var allFormats = {};
    apartmanyData.forEach(function (a) { allFormats[a.slug] = a; });
    colivingData.forEach(function (c) { allFormats[c.slug] = c; });

    function fmt(n) { return n.toLocaleString('cs-CZ') + ' Kč'; }

    function getCurrent() {
      var c = form.querySelector('.rez-step.is-current');
      return c ? parseInt(c.dataset.step, 10) : 1;
    }

    function showStep(n) {
      steps.forEach(function (s) {
        var stepNum = parseInt(s.dataset.step, 10);
        s.classList.toggle('is-current', stepNum === n);
        s.hidden = stepNum !== n;
      });
      progressItems.forEach(function (p) {
        var stepNum = parseInt(p.dataset.step, 10);
        p.classList.toggle('is-active', stepNum === n);
        p.classList.toggle('is-done', stepNum < n);
      });
      window.scrollTo({ top: 0, behavior: 'smooth' });
    }

    function validateStep(n) {
      var step = form.querySelector('.rez-step[data-step="' + n + '"]');
      if (!step) return true;
      var required = step.querySelectorAll('input[required], select[required]');
      var ok = true;
      var msg = '';
      required.forEach(function (el) {
        if (el.type === 'radio') {
          var group = form.querySelectorAll('input[name="' + el.name + '"]');
          var anyChecked = Array.prototype.some.call(group, function (x) { return x.checked; });
          if (!anyChecked) { ok = false; msg = 'Vyberte prosím jednu z možností'; }
        } else if (!el.value || (el.type === 'checkbox' && !el.checked)) {
          ok = false;
          el.focus();
          msg = 'Vyplňte prosím povinné pole';
        }
      });
      if (!ok && msg) alert(msg);
      return ok;
    }

    function next() {
      var cur = getCurrent();
      if (!validateStep(cur)) return;
      if (cur === 1) handleStep1Branch();
      if (cur < TOTAL_STEPS) showStep(cur + 1);
    }
    function prev() {
      var cur = getCurrent();
      if (cur > 1) showStep(cur - 1);
    }

    function handleStep1Branch() {
      var koncept = form.querySelector('input[name="koncept"]:checked');
      if (!koncept) return;
      var subs = form.querySelectorAll('.rez-sub');
      subs.forEach(function (s) {
        s.hidden = s.dataset.showFor !== koncept.value;
      });
      var step2Required = form.querySelectorAll('.rez-step[data-step="2"] input[type="radio"]');
      step2Required.forEach(function (r) { r.required = false; });
      var activeRadios = form.querySelectorAll('.rez-sub[data-show-for="' + koncept.value + '"] input[type="radio"]');
      if (koncept.value !== 'nevim') {
        activeRadios.forEach(function (r) { r.required = true; });
      }
    }

    function updateSidePrice() {
      var format = form.querySelector('input[name="format"]:checked');
      var delka = form.querySelector('input[name="delka"]:checked');
      var koncept = form.querySelector('input[name="koncept"]:checked');
      if (koncept && koncept.value === 'nevim') {
        var rozpocet = form.querySelector('input[name="nevim-rozpocet"]');
        if (rozpocet) {
          sidePrice.textContent = 'cíl ' + fmt(parseInt(rozpocet.value, 10));
          return;
        }
      }
      if (!format) {
        sidePrice.textContent = 'vyberte formát';
        return;
      }
      var data = allFormats[format.value];
      if (!data) { sidePrice.textContent = 'vyberte formát'; return; }
      var base = data.cena.anchor;
      if (delka) {
        if (delka.value === '3-5') base = data.cena.m3;
        else if (delka.value === '6-11') base = data.cena.m6;
        else if (delka.value === '12+') base = data.cena.m12;
      }
      var perPerson = (data.cena.perOsoba || data.cena.perOsoba12) ? '' : '';
      sidePrice.textContent = fmt(base) + '/měs';
    }

    /* Event handlers */
    form.addEventListener('click', function (e) {
      if (e.target.matches('[data-next]')) { e.preventDefault(); next(); return; }
      if (e.target.matches('[data-prev]')) { e.preventDefault(); prev(); return; }

      /* Karty bez <label>: klik kdekoliv kromě Detail linku označí radio. */
      var card = e.target.closest('[data-card]');
      if (card && !e.target.closest('[data-no-select]')) {
        var radio = card.querySelector('input[type="radio"]');
        if (radio) {
          radio.checked = true;
          radio.dispatchEvent(new Event('change', { bubbles: true }));
        }
      }
    });
    form.addEventListener('change', updateSidePrice);
    form.addEventListener('input', updateSidePrice);

    var rozpocetIn = document.getElementById('nevim-rozpocet');
    var rozpocetOut = document.getElementById('nevim-rozpocet-out');
    if (rozpocetIn && rozpocetOut) {
      rozpocetIn.addEventListener('input', function () {
        rozpocetOut.textContent = fmt(parseInt(rozpocetIn.value, 10)) + '/měs';
        updateSidePrice();
      });
    }

    form.addEventListener('submit', function (e) {
      e.preventDefault();
      if (!validateStep(TOTAL_STEPS)) return;
      var fd = new FormData(form);
      var payload = {};
      fd.forEach(function (v, k) { payload[k] = v; });
      console.log('[Hub Rezervace] payload:', payload);
      /* POST endpoint Phase 5b: form.startovacihub.cz/submit. Backend
         scaffold v `worker/` v repu, deploy přes Wrangler. */
      form.style.display = 'none';
      success.hidden = false;
      window.scrollTo({ top: 0, behavior: 'smooth' });
    });

    /* URL pre-fill: ?typ=<slug> z karet (RoomCard / Detail page CTAs) */
    var url = new URL(window.location.href);
    var typ = url.searchParams.get('typ');
    if (typ) {
      var formatRadio = form.querySelector('input[name="format"][value="' + typ + '"]');
      if (formatRadio) {
        formatRadio.checked = true;
        var isPrivatni = !!apartmanyData.find(function (a) { return a.slug === typ; });
        var konceptRadio = form.querySelector('input[name="koncept"][value="' + (isPrivatni ? 'privatni' : 'co-living') + '"]');
        if (konceptRadio) konceptRadio.checked = true;
        handleStep1Branch();
        updateSidePrice();
      }
    }
  }());
</script>

