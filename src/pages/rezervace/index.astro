    display: flex;
    align-items: center;
    gap: 12px;
    padding: 14px 16px;
    border: 1px solid var(--border-muted);
    border-radius: var(--radius-input);
    background: var(--bg);
    color: var(--fg);
    font: 600 var(--text-sm) / 1.25 var(--font-sans);
    text-align: left;
    cursor: pointer;
    transition: border-color 160ms ease, box-shadow 160ms ease, transform 120ms ease;
  }
  .rez__more-item:hover {
    border-color: hsl(var(--tile-hue, var(--hue)) 35% 55%);
    box-shadow: 0 4px 14px hsl(var(--tile-hue, var(--hue)) 35% 35% / 0.14);
