---
/*
 * Novinky , listing z kolekce `novinky` (3-sloupcový grid NewsCard).
 * Přidat článek = přidat MDX do src/content/novinky/, šablona se nemění.
 * Stránka je veřejná (žádný gate), články jsou náhledové, dokud klient
 * nedodá reálný obsah.
 */
import Base from '../../layouts/Base.astro';
import SubpageHero from '../../components/SubpageHero.astro';
import NewsCard from '../../components/NewsCard.astro';
import CtaBanner from '../../components/CtaBanner.astro';
import CrossLinkPair from '../../components/CrossLinkPair.astro';
import { getCollection } from 'astro:content';

const fmtDate = (iso: string) =>
  new Date(iso).toLocaleDateString('cs-CZ', { day: 'numeric', month: 'long', year: 'numeric' });

const news = (await getCollection('novinky'))
  .filter((n) => !n.data.hidden)
  .sort((a, b) => b.data.date.localeCompare(a.data.date));
---
<Base
  title="Novinky · Startovací Hub Klecany"
  description="Novinky ze Startovacího Hubu Klecany: spuštění rezervací, postup rekonstrukce, otevírání prvních budov a komunitní akce."
  headerVariant="overlay">

  <SubpageHero
    eyebrow="Novinky"
    title="Co je <em>nového</em>"
    sub="Spuštění rezervací, postup rekonstrukce a otevírání prvních budov. Články doplňujeme průběžně."
    variant="cream"
    ribbonPath="M 120 720 C 520 420, 980 860, 1380 540 C 1700 300, 1980 560, 2060 420"
    ariaId="novinky"
  />

  <div class="news-wrap">
    <p class="news-note">Náhled stylu s ukázkovým obsahem. Reálné články doplníme, jakmile bude co publikovat.</p>
    <div class="news-grid">
      {news.map((n) => (
        <NewsCard
          date={fmtDate(n.data.date)}
          category={n.data.category}
          title={n.data.title}
          excerpt={n.data.excerpt}
          source={n.data.source}
          image={n.data.image}
          href={`/novinky/${n.id}/`}
        />
      ))}
    </div>
  </div>

  <CtaBanner
    eyebrow="Rezervace"
    title="Nechcete o nic <em>přijít</em>?"
    lede="Zaregistrujte zájem o bydlení a ozveme se vám s novinkami i konkrétní nabídkou."
    cta={{ label: 'Nezávazná rezervace', href: '/rezervace/' }}
    variant="deep"
  />
  <CrossLinkPair
    items={[
      { eyebrow: 'Ubytování', title: 'Apartmány a <em>sdílené pokoje</em>', href: '/ubytovani/', variant: 'cream' },
      { eyebrow: 'Zázemí', title: 'Celé <em>zázemí</em> Hubu', href: '/zazemi/', variant: 'ink' },
    ]}
  />
</Base>

<style>
  .news-wrap {
    width: calc(100% - 2 * var(--gutter));
    max-width: var(--container-wide);
    margin: 0 auto;
    padding: var(--space-8) 0;
  }
  .news-note {
    font: 500 var(--text-sm) / 1.5 var(--font-sans);
    color: var(--fg-subtle);
    margin: 0 0 var(--space-5);
  }
  .news-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: clamp(16px, 2vw, 28px);
  }
  @media (max-width: 900px) { .news-grid { grid-template-columns: repeat(2, minmax(0, 1fr)); } }
  @media (max-width: 560px) { .news-grid { grid-template-columns: 1fr; } }
</style>
