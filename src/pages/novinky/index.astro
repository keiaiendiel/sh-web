---
/*
 * Novinky , 3-sloupcový grid karet (obrázek + datum/kategorie + nadpis +
 * perex). Reálné články zatím nemáme, níže je náhled stylu s ukázkovým
 * obsahem. Po dodání reálných článků se sem napojí kolekce / CMS.
 */
import Base from '../../layouts/Base.astro';
import SubpageHero from '../../components/SubpageHero.astro';
import NewsCard from '../../components/NewsCard.astro';
import CtaBanner from '../../components/CtaBanner.astro';
import CrossLinkPair from '../../components/CrossLinkPair.astro';

const news = [
  {
    date: '12. června 2026', category: 'Rezervace', title: 'Spouštíme nezávazné rezervace bydlení',
    excerpt: 'Vyberete si formát, termín a způsob kontaktu. Z rezervačního oddělení vám zavoláme do 24 hodin. Registrace je nezávazná a slouží k zmapování zájmu.',
    image: { src: '/images/hub/hero/h03.jpg', alt: 'Vnitřní dvůr areálu za modré hodiny' },
  },
  {
    date: '20. května 2026', category: 'Rekonstrukce', title: 'Postupuje rekonstrukce budovy C',
    excerpt: 'V budově C vzniká coworkingový sál, zasedací místnosti a dílny. Sledujte postup prací a plánované otevření prvních prostor.',
    image: { src: '/images/hub/areal/building-c.jpg', alt: 'Budova C v areálu Horních kasáren' },
  },
  {
    date: '28. dubna 2026', category: 'Coworking', title: 'Coworkingový sál otevírá jako první',
    excerpt: 'Volný stůl v sále, telefonní budky a kuchyňský kout. Pro rezidenty v ceně bydlení, pro veřejnost za zvýhodněnou sazbu.',
    image: { src: '/images/hub/coworking/cowork-interier-sal-c.jpg', alt: 'Coworkingový sál v budově C' },
  },
  {
    date: '15. března 2026', category: 'Doprava', title: 'Kyvadlová doprava k metru Kobylisy',
    excerpt: 'Hub-shuttle vás odveze k metru Kobylisy i k přívozu na vlak do centra. Pět jízd měsíčně máte v ceně bydlení.',
    image: { src: '/images/hub/doprava/hub-shuttle-zastavka.jpg', alt: 'Zastávka Hub-shuttle v areálu' },
  },
  {
    date: '24. února 2026', category: 'Komunita', title: 'Komunitní zahrádky pro rezidenty',
    excerpt: 'V severní části parku připravujeme sezónní záhony. Vypěstujte si vlastní bylinky a zeleninu pár kroků od bytu.',
    image: { src: '/images/hub/komunita/05-komunitni-zahrady.jpg', alt: 'Komunitní zahrádky v parku' },
  },
  {
    date: '10. ledna 2026', category: 'Stipendia', title: 'Pobytová stipendia: první kolo na podzim',
    excerpt: 'Bydlete v Hubu zdarma nebo zvýhodněně výměnou za přínos komunitě. První pilotní kolo plánujeme na podzim 2026.',
    image: { src: '/images/hub/stipendia/01-atelier.jpg', alt: 'Ateliér s rezidentem-tvůrcem' },
  },
];
---
<Base
  title="Novinky · Startovací Hub Klecany"
  description="Novinky ze Startovacího Hubu Klecany: spuštění rezervací, postup rekonstrukce, otevírání prvních budov a komunitní akce."
  headerVariant="overlay">

  <SubpageHero
    eyebrow="Novinky"
    title="Co je <em>nového</em>"
    sub="Spuštění rezervací, postup rekonstrukce a otevírání prvních budov. Reálné články doplňujeme průběžně, níže je náhled, jak budou vypadat."
    variant="cream"
    ribbonPath="M 120 720 C 520 420, 980 860, 1380 540 C 1700 300, 1980 560, 2060 420"
    ariaId="novinky"
  />

  <div class="news-wrap">
    <p class="news-note">Náhled stylu. Ukázkový obsah, reálné články doplníme, jakmile bude co publikovat.</p>
    <div class="news-grid">
      {news.map((n) => <NewsCard {...n} href="#" />)}
    </div>
  </div>

  <CtaBanner
    eyebrow="Rezervace"
    title="Nechcete o nic <em>přijít</em>?"
    lede="Zaregistrujte zájem o bydlení a ozveme se vám s novinkami i konkrétní nabídkou."
    cta={{ label: 'Nezávazná rezervace', href: '/rezervace/' }}
    variant="deep"
  />
  <CrossLinkPair
    items={[
      { eyebrow: 'Ubytování', title: 'Apartmány a <em>sdílené pokoje</em>', href: '/ubytovani/', variant: 'cream' },
      { eyebrow: 'Zázemí', title: 'Celé <em>zázemí</em> Hubu', href: '/zazemi/', variant: 'ink' },
    ]}
  />
</Base>

<style>
  .news-wrap {
    width: calc(100% - 2 * var(--gutter));
    max-width: var(--container-wide);
    margin: 0 auto;
    padding: var(--space-8) 0;
  }
  .news-note {
    font: 500 var(--text-sm) / 1.5 var(--font-sans);
    color: var(--fg-subtle);
    margin: 0 0 var(--space-5);
  }
  .news-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: clamp(16px, 2vw, 28px);
  }
  @media (max-width: 900px) { .news-grid { grid-template-columns: repeat(2, minmax(0, 1fr)); } }
  @media (max-width: 560px) { .news-grid { grid-template-columns: 1fr; } }
</style>
