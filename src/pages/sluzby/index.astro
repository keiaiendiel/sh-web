---
import Base from '../../layouts/Base.astro';
import Icon from '../../components/Icon.astro';
import { withBase } from '../../utils/url';

/* Doplňkové služby — placené nad rámec nájmu. Ceník je orientační a finální
   dostupnost v termínu rezervace doladí rezervační oddělení po telefonu. */

const services = [
  {
    id: 'stravovani',
    icon: 'utensils',
    title: 'Stravování',
    pitch: 'Snídaně, obědy, večeře a svačiny z areálové kuchyně. Možnost měsíčního paušálu nebo platba per jídlo. Vegetariánské i masové varianty, sezónní suroviny od lokálních dodavatelů.',
    items: [
      { label: 'Snídaně',         price: 'od 95 Kč',    note: 'Pečivo z areálové pekárny, vejce, sezónní ovoce.' },
      { label: 'Oběd',            price: 'od 145 Kč',   note: 'Polévka + hlavní jídlo, vegetariánská i masová varianta.' },
      { label: 'Večeře',          price: 'od 125 Kč',   note: 'Lehčí jídla, salát a hlavní.' },
      { label: 'Svačina',         price: 'od 55 Kč',    note: 'Sezónní ovoce, müsli, pečivo, jogurt.' },
      { label: 'Měsíční paušál',  price: 'od 4 200 Kč', note: 'Snídaně + oběd každý pracovní den.' },
    ],
  },
  {
    id: 'evozidla',
    icon: 'bike',
    title: 'Půjčovna e-vozidel',
    pitch: 'Sdílená flotila elektrokoloběžek, e-kol, e-motorek, sdílených aut, mikrobusů i obytných aut pro rezidenty. Hodinové i denní tarify, rezervace přes aplikaci.',
    items: [
      { label: 'E-koloběžka',  price: 'od 35 Kč/hod',    note: 'Pro denní cesty po areálu a do Klecan.' },
      { label: 'E-kolo',       price: 'od 65 Kč/hod',    note: 'Pro delší trasy podél Vltavy nebo do Prahy.' },
      { label: 'E-motorka',    price: 'od 95 Kč/hod',    note: 'Skútr 50 cc, řidičák B nebo AM.' },
      { label: 'Sdílené auto', price: 'od 240 Kč/hod',   note: 'Hatchback pro 4 osoby, k tomu mikrobus 9 míst.' },
      { label: 'Obytné auto',  price: 'od 1 850 Kč/den', note: 'Pro víkendovky a delší výlety.' },
    ],
  },
  {
    id: 'sklady',
    icon: 'warehouse',
    title: 'Kontejnerové sklady',
    pitch: 'Uzamykatelné boxy 24/7 pro horská kola, lyže, sezónní krámy, archiv firmy. Tři velikosti, vlastní zámek.',
    items: [
      { label: 'Box S — 1 m³', price: 'od 350 Kč/měsíc', note: 'Drobné věci, dokumenty, sezónní oblečení.' },
      { label: 'Box M — 2 m³', price: 'od 550 Kč/měsíc', note: 'Lyže, kolo, sportovní výbava.' },
      { label: 'Box L — 4 m³', price: 'od 850 Kč/měsíc', note: 'Archiv firmy, sklad pro OSVČ, větší nábytek.' },
    ],
  },
];
---
<Base
  title="Doplňkové služby · Startovací Hub Klecany"
  description="Stravování, půjčovna e-vozidel, kontejnerové sklady a sauna premium — placené služby nad rámec nájmu. Orientační ceník."
  headerVariant="dark"
>
  <section class="sluzby-hero osa-dark">
    <img class="sluzby-hero__bg" src={withBase('/images/hub/interior/hub-market-daytime.jpg')} alt="" aria-hidden="true" loading="eager" decoding="async" />
    <div class="sluzby-hero__scrim" aria-hidden="true"></div>
    <div class="sluzby-hero__inner">
      <span class="osa-eyebrow sluzby-hero__eyebrow">Doplňkové služby</span>
      <h1 class="sluzby-hero__title">Co můžete v Hubu přikoupit.</h1>
      <p class="sluzby-hero__lede">V nájmu jsou energie, internet, coworking, bazén, recepce a kyvadla. Tyhle služby si můžete přidat podle potřeby — placené z jednoho účtu, bez extra papírování.</p>
    </div>
  </section>

  <nav class="sluzby-nav" aria-label="Skok na sekci">
    {services.map((s) => (
      <a href={`#${s.id}`}>{s.title}</a>
    ))}
  </nav>

  <section class="sluzby-list">
    {services.map((s) => (
      <article id={s.id} class="sluzby-card">
        <header class="sluzby-card__head">
          <span class="sluzby-card__icon" aria-hidden="true"><Icon name={s.icon} /></span>
          <div>
            <h2 class="sluzby-card__title">{s.title}</h2>
            <p class="sluzby-card__pitch">{s.pitch}</p>
          </div>
        </header>
        <table class="sluzby-card__table">
          <thead>
            <tr>
              <th scope="col">Položka</th>
              <th scope="col">Cena</th>
              <th scope="col">Detail</th>
            </tr>
          </thead>
          <tbody>
            {s.items.map((i) => (
              <tr>
                <td class="sluzby-card__label">{i.label}</td>
                <td class="sluzby-card__price osa-figs">{i.price}</td>
                <td class="sluzby-card__note">{i.note}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </article>
    ))}
  </section>

  <section class="sluzby-note">
    <div class="sluzby-note__inner">
      <p><strong>Ceny jsou orientační.</strong> Konkrétní dostupnost služby v termínu vaší rezervace s vámi probere rezervační oddělení po telefonu. Pro nově zarezervované rezidenty obvykle úvodní sleva na první měsíc.</p>
    </div>
  </section>
</Base>

<style>
  .sluzby-hero {
    position: relative;
    isolation: isolate;
    min-height: clamp(320px, 46vh, 440px);
    display: flex;
    align-items: flex-end;
    color: #fff;
    overflow: hidden;
  }
  .sluzby-hero__bg {
    position: absolute; inset: 0;
    width: 100%; height: 100%;
    object-fit: cover;
    filter: brightness(0.85);
    z-index: 1;
  }
  .sluzby-hero__scrim {
    position: absolute; inset: 0; z-index: 2;
    background: linear-gradient(180deg, rgba(0,0,0,0) 0%, rgba(0,0,0,0.25) 55%, rgba(0,0,0,0.55) 100%);
  }
  .sluzby-hero__inner {
    position: relative; z-index: 3;
    padding: clamp(56px, 9vw, 96px) var(--gutter) clamp(40px, 6vw, 72px);
    max-width: var(--container-wide); margin: 0 auto; width: 100%;
  }
  .sluzby-hero__eyebrow { color: rgba(255,255,255,0.78); display: inline-block; margin-bottom: 14px; }
  .sluzby-hero__title {
    font-family: var(--font-sans);
    font-size: clamp(36px, 5.5vw, 64px);
    font-weight: 600;
    line-height: 1.04;
    letter-spacing: var(--tracking-tight);
    margin: 0 0 20px;
    text-wrap: balance;
    max-width: 18ch;
  }
  .sluzby-hero__lede {
    font-size: clamp(16px, 1.4vw, 19px);
    line-height: 1.55;
    color: rgba(255,255,255,0.88);
    margin: 0;
    max-width: 60ch;
  }

  .sluzby-nav {
    position: sticky;
    top: 56px;
    z-index: 5;
    background: var(--bg);
    border-bottom: 1px solid var(--border-muted);
    padding: 14px var(--gutter);
    max-width: var(--container-wide);
    margin: 0 auto;
    display: flex;
    gap: 24px;
    flex-wrap: wrap;
  }
  .sluzby-nav a {
    font: 600 14px var(--font-sans);
    color: var(--fg-muted);
    text-decoration: none;
    padding: 4px 0;
    border-bottom: 1px solid transparent;
    transition: color var(--dur-fast) linear, border-color var(--dur-fast) linear;
  }
  .sluzby-nav a:hover {
    color: var(--accent);
    border-bottom-color: var(--accent);
  }

  .sluzby-list {
    padding: clamp(48px, 6vw, 80px) var(--gutter);
    max-width: var(--container-wide); margin: 0 auto;
    display: grid;
    gap: clamp(40px, 5vw, 64px);
  }
  .sluzby-card {
    display: grid;
    gap: 24px;
    padding: clamp(28px, 4vw, 40px);
    border: 1px solid var(--accent-rule);
    border-radius: var(--radius-input);
    background: var(--bg);
    scroll-margin-top: 120px;
  }
  .sluzby-card__head {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 20px;
    align-items: start;
  }
  .sluzby-card__icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 56px; height: 56px;
    background: var(--accent-soft);
    color: var(--accent);
    border-radius: var(--radius-input);
    flex-shrink: 0;
  }
  .sluzby-card__icon :global(svg) { width: 32px; height: 32px; stroke: currentColor; }
  .sluzby-card__title {
    font-family: var(--font-sans);
    font-size: clamp(24px, 2.8vw, 32px);
    font-weight: 600;
    margin: 0 0 8px;
    line-height: 1.15;
    letter-spacing: var(--tracking-tight);
  }
  .sluzby-card__pitch {
    font-size: 15px;
    color: var(--fg-muted);
    margin: 0;
    line-height: 1.55;
    max-width: 64ch;
  }

  .sluzby-card__table {
    width: 100%;
    border-collapse: collapse;
    font-size: 14px;
  }
  .sluzby-card__table thead th {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--fg-subtle);
    text-align: left;
    padding: 8px 12px;
    border-bottom: 1px solid var(--border-muted);
    font-weight: 500;
  }
  .sluzby-card__table tbody tr {
    border-bottom: 1px solid var(--border-muted);
  }
  .sluzby-card__table tbody tr:last-child { border-bottom: 0; }
  .sluzby-card__table td {
    padding: 14px 12px;
    vertical-align: top;
  }
  .sluzby-card__label {
    font-weight: 600;
    color: var(--fg);
    white-space: nowrap;
  }
  .sluzby-card__price {
    font-weight: 600;
    color: var(--accent);
    white-space: nowrap;
  }
  .sluzby-card__note {
    color: var(--fg-muted);
    line-height: 1.5;
  }
  @media (max-width: 720px) {
    .sluzby-card__table thead { display: none; }
    .sluzby-card__table tbody tr {
      display: grid;
      grid-template-columns: 1fr auto;
      gap: 4px 12px;
      padding: 12px 0;
    }
    .sluzby-card__table td { padding: 0; }
    .sluzby-card__note { grid-column: 1 / -1; padding-top: 4px; }
    .sluzby-card__head { grid-template-columns: 1fr; }
  }

  .sluzby-note {
    padding: 0 var(--gutter) clamp(64px, 8vw, 96px);
    max-width: var(--container-wide); margin: 0 auto;
  }
  .sluzby-note__inner {
    max-width: 720px;
    padding: 20px 24px;
    background: var(--k-05);
    border-left: 3px solid var(--accent);
    border-radius: 0 var(--radius-input) var(--radius-input) 0;
  }
  .sluzby-note__inner p {
    margin: 0;
    font-size: 14px;
    line-height: 1.65;
    color: var(--fg);
  }
  .sluzby-note__inner strong { color: var(--k-100); }
</style>
