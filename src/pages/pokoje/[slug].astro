---
import Base from '../../layouts/Base.astro';
import { getCollection, render } from 'astro:content';
import { withBase } from '../../utils/url';

export async function getStaticPaths() {
  const all = await getCollection('rooms');
  return all.map((r) => ({ params: { slug: r.id }, props: { room: r } }));
}

const { room } = Astro.props;
const { Content } = await render(room);

const formatPrice = (n: number) => new Intl.NumberFormat('cs-CZ').format(n);
const priceFormatted = formatPrice(room.data.priceFrom);
const perPerson = room.data.maxBeds > 1 ? Math.round(room.data.priceFrom / room.data.maxBeds) : null;
const perPersonFormatted = perPerson ? formatPrice(perPerson) : null;

// 3-tier slevová struktura: 3+ / 6+ / 12+ měsíců. Compass research doporučuje
// přidat 3měsíční tier, který zachycuje Erasmus a semestrální studenty.
const priceTiers = [
  {
    label: 'Pobyt 1–2 měsíce',
    pct: 0,
    price: room.data.priceFrom,
  },
  room.data.discount3 ? {
    label: 'Pobyt 3+ měsíců',
    pct: room.data.discount3,
    price: Math.round(room.data.priceFrom * (1 - room.data.discount3 / 100) / 50) * 50,
  } : null,
  room.data.discount6 ? {
    label: 'Pobyt 6+ měsíců',
    pct: room.data.discount6,
    price: Math.round(room.data.priceFrom * (1 - room.data.discount6 / 100) / 50) * 50,
  } : null,
  room.data.discount12 ? {
    label: 'Pobyt 12+ měsíců',
    pct: room.data.discount12,
    price: Math.round(room.data.priceFrom * (1 - room.data.discount12 / 100) / 50) * 50,
  } : null,
].filter((t): t is { label: string; pct: number; price: number } => t !== null);

const reserveHref = withBase(`/rezervace/?typ=${room.data.type}`);
---
<Base
  title={`${room.data.name} · Startovací Hub Klecany`}
  description={room.data.pitch}
  headerVariant="dark"
>
  <section class="rd-hero osa-dark">
    <img class="rd-hero__bg" src={room.data.heroImage} alt={room.data.heroImageAlt} loading="eager" decoding="async" />
    <div class="rd-hero__scrim" aria-hidden="true"></div>
    <div class="rd-hero__inner">
      <a class="rd-hero__back" href={withBase('/pokoje/')}>← Všechny typy ubytování</a>
      <span class="osa-eyebrow rd-hero__eyebrow">{room.data.shortName}</span>
      <h1 class="rd-hero__title">{room.data.name}</h1>
      <p class="rd-hero__lede">{room.data.pitch}</p>
      <dl class="rd-hero__meta">
        <div><dt>Velikost</dt><dd>{room.data.size}</dd></div>
        <div><dt>Kapacita v ceně</dt><dd>{room.data.maxBeds === 1 ? '1 lůžko' : `až ${room.data.maxBeds} lůžek`}</dd></div>
        <div>
          <dt>Cena</dt>
          <dd class="rd-hero__price">
            <span class="osa-figs">od {priceFormatted}</span> Kč/měsíc
            {perPersonFormatted && (
              <span class="rd-hero__price-perperson">= <span class="osa-figs">{perPersonFormatted}</span> Kč/osoba při plné obsazenosti</span>
            )}
          </dd>
        </div>
      </dl>
    </div>
  </section>

  <section class="rd-ideal">
    <div class="rd-ideal__inner">
      <span class="osa-eyebrow rd-ideal__eyebrow">Pro koho dává smysl</span>
      <p>{room.data.idealFor}</p>
    </div>
  </section>

  <section class="rd-body">
    <div class="rd-body__inner">
      <Content />
    </div>
  </section>

  {priceTiers.length > 1 && (
    <section class="rd-pricing">
      <header class="osa-sub-head">
        <span class="osa-eyebrow">Cena podle délky pobytu</span>
        <h2 class="rd-pricing__heading">Čím dýl, tím méně.</h2>
        <p class="rd-pricing__intro">Cena platí za celou jednotku. Všechny tarify zahrnují energie, internet, úklid společných prostor, coworking, bazén a kyvadla.</p>
      </header>
      <ul class="rd-pricing__list">
        {priceTiers.map((t) => {
          const perPersonTier = room.data.maxBeds > 1 ? Math.round(t.price / room.data.maxBeds) : null;
          return (
            <li>
              <span class="rd-pricing__label">
                {t.label}
                {t.pct > 0 && <span class="rd-pricing__pct"> · sleva −{t.pct} %</span>}
              </span>
              <span class="rd-pricing__value">
                <span class="rd-pricing__value-main osa-figs">{formatPrice(t.price)} Kč/měsíc</span>
                {perPersonTier !== null && (
                  <span class="rd-pricing__value-perperson osa-figs">= {formatPrice(perPersonTier)} Kč/osoba</span>
                )}
              </span>
            </li>
          );
        })}
      </ul>
      <p class="rd-pricing__note">Ceny jsou orientační, finální nájemné se ladí s rezervačním oddělením po telefonu podle aktuální obsazenosti.</p>
    </section>
  )}

  <section class="rd-cta">
    <div class="rd-cta__inner">
      <p class="rd-cta__lede">Chcete tento formát? Vyplňte krátkou rezervaci, ozveme se do 24 hodin.</p>
      <div class="rd-cta__btns">
        <a class="rd-cta__btn rd-cta__btn--primary" href={reserveHref}>Rezervovat {room.data.shortName.toLowerCase()} →</a>
        <a class="rd-cta__btn rd-cta__btn--ghost" href={withBase('/pokoje/')}>Porovnat ostatní typy</a>
      </div>
    </div>
  </section>
</Base>

<style>
  .rd-hero {
    position: relative;
    isolation: isolate;
    min-height: clamp(420px, 60vh, 560px);
    display: flex;
    align-items: flex-end;
    color: #fff;
    overflow: hidden;
  }
  .rd-hero__bg {
    position: absolute; inset: 0;
    width: 100%; height: 100%;
    object-fit: cover;
    filter: brightness(0.85);
    z-index: 1;
  }
  .rd-hero__scrim {
    position: absolute; inset: 0; z-index: 2;
    background: linear-gradient(180deg, rgba(0,0,0,0) 0%, rgba(0,0,0,0.25) 50%, rgba(0,0,0,0.65) 100%);
  }
  .rd-hero__inner {
    position: relative; z-index: 3;
    padding: clamp(56px, 9vw, 96px) var(--gutter) clamp(40px, 6vw, 72px);
    max-width: var(--container-wide); margin: 0 auto; width: 100%;
  }
  .rd-hero__back {
    display: inline-block;
    font-size: 14px;
    color: rgba(255,255,255,0.78);
    text-decoration: none;
    margin-bottom: 14px;
    letter-spacing: var(--tracking-tight);
    transition: color var(--dur-fast) linear;
  }
  .rd-hero__back:hover { color: #fff; }
  .rd-hero__eyebrow { color: rgba(255,255,255,0.85); display: block; margin-bottom: 8px; }
  .rd-hero__title {
    font-family: var(--font-sans);
    font-size: clamp(36px, 5.5vw, 64px);
    font-weight: 600;
    line-height: 1.04;
    letter-spacing: var(--tracking-tight);
    margin: 0 0 16px;
    text-wrap: balance;
    max-width: 18ch;
  }
  .rd-hero__lede {
    font-size: clamp(16px, 1.4vw, 19px);
    line-height: 1.55;
    color: rgba(255,255,255,0.92);
    margin: 0 0 24px;
    max-width: 56ch;
  }
  .rd-hero__meta {
    display: flex;
    flex-wrap: wrap;
    gap: 0;
    margin: 0;
    padding: 16px 0 0;
    border-top: 1px solid rgba(255,255,255,0.25);
    max-width: 720px;
  }
  .rd-hero__meta > div {
    padding: 6px 24px 6px 0;
    border-right: 1px solid rgba(255,255,255,0.15);
    display: grid; gap: 2px;
  }
  .rd-hero__meta > div + div { padding-left: 24px; }
  .rd-hero__meta > div:last-child { border-right: 0; }
  .rd-hero__meta dt {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.6);
    margin: 0;
  }
  .rd-hero__meta dd {
    font-size: 16px;
    color: #fff;
    margin: 0;
    line-height: 1.3;
  }
  .rd-hero__price { font-weight: 600; }
  .rd-hero__price-perperson {
    display: block;
    font-weight: 400;
    font-size: 13px;
    color: rgba(255,255,255,0.78);
    margin-top: 2px;
  }
  @media (max-width: 600px) {
    .rd-hero__meta > div { padding: 6px 0; border-right: 0; border-bottom: 1px solid rgba(255,255,255,0.15); width: 100%; }
    .rd-hero__meta > div + div { padding-left: 0; }
    .rd-hero__meta > div:last-child { border-bottom: 0; }
  }

  .rd-ideal {
    padding: clamp(32px, 5vw, 56px) var(--gutter);
    max-width: var(--container-wide); margin: 0 auto;
    border-bottom: 1px solid var(--border-muted);
  }
  .rd-ideal__inner {
    max-width: 720px;
    padding: 20px 24px;
    background: var(--accent-soft);
    border-left: 3px solid var(--accent);
    border-radius: 0 var(--radius-input) var(--radius-input) 0;
  }
  .rd-ideal__eyebrow { display: block; color: var(--accent); margin-bottom: 8px; }
  .rd-ideal__inner p {
    margin: 0;
    font-size: 16px;
    line-height: 1.65;
    color: var(--fg);
    max-width: 64ch;
  }

  .rd-body {
    padding: clamp(48px, 6vw, 80px) var(--gutter);
    max-width: var(--container-wide); margin: 0 auto;
  }
  .rd-body__inner { max-width: 720px; }
  .rd-body__inner :global(h2) {
    font-family: var(--font-sans);
    font-size: clamp(22px, 2.4vw, 28px);
    font-weight: 600;
    margin: 32px 0 12px;
    line-height: 1.2;
    letter-spacing: var(--tracking-tight);
    text-wrap: balance;
  }
  .rd-body__inner :global(h2:first-child) { margin-top: 0; }
  .rd-body__inner :global(p) {
    font-size: 16px;
    line-height: 1.65;
    color: var(--fg);
    margin: 0 0 16px;
    max-width: 64ch;
  }
  .rd-body__inner :global(ul) {
    font-size: 16px;
    line-height: 1.65;
    color: var(--fg);
    margin: 0 0 16px;
    padding-left: 22px;
    max-width: 64ch;
  }
  .rd-body__inner :global(li) { margin: 0 0 6px; }
  .rd-body__inner :global(strong) { font-weight: 600; }
  .rd-body__inner :global(a) {
    color: var(--accent);
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .rd-pricing {
    padding: clamp(48px, 6vw, 80px) var(--gutter);
    max-width: var(--container-wide); margin: 0 auto;
    border-top: 1px solid var(--border-muted);
  }
  .rd-pricing__heading {
    font-family: var(--font-sans);
    font-size: clamp(22px, 2.4vw, 32px);
    font-weight: 600;
    margin: 0;
    letter-spacing: var(--tracking-tight);
    line-height: 1.15;
  }
  .rd-pricing__intro {
    font-size: clamp(14px, 1.1vw, 16px);
    color: var(--fg-muted);
    line-height: 1.55;
    margin: 8px 0 0;
    max-width: 64ch;
  }
  .rd-pricing__list {
    list-style: none;
    padding: 0; margin: 24px 0 0;
    display: grid;
    gap: 0;
    max-width: 720px;
  }
  .rd-pricing__list li {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 16px;
    padding: 16px 0;
    border-bottom: 1px solid var(--border-muted);
  }
  .rd-pricing__list li:last-child { border-bottom: 0; }
  .rd-pricing__label {
    font-size: 15px;
    color: var(--fg);
    line-height: 1.4;
  }
  .rd-pricing__pct {
    color: var(--accent);
    font-size: 13px;
    font-weight: 600;
  }
  .rd-pricing__value {
    display: grid;
    gap: 2px;
    text-align: right;
  }
  .rd-pricing__value-main {
    font-family: var(--font-sans);
    font-weight: 600;
    font-size: 18px;
    color: var(--accent);
    line-height: 1.2;
  }
  .rd-pricing__value-perperson {
    font-size: 12px;
    color: var(--fg-subtle);
    font-weight: 500;
  }
  .rd-pricing__note {
    max-width: 720px;
    font-size: 13px;
    color: var(--fg-subtle);
    line-height: 1.55;
    margin: 24px 0 0;
  }

  .rd-cta {
    padding: clamp(48px, 6vw, 80px) var(--gutter);
    max-width: var(--container-wide); margin: 0 auto;
    border-top: 1px solid var(--border-muted);
  }
  .rd-cta__inner {
    max-width: 720px; margin: 0 auto; text-align: center;
    display: grid; gap: 20px;
    padding: clamp(32px, 4vw, 48px);
    border: 1px solid var(--accent-rule);
    border-radius: var(--radius-input);
  }
  .rd-cta__lede {
    font-size: clamp(16px, 1.35vw, 18px);
    line-height: 1.55;
    color: var(--fg);
    margin: 0;
  }
  .rd-cta__btns {
    display: flex; gap: 12px;
    justify-content: center; flex-wrap: wrap;
  }
  .rd-cta__btn {
    display: inline-flex; align-items: center; gap: 8px;
    padding: 14px 24px;
    border-radius: var(--radius-input);
    font-weight: 600; font-size: 15px;
    text-decoration: none;
    transition: background var(--dur-base) var(--ease-decel), color var(--dur-base) var(--ease-decel);
  }
  .rd-cta__btn--primary {
    color: var(--accent-on);
    background: var(--accent);
    border: 1px solid var(--accent);
  }
  .rd-cta__btn--primary:hover { background: var(--k-100); border-color: var(--k-100); }
  .rd-cta__btn--ghost {
    color: var(--k-100);
    background: transparent;
    border: 1px solid var(--k-100);
  }
  .rd-cta__btn--ghost:hover {
    background: var(--k-100);
    color: var(--k-0);
  }
</style>
