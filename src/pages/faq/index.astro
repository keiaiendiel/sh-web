---
import Base from '../../layouts/Base.astro';
import { withBase } from '../../utils/url';
import { getCollection } from 'astro:content';

const all = (await getCollection('faq')).sort((a, b) => a.data.order - b.data.order);
const labels: Record<string, string> = {
  project: 'O projektu',
  resident: 'Pro obyvatele',
};
const groups = (['project', 'resident'] as const).map((aud) => ({
  aud,
  label: labels[aud],
  items: all.filter((q) => q.data.audience === aud),
}));
---
<Base
  title="FAQ · Startovací Hub Klecany"
  description="Odpovědi na nejčastější otázky o projektu a bydlení v Hubu."
  headerVariant="dark"
>
  <section class="sp-hero sp-hero--solid osa-dark">
    <div class="sp-hero__inner">
      <span class="osa-eyebrow sp-hero__eyebrow">Časté otázky</span>
      <h1 class="sp-hero__title">FAQ</h1>
      <p class="sp-hero__lede">Otázky, které dostáváme nejčastěji. Pokud něco chybí, ozvěte se na <a href="mailto:info@startovacihub.cz">info@startovacihub.cz</a>.</p>
    </div>
  </section>

  <section class="hub-section hub-faq">
    <div class="hub-faq__tabs" role="tablist">
      <button class="is-active" data-aud="all" role="tab" aria-selected="true">Vše</button>
      {groups.map((g) => (
        <button data-aud={g.aud} role="tab" aria-selected="false">{g.label}</button>
      ))}
    </div>

    {groups.map((g) => (
      <div class="hub-faq__group" data-group={g.aud}>
        <h2>{g.label}</h2>
        {g.items.map((q) => (
          <details class="hub-faq__item">
            <summary>{q.data.question}</summary>
            <p>{q.data.answer}</p>
          </details>
        ))}
      </div>
    ))}
  </section>
</Base>

<style>
  /* Sub-page hero — dark image bg + eyebrow + H1 + lede.
     Shared aesthetic across /faq/, /rezervace/, /o-arealu/, /projekty/. */
  .sp-hero {
    position: relative;
    isolation: isolate;
    min-height: clamp(320px, 46vh, 440px);
    display: flex;
    align-items: flex-end;
    background: var(--k-100);
    color: #fff;
    overflow: hidden;
  }
  .sp-hero__bg {
    position: absolute; inset: 0;
    width: 100%; height: 100%;
    object-fit: cover;
    filter: brightness(0.42) saturate(0.92);
    z-index: 1;
  }
  .sp-hero__scrim {
    position: absolute; inset: 0; z-index: 2;
    background: linear-gradient(180deg, rgba(0,0,0,0.30) 0%, rgba(0,0,0,0.18) 38%, rgba(0,0,0,0.65) 100%);
    pointer-events: none;
  }
  .sp-hero__inner {
    position: relative; z-index: 3;
    padding: clamp(56px, 9vw, 96px) var(--gutter) clamp(40px, 6vw, 72px);
    max-width: var(--container-wide); margin: 0 auto; width: 100%;
  }
  .sp-hero__inner > * { max-width: 760px; }
  .sp-hero__eyebrow { color: rgba(255,255,255,0.78); display: inline-block; margin-bottom: 14px; }
  .sp-hero__title {
    font-family: var(--font-sans);
    font-size: clamp(36px, 5.5vw, 64px);
    font-weight: 600;
    line-height: 1.04;
    letter-spacing: var(--tracking-tight);
    margin: 0 0 20px;
    text-wrap: balance;
  }
  .sp-hero__lede {
    font-size: clamp(16px, 1.4vw, 19px);
    line-height: 1.55;
    color: rgba(255,255,255,0.88);
    margin: 0;
    max-width: 56ch;
  }
  .sp-hero__lede a {
    color: #fff;
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .hub-section { padding: 32px 24px 96px; max-width: 1200px; margin: 0 auto; }

  .hub-faq__tabs {
    display: flex; gap: 8px; flex-wrap: wrap;
    margin: 32px 0;
    padding: 0 0 16px;
    border-bottom: 1px solid var(--border-muted);
  }
  .hub-faq__tabs button {
    padding: 8px 16px;
    border: 1px solid var(--border-muted);
    background: transparent;
    border-radius: 999px;
    font: inherit; font-size: 14px;
    cursor: pointer;
    transition: all 200ms cubic-bezier(0.16, 1, 0.3, 1);
  }
  .hub-faq__tabs button.is-active {
    background: var(--accent);
    color: var(--accent-on);
    border-color: var(--accent);
  }

  .hub-faq__group { margin: 32px 0; }
  .hub-faq__group h2 {
    font-size: 22px; font-weight: 700;
    margin: 0 0 16px;
    letter-spacing: -0.01em;
    color: var(--fg-muted);
  }

  .hub-faq__item {
    padding: 16px 0;
    border-bottom: 1px solid var(--border-muted);
  }
  .hub-faq__item summary {
    font-weight: 600; font-size: 17px;
    cursor: pointer; padding: 8px 0;
    list-style: none; line-height: 1.5;
    display: flex; align-items: flex-start; gap: 12px;
  }
  .hub-faq__item summary::-webkit-details-marker { display: none; }
  .hub-faq__item summary::before {
    content: '+'; flex-shrink: 0;
    transition: transform 200ms cubic-bezier(0.16, 1, 0.3, 1);
    display: inline-block; width: 18px; text-align: center;
    color: var(--accent);
  }
  .hub-faq__item[open] summary::before { transform: rotate(45deg); }
  .hub-faq__item p {
    padding: 0 0 8px 30px;
    line-height: 1.65;
    color: var(--fg);
    margin: 0; max-width: 880px;
  }
</style>

<script is:inline>
  document.addEventListener('DOMContentLoaded', () => {
    const tabs = document.querySelectorAll('.hub-faq__tabs button');
    const groups = document.querySelectorAll('.hub-faq__group');
    tabs.forEach((t) => t.addEventListener('click', () => {
      tabs.forEach((b) => { b.classList.remove('is-active'); b.setAttribute('aria-selected', 'false'); });
      t.classList.add('is-active'); t.setAttribute('aria-selected', 'true');
      const aud = t.dataset.aud;
      groups.forEach((g) => g.hidden = !(aud === 'all' || g.dataset.group === aud));
    }));
  });
</script>
