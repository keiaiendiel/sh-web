---
import Base from '../../layouts/Base.astro';
import { withBase } from '../../utils/url';
import { getCollection } from 'astro:content';

const faq = (await getCollection('faq')).sort((a, b) => a.data.order - b.data.order);
---
<Base
  title="Časté otázky · Startovací Hub Klecany"
  description="Co je Hub, kdy se mohu nastěhovat, co je v ceně bydlení, jak se sem dostanu z Prahy, jak funguje stipendium, mazlíčci, registrace sídla OSVČ.">
  <article class="page-stub">
    <p class="page-stub__eyebrow">FAQ</p>
    <h1>Deset nejčastějších otázek.</h1>
    <p class="page-stub__lede">
      Otázky, které dostáváme nejčastěji. Když něco chybí, napište na <a href="mailto:vpd@osa2.cz">vpd@osa2.cz</a>
      nebo to dejte do poznámky při <a href={withBase('/rezervace/')}>registraci zájmu</a>.
    </p>
  </article>

  <section class="sec-block">
    <div class="sec-block__inner">
      <ol class="faq-list">
        {faq.map((q, i) => (
          <li class="faq-item">
            <details>
              <summary>
                <span class="faq-item__num">{(i + 1).toString().padStart(2, '0')}</span>
                <span class="faq-item__q">{q.data.question}</span>
                <span class="faq-item__caret" aria-hidden="true">+</span>
              </summary>
              <div class="faq-item__body">
                <p>{q.data.answer}</p>
              </div>
            </details>
          </li>
        ))}
      </ol>
    </div>
  </section>

  <section class="sec-cta">
    <div class="sec-cta__inner">
      <h2 class="sec-cta__title">Něco tu chybí?</h2>
      <p class="sec-cta__lede">
        Napište na <a href="mailto:vpd@osa2.cz" style="color:#fff;text-decoration:underline">vpd@osa2.cz</a>, nebo to dejte do poznámky při registraci zájmu.
      </p>
      <a class="sec-cta__button" href={withBase('/rezervace/')}>Nezávazná rezervace</a>
    </div>
  </section>
</Base>

<style>
  .faq-list { list-style: none; padding: 0; margin: 0; display: grid; gap: 0; border-top: 1px solid var(--rule, rgba(0,0,0,0.1)); }
  .faq-item { border-bottom: 1px solid var(--rule, rgba(0,0,0,0.1)); }
  .faq-item details { padding: 0; }
  .faq-item summary {
    list-style: none;
    cursor: pointer;
    padding: var(--space-5) 0;
    display: grid;
    grid-template-columns: 60px 1fr 32px;
    gap: var(--space-4);
    align-items: center;
    font: 600 var(--text-lg) / 1.3 var(--font-sans);
    color: var(--fg);
    letter-spacing: var(--tracking-tight);
    transition: color 160ms ease;
  }
  .faq-item summary:hover { color: var(--accent); }
  .faq-item summary::-webkit-details-marker { display: none; }
  .faq-item__num {
    font: 600 var(--text-xs) / 1 var(--font-sans);
    letter-spacing: var(--tracking-wider);
    color: var(--accent);
  }
  .faq-item__caret {
    font: 400 var(--text-2xl) / 1 var(--font-sans);
    color: var(--accent);
    text-align: right;
    transition: transform 200ms ease;
  }
  .faq-item details[open] .faq-item__caret { transform: rotate(45deg); }
  .faq-item__body {
    padding: 0 32px var(--space-5) calc(60px + var(--space-4));
    max-width: 70ch;
  }
  .faq-item__body p { line-height: 1.65; margin: 0; color: var(--fg-muted); font-size: var(--text-md); }

  @media (max-width: 640px) {
    .faq-item summary { grid-template-columns: 40px 1fr 28px; gap: var(--space-2); font-size: var(--text-md); }
    .faq-item__body { padding-left: calc(40px + var(--space-2)); padding-right: 0; }
  }
</style>
