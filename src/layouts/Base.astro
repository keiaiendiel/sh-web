---
import '../styles/tokens.css';
import '../styles/kit.css';
import '../styles/motion.css';
import RevealOnScroll from '../components/RevealOnScroll.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { ClientRouter } from 'astro:transitions';
import { getEntry } from 'astro:content';
import { withBase } from '../utils/url';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  ogType?: 'website' | 'article';
  headerVariant?: 'light' | 'dark';
  noindex?: boolean;
}

const {
  title,
  description = 'Startovací bydlení s komunitním a coworkingovým zázemím v areálu horních kasáren v Klecanech, deset minut od Prahy. Přijímáme nezávazné před-rezervace.',
  ogImage = withBase('/og/default.png'),
  ogType = 'website',
  headerVariant = 'light',
  noindex = false,
} = Astro.props;

// Canonical URL: derived from Astro.site + current pathname.
// Astro.site is set in astro.config.mjs to https://startovacihub.cz.
const siteUrl = Astro.site?.toString().replace(/\/$/, '') ?? 'https://startovacihub.cz';
const canonical = `${siteUrl}${Astro.url.pathname}`;
const ogImageAbs = ogImage.startsWith('http') ? ogImage : `${siteUrl}${ogImage.startsWith('/') ? ogImage : withBase(ogImage)}`;

/* JSON-LD per SH_Web_Research_SEO.md § „Structured data":
   1. LocalBusiness (site-wide, na každé stránce v hlavičce)
   2. NGO parentOrganization (OSA II z.s.) jako sub-entity
   3. BreadcrumbList automaticky z URL pathu, lidsky znějící labely

   Per-page schema (Apartment, FAQPage, Service, Article) přidává
   jednotlivá stránka přes `pageSchema` prop. */
const orgEntry = await getEntry('org', 'identity');
const org = orgEntry?.data;

const localBusinessJsonLd = org
  ? {
      '@context': 'https://schema.org',
      '@type': 'LocalBusiness',
      '@id': `${siteUrl}${withBase('/')}#organization`,
      name: 'Startovací Hub Klecany',
      alternateName: ['Hub Klecany', 'Startovací Hub'],
      description: 'Co-living, privátní byty, kapsle a coworking v horních kasárnách v Klecanech, 15 minut autobusem z metra Kobylisy.',
      url: `${siteUrl}${withBase('/')}`,
      logo: `${siteUrl}${withBase('/og/default.png')}`,
      image: `${siteUrl}${withBase('/og/default.png')}`,
      email: org.email,
      telephone: org.phone,
      address: {
        '@type': 'PostalAddress',
        streetAddress: 'Horní Kasárna',
        addressLocality: 'Klecany',
        postalCode: '250 67',
        addressRegion: 'Středočeský kraj',
        addressCountry: 'CZ',
      },
      geo: { '@type': 'GeoCoordinates', latitude: 50.1743, longitude: 14.4082 },
      areaServed: { '@type': 'AdministrativeArea', name: 'Praha a okolí' },
      priceRange: '3000-25000 Kč/měsíc',
      parentOrganization: {
        '@type': 'NGO',
        name: org.name,
        alternateName: org.abbreviations,
        url: 'https://www.alternativa2.info/',
        foundingDate: org.founded,
        email: org.email,
        telephone: org.phone,
        address: {
          '@type': 'PostalAddress',
          streetAddress: 'Terronská 894/56',
          addressLocality: 'Praha 6, Bubeneč',
          postalCode: '160 00',
          addressCountry: 'CZ',
        },
        taxID: org.dic,
        identifier: { '@type': 'PropertyValue', name: 'IČO', value: org.ico.replace(/\s/g, '') },
        member: [
          { '@type': 'Person', name: org.predseda.name, jobTitle: 'Předseda', email: org.predseda.email, telephone: org.predseda.phone },
          { '@type': 'Person', name: org.mistopredseda.name, jobTitle: 'Místopředseda', email: org.mistopredseda.email, telephone: org.mistopredseda.phone },
        ],
      },
    }
  : null;

const breadcrumbLabels: Record<string, string> = {
  '/': 'Domů',
  '/ubytovani/': 'Ubytování',
  '/ubytovani/privatni/': 'Privátní apartmány',
  '/ubytovani/co-living/': 'Co-living',
  '/coworking/': 'Coworking',
  '/komunita/': 'Komunita',
  '/okoli/': 'Okolí',
  '/doprava/': 'Doprava',
  '/stipendia/': 'Stipendia',
  '/rezervace/': 'Registrace zájmu',
  '/kontakty/': 'Kontakty',
  '/kapsle/': 'Kapsle',
  '/faq/': 'FAQ',
  '/metodika-srovnani/': 'Metodika srovnání cen',
  '/gdpr/': 'Ochrana osobních údajů',
  '/druzstvo/': 'Družstvo',
};
const labelForSlug = (seg: string) => {
  if (/^\d+kk$/.test(seg)) return seg.replace('kk', '+kk');
  return seg.replace(/-/g, ' ').replace(/^\w/, (c) => c.toUpperCase());
};
const pathnameRaw = Astro.url.pathname;
const pathnameClean = pathnameRaw.replace(new RegExp('^' + withBase('/').replace(/\/$/, '')), '') || '/';
const crumbs: { name: string; item: string }[] = [];
if (pathnameClean !== '/' && pathnameClean !== '') {
  crumbs.push({ name: 'Domů', item: `${siteUrl}${withBase('/')}` });
  const segs = pathnameClean.split('/').filter(Boolean);
  let acc = '';
  for (const seg of segs) {
    acc += '/' + seg;
    const key = acc + '/';
    const name = breadcrumbLabels[key] ?? labelForSlug(seg);
    crumbs.push({ name, item: `${siteUrl}${withBase(key)}` });
  }
}
const breadcrumbJsonLd = crumbs.length > 1
  ? {
      '@context': 'https://schema.org',
      '@type': 'BreadcrumbList',
      itemListElement: crumbs.map((c, i) => ({ '@type': 'ListItem', position: i + 1, name: c.name, item: c.item })),
    }
  : null;
---
<!doctype html>
<html lang="cs">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}

    {/* Open Graph */}
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImageAbs} />
    <meta property="og:site_name" content="Startovací Hub Klecany" />
    <meta property="og:locale" content="cs_CZ" />

    {/* Twitter Card */}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageAbs} />

    {/* Canonical + favicons + manifest */}
    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/svg+xml" href={withBase('/favicon.svg')} />
    <link rel="alternate icon" href={withBase('/favicon.ico')} sizes="16x16 32x32" />
    <link rel="apple-touch-icon" href={withBase('/apple-touch-icon.png')} />
    <link rel="manifest" href={withBase('/manifest.webmanifest')} />

    {/* Sitemap hint for some crawlers */}
    <link rel="sitemap" type="application/xml" href={withBase('/sitemap-index.xml')} />

    <ClientRouter />

    <title>{title}</title>

    {/* Structured data: LocalBusiness + BreadcrumbList (site-wide) */}
    {localBusinessJsonLd && (
      <script type="application/ld+json" set:html={JSON.stringify(localBusinessJsonLd)} />
    )}
    {breadcrumbJsonLd && (
      <script type="application/ld+json" set:html={JSON.stringify(breadcrumbJsonLd)} />
    )}

    {/* Fallback for JS-off readers: the reveal system hides the
        word-reveal host element until the script splits the text. If
        the script never runs, the element must stay visible. */}
    <noscript>
      <style>{`[data-reveal-words]:not([data-split="done"]) { opacity: 1 !important; }`}</style>
    </noscript>
  </head>
  <body class="osa-body">
    <a class="skip-link" href="#main">Přeskočit na hlavní obsah</a>
    <Header variant={headerVariant} transition:persist />
    <main id="main" transition:animate="fade"><slot /></main>
    <Footer transition:persist />
    <RevealOnScroll />

    {/*
     * Czech typographer: binds single-letter prepositions / conjunctions to
     * the following word with a non-breaking space so they never end up
     * orphaned at the end of a line. Covers k, s, v, z, o, u, a, i (both
     * cases). Walks text nodes once after load; skips code/pre/script/
     * style/textarea plus anything marked [data-no-typograf].
     */}
    <script is:inline>
      (function () {
        var SKIP = { SCRIPT: 1, STYLE: 1, CODE: 1, PRE: 1, TEXTAREA: 1, KBD: 1, SAMP: 1 };
        var RE = /(^|[\s(\[„“"\u2018\u201C\u201A\u201E])([kKsSvVzZoOuUiIaA])[ \t]+(?=\S)/g;
        function run() {
          var walker = document.createTreeWalker(document.body, NodeFilter.SHOW_TEXT, {
            acceptNode: function (node) {
              var p = node.parentNode;
              while (p && p !== document.body) {
                if (SKIP[p.nodeName]) return NodeFilter.FILTER_REJECT;
                if (p.hasAttribute && p.hasAttribute('data-no-typograf')) return NodeFilter.FILTER_REJECT;
                p = p.parentNode;
              }
              return RE.test(node.nodeValue) ? NodeFilter.FILTER_ACCEPT : NodeFilter.FILTER_REJECT;
            },
          });
          var n;
          while ((n = walker.nextNode())) {
            n.nodeValue = n.nodeValue.replace(RE, '$1$2\u00A0');
          }
        }
        // astro:page-load fires on initial load AND after every view transition,
        // so a single binding handles both cold loads and SPA navs.
        document.addEventListener('astro:page-load', run);
      }());
    </script>
  </body>
</html>
<style is:global>
  *, *::before, *::after { box-sizing: border-box; }
  html {
    background: var(--bg, var(--k-0));
    color: var(--fg, var(--k-100));
    /* Smooth scroll pro #main skip-link target a anchor links. */
    scroll-behavior: smooth;
    scroll-padding-top: 80px;
  }
  body {
    margin: 0;
    font-family: var(--font-sans);
    font-size: var(--text-md);
    line-height: var(--lh-normal);
    /* Sofistikovaná typografie: kerning + ligatury + contextual alternates
       z Atyp Special OpenType features. Plus antialiasing pro retinu. */
    font-feature-settings: "kern" 1, "liga" 1, "calt" 1, "ss01" 1;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
    text-rendering: optimizeLegibility;
  }
  a { color: inherit; text-decoration: none; }
  ul, ol { margin: 0; padding: 0; list-style: none; }
  img, svg { display: block; max-width: 100%; }
  button { font: inherit; color: inherit; background: none; border: 0; padding: 0; cursor: pointer; }
  /* Tabular numerals pro ceny, statistiky, čísla v tabulkách. Atyp
     Special má tabular variant. Aplikováno globálně na <td>, <dd>
     a vlastní data atribut pro flex. */
  td, dd, .tabular-nums { font-variant-numeric: tabular-nums; }

  /* Plum text-selection , Hub's reserved sub-identity, applied site-wide
     because the entire site IS the Hub. One free brand cue. */
  ::selection { background: var(--accent); color: var(--accent-on); }

  /* Hub eyebrows are plum, not grey. Promotes the accent without breaking
     the parent OSA monochrome rule (eyebrows are a Hub-only construct). */
  .hub-section__head .osa-eyebrow,
  .hub-section__intro .osa-eyebrow,
  .osa-sub-head .osa-eyebrow,
  .osa-page-head .osa-eyebrow,
  .hub-hero__eyebrow {
    color: var(--accent);
  }
  /* Inverse surfaces (dark hero, dark CTA bands) keep eyebrows readable. */
  .osa-dark .osa-eyebrow,
  .hub-header--dark .osa-eyebrow { color: var(--k-30); }

  @media (prefers-reduced-motion: reduce) {
    *, *::before, *::after { transition-duration: 0.01ms !important; animation-duration: 0.01ms !important; }
  }
</style>
