---
import '../styles/tokens.css';
import '../styles/kit.css';
import '../styles/motion.css';
import RevealOnScroll from '../components/RevealOnScroll.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { getEntry } from 'astro:content';
import { withBase } from '../utils/url';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  ogType?: 'website' | 'article';
  headerVariant?: 'light' | 'dark';
  showRoleChip?: boolean;
  activeRole?: 'resident' | 'investor' | null;
}

const {
  title,
  description = 'První etapa záměru VPD1: dostupné sdílené bydlení v areálu horních kasáren, deset minut od Prahy.',
  ogImage = withBase('/og/default.png'),
  ogType = 'website',
  headerVariant = 'light',
  showRoleChip = false,
  activeRole = null,
} = Astro.props;

// Canonical URL: derived from Astro.site + current pathname.
// Astro.site is set in astro.config.mjs to https://klecany.osa2.cz.
const siteUrl = Astro.site?.toString().replace(/\/$/, '') ?? 'https://klecany.osa2.cz';
const canonical = `${siteUrl}${Astro.url.pathname}`;
const ogImageAbs = ogImage.startsWith('http') ? ogImage : `${siteUrl}${ogImage.startsWith('/') ? ogImage : withBase(ogImage)}`;

// Organization JSON-LD from content collection. The Hub site represents
// the Startovací Hub Klecany project; the operating org (OSA II, z.s.) is
// referenced as parentOrganization. Falls back to hardcoded defaults if
// the entry is missing (shouldnt happen, Zod validates on build).
const orgEntry = await getEntry('org', 'identity');
const org = orgEntry?.data;
const orgJsonLd = org
  ? {
      '@context': 'https://schema.org',
      '@type': 'Organization',
      name: 'Startovací Hub Klecany',
      url: `${siteUrl}${withBase('/')}`,
      subjectOf: {
        '@type': 'WebPage',
        url: 'https://osa2.cz/zamer-vpd/',
      },
      parentOrganization: {
        '@type': 'NGO',
        name: org.name,
        alternateName: org.abbreviations,
        url: 'https://osa2.cz',
        foundingDate: org.founded,
        email: org.email,
        telephone: org.phone,
        address: {
          '@type': 'PostalAddress',
          streetAddress: 'Terronská 894/56',
          addressLocality: 'Praha 6 - Bubeneč',
          postalCode: '160 00',
          addressCountry: 'CZ',
        },
        taxID: org.dic,
        vatID: org.dic,
        identifier: {
          '@type': 'PropertyValue',
          name: 'IČO',
          value: org.ico.replace(/\s/g, ''),
        },
        member: [
          {
            '@type': 'Person',
            name: org.predseda.name,
            jobTitle: 'Předseda',
            email: org.predseda.email,
            telephone: org.predseda.phone,
          },
          {
            '@type': 'Person',
            name: org.mistopredseda.name,
            jobTitle: 'Místopředseda',
            email: org.mistopredseda.email,
            telephone: org.mistopredseda.phone,
          },
        ],
      },
    }
  : null;
---
<!doctype html>
<html lang="cs">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />

    {/* Open Graph */}
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImageAbs} />
    <meta property="og:site_name" content="Startovací Hub Klecany" />
    <meta property="og:locale" content="cs_CZ" />

    {/* Twitter Card */}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageAbs} />

    {/* Canonical + favicons + manifest */}
    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/svg+xml" href={withBase('/favicon.svg')} />
    <link rel="alternate icon" href={withBase('/favicon.ico')} sizes="16x16 32x32" />
    <link rel="apple-touch-icon" href={withBase('/apple-touch-icon.png')} />
    <link rel="manifest" href={withBase('/manifest.webmanifest')} />

    {/* Sitemap hint for some crawlers */}
    <link rel="sitemap" type="application/xml" href={withBase('/sitemap-index.xml')} />

    <title>{title}</title>

    {/* Structured data: Organization (site-wide) */}
    {orgJsonLd && (
      <script type="application/ld+json" set:html={JSON.stringify(orgJsonLd)} />
    )}

    {/* Fallback for JS-off readers: the reveal system hides the
        word-reveal host element until the script splits the text. If
        the script never runs, the element must stay visible. */}
    <noscript>
      <style>{`[data-reveal-words]:not([data-split="done"]) { opacity: 1 !important; }`}</style>
    </noscript>
  </head>
  <body class="osa-body">
    <Header variant={headerVariant} showRoleChip={showRoleChip} activeRole={activeRole} />
    <slot />
    <Footer />
    <RevealOnScroll />

    {/*
     * Czech typographer: binds single-letter prepositions / conjunctions to
     * the following word with a non-breaking space so they never end up
     * orphaned at the end of a line. Covers k, s, v, z, o, u, a, i (both
     * cases). Walks text nodes once after load; skips code/pre/script/
     * style/textarea plus anything marked [data-no-typograf].
     */}
    <script is:inline>
      (function () {
        var SKIP = { SCRIPT: 1, STYLE: 1, CODE: 1, PRE: 1, TEXTAREA: 1, KBD: 1, SAMP: 1 };
        var RE = /(^|[\s(\[„“"\u2018\u201C\u201A\u201E])([kKsSvVzZoOuUiIaA])[ \t]+(?=\S)/g;
        function run() {
          var walker = document.createTreeWalker(document.body, NodeFilter.SHOW_TEXT, {
            acceptNode: function (node) {
              var p = node.parentNode;
              while (p && p !== document.body) {
                if (SKIP[p.nodeName]) return NodeFilter.FILTER_REJECT;
                if (p.hasAttribute && p.hasAttribute('data-no-typograf')) return NodeFilter.FILTER_REJECT;
                p = p.parentNode;
              }
              return RE.test(node.nodeValue) ? NodeFilter.FILTER_ACCEPT : NodeFilter.FILTER_REJECT;
            },
          });
          var n;
          while ((n = walker.nextNode())) {
            n.nodeValue = n.nodeValue.replace(RE, '$1$2\u00A0');
          }
        }
        if (document.readyState === 'loading') {
          document.addEventListener('DOMContentLoaded', run);
        } else {
          run();
        }
      }());
    </script>
  </body>
</html>
<style is:global>
  *, *::before, *::after { box-sizing: border-box; }
  html { background: var(--bg, var(--k-0)); color: var(--fg, var(--k-100)); }
  body { margin: 0; font-family: var(--font-sans); font-size: var(--text-md); line-height: var(--lh-normal); }
  a { color: inherit; text-decoration: none; }
  ul, ol { margin: 0; padding: 0; list-style: none; }
  img, svg { display: block; max-width: 100%; }
  button { font: inherit; color: inherit; background: none; border: 0; padding: 0; cursor: pointer; }
  @media (prefers-reduced-motion: reduce) {
    *, *::before, *::after { transition-duration: 0.01ms !important; animation-duration: 0.01ms !important; }
  }
</style>
