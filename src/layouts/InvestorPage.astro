---
/*
 * InvestorPage , samostatný layout pod-webu /investori/ (Podklady pro
 * investory, záměr VPD1). Nepoužívá hub Header/Footer ani JSON-LD;
 * sdílí tokens.css (paleta, typografie) + vlastní investor.css.
 *
 * Brána: klientská kontrola localStorage otisku proti allowlistu
 * (utils/investorAuth.ts). Gated stránky se před ověřením nevykreslí
 * (html.inv-wait) a bez platného otisku přesměrují na login s ?next=.
 * Měkká ochrana, viz poznámka v investorAuth.ts.
 */
import '../styles/tokens.css';
import '../styles/investor.css';
import { withBase } from '../utils/url';
import { INVESTOR_ACCESS, INVESTOR_AUTH_KEY } from '../utils/investorAuth';
import meta from '../data/investori/meta.json';
import Lightbox from '../components/Lightbox.astro';

interface Props {
  title: string;
  active?: 'zamer' | 'vypocty' | 'scenare' | 'poznamky' | 'smlouvy';
  gate?: boolean;
  /* Záměr (.vz vzhled zrcadla) nese vlastní spodní verzi (.vzver), proto si
     na něm sdílenou plum patičku potlačíme. */
  bareFooter?: boolean;
}

const { title, active, gate = true, bareFooter = false } = Astro.props;

const loginUrl = withBase('/investori/');
/* Menu: jen tři hlavní oddíly. „Koncept smlouvy" a „Poznámky" jsou z menu
   vyřazené (rozhodnutí klienta 2026-06-13, zatím nepodstatné); stránky
   zůstávají dostupné přímo přes URL, jen nejsou v navigaci. */
const nav = [
  { id: 'zamer', href: withBase('/investori/zamer/'), label: 'Investiční záměr' },
  { id: 'vypocty', href: withBase('/investori/udaje-a-vypocty/'), label: 'Údaje & výpočty' },
  { id: 'scenare', href: withBase('/investori/scenare/'), label: 'Scénáře' },
];
---
<!doctype html>
<html lang="cs" class={gate ? 'inv-wait' : undefined}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1,viewport-fit=cover" />
    <meta name="robots" content="noindex, nofollow" />
    <meta name="description" content="Podklady pro investory, záměr VPD. Přístup jen pro přihlášené." />
    <link rel="icon" type="image/svg+xml" href={withBase('/favicon.svg')} />
    <title>{title}</title>
    {gate && (
      <script is:inline define:vars={{ allow: INVESTOR_ACCESS, key: INVESTOR_AUTH_KEY, loginUrl }}>
        /* Synchronně před vykreslením: bez platného otisku ven na login. */
        (function () {
          var ok = false;
          try { ok = allow.indexOf(localStorage.getItem(key)) !== -1; } catch (e) {}
          if (!ok) {
            location.replace(loginUrl + '?next=' + encodeURIComponent(location.pathname + location.hash));
          } else {
            document.documentElement.classList.remove('inv-wait');
          }
        })();
      </script>
    )}
    <style is:inline>html.inv-wait body { visibility: hidden; }</style>
    <script is:inline>
      /* Reveal-on-scroll jen tam, kde to dává smysl a kde to nezablikne:
         synchronně v <head> zapneme skrytý výchozí stav, observer (na konci
         body) ho po vstupu do viewportu odhalí. Bez JS / s reduced-motion
         zůstává obsah rovnou viditelný. */
      (function () {
        try {
          var rm = window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches;
          if (!rm && 'IntersectionObserver' in window) {
            document.documentElement.classList.add('inv-anim');
          }
        } catch (e) {}
      })();
    </script>
  </head>
  <body class="inv-body">
    <header class="inv-top">
      <div class="inv-top__inner">
        <a class="inv-top__brand" href={gate ? withBase('/investori/zamer/') : loginUrl}>
          <span>Podklady pro investory</span>
        </a>
        {gate && (
          <nav class="inv-top__nav" aria-label="Sekce podkladů">
            {nav.map((n) => (
              <a href={n.href} aria-current={active === n.id ? 'page' : undefined}>{n.label}</a>
            ))}
            <button type="button" class="inv-top__logout" data-inv-logout>Odhlásit se</button>
          </nav>
        )}
      </div>
    </header>

    <main class="inv-main" id="main">
      <slot />
    </main>

    {!bareFooter && (
      <footer class="inv-footer">
        <div class="inv-footer__inner">
          <span class="inv-footer__badge" data-no-typograf>{meta.badge}</span>
          <span>{meta.aktualizace}</span>
          <span class="inv-footer__spacer"></span>
          <span>Podklady pro jednání o spolupráci, nejde o veřejnou nabídku.</span>
          <a href={withBase('/')}>startovacihub.cz</a>
        </div>
      </footer>
    )}

    {gate && (
      <script is:inline define:vars={{ key: INVESTOR_AUTH_KEY, loginUrl }}>
        (function () {
          var btn = document.querySelector('[data-inv-logout]');
          if (!btn) return;
          btn.addEventListener('click', function () {
            try { localStorage.removeItem(key); } catch (e) {}
            location.href = loginUrl;
          });
        })();
      </script>
    )}

    <script is:inline>
      (function () {
        if (!document.documentElement.classList.contains('inv-anim')) return;
        var els = document.querySelectorAll('.inv-hero, .inv-section');
        if (!els.length || !('IntersectionObserver' in window)) {
          document.documentElement.classList.remove('inv-anim');
          return;
        }
        var io = new IntersectionObserver(function (entries) {
          entries.forEach(function (e) {
            if (e.isIntersecting) { e.target.classList.add('is-in'); io.unobserve(e.target); }
          });
        }, { rootMargin: '0px 0px -8% 0px', threshold: 0.04 });
        els.forEach(function (el) { io.observe(el); });
      })();
    </script>

    <Lightbox />
    <script is:inline>
      (function () {
        /* 1) Zvětšitelné obrázky: označíme všechny investorské figury a zóny
              atributy data-lb a probudíme sdílený Lightbox (na pod-webu není
              ViewTransitions, takže bind ručně vyvoláme astro:page-load). */
        function tag(el, src, alt, group) {
          if (!el || el.hasAttribute('data-lb')) return;
          el.setAttribute('data-lb', '');
          el.setAttribute('data-lb-src', src);
          el.setAttribute('data-lb-alt', alt || '');
          el.setAttribute('data-lb-group', group);
          el.classList.add('is-zoomable');
        }
        document.querySelectorAll('.inv-figure').forEach(function (fig) {
          var img = fig.querySelector('img'); if (!img) return;
          var cap = fig.querySelector('figcaption');
          var grp = (fig.closest('.inv-section') && fig.closest('.inv-section').id) || 'inv';
          tag(fig, img.src, img.getAttribute('alt') || (cap ? cap.textContent.trim() : ''), grp);
        });
        document.querySelectorAll('.inv-zone__img').forEach(function (img) {
          var grp = (img.closest('.inv-section') && img.closest('.inv-section').id) || 'inv';
          tag(img, img.src, img.getAttribute('alt') || '', grp);
        });
        try { document.dispatchEvent(new Event('astro:page-load')); } catch (e) {}

        /* 2) Vodorovný scroll široké tabulky: rámeček se šipkami + okrajové stíny,
              aktivní jen když tabulka přetéká. */
        function arrow(dir) {
          var pts = dir === 'prev' ? '15 18 9 12 15 6' : '9 18 15 12 9 6';
          return '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="' + pts + '"/></svg>';
        }
        document.querySelectorAll('.inv-table-wrap').forEach(function (wrap) {
          if (wrap.closest('.inv-tscroll')) return;
          var box = document.createElement('div');
          box.className = 'inv-tscroll';
          wrap.parentNode.insertBefore(box, wrap);
          box.appendChild(wrap);
          function mk(dir, label) {
            var b = document.createElement('button');
            b.type = 'button';
            b.className = 'inv-tscroll__btn inv-tscroll__btn--' + dir;
            b.setAttribute('aria-label', label);
            b.innerHTML = arrow(dir);
            return b;
          }
          var prev = mk('prev', 'Posunout tabulku vlevo');
          var next = mk('next', 'Posunout tabulku vpravo');
          box.appendChild(prev);
          box.appendChild(next);
          function update() {
            var max = wrap.scrollWidth - wrap.clientWidth;
            var x = wrap.scrollLeft;
            box.classList.toggle('is-scrollable', max > 4);
            box.classList.toggle('at-start', x <= 2);
            box.classList.toggle('at-end', x >= max - 2);
          }
          prev.addEventListener('click', function () { wrap.scrollBy({ left: -Math.round(wrap.clientWidth * 0.8), behavior: 'smooth' }); });
          next.addEventListener('click', function () { wrap.scrollBy({ left: Math.round(wrap.clientWidth * 0.8), behavior: 'smooth' }); });
          wrap.addEventListener('scroll', update, { passive: true });
          window.addEventListener('resize', update);
          update();
        });
      })();
    </script>
  </body>
</html>
<style is:global>
  *, *::before, *::after { box-sizing: border-box; }
  html { scroll-behavior: smooth; }
  body {
    margin: 0;
    font-family: var(--font-sans);
    font-size: var(--text-md);
    line-height: var(--lh-normal);
    color: var(--fg);
    font-feature-settings: "kern" 1, "liga" 1, "calt" 1, "ss01" 1;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
    text-rendering: optimizeLegibility;
  }
  img, svg { display: block; max-width: 100%; }
  ::selection { background: var(--accent); color: var(--accent-on); }
  /* Lightbox zamkne scroll pozadí (na pod-webu není kit.css, kde to žije jinak) */
  html.osa-nav-lock, html.osa-nav-lock body { overflow: hidden; }
</style>
