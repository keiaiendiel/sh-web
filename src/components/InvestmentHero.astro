---
/*
 * Aktuálně: Záměr VPD - Investment Call.
 *
 * Landing teaser for the VPD investment call. Every financial figure still
 * sits inside a mustard .draft wrapper: numbers on this surface have not been
 * signed off by Marek Semerád yet, so the wash makes it obvious which values
 * are provisional.
 *
 * Motion vocabulary:
 *   - Copy and chart blocks fade in on [data-reveal] with a short stagger.
 *   - Each numeric figure rolls up from 0 via [data-count-to] using the
 *     shared counter observer in RevealOnScroll.astro. Formats used:
 *       int         for m², rok, počet bytů, počet jednotek
 *       percent     for ROI, IRR, % znalecké hodnoty
 *       money-mkc   for investice v mil. Kč (formatter suffixes " mil. Kč")
 *     Fallback text inside each count span matches the finished format so
 *     reduced-motion users see the final value without the animation.
 *
 * The block carries a SINGLE CTA that links into the matching aktualita
 * (src/content/aktuality/vpd-hledame-strategickeho-partnera.mdx). The
 * article is where the full narrative lives. This section's job on the
 * landing is to plant the claim and route the reader into the long-form piece.
 *
 * `hideVpdLink` prop: when the component is embedded on /projekty/vpd/
 * itself, the "O VPD" CTA would self-link, so it is suppressed.
 *
 * To activate for a public launch:
 *   1. Confirm each .draft figure with Marek Semerád. Reconcile with the
 *      PDF-verified numbers used in the aktualita body (the two sources
 *      currently disagree on IRR / ROI, see Known issues in CLAUDE.md).
 *   2. Strip the <span class="draft"> wrappers (keep the inner value).
 *   3. No aria-disabled to remove and no PDF to wire; the CTA already
 *      points into the canonical article.
 */
import { withBase } from '../utils/url';
interface Props { hideVpdLink?: boolean; }
const { hideVpdLink = false } = Astro.props;
// "Celý článek" now routes to the bespoke /zamer-vpd/ landing instead of
// the aktualita. The aktualita was decommissioned once the dedicated
// investor page went live.
const articleHref = withBase('/zamer-vpd/');
---
<section class="osa-ih section" aria-labelledby="ih-title">
  <div class="container-wide osa-ih__grid">
    <header class="osa-ih__header">
      <span class="osa-eyebrow" data-reveal>Aktuálně · Záměr VPD</span>
      <h2 id="ih-title" class="osa-h1 osa-ih__title" data-reveal>
        Hledáme strategického partnera pro revitalizaci
        <span class="draft" data-review="pending"><span data-count-to="83327" data-count-format="int">83&nbsp;327</span>&nbsp;m²</span>
        na prahu metropole.
      </h2>
      <p class="osa-body osa-ih__lede" data-reveal data-reveal-delay="1">
        Od opuštěných kasáren k živé městské čtvrti. Záměr plně v souladu s platným územním plánem.
      </p>
    </header>

    <aside class="osa-ih__chart" aria-hidden="true" data-reveal data-reveal-delay="2">
      <div class="osa-ih__chart-grid">
        {Array.from({ length: 28 }).map(() => <span></span>)}
      </div>
      <p class="osa-mono osa-ih__chart-cap">
        Schematický pohled na areál · <span class="draft" data-review="pending"><span data-count-to="12" data-count-format="int">12</span>&nbsp;km od centra Prahy</span>
      </p>
    </aside>

    <dl class="osa-ih__metrics">
      <div data-reveal data-reveal-delay="1">
        <dt class="osa-eyebrow">Lokalita</dt>
        <dd><span class="draft" data-review="pending">Horní kasárna Klecany, <span data-count-to="12" data-count-format="int">12</span>&nbsp;km od centra Prahy</span></dd>
      </div>
      <div data-reveal data-reveal-delay="2">
        <dt class="osa-eyebrow">Potenciál</dt>
        <dd><span class="draft" data-review="pending"><span data-count-to="10" data-count-format="int">10</span>+&nbsp;mld.&nbsp;Kč hrubý zisk, <span data-count-to="88946" data-count-format="int">88&nbsp;946</span>&nbsp;m² ČPP nových bytů, cca <span data-count-to="1572" data-count-format="int">1&nbsp;572</span>&nbsp;bytů</span></dd>
      </div>
      <div data-reveal data-reveal-delay="3">
        <dt class="osa-eyebrow">Práva</dt>
        <dd><span class="draft" data-review="pending">Smluvně do roku 2039 (právo odkupu, užívání, stavby); kupní cena na úrovni <span data-count-to="82" data-count-format="percent">82&nbsp;%</span> znalecké hodnoty</span></dd>
      </div>
      <div data-reveal data-reveal-delay="3">
        <dt class="osa-eyebrow">Krok 1 · Startovací hub</dt>
        <dd><span class="draft" data-review="pending"><span data-count-to="331" data-count-format="int">331</span>&nbsp;jednotek 1+kk, investice cca <span data-count-to="285" data-count-format="money-mkc">285&nbsp;mil.&nbsp;Kč</span>, ROI <span data-count-to="141" data-count-format="percent">141&nbsp;%</span>, IRR <span data-count-to="78" data-count-format="percent">78&nbsp;%</span></span></dd>
    </div>
    </dl>

    <div class="osa-ih__ctas" data-reveal data-reveal-delay="3">
      <a class="btn btn--primary" href={articleHref}>Celý článek</a>
      {!hideVpdLink && (
        <a class="btn btn--ghost" href={withBase('/projekty/vpd/')}>O VPD</a>
      )}
    </div>
  </div>
</section>

<style>
  .osa-ih {
    border-top: 1px solid var(--rule);
    border-bottom: 1px solid var(--rule);
  }
  .osa-ih__grid {
    display: grid;
    grid-template-columns: 1.2fr 1fr;
    grid-template-areas:
      "header  chart"
      "metrics chart"
      "ctas    chart";
    column-gap: var(--space-7);
    row-gap: var(--space-5);
    align-items: start;
  }
  .osa-ih__header  { grid-area: header; display: grid; gap: var(--space-4); align-self: start; }
  .osa-ih__chart   { grid-area: chart; align-self: center; }
  .osa-ih__metrics { grid-area: metrics; }
  .osa-ih__ctas    { grid-area: ctas; }
  @media (max-width: 860px) {
    /* Mobile order per client: heading, sub, chart, metrics, CTAs. */
    .osa-ih__grid {
      grid-template-columns: 1fr;
      grid-template-areas:
        "header"
        "chart"
        "metrics"
        "ctas";
      row-gap: var(--space-5);
    }
  }
  .osa-ih__title  { margin: 0; }
  .osa-ih__lede   { margin: 0; color: var(--fg-muted); max-width: 56ch; }
  .osa-ih__metrics {
    display: grid;
    gap: var(--space-4);
    margin: 0;
    padding: var(--space-5) 0;
    border-top: 1px solid var(--rule);
    border-bottom: 1px solid var(--rule);
  }
  .osa-ih__metrics > div {
    display: grid;
    grid-template-columns: 160px 1fr;
    gap: var(--space-4);
  }
  .osa-ih__metrics dt { color: var(--fg-muted); }
  .osa-ih__metrics dd {
    margin: 0;
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    color: var(--fg);
    line-height: var(--lh-normal);
  }
  .osa-ih__ctas { display: flex; flex-wrap: wrap; gap: var(--space-3); }
  @media (max-width: 560px) {
    /* Tight metrics + flexible CTA wrap on small screens. The dt column
       collapses above the dd so the numbers stay on their own lines. */
    .osa-ih__metrics > div {
      grid-template-columns: 1fr;
      gap: var(--space-2);
    }
    .osa-ih__metrics dd { font-size: var(--text-xs); }
  }

  /* draft flag: mustard wash highlighting values awaiting confirmation. No underline. */
  .draft {
    background: color-mix(in oklab, var(--c-mustard) 28%, transparent);
    padding: 0 4px;
    border-radius: 0;
    text-decoration: none;
  }

  .osa-ih__chart {
    aspect-ratio: 4 / 3;
    border: 1px solid var(--rule);
    padding: var(--space-5);
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    background: var(--bg);
  }
  .osa-ih__chart-grid {
    display: grid;
    grid-template-columns: repeat(7, 1fr);
    gap: 1px;
    flex: 1;
    background: var(--rule);
  }
  .osa-ih__chart-grid > span {
    background: var(--bg);
    aspect-ratio: 1 / 1;
  }
  /* a few cells use a diagonal motif to hint architecture */
  .osa-ih__chart-grid > span:nth-child(3n) {
    background: linear-gradient(60deg, var(--bg) 48%, var(--fg) 49%, var(--fg) 51%, var(--bg) 52%);
  }
  .osa-ih__chart-cap {
    color: var(--fg-muted);
    font-size: var(--text-2xs);
    margin: var(--space-3) 0 0;
  }
</style>
