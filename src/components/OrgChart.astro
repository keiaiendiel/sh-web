---
/*
 * Organizační struktura - minimal typographic diagram.
 * Three numbered rows, each listing the bodies within that tier.
 * Pure HTML + CSS; no SVG wrangling. Zero JS.
 */
const tiers = [
  {
    n: '01',
    label: 'Kolektivní orgány',
    note: 'Rozhodují konsensem.',
    items: ['Členský sněm', 'Všečlenské zasedání', 'Orgán pro nábor a příspěvky', 'Projektová rada'],
  },
  {
    n: '02',
    label: 'Statutární orgán',
    note: 'Zastupuje spolek navenek.',
    items: ['Představenstvo', 'Předseda', 'Místopředseda'],
  },
  {
    n: '03',
    label: 'Autonomní projekty',
    note: 'Decentralizovaná výkonná úroveň.',
    items: ['Výletná', 'Gas Town', 'Kreativní prostory', 'Metro Farm', 'Junktown', 'a další'],
  },
];
---
<section class="osa-org">
  {tiers.map(t => (
    <div class="osa-org__row">
      <div class="osa-org__left">
        <span class="osa-mono osa-org__n">{t.n}</span>
        <div>
          <h3 class="osa-h3 osa-org__label">{t.label}</h3>
          <p class="osa-body-sm osa-org__note">{t.note}</p>
        </div>
      </div>
      <ul class="osa-org__items" role="list">
        {t.items.map(i => <li class="osa-org__item">{i}</li>)}
      </ul>
    </div>
  ))}
</section>

<style>
  .osa-org {
    border-top: 1px solid var(--rule);
    border-bottom: 1px solid var(--rule);
  }
  .osa-org__row {
    display: grid;
    grid-template-columns: 280px 1fr;
    gap: var(--space-6);
    padding: var(--space-6) 0;
    border-top: 1px solid var(--rule);
  }
  .osa-org__row:first-child { border-top: 0; }
  @media (max-width: 720px) {
    .osa-org__row { grid-template-columns: 1fr; gap: var(--space-4); }
  }

  .osa-org__left {
    display: grid;
    grid-template-columns: 48px 1fr;
    gap: var(--space-3);
    align-items: baseline;
  }
  .osa-org__n     { color: var(--fg-muted); font-size: var(--text-xs); letter-spacing: var(--tracking-wider); }
  .osa-org__label { margin: 0; }
  .osa-org__note  { margin: var(--space-1) 0 0; color: var(--fg-muted); }

  .osa-org__items {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
    gap: 0;
    align-content: start;
    align-self: start;
  }
  .osa-org__item {
    padding: var(--space-3) var(--space-4);
    border-left: 1px solid var(--rule);
    font: 600 var(--text-md) / var(--lh-snug) var(--font-sans);
    letter-spacing: var(--tracking-tight);
    color: var(--fg);
  }
  .osa-org__item:first-child { border-left: 0; }
  @media (max-width: 720px) {
    .osa-org__item { border-left: 0; border-top: 1px solid var(--border-muted); padding-inline: 0; }
    .osa-org__item:first-child { border-top: 0; }
  }
</style>
