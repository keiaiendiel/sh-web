---
interface Props {
  size?: string;
  class?: string;
}
const { size = '1em', class: className } = Astro.props;
---
<svg
  xmlns="http://www.w3.org/2000/svg"
  viewBox="0 0 393 341"
  width={size}
  height={size}
  aria-hidden="true"
  class={className}
  style={`display:inline-block;flex-shrink:0;color:currentColor`}>
  <path d="M195 0 H393 V341 H0 Z" fill="currentColor" />
</svg>
