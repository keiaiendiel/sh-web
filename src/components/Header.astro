---
import { withBase } from '../utils/url';
interface Props { variant?: 'light' | 'dark'; }
const { variant = 'light' } = Astro.props;
const nav = [
  { path: '/',            label: 'Úvod' },
  { path: '/o-spolku/',   label: 'O spolku' },
  { path: '/projekty/',   label: 'Projekty' },
  { path: '/aktuality/',  label: 'Aktuality' },
  { path: '/zapojte-se/', label: 'Zapojte se' },
  { path: '/kontakty/',   label: 'Kontakty' },
];
const current = Astro.url.pathname;
const isActive = (path: string) => {
  const full = withBase(path);
  return path === '/' ? current === full : current.startsWith(full);
};
---
<header class:list={['osa-header', { 'osa-dark': variant === 'dark' }]}>
  <div class="container-wide osa-header__inner">
    <a href={withBase('/')} class="osa-header__brand" aria-label="Občanské sdružení Alternativa II - domů">
      <img src={withBase('/logo/OSA-Logo-Black.svg')} alt="" aria-hidden="true" class="osa-header__logo osa-header__logo--light" />
      <img src={withBase('/logo/OSA-Logo-White.svg')} alt="" aria-hidden="true" class="osa-header__logo osa-header__logo--dark" />
    </a>

    <nav class="osa-header__nav" aria-label="Hlavní navigace">
      {nav.map(n => (
        <a
          href={withBase(n.path)}
          class="osa-header__link"
          aria-current={isActive(n.path) ? 'page' : undefined}>{n.label}</a>
      ))}
    </nav>
  </div>
  <div class="rule" role="presentation"></div>
</header>

<style>
  .osa-header {
    position: sticky; top: 0; z-index: 20;
    background: var(--bg);
    color: var(--fg);
  }
  .osa-header.osa-dark {
    background: var(--bg);
    color: var(--fg);
  }
  /* Hide the hairline rule when the header merges into a dark hero: the hero's own edge is enough. */
  .osa-header.osa-dark .rule { display: none; }
  .osa-header__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-6);
    padding: 12px var(--gutter);
  }
  .osa-header__brand {
    display: inline-flex;
    align-items: center;
    color: var(--fg);
    line-height: 0;
  }
  .osa-header__logo {
    display: block;
    width: 28px;
    height: 28px;
  }
  /* swap logo by theme: light header shows Black; dark parent surfaces show White */
  .osa-header__logo--dark  { display: none; }
  .osa-dark .osa-header__logo--light { display: none; }
  .osa-dark .osa-header__logo--dark  { display: block; }

  .osa-header__nav {
    display: flex;
    gap: var(--space-6);
  }
  .osa-header__link {
    font: 600 var(--text-sm) / 1 var(--font-sans);
    color: var(--fg-muted);
    padding: 6px 0;
    border-bottom: 1px solid transparent;
    transition: color var(--dur-fast) linear, border-color var(--dur-fast) linear;
  }
  .osa-header__link[aria-current='page'] {
    color: var(--fg);
    border-bottom-color: var(--fg);
  }
  .osa-header__link:hover {
    opacity: 1;
    color: var(--fg);
  }
  @media (max-width: 720px) {
    .osa-header__nav { display: none; }
    .osa-header__logo { width: 24px; height: 24px; }
  }
</style>
