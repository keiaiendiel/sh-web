---
import { withBase } from '../utils/url';
import OsaGlyph from './OsaGlyph.astro';

interface Props {
  variant?: 'light' | 'dark';
}
const { variant = 'light' } = Astro.props;

/* Site-wide nav. Order locked per SH_Web_Plan.md ř. 211 a Site_Copy § 0.2.
   Rezervace nepatří do nav array, je to samostatný CTA chip vpravo. */
type DropdownItem = { label: string; href: string };
type NavItem = {
  path: string;
  label: string;
  dropdown?: { items: DropdownItem[] };
};

const nav: NavItem[] = [
  {
    path: '/ubytovani/',
    label: 'Ubytování',
    dropdown: {
      items: [
        { label: 'Co-living',          href: '/ubytovani/#ub-coliving-title' },
        { label: 'Privátní apartmány', href: '/ubytovani/#ub-privatni-title' },
      ],
    },
  },
  {
    path: '/coworking/',
    label: 'Coworking',
    dropdown: {
      items: [
        { label: 'Coworkingový sál',  href: '/coworking/#cw-sal' },
        { label: 'Fixní stůl',        href: '/coworking/#cw-fix' },
        { label: 'Sdílená kancelář',  href: '/coworking/#cw-shared' },
        { label: 'Zasedací místnost', href: '/coworking/#cw-zasedacka' },
        { label: 'Ateliéry a dílny',  href: '/coworking/#cw-ateliery-dilny' },
      ],
    },
  },
  {
    path: '/komunita/',
    label: 'Komunita',
    dropdown: {
      items: [
        { label: 'Wellness', href: '/komunita/#km-wellness' },
        { label: 'Park',     href: '/komunita/#km-park' },
        { label: 'Gastro',   href: '/komunita/#km-gastro' },
        { label: 'Klubovna', href: '/komunita/#km-klubovna' },
      ],
    },
  },
  { path: '/okoli/',     label: 'Okolí' },
  { path: '/doprava/',   label: 'Doprava' },
  { path: '/stipendia/', label: 'Stipendia' },
];

const current = Astro.url.pathname;
const isActive = (path: string) => {
  const full = withBase(path);
  return path === '/' ? current === full : current.startsWith(full);
};
const reservationActive = isActive('/rezervace/');
---
<header class:list={['hub-header', { 'hub-header--dark': variant === 'dark' }]}>
  <div class="hub-header__bar">
    <a href={withBase('/')} class="hub-header__brand" aria-label="Startovací Hub Klecany, domů">
      <span class="hub-header__glyph" aria-hidden="true"><OsaGlyph size="13px" /></span>
      <span class="hub-header__wordmark">Startovací Hub</span>
    </a>

    <nav class="hub-header__nav" aria-label="Hlavní navigace">
      {nav.map((n) => (
        n.dropdown ? (
          <div class="hub-header__nav-item hub-header__nav-item--has-dropdown">
            <a
              href={withBase(n.path)}
              class="hub-header__link"
              aria-current={isActive(n.path) ? 'page' : undefined}
              aria-haspopup="true">
              {n.label}
              <span class="hub-header__caret" aria-hidden="true">▾</span>
            </a>
            <div class="hub-header__dropdown" role="menu">
              <ul class="hub-header__dd-list">
                {(n.dropdown.items ?? []).map((it) => (
                  <li><a href={withBase(it.href)} role="menuitem">{it.label}</a></li>
                ))}
              </ul>
            </div>
          </div>
        ) : (
          <a
            href={withBase(n.path)}
            class="hub-header__link"
            aria-current={isActive(n.path) ? 'page' : undefined}>{n.label}</a>
        )
      ))}
      <a
        href={withBase('/rezervace/')}
        class="hub-header__cta"
        aria-current={reservationActive ? 'page' : undefined}>Rezervace</a>
    </nav>

    <a
      href={withBase('/rezervace/')}
      class="hub-header__cta hub-header__cta--mobile"
      aria-current={reservationActive ? 'page' : undefined}>Rezervace</a>

    <button
      class="hub-header__burger"
      type="button"
      aria-controls="hub-drawer"
      aria-expanded="false"
      aria-label="Otevřít menu">
      <span class="hub-header__burger-box" aria-hidden="true">
        <span></span><span></span><span></span>
      </span>
    </button>
  </div>
  <div class="hub-header__rule" role="presentation"></div>

  <div id="hub-drawer" class="hub-drawer" role="dialog" aria-modal="true" aria-label="Hlavní navigace" hidden>
    <nav class="hub-drawer__nav" aria-label="Mobilní navigace">
      {nav.map((n) => (
        n.dropdown ? (
          <details class="hub-drawer__group">
            <summary class="hub-drawer__link hub-drawer__link--summary">
              {n.label}
              <span class="hub-drawer__caret" aria-hidden="true">▾</span>
            </summary>
            <div class="hub-drawer__sub">
              <a href={withBase(n.path)} class="hub-drawer__sublink hub-drawer__sublink--overview">Všechno z {n.label.toLowerCase()} →</a>
              {n.dropdown.items.map((it) => (
                <a href={withBase(it.href)} class="hub-drawer__sublink">{it.label}</a>
              ))}
            </div>
          </details>
        ) : (
          <a
            href={withBase(n.path)}
            class="hub-drawer__link"
            aria-current={isActive(n.path) ? 'page' : undefined}>{n.label}</a>
        )
      ))}
      <a
        href={withBase('/rezervace/')}
        class="hub-drawer__link hub-drawer__link--cta"
        aria-current={reservationActive ? 'page' : undefined}>Rezervace</a>
    </nav>
  </div>
</header>

<script is:inline>
  (function () {
    var btn = document.querySelector('.hub-header__burger');
    var panel = document.getElementById('hub-drawer');
    if (!btn || !panel) return;

    function setOpen(open) {
      btn.setAttribute('aria-expanded', open ? 'true' : 'false');
      btn.setAttribute('aria-label', open ? 'Zavřít menu' : 'Otevřít menu');
      if (open) {
        panel.hidden = false;
        requestAnimationFrame(function () { panel.classList.add('open'); });
        document.documentElement.classList.add('osa-nav-lock');
      } else {
        panel.classList.remove('open');
        document.documentElement.classList.remove('osa-nav-lock');
        setTimeout(function () {
          if (btn.getAttribute('aria-expanded') === 'false') panel.hidden = true;
        }, 280);
      }
    }

    btn.onclick = function (e) {
      e.stopPropagation();
      setOpen(btn.getAttribute('aria-expanded') !== 'true');
    };

    document.addEventListener('keydown', function (e) {
      if (e.key === 'Escape' && btn.getAttribute('aria-expanded') === 'true') setOpen(false);
    });

    panel.addEventListener('click', function (e) {
      if (e.target.closest('a')) setOpen(false);
    });
  }());
</script>

<style>
  .hub-header {
    position: sticky; top: 0; z-index: 30;
    background: var(--bg);
    color: var(--fg);
  }
  .hub-header--dark {
    background: var(--k-100);
    color: var(--k-0);
  }
  :global(html.osa-nav-lock) .hub-header {
    position: fixed;
    top: 0; left: 0; right: 0;
    background: var(--bg);
    color: var(--fg);
    z-index: 30;
  }
  :global(html.osa-nav-lock) .hub-header .hub-header__rule { display: none; }
  .hub-header--dark .hub-header__rule { display: none; }
  .hub-header__rule {
    height: 1px;
    background: var(--k-10);
  }

  .hub-header__bar {
    display: flex;
    align-items: center;
    gap: var(--space-5);
    padding: 10px var(--gutter);
    max-width: var(--container-wide);
    margin: 0 auto;
  }

  .hub-header__brand {
    display: inline-flex;
    align-items: flex-end;
    gap: 6px;
    color: inherit;
    font-family: var(--font-sans);
    font-weight: 600;
    font-size: var(--text-base);
    letter-spacing: var(--tracking-tight);
    line-height: 1;
    text-decoration: none;
    position: relative;
    z-index: 35;
    flex-shrink: 0;
  }
  .hub-header__glyph { display: inline-flex; line-height: 0; margin-bottom: 1px; }
  .hub-header__wordmark { white-space: nowrap; }

  .hub-header__nav {
    display: flex;
    align-items: center;
    gap: var(--space-5);
    margin-left: auto;
  }
  .hub-header__nav-item {
    position: relative;
    display: flex;
    align-items: center;
  }
  .hub-header__link {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    font: 500 var(--text-sm) / 1 var(--font-sans);
    color: var(--fg);
    padding: 4px 0;
    border-bottom: 1px solid transparent;
    text-decoration: none;
    transition: color var(--dur-fast) linear, border-color var(--dur-fast) linear;
    white-space: nowrap;
  }
  .hub-header--dark .hub-header__link { color: rgba(255, 255, 255, 0.9); }
  .hub-header__link[aria-current='page'] {
    color: var(--accent);
    border-bottom-color: var(--accent);
  }
  .hub-header__link:hover { color: var(--accent); }
  .hub-header--dark .hub-header__link:hover,
  .hub-header--dark .hub-header__link[aria-current='page'] { color: #fff; }

  .hub-header__caret {
    font-size: 0.65em;
    line-height: 1;
    opacity: 0.55;
    transition: transform 200ms var(--ease-standard), opacity 200ms var(--ease-standard);
  }
  .hub-header__nav-item--has-dropdown:hover .hub-header__caret,
  .hub-header__nav-item--has-dropdown:focus-within .hub-header__caret {
    transform: rotate(180deg);
    opacity: 1;
  }

  /* Dropdown panel: minimalist white card, plum accent, smooth fade-in.
     Bridged 14 px gap pseudo-elementem, aby hover nezhasl při přejezdu
     ze linku na panel. Vždy flat single-column list (max 5 short items),
     šíře 220 px, anchored na levý okraj triggeru pro konzistentní vizuální
     zarovnání s nav itemem. Šíře 220 px se vždy vejde i pro nav items v
     pravé části headeru (Komunita) v 1280+ viewport (nav skrytý pod 1024). */
  .hub-header__dropdown {
    position: absolute;
    top: 100%;
    left: 0;
    min-width: 220px;
    margin-top: 14px;
    padding: 8px;
    background: var(--bg);
    color: var(--fg);
    border: 1px solid var(--border-muted);
    border-radius: var(--radius-input);
    box-shadow:
      0 12px 32px rgba(0, 0, 0, 0.10),
      0 2px 8px rgba(0, 0, 0, 0.04);
    opacity: 0;
    visibility: hidden;
    transform: translateY(-6px);
    transition:
      opacity 180ms var(--ease-standard),
      transform 180ms var(--ease-standard),
      visibility 0s linear 180ms;
    z-index: 40;
  }
  .hub-header__dropdown::before {
    /* Invisible hover bridge between trigger link and panel. */
    content: "";
    position: absolute;
    top: -14px;
    left: 0;
    right: 0;
    height: 14px;
  }
  .hub-header__nav-item--has-dropdown:hover .hub-header__dropdown,
  .hub-header__nav-item--has-dropdown:focus-within .hub-header__dropdown {
    opacity: 1;
    visibility: visible;
    transform: translateY(0);
    transition:
      opacity 180ms var(--ease-standard),
      transform 180ms var(--ease-standard),
      visibility 0s linear 0s;
  }

  .hub-header__dd-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: 1px;
  }
  .hub-header__dd-list a {
    display: block;
    padding: 10px 12px;
    font: 500 var(--text-sm) / 1.35 var(--font-sans);
    color: var(--fg);
    text-decoration: none;
    border-radius: var(--radius-input);
    transition: background 160ms ease, color 160ms ease;
    white-space: nowrap;
    letter-spacing: -0.005em;
  }
  .hub-header__dd-list a:hover,
  .hub-header__dd-list a:focus-visible {
    background: var(--accent-soft);
    color: var(--accent);
    outline: none;
  }

  /* CTA pill , Rezervace.
     Wipe pattern: outline at rest; fill rises from bottom on hover. */
  .hub-header__cta {
    position: relative;
    isolation: isolate;
    overflow: hidden;
    font: 500 var(--text-sm) / 1 var(--font-sans);
    color: inherit;
    padding: 6px 14px;
    border: 1px solid currentColor;
    border-radius: var(--radius-input);
    text-decoration: none;
    transition: color 160ms cubic-bezier(0.65, 0, 0.35, 1);
    flex-shrink: 0;
    white-space: nowrap;
  }
  .hub-header__cta::after {
    content: "";
    position: absolute;
    inset: 0;
    z-index: -1;
    clip-path: inset(100% 0 0 0);
    transition: clip-path 160ms cubic-bezier(0.65, 0, 0.35, 1);
  }
  .hub-header__cta:hover::after,
  .hub-header__cta:focus-visible::after,
  .hub-header__cta[aria-current='page']::after {
    clip-path: inset(0 0 0 0);
  }
  .hub-header--dark .hub-header__cta::after { background: #fff; }
  .hub-header--dark .hub-header__cta:hover,
  .hub-header--dark .hub-header__cta:focus-visible,
  .hub-header--dark .hub-header__cta[aria-current='page'] {
    color: var(--k-100);
    outline: none;
  }
  .hub-header:not(.hub-header--dark) .hub-header__cta { color: var(--accent); border-color: var(--accent); }
  .hub-header:not(.hub-header--dark) .hub-header__cta::after { background: var(--accent); }
  .hub-header:not(.hub-header--dark) .hub-header__cta:hover,
  .hub-header:not(.hub-header--dark) .hub-header__cta:focus-visible,
  .hub-header:not(.hub-header--dark) .hub-header__cta[aria-current='page'] {
    color: #fff;
    outline: none;
  }
  /* Mobile CTA: stejný styl jako desktop, ale ukazuje se vedle burgeru,
     ne uvnitř nav. Default skrytý, zobrazí se pod 1024px. */
  .hub-header__cta--mobile { display: none; margin-left: auto; }

  @media (prefers-reduced-motion: reduce) {
    .hub-header__cta,
    .hub-header__cta::after { transition: none; }
  }

  /* Burger */
  .hub-header__burger {
    display: none;
    width: 32px; height: 32px;
    padding: 0; margin: 0;
    background: transparent; border: 0;
    color: inherit;
    cursor: pointer;
    position: relative;
    z-index: 35;
  }
  .hub-header__burger-box {
    display: grid;
    gap: 5px;
    width: 20px;
    margin: 0 auto;
  }
  .hub-header__burger-box > span {
    display: block;
    height: 1.5px;
    background: currentColor;
    transition:
      transform 240ms cubic-bezier(0.25, 1, 0.5, 1),
      opacity 160ms linear;
    transform-origin: 50% 50%;
  }
  .hub-header__burger[aria-expanded='true'] .hub-header__burger-box > span:nth-child(1) {
    transform: translateY(6.5px) rotate(45deg);
  }
  .hub-header__burger[aria-expanded='true'] .hub-header__burger-box > span:nth-child(2) {
    opacity: 0;
  }
  .hub-header__burger[aria-expanded='true'] .hub-header__burger-box > span:nth-child(3) {
    transform: translateY(-6.5px) rotate(-45deg);
  }
  .hub-header__burger:focus-visible {
    outline: 2px solid currentColor;
    outline-offset: 2px;
  }

  /* Mobile drawer — white, spacious, minimal */
  .hub-drawer {
    position: fixed;
    inset: 0;
    z-index: 29;
    background: var(--bg);
    color: var(--fg);
    padding: calc(48px + var(--space-7)) var(--gutter) var(--space-7);
    overflow-y: auto;
    opacity: 0;
    transform: translateY(-8px);
    transition:
      opacity 220ms cubic-bezier(0.25, 1, 0.5, 1),
      transform 260ms cubic-bezier(0.25, 1, 0.5, 1);
  }
  .hub-drawer.open {
    opacity: 1;
    transform: translateY(0);
  }
  .hub-drawer__nav {
    display: grid;
    gap: 0;
    max-width: 480px;
    margin: 0 auto;
  }
  .hub-drawer__link {
    font-family: var(--font-sans);
    font-weight: 500;
    font-size: var(--text-xl);
    letter-spacing: var(--tracking-tight);
    padding: var(--space-4) 0;
    border-bottom: 1px solid var(--border-muted);
    color: var(--fg);
    text-decoration: none;
    display: block;
    transition: color 160ms ease;
  }
  .hub-drawer__link:hover { color: var(--accent); }
  .hub-drawer__link[aria-current='page'] { color: var(--accent); }

  /* Drawer accordion (mobile dropdown). */
  .hub-drawer__group {
    border-bottom: 1px solid var(--border-muted);
  }
  .hub-drawer__link--summary {
    list-style: none;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: space-between;
    border-bottom: 0;
  }
  .hub-drawer__link--summary::-webkit-details-marker { display: none; }
  .hub-drawer__caret {
    font-size: 0.55em;
    opacity: 0.45;
    transition: transform 220ms var(--ease-standard);
  }
  .hub-drawer__group[open] .hub-drawer__caret { transform: rotate(180deg); }
  .hub-drawer__sub {
    display: grid;
    gap: 2px;
    padding: 0 0 var(--space-4) var(--space-3);
    border-left: 2px solid var(--border-muted);
    margin-left: var(--space-2);
  }
  .hub-drawer__sublink {
    display: block;
    font: 400 var(--text-md) / 1.3 var(--font-sans);
    color: var(--fg-muted);
    padding: 8px var(--space-3);
    text-decoration: none;
    border-radius: var(--radius-input);
    transition: background 160ms ease, color 160ms ease;
  }
  .hub-drawer__sublink--overview {
    color: var(--accent);
    font-weight: 600;
    padding-top: var(--space-2);
    padding-bottom: var(--space-3);
  }
  .hub-drawer__sublink:hover,
  .hub-drawer__sublink:focus-visible {
    background: var(--accent-soft);
    color: var(--accent);
    outline: none;
  }
  .hub-drawer__link--cta {
    position: relative;
    isolation: isolate;
    overflow: hidden;
    margin-top: var(--space-5);
    color: #fff;
    background: var(--accent);
    padding: var(--space-4) var(--space-5);
    border: 1px solid var(--accent);
    border-radius: var(--radius-input);
    font-weight: 600;
    text-align: center;
    transition: background 200ms ease, border-color 200ms ease;
  }
  .hub-drawer__link--cta:hover,
  .hub-drawer__link--cta:focus-visible {
    background: transparent;
    color: var(--accent);
  }

  :global(html.osa-nav-lock),
  :global(html.osa-nav-lock body) { overflow: hidden; }

  /* Mobile: burger replaces nav, mobile CTA shows next to burger.
     Breakpoint raised from 720 to 1024 because 8 nav items + brand +
     status badge + CTA chip don't fit comfortably under ~1100 px. */
  @media (max-width: 1024px) {
    .hub-header__nav { display: none; }
    .hub-header__cta--mobile { display: inline-flex; align-items: center; }
    .hub-header__burger {
      display: inline-flex;
      align-items: center;
      justify-content: center;
    }
  }

  @media (min-width: 1025px) {
    .hub-drawer { display: none; }
  }

  @media (prefers-reduced-motion: reduce) {
    .hub-drawer,
    .hub-header__burger-box > span,
    .hub-header__cta { transition: none; }
  }
</style>
