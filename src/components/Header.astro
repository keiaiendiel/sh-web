---
import { withBase } from '../utils/url';
import BrandLogo from './BrandLogo.astro';
import Icon from './Icon.astro';

interface Props {
  variant?: 'light' | 'dark' | 'overlay';
}
const { variant = 'light' } = Astro.props;

/* Site-wide nav. Vše žije v off-canvas draweru (žádná desktop horizontal nav).
   „Novinky" je zatím placeholder. Rezervace nepatří do nav array , je to
   samostatný CTA chip (vpravo, odkrytý po scrollu) + zvýrazněné tlačítko
   dole v draweru. */
type NavLink = { path: string; label: string; placeholder?: boolean };

const nav: NavLink[] = [
  { path: '/ubytovani/', label: 'Ubytování' },
  { path: '/coworking/', label: 'Coworking' },
  { path: '/komunita/',  label: 'Komunita' },
  { path: '/stipendia/', label: 'Stipendia' },
  { path: '/doprava/',   label: 'Doprava' },
  { path: '/cenik/',     label: 'Ceník' },
  { path: '#',           label: 'Novinky', placeholder: true },
];

const current = Astro.url.pathname;
const isActive = (path: string) => {
  const full = withBase(path);
  return path === '/' ? current === full : current.startsWith(full);
};
const reservationActive = isActive('/rezervace/');
const isHome = current === withBase('/');
---
<header class:list={['hub-header', { 'hub-header--dark': variant === 'dark', 'hub-header--overlay': variant === 'overlay' }]} data-variant={variant}>
  <div class="hub-header__bar">
    <a
      href={withBase('/')}
      class="hub-header__brand"
      aria-label={isHome ? 'Startovací Hub Klecany, domů' : 'Zpět na Startovací Hub'}>
      <BrandLogo class="hub-header__logo" />
    </a>

    <div class="hub-header__actions">
      <a
        href={withBase('/rezervace/')}
        class="hub-header__cta hub-header__reserve osa-nolink"
        tabindex="-1"
        aria-current={reservationActive ? 'page' : undefined}>Rezervace</a>

      <button
        class="hub-header__burger"
        type="button"
        aria-controls="hub-drawer"
        aria-expanded="false"
        aria-label="Otevřít menu">
        <span class="hub-header__burger-box" aria-hidden="true">
          <span></span><span></span><span></span>
        </span>
      </button>
    </div>
  </div>
  <div class="hub-header__rule" role="presentation"></div>

  <div id="hub-drawer" class="hub-drawer" hidden>
    <div class="hub-drawer__scrim" data-drawer-close></div>
    <aside class="hub-drawer__panel" role="dialog" aria-modal="true" aria-label="Hlavní navigace">
      <div class="hub-drawer__top">
        <button class="hub-drawer__close" type="button" data-drawer-close aria-label="Zavřít menu">
          <Icon name="x" size={22} />
        </button>
      </div>

      <nav class="hub-drawer__nav" aria-label="Hlavní navigace">
        {nav.map((item) => (
          <a
            href={item.placeholder ? '#' : withBase(item.path)}
            class:list={['hub-drawer__link', { 'osa-nolink': item.placeholder }]}
            data-placeholder={item.placeholder ? '' : undefined}
            aria-current={!item.placeholder && isActive(item.path) ? 'page' : undefined}>{item.label}</a>
        ))}
      </nav>

      <div class="hub-drawer__foot">
        <a
          href={withBase('/rezervace/')}
          class="hub-drawer__reserve-btn osa-nolink"
          aria-current={reservationActive ? 'page' : undefined}>
          <span>Rezervovat</span>
          <Icon name="arrow-right" size={18} />
        </a>

        <div class="hub-drawer__divider" role="presentation"></div>

        <div class="hub-drawer__account">
          <button type="button" class="hub-drawer__acct" data-placeholder aria-label="Přihlásit se (připravujeme)">
            <Icon name="log-in" size={18} />
            <span>Přihlásit se</span>
          </button>
          <button type="button" class="hub-drawer__acct" data-placeholder aria-label="Přepnout účet (připravujeme)">
            <Icon name="arrow-left-right" size={18} />
            <span>Přepnout účet</span>
          </button>
        </div>
      </div>
    </aside>
  </div>
</header>

<script is:inline>
  /* Off-canvas drawer init. Re-runs na každém astro:page-load, protože header
     persist (transition:persist) nemusí zachovat handler napříč navigací.
     Guard přes dataset zabrání dvojitému bindu na stejném node. */
  (function () {
    function bindDrawer() {
      var btn = document.querySelector('.hub-header__burger');
      var drawer = document.getElementById('hub-drawer');
      if (!btn || !drawer) return;
      if (btn.dataset.burgerBound === '1') return;
      btn.dataset.burgerBound = '1';

      function setOpen(open) {
        btn.setAttribute('aria-expanded', open ? 'true' : 'false');
        btn.setAttribute('aria-label', open ? 'Zavřít menu' : 'Otevřít menu');
        if (open) {
          drawer.hidden = false;
          /* Force reflow, aby slide-in transition naběhl i při prvním otevření
             (toggle display:none→block + okamžitá class jinak browser zbatchuje
             a panel skočí bez animace). */
          void drawer.offsetWidth;
          drawer.classList.add('open');
          document.documentElement.classList.add('osa-nav-lock');
          var closeBtn = drawer.querySelector('.hub-drawer__close');
          if (closeBtn) setTimeout(function () { closeBtn.focus(); }, 60);
        } else {
          drawer.classList.remove('open');
          document.documentElement.classList.remove('osa-nav-lock');
          setTimeout(function () {
            if (btn.getAttribute('aria-expanded') === 'false') drawer.hidden = true;
          }, 340);
        }
      }

      btn.onclick = function (e) {
        e.stopPropagation();
        setOpen(btn.getAttribute('aria-expanded') !== 'true');
      };

      drawer.addEventListener('click', function (e) {
        if (e.target.closest('[data-drawer-close]')) { setOpen(false); return; }
        var link = e.target.closest('a');
        if (link) {
          if (link.hasAttribute('data-placeholder')) { e.preventDefault(); return; }
          setOpen(false);
        }
      });

      // Placeholder akce (přihlášení / přepnutí účtu) zatím nic nedělají.
      drawer.querySelectorAll('button[data-placeholder]').forEach(function (el) {
        el.addEventListener('click', function (e) { e.preventDefault(); });
      });
    }

    if (!window.__hubHeaderEscBound) {
      window.__hubHeaderEscBound = true;
      document.addEventListener('keydown', function (e) {
        var btn = document.querySelector('.hub-header__burger');
        if (e.key === 'Escape' && btn && btn.getAttribute('aria-expanded') === 'true') btn.click();
      });
    }

    bindDrawer();
    document.addEventListener('astro:page-load', bindDrawer);
  }());
</script>

<script is:inline>
  /* Scroll past hero → header dostane class `is-stuck`.
     Dvě role:
       1. overlay varianta (landing) přepne z transparent na bílé pozadí,
       2. odkryje Rezervace chip vedle hamburgeru (na všech variantách).
     Najde první hero sekci a observuje její spodek. Když není hero (krátké
     stránky), is-stuck nastaví hned, takže chip je vidět. Tear-down na každém
     astro:page-load , persistent header by jinak observoval odpojený sentinel. */
  (function () {
    if (window.__hubHeaderStuckBound) return;
    window.__hubHeaderStuckBound = true;
    function initStuck() {
      var header = document.querySelector('.hub-header');
      if (!header) return;
      if (header.__hubIO) { header.__hubIO.disconnect(); header.__hubIO = null; }
      header.classList.remove('is-stuck');
      if (!('IntersectionObserver' in window)) { header.classList.add('is-stuck'); return; }
      var hero = document.querySelector('.lp-hero, .ub-hero, .sec-hero, .apt-hero, .kp-hero, .subpage-hero');
      if (!hero) { header.classList.add('is-stuck'); return; }
      var sentinel = document.createElement('div');
      sentinel.setAttribute('aria-hidden', 'true');
      sentinel.style.cssText = 'position:absolute;left:0;right:0;bottom:1px;height:1px;pointer-events:none;';
      if (getComputedStyle(hero).position === 'static') hero.style.position = 'relative';
      hero.appendChild(sentinel);
      var io = new IntersectionObserver(function (entries) {
        for (var i = 0; i < entries.length; i++) {
          header.classList.toggle('is-stuck', !entries[i].isIntersecting);
        }
      }, { rootMargin: '-80px 0px 0px 0px', threshold: 0 });
      io.observe(sentinel);
      header.__hubIO = io;
    }
    document.addEventListener('astro:page-load', initStuck);
  }());
</script>

<style>
  .hub-header {
    position: sticky; top: 0; z-index: 30;
    background: var(--bg);
    color: var(--fg);
  }
  .hub-header--dark {
    background: var(--plum-deep);
    color: var(--k-0);
  }

  /* Overlay varianta: fixed nad hero, default průhledný, bílý text.
     Po scrollu přes hero přidá JS `is-stuck` → bílé pozadí, tmavý text. */
  .hub-header--overlay {
    position: fixed;
    top: 0; left: 0; right: 0;
    background: transparent;
    color: #fff;
    border-bottom: 1px solid transparent;
    transition: background 220ms ease, color 220ms ease, border-color 220ms ease;
  }
  .hub-header--overlay .hub-header__rule { display: none; }
  .hub-header--overlay .hub-header__burger { color: #fff; }
  .hub-header--overlay.is-stuck {
    background: var(--bg);
    color: var(--fg);
    border-bottom-color: var(--border-muted);
  }
  .hub-header--overlay.is-stuck .hub-header__burger { color: var(--fg); }
  .hub-header--dark .hub-header__rule { display: none; }
  .hub-header__rule { height: 1px; background: var(--k-10); }

  /* Drawer otevřený: zvedni celý header nad FloatingAction (40) i HueSlider (50),
     ať scrim + panel překryjí veškeré plovoucí UI. Scroll lock na html+body. */
  :global(html.osa-nav-lock) .hub-header { z-index: 200; }
  :global(html.osa-nav-lock),
  :global(html.osa-nav-lock body) { overflow: hidden; }

  .hub-header__bar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-4);
    padding: 10px 0;
    width: calc(100% - 2 * var(--gutter));
    max-width: var(--container-wide);
    margin: 0 auto;
  }

  .hub-header__brand {
    display: inline-flex;
    align-items: center;
    color: inherit;
    text-decoration: none;
    position: relative;
    z-index: 2;
    flex-shrink: 0;
    line-height: 0;
  }
  :global(.hub-header__logo) { display: block; height: 18px; width: auto; flex-shrink: 0; }

  .hub-header__actions {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    position: relative;
    z-index: 2;
  }

  /* CTA pill , Rezervace chip. Wipe pattern: outline v klidu, fill stoupá zdola.
     Skrytý dokud nejsme za hero (is-stuck), pak fade + jemný posun dolů. */
  .hub-header__cta {
    position: relative;
    isolation: isolate;
    overflow: hidden;
    font: 600 var(--text-sm) / 1 var(--font-sans);
    color: inherit;
    padding: 6px 14px;
    border: 1px solid currentColor;
    border-radius: var(--radius-input);
    text-decoration: none;
    transition: color 160ms cubic-bezier(0.65, 0, 0.35, 1);
    flex-shrink: 0;
    white-space: nowrap;
  }
  .hub-header__cta::after {
    content: "";
    position: absolute;
    inset: 0;
    z-index: -1;
    clip-path: inset(100% 0 0 0);
    transition: clip-path 160ms cubic-bezier(0.65, 0, 0.35, 1);
  }
  .hub-header__cta:hover::after,
  .hub-header__cta:focus-visible::after,
  .hub-header__cta[aria-current='page']::after { clip-path: inset(0 0 0 0); }

  .hub-header--dark .hub-header__cta::after { background: #fff; }
  .hub-header--dark .hub-header__cta:hover,
  .hub-header--dark .hub-header__cta:focus-visible,
  .hub-header--dark .hub-header__cta[aria-current='page'] { color: var(--plum-deep); outline: none; }

  .hub-header--overlay.is-stuck .hub-header__cta { color: var(--accent); border-color: var(--accent); }
  .hub-header--overlay.is-stuck .hub-header__cta::after { background: var(--accent); }
  .hub-header--overlay.is-stuck .hub-header__cta:hover,
  .hub-header--overlay.is-stuck .hub-header__cta:focus-visible,
  .hub-header--overlay.is-stuck .hub-header__cta[aria-current='page'] { color: #fff; outline: none; }

  .hub-header:not(.hub-header--dark):not(.hub-header--overlay) .hub-header__cta { color: var(--accent); border-color: var(--accent); }
  .hub-header:not(.hub-header--dark):not(.hub-header--overlay) .hub-header__cta::after { background: var(--accent); }
  .hub-header:not(.hub-header--dark):not(.hub-header--overlay) .hub-header__cta:hover,
  .hub-header:not(.hub-header--dark):not(.hub-header--overlay) .hub-header__cta:focus-visible,
  .hub-header:not(.hub-header--dark):not(.hub-header--overlay) .hub-header__cta[aria-current='page'] { color: #fff; outline: none; }

  /* Reveal chip , skrytý dokud header není za hero. */
  .hub-header__reserve {
    opacity: 0;
    transform: translateY(-6px);
    visibility: hidden;
    pointer-events: none;
    transition: opacity 220ms ease, transform 220ms ease;
  }
  .hub-header.is-stuck .hub-header__reserve {
    opacity: 1;
    transform: none;
    visibility: visible;
    pointer-events: auto;
  }

  /* Burger , 44×44 tap target (WCAG 2.5.5), vizuální linky 20×17 uvnitř. */
  .hub-header__burger {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 44px; height: 44px;
    padding: 0; margin: 0 -10px 0 0;
    background: transparent; border: 0;
    color: inherit;
    cursor: pointer;
    position: relative;
    z-index: 2;
  }
  .hub-header__burger-box {
    display: grid;
    gap: 5px;
    width: 20px;
    margin: 0 auto;
  }
  .hub-header__burger-box > span {
    display: block;
    height: 1.5px;
    background: currentColor;
    transition: transform 240ms cubic-bezier(0.25, 1, 0.5, 1), opacity 160ms linear;
    transform-origin: 50% 50%;
  }
  .hub-header__burger:focus-visible { outline: 2px solid currentColor; outline-offset: 2px; }

  /* Off-canvas drawer , vyjíždí zprava, scrim ztmaví zbytek stránky. */
  .hub-drawer {
    position: fixed;
    inset: 0;
    z-index: 100;
  }
  .hub-drawer[hidden] { display: none; }

  .hub-drawer__scrim {
    position: absolute;
    inset: 0;
    background: hsl(var(--hue) 41% 13% / 0.42);
    opacity: 0;
    transition: opacity 300ms ease;
    z-index: 1;
  }
  .hub-drawer.open .hub-drawer__scrim { opacity: 1; }

  .hub-drawer__panel {
    position: absolute;
    top: 0; right: 0; bottom: 0;
    width: min(360px, 86vw);
    z-index: 2;
    display: flex;
    flex-direction: column;
    background: #fff;
    color: var(--fg);
    padding: var(--space-4) var(--space-6) calc(var(--space-6) + env(safe-area-inset-bottom, 0px));
    overflow-y: auto;
    overscroll-behavior: contain;
    transform: translateX(100%);
    transition: transform 340ms cubic-bezier(0.25, 1, 0.5, 1);
    box-shadow: -18px 0 56px hsl(var(--hue) 41% 13% / 0.18);
  }
  .hub-drawer.open .hub-drawer__panel { transform: translateX(0); }

  .hub-drawer__top {
    display: flex;
    justify-content: flex-end;
    margin-bottom: var(--space-2);
  }
  .hub-drawer__close {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 44px; height: 44px;
    margin-right: -8px;
    border-radius: 8px;
    color: var(--fg);
    cursor: pointer;
    transition: color 160ms ease, background 160ms ease;
  }
  .hub-drawer__close:hover { color: var(--accent); background: var(--bg-muted); }
  .hub-drawer__close:focus-visible { outline: 2px solid var(--accent); outline-offset: 2px; }

  .hub-drawer__nav {
    display: flex;
    flex-direction: column;
    flex: 1 1 auto;
  }
  .hub-drawer__link {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    font: 600 var(--text-xl) / 1.15 var(--font-sans);
    letter-spacing: var(--tracking-tight);
    padding: var(--space-3) 0;
    min-height: 48px;
    color: var(--fg);
    text-decoration: none;
    transition: color 160ms ease;
  }
  .hub-drawer__link:hover { color: var(--accent); }
  .hub-drawer__link[aria-current='page'] { color: var(--accent); }
  .hub-drawer__link[data-placeholder] { color: var(--k-50); cursor: default; }
  .hub-drawer__link[data-placeholder]:hover { color: var(--k-50); }

  /* Spodní blok , Rezervovat + účty kotvené dolů. */
  .hub-drawer__foot {
    margin-top: auto;
    display: flex;
    flex-direction: column;
    padding-top: var(--space-6);
  }
  .hub-drawer__divider {
    height: 1px;
    background: var(--border-muted);
    margin: var(--space-4) 0;
  }

  /* Rezervovat , solidní accent CTA, plná šířka panelu. */
  .hub-drawer__reserve-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-2);
    font: 700 var(--text-md) / 1 var(--font-sans);
    padding: var(--space-3) var(--space-5);
    background: var(--accent);
    color: var(--accent-on);
    border-radius: var(--radius-input);
    text-decoration: none;
    transition: background 180ms ease;
  }
  .hub-drawer__reserve-btn:hover,
  .hub-drawer__reserve-btn:focus-visible { background: var(--plum-deep); outline: none; }
  .hub-drawer__reserve-btn :global(svg) { transition: transform 180ms ease; }
  .hub-drawer__reserve-btn:hover :global(svg) { transform: translateX(3px); }

  /* Account , placeholdery (přihlášení / přepnutí účtu). Zatím inertní, ztlumené. */
  .hub-drawer__account {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }
  .hub-drawer__acct {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    font: 500 var(--text-md) / 1 var(--font-sans);
    color: var(--fg-subtle);
    padding: var(--space-3) 0;
    min-height: 44px;
    text-align: left;
    cursor: pointer;
    transition: color 160ms ease;
  }
  .hub-drawer__acct :global(svg) { flex-shrink: 0; transition: color 160ms ease; }
  .hub-drawer__acct:hover { color: var(--accent); }

  /* Telefon: menu fullscreen (panel přes celou šířku). */
  @media (max-width: 640px) {
    .hub-drawer__panel {
      width: 100%;
      box-shadow: none;
    }
  }

  /* Narrow viewports (iPhone SE atd.): menší logo. */
  @media (max-width: 380px) {
    :global(.hub-header__logo) { height: 16px; }
  }

  @media (prefers-reduced-motion: reduce) {
    .hub-header--overlay,
    .hub-header__cta,
    .hub-header__cta::after,
    .hub-header__reserve,
    .hub-header__burger-box > span,
    .hub-drawer__scrim,
    .hub-drawer__panel,
    .hub-drawer__reserve-btn,
    .hub-drawer__reserve-btn :global(svg) { transition: none; }
  }
</style>
