---
import { withBase } from '../utils/url';
import BrandLogo from './BrandLogo.astro';
import Icon from './Icon.astro';

interface Props {
  variant?: 'light' | 'dark' | 'overlay';
}
const { variant = 'light' } = Astro.props;

/* Desktop: vodorovná lišta se všemi kategoriemi v jedné linii + Přihlásit se +
   vždy viditelné tlačítko Rezervace. Mobil (<1024): hamburger → menu shora. */
type NavLink = { path: string; label: string; placeholder?: boolean };

const nav: NavLink[] = [
  { path: '/ubytovani/', label: 'Ubytování' },
  { path: '/zazemi/',    label: 'Zázemí' },
  { path: '/doprava/',   label: 'Doprava' },
  { path: '/stipendia/', label: 'Stipendia' },
  { path: '/galerie/',   label: 'Galerie' },
  { path: '/cenik/',     label: 'Ceník' },
  { path: '/novinky/',   label: 'Novinky' },
];

const current = Astro.url.pathname;
const isActive = (path: string) => {
  const full = withBase(path);
  return path === '/' ? current === full : current.startsWith(full);
};
const reservationActive = isActive('/rezervace/');
const isHome = current === withBase('/');
---
<header class:list={['hub-header', { 'hub-header--dark': variant === 'dark', 'hub-header--overlay': variant === 'overlay' }]} data-variant={variant}>
  <div class="hub-header__bar">
    <a
      href={withBase('/')}
      class="hub-header__brand"
      aria-label={isHome ? 'Startovací Hub Klecany, domů' : 'Zpět na Startovací Hub'}>
      <BrandLogo class="hub-header__logo" />
    </a>

    <nav class="hub-header__nav" aria-label="Hlavní navigace">
      {nav.map((item) => (
        <a
          href={withBase(item.path)}
          class="hub-header__link osa-nolink"
          aria-current={isActive(item.path) ? 'page' : undefined}>{item.label}</a>
      ))}
    </nav>

    <div class="hub-header__actions">
      <button type="button" class="hub-header__login" data-placeholder aria-label="Přihlásit se (připravujeme)">
        <Icon name="log-in" size={16} />
        <span>Přihlásit se</span>
      </button>

      <a
        href={withBase('/rezervace/')}
        class="hub-header__cta osa-nolink"
        aria-current={reservationActive ? 'page' : undefined}>Rezervace</a>

      <button
        class="hub-header__burger"
        type="button"
        aria-controls="hub-menu"
        aria-expanded="false"
        aria-label="Otevřít menu">
        <span class="hub-header__burger-box" aria-hidden="true">
          <span></span><span></span><span></span>
        </span>
      </button>
    </div>
  </div>
  <div class="hub-header__rule" role="presentation"></div>

  {/* Mobilní menu (dropdown shora, jen <1024). */}
  <div id="hub-menu" class="hub-menu" role="dialog" aria-modal="true" aria-label="Hlavní navigace">
    <div class="hub-menu__inner">
      <nav class="hub-menu__nav" aria-label="Hlavní navigace">
        {nav.map((item) => (
          <a
            href={withBase(item.path)}
            class="hub-menu__link osa-nolink"
            aria-current={isActive(item.path) ? 'page' : undefined}>{item.label}</a>
        ))}
      </nav>
      <div class="hub-menu__foot">
        <a href={withBase('/rezervace/')} class="hub-menu__reserve-btn osa-nolink" aria-current={reservationActive ? 'page' : undefined}>
          <span>Rezervovat</span>
          <Icon name="arrow-right" size={18} />
        </a>
        <button type="button" class="hub-menu__acct" data-placeholder aria-label="Přihlásit se (připravujeme)">
          <Icon name="log-in" size={18} />
          <span>Přihlásit se</span>
        </button>
      </div>
    </div>
  </div>
  <div class="hub-menu__scrim" data-menu-close aria-hidden="true"></div>
</header>

<script is:inline>
  /* Mobilní top-dropdown menu. Burger toggle is-menu-open. Re-bind na page-load. */
  (function () {
    function bindMenu() {
      var header = document.querySelector('.hub-header');
      var btn = document.querySelector('.hub-header__burger');
      var menu = document.getElementById('hub-menu');
      if (!header || !btn || !menu) return;
      if (btn.dataset.menuBound === '1') return;
      btn.dataset.menuBound = '1';
      function setOpen(open) {
        btn.setAttribute('aria-expanded', open ? 'true' : 'false');
        btn.setAttribute('aria-label', open ? 'Zavřít menu' : 'Otevřít menu');
        header.classList.toggle('is-menu-open', open);
        document.documentElement.classList.toggle('osa-nav-lock', open);
      }
      btn.onclick = function (e) { e.stopPropagation(); setOpen(btn.getAttribute('aria-expanded') !== 'true'); };
      header.addEventListener('click', function (e) {
        if (e.target.closest('[data-menu-close]')) { setOpen(false); return; }
        var link = e.target.closest('a.hub-menu__link');
        if (link) { setOpen(false); }
      });
      header.querySelectorAll('button[data-placeholder]').forEach(function (el) {
        el.addEventListener('click', function (e) { e.preventDefault(); });
      });
    }
    function closeMenu() {
      var header = document.querySelector('.hub-header');
      if (header) header.classList.remove('is-menu-open');
      document.documentElement.classList.remove('osa-nav-lock');
      var btn = document.querySelector('.hub-header__burger');
      if (btn) { btn.setAttribute('aria-expanded', 'false'); btn.setAttribute('aria-label', 'Otevřít menu'); }
    }
    if (!window.__hubHeaderEscBound) {
      window.__hubHeaderEscBound = true;
      document.addEventListener('keydown', function (e) {
        var btn = document.querySelector('.hub-header__burger');
        if (e.key === 'Escape' && btn && btn.getAttribute('aria-expanded') === 'true') closeMenu();
      });
    }
    document.addEventListener('astro:page-load', function () { closeMenu(); bindMenu(); });
    bindMenu();
  }());
</script>

<script is:inline>
  /* Scroll past hero → header dostane class `is-stuck` (overlay → pevné pozadí). */
  (function () {
    if (window.__hubHeaderStuckBound) return;
    window.__hubHeaderStuckBound = true;
    function initStuck() {
      var header = document.querySelector('.hub-header');
      if (!header) return;
      if (header.__hubIO) { header.__hubIO.disconnect(); header.__hubIO = null; }
      header.classList.remove('is-stuck');
      if (!('IntersectionObserver' in window)) { header.classList.add('is-stuck'); return; }
      var hero = document.querySelector('.lp-hero, .subpage-hero, .sec-hero, .apt-hero');
      if (!hero) { header.classList.add('is-stuck'); return; }
      var sentinel = document.createElement('div');
      sentinel.setAttribute('aria-hidden', 'true');
      sentinel.style.cssText = 'position:absolute;left:0;right:0;bottom:1px;height:1px;pointer-events:none;';
      if (getComputedStyle(hero).position === 'static') hero.style.position = 'relative';
      hero.appendChild(sentinel);
      var io = new IntersectionObserver(function (entries) {
        for (var i = 0; i < entries.length; i++) header.classList.toggle('is-stuck', !entries[i].isIntersecting);
      }, { rootMargin: '-80px 0px 0px 0px', threshold: 0 });
      io.observe(sentinel);
      header.__hubIO = io;
    }
    document.addEventListener('astro:page-load', initStuck);
  }());
</script>

<style>
  .hub-header { position: sticky; top: 0; z-index: 30; background: var(--bg); color: var(--fg); }
  .hub-header--dark { background: var(--plum-deep); color: var(--k-0); }
  .hub-header--overlay {
    position: fixed; top: 0; left: 0; right: 0;
    background: transparent; color: #fff;
    border-bottom: 1px solid transparent;
    transition: background 220ms ease, color 220ms ease, border-color 220ms ease;
  }
  .hub-header--overlay .hub-header__rule { display: none; }
  .hub-header--overlay .hub-header__burger { color: #fff; }
  .hub-header--overlay.is-stuck {
    background: var(--bg); color: var(--fg); border-bottom-color: var(--border-muted);
  }
  .hub-header--overlay.is-stuck .hub-header__burger { color: var(--fg); }
  .hub-header--dark .hub-header__rule { display: none; }
  .hub-header__rule { height: 1px; background: var(--k-10); }

  .hub-header.is-menu-open {
    background: var(--bg); color: var(--fg); border-bottom-color: var(--border-muted);
  }
  .hub-header.is-menu-open .hub-header__burger,
  .hub-header.is-menu-open .hub-header__brand { color: var(--fg); }
  :global(html.osa-nav-lock) .hub-header { z-index: 200; }
  :global(html.osa-nav-lock),
  :global(html.osa-nav-lock body) { overflow: hidden; }

  .hub-header__bar {
    position: relative; z-index: 3;
    display: flex; align-items: center; gap: var(--space-5);
    padding: 12px 0;
    width: calc(100% - 2 * var(--gutter));
    max-width: var(--container-wide);
    margin: 0 auto;
    background: inherit;
  }
  .hub-header__brand {
    display: inline-flex; align-items: center; color: inherit; text-decoration: none;
    position: relative; z-index: 2; flex-shrink: 0; line-height: 0;
  }
  :global(.hub-header__logo) { display: block; height: 18px; width: auto; flex-shrink: 0; }

  /* Inline desktop nav , jediná linie. */
  .hub-header__nav {
    display: none;
    align-items: center;
    gap: clamp(14px, 1.6vw, 28px);
    margin: 0 auto 0 var(--space-4);
  }
  .hub-header__link {
    position: relative;
    font: 600 var(--text-sm) / 1 var(--font-sans);
    color: inherit;
    text-decoration: none;
    padding: 6px 0;
    opacity: 0.92;
    transition: opacity 160ms ease, color 160ms ease;
  }
  .hub-header__link::after {
    content: ""; position: absolute; left: 0; right: 100%; bottom: -2px; height: 2px;
    background: currentColor;
    transition: right 220ms cubic-bezier(0.25, 1, 0.5, 1);
  }
  .hub-header__link:hover { opacity: 1; }
  .hub-header__link:hover::after { right: 0; }
  .hub-header__link[aria-current='page'] { opacity: 1; }
  .hub-header__link[aria-current='page']::after { right: 0; }

  .hub-header__actions {
    display: flex; align-items: center; gap: var(--space-3);
    position: relative; z-index: 2; margin-left: auto;
  }

  /* Přihlásit se , ghost, jen desktop. */
  .hub-header__login {
    display: none;
    align-items: center; gap: 6px;
    font: 600 var(--text-sm) / 1 var(--font-sans);
    color: inherit; opacity: 0.85; cursor: pointer;
    transition: opacity 160ms ease;
  }
  .hub-header__login:hover { opacity: 1; }
  .hub-header__login :global(svg) { flex-shrink: 0; }

  /* CTA pill , Rezervace, vždy viditelné. */
  .hub-header__cta {
    position: relative; isolation: isolate; overflow: hidden;
    font: 700 var(--text-sm) / 1 var(--font-sans);
    color: inherit; padding: 8px 18px;
    border: 1px solid currentColor; border-radius: var(--radius-input);
    text-decoration: none; white-space: nowrap; flex-shrink: 0;
    transition: color 160ms cubic-bezier(0.65, 0, 0.35, 1), transform 120ms ease;
  }
  .hub-header__cta:active { transform: scale(0.97); }
  .hub-header__cta::after {
    content: ""; position: absolute; inset: 0; z-index: -1;
    clip-path: inset(100% 0 0 0);
    transition: clip-path 220ms cubic-bezier(0.65, 0, 0.35, 1);
  }
  .hub-header__cta:hover::after,
  .hub-header__cta:focus-visible::after,
  .hub-header__cta[aria-current='page']::after { clip-path: inset(0 0 0 0); }

  .hub-header--dark .hub-header__cta::after { background: #fff; }
  .hub-header--dark .hub-header__cta:hover,
  .hub-header--dark .hub-header__cta[aria-current='page'] { color: var(--plum-deep); outline: none; }
  .hub-header--overlay.is-stuck .hub-header__cta,
  .hub-header.is-menu-open .hub-header__cta { color: var(--accent); border-color: var(--accent); }
  .hub-header--overlay.is-stuck .hub-header__cta::after,
  .hub-header.is-menu-open .hub-header__cta::after { background: var(--accent); }
  .hub-header--overlay.is-stuck .hub-header__cta:hover,
  .hub-header--overlay.is-stuck .hub-header__cta[aria-current='page'] { color: #fff; }
  .hub-header:not(.hub-header--dark):not(.hub-header--overlay) .hub-header__cta { color: var(--accent); border-color: var(--accent); }
  .hub-header:not(.hub-header--dark):not(.hub-header--overlay) .hub-header__cta::after { background: var(--accent); }
  .hub-header:not(.hub-header--dark):not(.hub-header--overlay) .hub-header__cta:hover,
  .hub-header:not(.hub-header--dark):not(.hub-header--overlay) .hub-header__cta[aria-current='page'] { color: #fff; }

  /* Burger , jen mobil (<1024). */
  .hub-header__burger {
    display: inline-flex; align-items: center; justify-content: center;
    width: 44px; height: 44px; padding: 0; margin: 0 -10px 0 0;
    background: transparent; border: 0; color: inherit; cursor: pointer;
    position: relative; z-index: 2;
  }
  .hub-header__burger-box { display: grid; gap: 5px; width: 20px; margin: 0 auto; }
  .hub-header__burger-box > span {
    display: block; height: 1.5px; background: currentColor;
    transition: transform 240ms cubic-bezier(0.25, 1, 0.5, 1), opacity 160ms linear;
    transform-origin: 50% 50%;
  }
  .hub-header.is-menu-open .hub-header__burger-box > span:nth-child(1) { transform: translateY(6.5px) rotate(45deg); }
  .hub-header.is-menu-open .hub-header__burger-box > span:nth-child(2) { opacity: 0; }
  .hub-header.is-menu-open .hub-header__burger-box > span:nth-child(3) { transform: translateY(-6.5px) rotate(-45deg); }
  .hub-header__burger:focus-visible { outline: 2px solid currentColor; outline-offset: 2px; }

  /* ≥1024: inline nav + login, schovej burger. */
  @media (min-width: 1024px) {
    .hub-header__nav { display: flex; }
    .hub-header__login { display: inline-flex; }
    .hub-header__burger { display: none; }
  }

  /* === Mobilní dropdown menu (jen <1024) === */
  .hub-menu {
    position: absolute; top: 100%; left: 0; right: 0; z-index: 2;
    background: var(--bg); color: var(--fg);
    border-bottom: 1px solid var(--border-muted);
    box-shadow: 0 24px 48px hsl(var(--hue) 41% 13% / 0.12);
    transform: translateY(-14px); opacity: 0; visibility: hidden; pointer-events: none;
    transition: opacity 260ms var(--ease-quart), transform 260ms var(--ease-quart), visibility 0s 260ms;
  }
  .hub-header.is-menu-open .hub-menu {
    opacity: 1; transform: none; visibility: visible; pointer-events: auto;
    transition: opacity 260ms var(--ease-quart), transform 260ms var(--ease-quart), visibility 0s;
  }
  .hub-menu__inner {
    width: calc(100% - 2 * var(--gutter)); max-width: var(--container-wide); margin: 0 auto;
    display: flex; flex-direction: column; align-items: center; justify-content: flex-start;
    gap: var(--space-5);
    min-height: calc(100dvh - 64px);
    padding: var(--space-7) 0 calc(var(--space-7) + env(safe-area-inset-bottom, 0px));
  }
  .hub-menu__nav { display: flex; flex-direction: column; align-items: center; gap: var(--space-3); flex: 1 1 auto; justify-content: center; }
  .hub-menu__link {
    font: 700 var(--text-2xl) / 1.1 var(--font-sans);
    letter-spacing: var(--tracking-tight);
    color: var(--fg); text-decoration: none; text-align: center;
    transition: color 160ms ease;
  }
  .hub-menu__link:hover, .hub-menu__link[aria-current='page'] { color: var(--accent); }
  .hub-menu__foot { display: flex; flex-direction: column; gap: var(--space-3); width: min(320px, 100%); align-items: center; }
  .hub-menu__reserve-btn {
    display: inline-flex; align-items: center; justify-content: center; gap: var(--space-2); width: 100%;
    font: 700 var(--text-md) / 1 var(--font-sans);
    padding: var(--space-3) var(--space-5);
    background: var(--accent); color: var(--accent-on); border-radius: var(--radius-input);
    text-decoration: none; transition: background 180ms ease;
  }
  .hub-menu__reserve-btn:hover { background: var(--plum-deep); }
  .hub-menu__reserve-btn :global(svg) { transition: transform 180ms ease; }
  .hub-menu__reserve-btn:hover :global(svg) { transform: translateX(3px); }
  .hub-menu__acct {
    display: inline-flex; align-items: center; gap: var(--space-2);
    font: 500 var(--text-md) / 1 var(--font-sans);
    color: var(--fg-subtle); cursor: pointer; padding: var(--space-2) 0;
  }
  .hub-menu__acct:hover { color: var(--accent); }
  .hub-menu__scrim {
    position: fixed; inset: 0; z-index: 1;
    background: hsl(var(--hue) 41% 13% / 0.30);
    opacity: 0; visibility: hidden; pointer-events: none;
    transition: opacity 260ms ease, visibility 0s 260ms;
  }
  .hub-header.is-menu-open .hub-menu__scrim {
    opacity: 1; visibility: visible; pointer-events: auto;
    transition: opacity 260ms ease, visibility 0s;
  }
  @media (min-width: 1024px) {
    .hub-menu, .hub-menu__scrim { display: none; }
  }

  @media (max-width: 380px) {
    :global(.hub-header__logo) { height: 16px; }
  }

  @media (prefers-reduced-motion: reduce) {
    .hub-header--overlay, .hub-header__cta, .hub-header__cta::after,
    .hub-header__link::after, .hub-header__burger-box > span,
    .hub-menu, .hub-menu__scrim, .hub-menu__reserve-btn,
    .hub-menu__reserve-btn :global(svg) { transition: none; }
  }
</style>
