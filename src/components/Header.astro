---
import { withBase } from '../utils/url';
import OsaGlyph from './OsaGlyph.astro';

interface Props {
  variant?: 'light' | 'dark' | 'overlay';
}
const { variant = 'light' } = Astro.props;

/* Site-wide nav. Order locked per SH_Web_Plan.md ř. 211 a Site_Copy § 0.2.
   Rezervace nepatří do nav array, je to samostatný CTA chip vpravo. */
type NavItem = {
  path: string;
  label: string;
};

const nav: NavItem[] = [
  { path: '/ubytovani/', label: 'Ubytování' },
  { path: '/coworking/', label: 'Coworking' },
  { path: '/komunita/',  label: 'Komunita' },
  { path: '/stipendia/', label: 'Stipendia' },
  { path: '/okoli/',     label: 'Okolí' },
  { path: '/doprava/',   label: 'Doprava' },
];

const current = Astro.url.pathname;
const isActive = (path: string) => {
  const full = withBase(path);
  return path === '/' ? current === full : current.startsWith(full);
};
const reservationActive = isActive('/rezervace/');
const isHome = current === withBase('/');
---
<header class:list={['hub-header', { 'hub-header--dark': variant === 'dark', 'hub-header--overlay': variant === 'overlay' }]} data-variant={variant}>
  <div class="hub-header__bar">
    <a
      href={withBase('/')}
      class="hub-header__brand"
      aria-label={isHome ? 'Startovací Hub Klecany, domů' : 'Zpět na Startovací Hub'}>
      <span class="hub-header__glyph" aria-hidden="true"><OsaGlyph size="13px" /></span>
      <span class="hub-header__wordmark">Startovací Hub</span>
    </a>

    <nav class="hub-header__nav" aria-label="Hlavní navigace">
      {nav.map((n) => (
        <a
          href={withBase(n.path)}
          class="hub-header__link"
          aria-current={isActive(n.path) ? 'page' : undefined}>{n.label}</a>
      ))}
      <a
        href={withBase('/rezervace/')}
        class="hub-header__cta osa-nolink"
        aria-current={reservationActive ? 'page' : undefined}>Rezervace</a>
    </nav>

    <a
      href={withBase('/rezervace/')}
      class="hub-header__cta hub-header__cta--mobile osa-nolink"
      aria-current={reservationActive ? 'page' : undefined}>Rezervace</a>

    <button
      class="hub-header__burger"
      type="button"
      aria-controls="hub-drawer"
      aria-expanded="false"
      aria-label="Otevřít menu">
      <span class="hub-header__burger-box" aria-hidden="true">
        <span></span><span></span><span></span>
      </span>
    </button>
  </div>
  <div class="hub-header__rule" role="presentation"></div>

  <div id="hub-drawer" class="hub-drawer" role="dialog" aria-modal="true" aria-label="Hlavní navigace" hidden>
    <nav class="hub-drawer__nav" aria-label="Mobilní navigace">
      {nav.map((n) => (
        <a
          href={withBase(n.path)}
          class="hub-drawer__link"
          aria-current={isActive(n.path) ? 'page' : undefined}>{n.label}</a>
      ))}
      <a
        href={withBase('/rezervace/')}
        class="hub-drawer__link hub-drawer__link--cta"
        aria-current={reservationActive ? 'page' : undefined}>Rezervace</a>
    </nav>
  </div>
</header>

<script is:inline>
  /* Burger drawer init. Re-runs na každém astro:page-load, protože header
     persist nemusí zachovat element napříč navigací (variant prop se mění
     overlay↔light). Globální guard nestačí, potřebujeme nové handler na
     novém DOM node. */
  (function () {
    function bindBurger() {
      var btn = document.querySelector('.hub-header__burger');
      var panel = document.getElementById('hub-drawer');
      if (!btn || !panel) return;
      if (btn.dataset.burgerBound === '1') return;
      btn.dataset.burgerBound = '1';

      function setOpen(open) {
        btn.setAttribute('aria-expanded', open ? 'true' : 'false');
        btn.setAttribute('aria-label', open ? 'Zavřít menu' : 'Otevřít menu');
        if (open) {
          panel.hidden = false;
          requestAnimationFrame(function () { panel.classList.add('open'); });
          document.documentElement.classList.add('osa-nav-lock');
        } else {
          panel.classList.remove('open');
          document.documentElement.classList.remove('osa-nav-lock');
          setTimeout(function () {
            if (btn.getAttribute('aria-expanded') === 'false') panel.hidden = true;
          }, 280);
        }
      }

      btn.onclick = function (e) {
        e.stopPropagation();
        setOpen(btn.getAttribute('aria-expanded') !== 'true');
      };

      panel.addEventListener('click', function (e) {
        if (e.target.closest('a')) setOpen(false);
      });
    }

    // Globální Escape handler, připojen jen jednou.
    if (!window.__hubHeaderEscBound) {
      window.__hubHeaderEscBound = true;
      document.addEventListener('keydown', function (e) {
        var btn = document.querySelector('.hub-header__burger');
        if (e.key === 'Escape' && btn && btn.getAttribute('aria-expanded') === 'true') {
          btn.click();
        }
      });
    }

    bindBurger();
    document.addEventListener('astro:page-load', bindBurger);
  }());
</script>

<script is:inline>
  /* Header overlay → opaque switch při scrollu mimo hero.
     Hledá první image-hero sekci (.lp-hero, .ub-hero, .sec-hero,
     .apt-hero, .kp-hero) a observuje její spodek. Dokud je hero
     viditelné, header zůstává transparent. Když hero opustí viewport,
     přidá se class `is-stuck` (bílé pozadí, tmavé písmo). */
  (function () {
    if (window.__hubHeaderOverlayBound) return;
    window.__hubHeaderOverlayBound = true;
    function initOverlay() {
      var header = document.querySelector('.hub-header--overlay');
      if (!header || !('IntersectionObserver' in window)) return;
      if (header.dataset.overlayBound === '1') return;
      var hero = document.querySelector('.lp-hero, .ub-hero, .sec-hero, .apt-hero, .kp-hero, .subpage-hero');
      if (!hero) {
        header.classList.add('is-stuck');
        return;
      }
      header.dataset.overlayBound = '1';
      var sentinel = document.createElement('div');
      sentinel.setAttribute('aria-hidden', 'true');
      sentinel.style.cssText = 'position:absolute;left:0;right:0;bottom:1px;height:1px;pointer-events:none;';
      if (getComputedStyle(hero).position === 'static') hero.style.position = 'relative';
      hero.appendChild(sentinel);
      var io = new IntersectionObserver(function (entries) {
        for (var i = 0; i < entries.length; i++) {
          header.classList.toggle('is-stuck', !entries[i].isIntersecting);
        }
      }, { rootMargin: '-80px 0px 0px 0px', threshold: 0 });
      io.observe(sentinel);
    }
    document.addEventListener('astro:page-load', initOverlay);
  }());
</script>

<style>
  .hub-header {
    position: sticky; top: 0; z-index: 30;
    background: var(--bg);
    color: var(--fg);
  }
  .hub-header--dark {
    background: var(--plum-deep);
    color: var(--k-0);
  }

  /* Overlay variant: fixed nad hero, default průhledný, bílý text.
     Po scrolování přes hero přidá JS class `is-stuck` a header dostane
     bílé pozadí a tmavý text (= light look). */
  .hub-header--overlay {
    position: fixed;
    top: 0; left: 0; right: 0;
    background: transparent;
    color: #fff;
    border-bottom: 1px solid transparent;
    transition: background 220ms ease, color 220ms ease, border-color 220ms ease;
  }
  .hub-header--overlay .hub-header__rule { display: none; }
  .hub-header--overlay .hub-header__link { color: rgba(255,255,255,0.95); }
  .hub-header--overlay .hub-header__link:hover { color: #fff; }
  .hub-header--overlay .hub-header__cta { color: #fff; border-color: #fff; }
  .hub-header--overlay .hub-header__cta::after { background: #fff; }
  .hub-header--overlay .hub-header__cta:hover,
  .hub-header--overlay .hub-header__cta:focus-visible,
  .hub-header--overlay .hub-header__cta[aria-current='page'] { color: var(--plum-deep); }
  .hub-header--overlay .hub-header__burger { color: #fff; }

  .hub-header--overlay.is-stuck {
    background: var(--bg);
    color: var(--fg);
    border-bottom-color: var(--border-muted);
  }
  .hub-header--overlay.is-stuck .hub-header__link { color: var(--fg); }
  .hub-header--overlay.is-stuck .hub-header__link:hover { color: var(--accent); }
  .hub-header--overlay.is-stuck .hub-header__cta { color: var(--accent); border-color: var(--accent); }
  .hub-header--overlay.is-stuck .hub-header__cta::after { background: var(--accent); }
  .hub-header--overlay.is-stuck .hub-header__cta:hover,
  .hub-header--overlay.is-stuck .hub-header__cta:focus-visible,
  .hub-header--overlay.is-stuck .hub-header__cta[aria-current='page'] { color: #fff; }
  .hub-header--overlay.is-stuck .hub-header__burger { color: var(--fg); }
  :global(html.osa-nav-lock) .hub-header {
    position: fixed;
    top: 0; left: 0; right: 0;
    background: var(--bg);
    color: var(--fg);
    z-index: 30;
  }
  :global(html.osa-nav-lock) .hub-header .hub-header__rule { display: none; }
  /* Když je drawer otevřený, header se přepne na light look , burger (teď X)
     musí být tmavý, ne zděděný white z .hub-header--overlay. Aplikujeme i na
     ostatní elementy v headeru, kterým CSS výš nastavilo bílý color. */
  :global(html.osa-nav-lock) .hub-header.hub-header__burger,
  :global(html.osa-nav-lock) .hub-header .hub-header__burger,
  :global(html.osa-nav-lock) .hub-header.hub-header--overlay .hub-header__burger,
  :global(html.osa-nav-lock) .hub-header.hub-header--overlay .hub-header__brand,
  :global(html.osa-nav-lock) .hub-header.hub-header--overlay .hub-header__link { color: var(--fg); }
  :global(html.osa-nav-lock) .hub-header.hub-header--overlay .hub-header__cta { color: var(--accent); border-color: var(--accent); }
  :global(html.osa-nav-lock) .hub-header.hub-header--overlay .hub-header__cta::after { background: var(--accent); }
  .hub-header--dark .hub-header__rule { display: none; }
  .hub-header__rule {
    height: 1px;
    background: var(--k-10);
  }

  .hub-header__bar {
    display: flex;
    align-items: center;
    gap: var(--space-5);
    /* Width pattern: content edge aligns s tile grid (1480 max, gutter-aware
       na menších viewportech). Žádný vlastní padding-x. */
    padding: 10px 0;
    width: calc(100% - 2 * var(--gutter));
    max-width: var(--container-wide);
    margin: 0 auto;
  }

  .hub-header__brand {
    display: inline-flex;
    align-items: flex-end;
    gap: 6px;
    color: inherit;
    font-family: var(--font-sans);
    font-weight: 600;
    font-size: var(--text-base);
    letter-spacing: var(--tracking-tight);
    line-height: 1;
    text-decoration: none;
    position: relative;
    z-index: 35;
    flex-shrink: 0;
  }
  .hub-header__glyph { display: inline-flex; line-height: 0; margin-bottom: 1px; }
  .hub-header__wordmark { white-space: nowrap; }

  @media (prefers-reduced-motion: reduce) {
  }

  .hub-header__nav {
    display: flex;
    align-items: center;
    gap: var(--space-5);
    margin-left: auto;
  }
  .hub-header__link {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    font: 600 var(--text-sm) / 1 var(--font-sans);
    color: var(--fg);
    padding: 4px 0;
    border-bottom: 1px solid transparent;
    text-decoration: none;
    transition: color var(--dur-fast) linear, border-color var(--dur-fast) linear;
    white-space: nowrap;
  }
  .hub-header--dark .hub-header__link { color: rgba(255, 255, 255, 0.9); }
  .hub-header__link[aria-current='page'] {
    color: var(--accent);
    border-bottom-color: var(--accent);
  }
  .hub-header__link:hover { color: var(--accent); }
  .hub-header--dark .hub-header__link:hover,
  .hub-header--dark .hub-header__link[aria-current='page'] { color: #fff; }

  /* Overlay (transparent, nad hero): aktivní link je bílý + bílý underline,
     ALE jen na dark hero. Na light hero (cream/rose) drží plum.
     :global(body:not...) zachytí oba případy v rámci scoped CSS pravidla. */
  :global(body:not([data-hero-tone="light"])) .hub-header--overlay:not(.is-stuck) .hub-header__link[aria-current='page'] {
    color: #fff;
    border-bottom-color: #fff;
  }

  /* CTA pill , Rezervace.
     Wipe pattern: outline at rest; fill rises from bottom on hover. */
  .hub-header__cta {
    position: relative;
    isolation: isolate;
    overflow: hidden;
    font: 600 var(--text-sm) / 1 var(--font-sans);
    color: inherit;
    padding: 6px 14px;
    border: 1px solid currentColor;
    border-radius: var(--radius-input);
    text-decoration: none;
    transition: color 160ms cubic-bezier(0.65, 0, 0.35, 1);
    flex-shrink: 0;
    white-space: nowrap;
  }
  .hub-header__cta::after {
    content: "";
    position: absolute;
    inset: 0;
    z-index: -1;
    clip-path: inset(100% 0 0 0);
    transition: clip-path 160ms cubic-bezier(0.65, 0, 0.35, 1);
  }
  .hub-header__cta:hover::after,
  .hub-header__cta:focus-visible::after,
  .hub-header__cta[aria-current='page']::after {
    clip-path: inset(0 0 0 0);
  }
  .hub-header--dark .hub-header__cta::after { background: #fff; }
  .hub-header--dark .hub-header__cta:hover,
  .hub-header--dark .hub-header__cta:focus-visible,
  .hub-header--dark .hub-header__cta[aria-current='page'] {
    color: var(--plum-deep);
    outline: none;
  }
  .hub-header:not(.hub-header--dark):not(.hub-header--overlay) .hub-header__cta { color: var(--accent); border-color: var(--accent); }
  .hub-header:not(.hub-header--dark):not(.hub-header--overlay) .hub-header__cta::after { background: var(--accent); }
  .hub-header:not(.hub-header--dark):not(.hub-header--overlay) .hub-header__cta:hover,
  .hub-header:not(.hub-header--dark):not(.hub-header--overlay) .hub-header__cta:focus-visible,
  .hub-header:not(.hub-header--dark):not(.hub-header--overlay) .hub-header__cta[aria-current='page'] {
    color: #fff;
    outline: none;
  }
  /* Mobile CTA: stejný styl jako desktop, ale ukazuje se vedle burgeru,
     ne uvnitř nav. Default skrytý, zobrazí se pod 1024px. */
  .hub-header__cta--mobile { display: none; margin-left: auto; }

  @media (prefers-reduced-motion: reduce) {
    .hub-header__cta,
    .hub-header__cta::after { transition: none; }
  }

  /* Burger. 44×44 minimum tap target per WCAG 2.5.5; visual hamburger
     stays 20×17 inside the box via .hub-header__burger-box. */
  .hub-header__burger {
    display: none;
    width: 44px; height: 44px;
    padding: 0; margin: 0 -10px 0 0; /* negative margin keeps optical alignment with edge */
    background: transparent; border: 0;
    color: inherit;
    cursor: pointer;
    position: relative;
    z-index: 35;
  }
  .hub-header__burger-box {
    display: grid;
    gap: 5px;
    width: 20px;
    margin: 0 auto;
  }
  .hub-header__burger-box > span {
    display: block;
    height: 1.5px;
    background: currentColor;
    transition:
      transform 240ms cubic-bezier(0.25, 1, 0.5, 1),
      opacity 160ms linear;
    transform-origin: 50% 50%;
  }
  .hub-header__burger[aria-expanded='true'] .hub-header__burger-box > span:nth-child(1) {
    transform: translateY(6.5px) rotate(45deg);
  }
  .hub-header__burger[aria-expanded='true'] .hub-header__burger-box > span:nth-child(2) {
    opacity: 0;
  }
  .hub-header__burger[aria-expanded='true'] .hub-header__burger-box > span:nth-child(3) {
    transform: translateY(-6.5px) rotate(-45deg);
  }
  .hub-header__burger:focus-visible {
    outline: 2px solid currentColor;
    outline-offset: 2px;
  }

  /* Mobile drawer , bottom-anchored panel, slides up from bottom.
     Nezakrývá zbytečně celou stránku: max-height 75vh, scroll uvnitř,
     scrim nad zbytkem stránky. Položky jsou centered text-align, anchored
     dolů, fontově trochu tučnější. */
  .hub-drawer {
    position: fixed;
    left: 0; right: 0; bottom: 0;
    top: auto;
    z-index: 29;
    background: #fff;
    color: var(--fg);
    padding: var(--space-7) var(--gutter) calc(var(--space-7) + env(safe-area-inset-bottom, 0px));
    max-height: 75vh;
    overflow-y: auto;
    opacity: 0;
    transform: translateY(100%);
    transition:
      opacity 240ms cubic-bezier(0.25, 1, 0.5, 1),
      transform 320ms cubic-bezier(0.25, 1, 0.5, 1);
    border-top: 1px solid hsl(var(--hue) 14% 88%);
    box-shadow:
      0 -2px 6px hsl(var(--hue) 41% 13% / 0.04),
      0 -16px 48px hsl(var(--hue) 41% 13% / 0.12);
    border-top-left-radius: 18px;
    border-top-right-radius: 18px;
  }
  .hub-drawer.open {
    opacity: 1;
    transform: translateY(0);
  }
  /* Scrim nad zbytkem stránky, klik mimo zavře drawer. Aplikujeme přes
     globální html.osa-nav-lock::before, abychom se vyhnuli stacking
     kontext kolizi v ::before na samotném draweru. */
  :global(html.osa-nav-lock)::before {
    content: "";
    position: fixed;
    inset: 0;
    background: hsl(var(--hue) 41% 13% / 0.42);
    z-index: 28;
    opacity: 1;
    pointer-events: auto;
  }
  .hub-drawer__nav {
    display: grid;
    gap: 0;
    max-width: 420px;
    margin: 0 auto;
    text-align: center;
  }
  .hub-drawer__link {
    font-family: var(--font-sans);
    font-weight: 600;
    font-size: var(--text-xl);
    letter-spacing: var(--tracking-tight);
    padding: var(--space-3) 0;
    min-height: 44px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-bottom: 1px solid var(--border-muted);
    color: var(--fg);
    text-decoration: none;
    transition: color 160ms ease;
  }
  .hub-drawer__link:last-of-type:not(.hub-drawer__link--cta) { border-bottom: 0; }
  .hub-drawer__link:hover { color: var(--accent); }
  .hub-drawer__link[aria-current='page'] { color: var(--accent); }

  .hub-drawer__link--cta {
    position: relative;
    margin-top: var(--space-4);
    color: var(--accent);
    background: transparent;
    padding: var(--space-3) var(--space-6);
    border: 1px solid var(--accent);
    border-radius: var(--radius-input);
    font-weight: 700;
    text-align: center;
    justify-content: center;
    justify-self: center;
    width: fit-content;
    min-width: 180px;
    transition: background 200ms ease, color 200ms ease;
  }
  .hub-drawer__link--cta:hover,
  .hub-drawer__link--cta:focus-visible {
    background: var(--accent);
    color: #fff;
  }

  :global(html.osa-nav-lock),
  :global(html.osa-nav-lock body) { overflow: hidden; }

  /* Mobile: burger replaces nav, mobile CTA shows next to burger.
     Breakpoint raised from 720 to 1024 because 8 nav items + brand +
     status badge + CTA chip don't fit comfortably under ~1100 px. */
  @media (max-width: 1024px) {
    .hub-header__nav { display: none; }
    .hub-header__cta--mobile { display: inline-flex; align-items: center; }
    .hub-header__burger {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      width: 40px;
      height: 40px;
    }
    /* Užší header bar na telefonu, méně padding-y a kompaktnější CTA. */
    .hub-header__bar { padding: 6px 0; gap: var(--space-4); }
    .hub-header__cta { padding: 5px 12px; font-size: 13px; }
  }

  /* Narrow viewports (iPhone SE etc.): shrink brand font slightly. Glyph
     stays visible, back arrow moved to floating action button. */
  @media (max-width: 380px) {
    .hub-header__brand { font-size: 14px; gap: 5px; }
  }

  @media (min-width: 1025px) {
    .hub-drawer { display: none; }
  }

  @media (prefers-reduced-motion: reduce) {
    .hub-drawer,
    .hub-header__burger-box > span,
    .hub-header__cta { transition: none; }
  }
</style>
