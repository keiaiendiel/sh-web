---
const nav = [
  { href: '/',            label: 'Úvod' },
  { href: '/o-spolku/',   label: 'O spolku' },
  { href: '/projekty/',   label: 'Projekty' },
  { href: '/zapojte-se/', label: 'Zapojte se' },
  { href: '/kontakty/',   label: 'Kontakty' },
];
const current = Astro.url.pathname;
const isActive = (href: string) =>
  href === '/' ? current === '/' : current.startsWith(href);
---
<header class="osa-header">
  <div class="container-wide osa-header__inner">
    <a href="/" class="osa-header__brand" aria-label="Občanské sdružení Alternativa II - domů">
      <img src="/logo/OSA-Logo-Black.svg" alt="" aria-hidden="true" class="osa-header__logo osa-header__logo--light" />
      <img src="/logo/OSA-Logo-White.svg" alt="" aria-hidden="true" class="osa-header__logo osa-header__logo--dark" />
    </a>

    <nav class="osa-header__nav" aria-label="Hlavní navigace">
      {nav.map(n => (
        <a
          href={n.href}
          class="osa-header__link"
          aria-current={isActive(n.href) ? 'page' : undefined}>{n.label}</a>
      ))}
    </nav>
  </div>
  <div class="rule" role="presentation"></div>
</header>

<style>
  .osa-header {
    position: sticky; top: 0; z-index: 20;
    background: var(--bg);
    color: var(--fg);
  }
  .osa-header__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-6);
    padding: 18px var(--gutter);
  }
  .osa-header__brand {
    display: inline-flex;
    align-items: center;
    color: var(--fg);
    line-height: 0;
  }
  .osa-header__logo {
    display: block;
    width: 40px;
    height: 40px;
  }
  /* swap logo by theme: light header shows Black; dark parent surfaces show White */
  .osa-header__logo--dark  { display: none; }
  .osa-dark .osa-header__logo--light { display: none; }
  .osa-dark .osa-header__logo--dark  { display: block; }

  .osa-header__nav {
    display: flex;
    gap: var(--space-6);
  }
  .osa-header__link {
    font: 600 var(--text-sm) / 1 var(--font-sans);
    color: var(--fg-muted);
    padding: 6px 0;
    border-bottom: 1px solid transparent;
    transition: color var(--dur-fast) linear, border-color var(--dur-fast) linear;
  }
  .osa-header__link[aria-current='page'] {
    color: var(--fg);
    border-bottom-color: var(--fg);
  }
  .osa-header__link:hover {
    opacity: 1;
    color: var(--fg);
  }
  @media (max-width: 720px) {
    .osa-header__nav { display: none; }
    .osa-header__logo { width: 32px; height: 32px; }
  }
</style>
