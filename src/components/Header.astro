---
import { withBase } from '../utils/url';
import BrandLogo from './BrandLogo.astro';
import Icon from './Icon.astro';
import Arrow from './Arrow.astro';

interface Props {
  variant?: 'light' | 'dark' | 'overlay';
}
const { variant = 'light' } = Astro.props;

/* Jednotná navigace přes hamburger na DESKTOPU i MOBILU (klient 16. 6. 2026).
   Lišta nad hero = jen hamburger vpravo. Po scrollu pod hero (is-stuck) nebo
   na podstránkách (ne-overlay) = logo vlevo + Rezervace + hamburger vpravo.
   Vše ostatní (kategorie, přihlášení) žije v celoobrazovkovém plum menu. */
type NavLink = { path: string; label: string };

const nav: NavLink[] = [
  { path: '/ubytovani/', label: 'Ubytování' },
  { path: '/stipendia/', label: 'Stipendia' },
  { path: '/zazemi/',    label: 'Zázemí' },
  { path: '/doprava/',   label: 'Doprava' },
  { path: '/galerie/',   label: 'Galerie' },
  { path: '/cenik/',     label: 'Ceník' },
  { path: '/novinky/',   label: 'Novinky' },
];

const current = Astro.url.pathname;
const isActive = (path: string) => {
  const full = withBase(path);
  return path === '/' ? current === full : current.startsWith(full);
};
const reservationActive = isActive('/rezervace/');
const isHome = current === withBase('/');
---
<header class:list={['hub-header', { 'hub-header--dark': variant === 'dark', 'hub-header--overlay': variant === 'overlay' }]} data-variant={variant}>
  <div class="hub-header__bar">
    <a
      href={withBase('/')}
      class="hub-header__brand"
      aria-label={isHome ? 'Startovací Hub Klecany, domů' : 'Zpět na Startovací Hub'}>
      <BrandLogo class="hub-header__logo" />
    </a>

    <div class="hub-header__actions">
      <a
        href={withBase('/rezervace/')}
        class="hub-header__cta osa-nolink"
        aria-current={reservationActive ? 'page' : undefined}>Rezervace</a>

      <button
        class="hub-header__burger"
        type="button"
        aria-controls="hub-menu"
        aria-expanded="false"
        aria-label="Otevřít menu">
        <span class="hub-header__burger-box" aria-hidden="true">
          <span></span><span></span><span></span>
        </span>
      </button>
    </div>
  </div>
  <div class="hub-header__rule" role="presentation"></div>

  {/* Celoobrazovkové menu (desktop i mobil): logo + všechny kategorie +
      Rezervace + Přihlásit se. Plum-deep plocha, velká Atyp typografie. */}
  <div id="hub-menu" class="hub-menu" role="dialog" aria-modal="true" aria-label="Hlavní navigace">
    <div class="hub-menu__inner">
      <a href={withBase('/')} class="hub-menu__brand osa-nolink" aria-label="Startovací Hub Klecany, domů">
        <BrandLogo class="hub-menu__logo" />
      </a>

      {/* Rezervace hned pod logem */}
      <a href={withBase('/rezervace/')} class="hub-menu__reserve-btn osa-nolink" aria-current={reservationActive ? 'page' : undefined}>
        <span>Rezervace</span>
        <Arrow dir="right" variant="chevron" size={18} weight={2.4} />
      </a>

      <nav class="hub-menu__nav" aria-label="Hlavní navigace">
        {nav.map((item, i) => (
          <a
            href={withBase(item.path)}
            class="hub-menu__link osa-nolink"
            style={`--i:${i}`}
            aria-current={isActive(item.path) ? 'page' : undefined}>
            <span class="hub-menu__link-text">{item.label}</span>
          </a>
        ))}
      </nav>

      {/* Účet (stuby, auth backend = fáze 2) */}
      <div class="hub-menu__foot">
        <button type="button" class="hub-menu__acct" data-placeholder aria-label="Přihlásit se / Odhlásit se (připravujeme)">
          <Icon name="user" size={18} />
          <span>Přihlásit se / Odhlásit se</span>
        </button>
        <button type="button" class="hub-menu__acct" data-placeholder aria-label="Přepnout účet (připravujeme)">
          <Icon name="repeat" size={18} />
          <span>Přepnout účet</span>
        </button>
      </div>
    </div>
  </div>
</header>

<script is:inline>
  /* Celoobrazovkové menu. Burger toggle → is-menu-open. Zavírá: burger, klik na
     odkaz, Esc. Re-bind na každý astro:page-load (SPA navigace). */
  (function () {
    function bindMenu() {
      var header = document.querySelector('.hub-header');
      var btn = document.querySelector('.hub-header__burger');
      var menu = document.getElementById('hub-menu');
      if (!header || !btn || !menu) return;
      if (btn.dataset.menuBound === '1') return;
      btn.dataset.menuBound = '1';
      function setOpen(open) {
        btn.setAttribute('aria-expanded', open ? 'true' : 'false');
        btn.setAttribute('aria-label', open ? 'Zavřít menu' : 'Otevřít menu');
        header.classList.toggle('is-menu-open', open);
        document.documentElement.classList.toggle('osa-nav-lock', open);
      }
      btn.onclick = function (e) { e.stopPropagation(); setOpen(btn.getAttribute('aria-expanded') !== 'true'); };
      header.addEventListener('click', function (e) {
        var link = e.target.closest('a.hub-menu__link, a.hub-menu__brand, a.hub-menu__reserve-btn');
        if (link) { setOpen(false); }
      });
      header.querySelectorAll('button[data-placeholder]').forEach(function (el) {
        el.addEventListener('click', function (e) { e.preventDefault(); });
      });
    }
    function closeMenu() {
      var header = document.querySelector('.hub-header');
      if (header) header.classList.remove('is-menu-open');
      document.documentElement.classList.remove('osa-nav-lock');
      var btn = document.querySelector('.hub-header__burger');
      if (btn) { btn.setAttribute('aria-expanded', 'false'); btn.setAttribute('aria-label', 'Otevřít menu'); }
    }
    if (!window.__hubHeaderEscBound) {
      window.__hubHeaderEscBound = true;
      document.addEventListener('keydown', function (e) {
        var btn = document.querySelector('.hub-header__burger');
        if (e.key === 'Escape' && btn && btn.getAttribute('aria-expanded') === 'true') closeMenu();
      });
    }
    document.addEventListener('astro:page-load', function () { closeMenu(); bindMenu(); });
    bindMenu();
  }());
</script>

<script is:inline>
  /* Scroll past hero → header dostane class `is-stuck` (overlay → pevné pozadí +
     odhalí logo a Rezervace v liště). */
  (function () {
    if (window.__hubHeaderStuckBound) return;
    window.__hubHeaderStuckBound = true;
    function initStuck() {
      var header = document.querySelector('.hub-header');
      if (!header) return;
      if (header.__hubIO) { header.__hubIO.disconnect(); header.__hubIO = null; }
      header.classList.remove('is-stuck');
      if (!('IntersectionObserver' in window)) { header.classList.add('is-stuck'); return; }
      var hero = document.querySelector('.lp-hero, .subpage-hero, .sec-hero, .apt-hero');
      if (!hero) { header.classList.add('is-stuck'); return; }
      var sentinel = document.createElement('div');
      sentinel.setAttribute('aria-hidden', 'true');
      sentinel.style.cssText = 'position:absolute;left:0;right:0;bottom:1px;height:1px;pointer-events:none;';
      if (getComputedStyle(hero).position === 'static') hero.style.position = 'relative';
      hero.appendChild(sentinel);
      var io = new IntersectionObserver(function (entries) {
        for (var i = 0; i < entries.length; i++) header.classList.toggle('is-stuck', !entries[i].isIntersecting);
      }, { rootMargin: '-80px 0px 0px 0px', threshold: 0 });
      io.observe(sentinel);
      header.__hubIO = io;
    }
    document.addEventListener('astro:page-load', initStuck);
  }());
</script>

<style>
  .hub-header {
    --hub-bar-h: 68px;
    position: sticky; top: 0; z-index: 30; background: var(--bg); color: var(--fg);
  }
  .hub-header--dark { background: var(--plum-deep); color: var(--k-0); }
  .hub-header--overlay {
    position: fixed; top: 0; left: 0; right: 0;
    background: transparent; color: #fff;
    border-bottom: 1px solid transparent;
    transition: background 220ms ease, color 220ms ease, border-color 220ms ease;
  }
  .hub-header--overlay .hub-header__rule { display: none; }
  .hub-header--overlay.is-stuck {
    background: var(--bg); color: var(--fg); border-bottom-color: var(--border-muted);
  }
  .hub-header--dark .hub-header__rule { display: none; }
  .hub-header__rule { height: 1px; background: var(--k-10); }

  /* Menu otevřené: lišta i plocha plum-deep, X bílé. */
  .hub-header.is-menu-open { background: transparent; color: #fff; border-bottom-color: transparent; }
  :global(html.osa-nav-lock) .hub-header { z-index: 200; }
  :global(html.osa-nav-lock),
  :global(html.osa-nav-lock body) { overflow: hidden; }

  .hub-header__bar {
    position: relative; z-index: 3;
    display: flex; align-items: center; gap: var(--space-5);
    min-height: var(--hub-bar-h);
    /* viewport-fit=cover → lišta musí uhnout notchi (portrait: nahoře). */
    padding: calc(12px + env(safe-area-inset-top, 0px)) 0 12px;
    width: calc(100% - 2 * var(--gutter));
    max-width: var(--container-wide);
    margin: 0 auto;
    background: inherit;
  }
  .hub-header__brand {
    display: inline-flex; align-items: center; color: inherit; text-decoration: none;
    position: relative; z-index: 2; flex-shrink: 0; line-height: 0;
    transition: opacity 240ms var(--ease-quart), transform 240ms var(--ease-quart), visibility 0s;
  }
  :global(.hub-header__logo) { display: block; height: 18px; width: auto; flex-shrink: 0; }

  .hub-header__actions {
    display: flex; align-items: center; gap: var(--space-3);
    position: relative; z-index: 2; margin-left: auto;
  }

  /* CTA pill , Rezervace. Viditelné jen v plné liště (stuck / ne-overlay). */
  .hub-header__cta {
    position: relative; isolation: isolate; overflow: hidden;
    font: 700 var(--text-sm) / 1 var(--font-sans);
    color: inherit; padding: 8px 18px;
    border: 1px solid currentColor; border-radius: var(--radius-input);
    text-decoration: none; white-space: nowrap; flex-shrink: 0;
    transition: color 160ms cubic-bezier(0.65, 0, 0.35, 1), transform 120ms ease,
      opacity 240ms var(--ease-quart), visibility 0s;
  }
  .hub-header__cta:active { transform: scale(0.97); }
  .hub-header__cta::after {
    content: ""; position: absolute; inset: 0; z-index: -1;
    clip-path: inset(100% 0 0 0);
    transition: clip-path 220ms cubic-bezier(0.65, 0, 0.35, 1);
  }
  .hub-header__cta:hover::after,
  .hub-header__cta:focus-visible::after,
  .hub-header__cta[aria-current='page']::after { clip-path: inset(0 0 0 0); }

  .hub-header--dark .hub-header__cta::after { background: #fff; }
  .hub-header--dark .hub-header__cta:hover,
  .hub-header--dark .hub-header__cta[aria-current='page'] { color: var(--plum-deep); outline: none; }
  .hub-header--overlay.is-stuck .hub-header__cta { color: var(--accent); border-color: var(--accent); }
  .hub-header--overlay.is-stuck .hub-header__cta::after { background: var(--accent); }
  .hub-header--overlay.is-stuck .hub-header__cta:hover,
  .hub-header--overlay.is-stuck .hub-header__cta[aria-current='page'] { color: #fff; }
  .hub-header:not(.hub-header--dark):not(.hub-header--overlay) .hub-header__cta { color: var(--accent); border-color: var(--accent); }
  .hub-header:not(.hub-header--dark):not(.hub-header--overlay) .hub-header__cta::after { background: var(--accent); }
  .hub-header:not(.hub-header--dark):not(.hub-header--overlay) .hub-header__cta:hover,
  .hub-header:not(.hub-header--dark):not(.hub-header--overlay) .hub-header__cta[aria-current='page'] { color: #fff; }

  /* Skrytí loga + Rezervace nad hero (overlay bez stuck) a vždy při otevřeném
     menu (menu má vlastní logo i Rezervace). Lišta = jen hamburger. */
  .hub-header--overlay:not(.is-stuck) .hub-header__brand,
  .hub-header--overlay:not(.is-stuck) .hub-header__cta,
  .hub-header.is-menu-open .hub-header__brand,
  .hub-header.is-menu-open .hub-header__cta {
    opacity: 0; visibility: hidden; transform: translateY(-4px); pointer-events: none;
  }

  /* Burger , vždy viditelný. */
  .hub-header__burger {
    display: inline-flex; align-items: center; justify-content: center;
    width: 44px; height: 44px; padding: 0; margin: 0 -10px 0 0;
    background: transparent; border: 0; color: inherit; cursor: pointer;
    position: relative; z-index: 4;
  }
  .hub-header--overlay .hub-header__burger { color: #fff; }
  .hub-header--overlay.is-stuck .hub-header__burger { color: var(--fg); }
  .hub-header.is-menu-open .hub-header__burger { color: #fff; }
  .hub-header__burger-box { display: grid; gap: 5px; width: 22px; margin: 0 auto; }
  .hub-header__burger-box > span {
    display: block; height: 1.5px; background: currentColor; border-radius: 2px;
    transition: transform 280ms cubic-bezier(0.25, 1, 0.5, 1), opacity 160ms linear;
    transform-origin: 50% 50%;
  }
  .hub-header.is-menu-open .hub-header__burger-box > span:nth-child(1) { transform: translateY(6.5px) rotate(45deg); }
  .hub-header.is-menu-open .hub-header__burger-box > span:nth-child(2) { opacity: 0; }
  .hub-header.is-menu-open .hub-header__burger-box > span:nth-child(3) { transform: translateY(-6.5px) rotate(-45deg); }
  .hub-header__burger:focus-visible { outline: 2px solid currentColor; outline-offset: 2px; border-radius: 4px; }

  /* === Celoobrazovkové menu (plum-deep) === */
  /* Fixed inset:0 = plná plocha včetně za lištou; X (z-index 4) pluje nad ní. */
  .hub-menu {
    position: fixed; inset: 0; z-index: 2;
    overflow-y: auto;
    overscroll-behavior: contain;
    color: #fff;
    background:
      radial-gradient(ellipse at 88% 105%, hsl(calc(var(--hue) + 44) 30% 70% / 0.16) 0%, transparent 50%),
      linear-gradient(150deg, hsl(var(--hue) 41% 13%) 0%, hsl(var(--hue) 36% 18%) 100%);
    opacity: 0; visibility: hidden; pointer-events: none;
    transform: translateY(-8px);
    transition: opacity 320ms var(--ease-quart), transform 380ms var(--ease-quart), visibility 0s 380ms;
  }
  .hub-header.is-menu-open .hub-menu {
    opacity: 1; visibility: visible; pointer-events: auto; transform: none;
    transition: opacity 320ms var(--ease-quart), transform 380ms var(--ease-quart), visibility 0s;
  }
  .hub-menu__inner {
    width: calc(100% - 2 * var(--gutter)); max-width: var(--container-wide); margin: 0 auto;
    min-height: 100%;
    display: flex; flex-direction: column;
    gap: clamp(var(--space-5), 4vh, var(--space-7));
    padding: calc(var(--hub-bar-h) + clamp(var(--space-3), 3vh, var(--space-5)) + env(safe-area-inset-top, 0px)) 0 calc(clamp(var(--space-6), 6vh, var(--space-8)) + env(safe-area-inset-bottom, 0px));
  }
  .hub-menu__brand { display: inline-flex; align-items: center; color: #fff; line-height: 0; align-self: center; }
  :global(.hub-menu__logo) { display: block; height: clamp(22px, 2.6vw, 30px); width: auto; }

  .hub-menu__nav {
    display: flex; flex-direction: column; align-items: center;
    gap: clamp(2px, 1.2vh, 12px);
    flex: 1 1 auto; justify-content: center;
    width: 100%;
  }
  .hub-menu__link {
    display: inline-flex; align-items: center; gap: clamp(10px, 1.6vw, 22px);
    color: #fff; text-decoration: none;
    font: 700 clamp(1.75rem, 5.2vw, 3.5rem) / 1.04 var(--font-sans);
    letter-spacing: var(--tracking-tight);
    padding: clamp(2px, 0.5vh, 6px) 0;
    transition: color 200ms var(--ease-quart), transform 320ms var(--ease-quart), opacity 320ms var(--ease-quart);
  }
  .hub-menu__link:hover,
  .hub-menu__link:focus-visible { color: var(--rose); outline: none; }
  .hub-menu__link[aria-current='page'] { color: var(--rose); }
  .hub-menu__link:focus-visible .hub-menu__link-text {
    text-decoration: underline; text-underline-offset: 6px; text-decoration-thickness: 2px;
  }

  /* Staggered reveal odkazů při otevření. */
  .hub-menu__link { opacity: 0; transform: translateY(10px); }
  .hub-header.is-menu-open .hub-menu__link {
    opacity: 1; transform: none;
    transition: color 200ms var(--ease-quart), transform 460ms var(--ease-quart), opacity 460ms var(--ease-quart);
    transition-delay: calc(120ms + var(--i) * 45ms);
  }

  .hub-menu__foot {
    display: flex; flex-direction: column; align-items: center; gap: var(--space-3);
    padding-top: clamp(var(--space-4), 3vh, var(--space-6));
    border-top: 1px solid hsl(0 0% 100% / 0.14);
  }
  .hub-menu__reserve-btn {
    align-self: center;
    display: inline-flex; align-items: center; justify-content: center; gap: var(--space-2);
    font: 700 var(--text-md) / 1 var(--font-sans);
    padding: var(--space-3) var(--space-6);
    background: var(--rose); color: var(--plum-deep); border-radius: var(--radius-input);
    text-decoration: none; transition: background 200ms var(--ease-quart), transform 200ms var(--ease-quart);
  }
  .hub-menu__reserve-btn:hover,
  .hub-menu__reserve-btn:focus-visible { background: #fff; transform: translateY(-1px); outline: none; }
  .hub-menu__reserve-btn:focus-visible { outline: 2px solid #fff; outline-offset: 3px; }
  .hub-menu__reserve-btn :global(svg) { transition: transform 200ms var(--ease-quart); }
  .hub-menu__reserve-btn:hover :global(svg) { transform: translateX(3px); }
  .hub-menu__acct {
    display: inline-flex; align-items: center; gap: var(--space-2);
    font: 600 var(--text-md) / 1 var(--font-sans);
    color: hsl(0 0% 100% / 0.78); cursor: pointer; padding: var(--space-2) 0;
    transition: color 180ms var(--ease-quart);
  }
  .hub-menu__acct:hover { color: var(--rose); }
  .hub-menu__acct :global(svg) { flex-shrink: 0; }

  @media (max-width: 380px) {
    :global(.hub-header__logo) { height: 16px; }
  }

  /* Telefon na šířku (nízký viewport): celoobrazovkové menu má obří odkazy
     (až 3.5rem) → na ~390 px výšky by se vešlo jen se scrollem. Font škálujeme
     dle VÝŠKY (vh), stáhneme mezery a horní padding, ať se nabídka vejde celá. */
  @media (orientation: landscape) and (max-height: 560px) {
    .hub-menu__inner {
      gap: var(--space-4);
      padding-top: calc(var(--hub-bar-h) + var(--space-3));
      padding-bottom: calc(var(--space-4) + env(safe-area-inset-bottom, 0px));
    }
    .hub-menu__nav { gap: clamp(0px, 0.4vh, 6px); }
    .hub-menu__link { font-size: clamp(1.25rem, 4.6vh, 2rem); }
    .hub-menu__foot { padding-top: var(--space-4); }
  }

  @media (prefers-reduced-motion: reduce) {
    .hub-header--overlay, .hub-header__cta, .hub-header__cta::after, .hub-header__brand,
    .hub-header__burger-box > span, .hub-menu, .hub-menu__link, .hub-menu__link-arrow,
    .hub-menu__reserve-btn, .hub-menu__reserve-btn :global(svg) { transition: none; }
    .hub-menu__link { opacity: 1; transform: none; }
    .hub-header.is-menu-open .hub-menu__link { transition-delay: 0s; }
  }
</style>
