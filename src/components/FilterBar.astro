---
/*
 * FilterBar - one interactive island on the site.
 * Pure vanilla JS, <1 KB gzipped. No React.
 *
 * Filter contract:
 *   - Each ProjectCard wrapper in the target grid has
 *     data-status="<status>" data-topic="<topic>".
 *   - FilterBar writes active filters to data-* on <body> or on the grid root.
 *   - A CSS rule hides any card that doesn't match all active filter groups.
 *
 * No URL state in v1; filters reset on reload.
 */
const statuses: { value: string; label: string }[] = [
  { value: 'realizovany',  label: 'Realizované' },
  { value: 'pripravovany', label: 'Připravované' },
  { value: 've-spanku',    label: 'Ve spánku' },
];
const topics: { value: string; label: string }[] = [
  { value: 'urbanismus',  label: 'Urbanismus' },
  { value: 'kultura',     label: 'Kultura' },
  { value: 'sport',       label: 'Sport' },
  { value: 'media',       label: 'Média' },
  { value: 'vzdelavani',  label: 'Vzdělávání' },
  { value: 'tvorba',      label: 'Tvorba' },
  { value: 'komunita',    label: 'Komunita' },
  { value: 'larp',        label: 'LARP' },
];
---
<form class="osa-filter" role="search" aria-label="Filtr projektů" data-filter-bar>
  <fieldset class="osa-filter__group">
    <legend class="osa-eyebrow osa-filter__legend">Stav</legend>
    <div class="osa-filter__row">
      {statuses.map(s => (
        <button type="button" class="osa-filter__btn" data-filter="status" data-value={s.value} aria-pressed="false">{s.label}</button>
      ))}
    </div>
  </fieldset>
  <fieldset class="osa-filter__group">
    <legend class="osa-eyebrow osa-filter__legend">Téma</legend>
    <div class="osa-filter__row">
      {topics.map(t => (
        <button type="button" class="osa-filter__btn" data-filter="topic" data-value={t.value} aria-pressed="false">{t.label}</button>
      ))}
    </div>
  </fieldset>
  <button type="button" class="osa-filter__reset osa-eyebrow" data-filter-reset>Zrušit filtry</button>
</form>

<script is:inline>
  /*
   * FilterBar behavior:
   *   - Click a toggle: CSS transition runs (opacity 0 + clip-path inset from
   *     bottom + subtle translateY) over 400 ms with expo-out easing.
   *   - After transition end, we set [hidden] so the CSS grid collapses gaps.
   *   - On reveal we remove both [hidden] and [data-filter-out] in the next
   *     frame so the reverse transition plays.
   *   - Respects prefers-reduced-motion via the CSS side.
   */
  document.addEventListener('DOMContentLoaded', () => {
    const form = document.querySelector('[data-filter-bar]');
    const grid = document.querySelector('[data-filter-target]');
    if (!form || !grid) return;

    const active = { status: new Set(), topic: new Set() };
    const DURATION = 380;

    function apply() {
      grid.querySelectorAll('[data-filterable]').forEach((card) => {
        const statusOk = active.status.size === 0 || active.status.has(card.dataset.status);
        const topicOk  = active.topic.size  === 0 || active.topic.has(card.dataset.topic);
        const match = statusOk && topicOk;
        const wrapper = card.closest('[data-filter-item]') || card;

        if (match) {
          if (wrapper.hasAttribute('hidden')) {
            wrapper.removeAttribute('hidden');
            // Force reflow so the incoming transition starts from "out" state.
            void wrapper.offsetWidth;
          }
          wrapper.removeAttribute('data-filter-out');
        } else {
          wrapper.setAttribute('data-filter-out', '');
          window.setTimeout(() => {
            if (wrapper.hasAttribute('data-filter-out')) wrapper.setAttribute('hidden', '');
          }, DURATION);
        }
      });
    }

    form.addEventListener('click', (e) => {
      const target = e.target;
      if (target.matches && target.matches('[data-filter-reset]')) {
        active.status.clear();
        active.topic.clear();
        form.querySelectorAll('[data-filter]').forEach((b) => b.setAttribute('aria-pressed', 'false'));
        apply();
        return;
      }
      const btn = target.closest && target.closest('[data-filter]');
      if (!btn) return;
      const group = btn.dataset.filter;
      const value = btn.dataset.value;
      const set = active[group];
      if (set.has(value)) { set.delete(value); btn.setAttribute('aria-pressed', 'false'); }
      else                { set.add(value);    btn.setAttribute('aria-pressed', 'true'); }
      apply();
    });
  });
</script>

<style>
  .osa-filter {
    display: grid;
    gap: var(--space-5);
    padding: var(--space-6) 0;
    border-top: 1px solid var(--rule);
    border-bottom: 1px solid var(--rule);
    margin-bottom: var(--space-7);
  }
  .osa-filter__group { border: 0; padding: 0; margin: 0; display: grid; gap: var(--space-4); }
  /* The eyebrow sits tight against the button row because legend/fieldset
     layout doesn't always respect the grid gap cleanly, and the eyebrow's
     uppercase tracking makes its descender area read as optical contact.
     A small margin-bottom lifts "STAV" / "TÉMA" a few px off the first
     filter pill beneath. */
  .osa-filter__legend { color: var(--fg-muted); padding: 0; margin: 0 0 var(--space-2); }
  .osa-filter__row { display: flex; flex-wrap: wrap; gap: var(--space-3); }
  .osa-filter__btn {
    font: 600 var(--text-sm) / 1 var(--font-sans);
    letter-spacing: var(--tracking-wide);
    padding: 8px 12px;
    background: var(--bg);
    color: var(--fg);
    border: 1px solid var(--rule);
    border-radius: 0;
    cursor: pointer;
    transition: background var(--dur-fast) linear, color var(--dur-fast) linear;
  }
  .osa-filter__btn:hover { background: var(--fg); color: var(--bg); }
  .osa-filter__btn[aria-pressed='true'] {
    background: var(--fg);
    color: var(--bg);
  }
  .osa-filter__reset {
    justify-self: start;
    background: transparent;
    border: 0;
    color: var(--fg-muted);
    cursor: pointer;
    padding: 0;
    text-decoration: underline;
    text-underline-offset: 3px;
  }
  .osa-filter__reset:hover { color: var(--fg); }
</style>
