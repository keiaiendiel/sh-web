---
interface Props {
  eyebrow?: string;
  heading: string;
  ctaHref?: string;
  ctaLabel?: string;
}
const { eyebrow, heading, ctaHref, ctaLabel } = Astro.props;
---
<section class="osa-section-block" data-reveal>
  <header class="osa-section-block__head">
    {eyebrow && <span class="osa-eyebrow osa-section-block__eyebrow">{eyebrow}</span>}
    <span class="osa-section-block__rule" aria-hidden="true"></span>
  </header>
  <div class="osa-section-block__content">
    <h3 class="osa-h3 osa-section-block__heading">{heading}</h3>
    <div class="osa-section-block__body osa-body">
      <slot />
    </div>
    {ctaHref && ctaLabel && (
      <footer class="osa-section-block__foot">
        <a class="osa-inline-cta" href={ctaHref}>
          <span class="osa-inline-cta__chevron" aria-hidden="true"></span>
          <span>{ctaLabel}</span>
        </a>
      </footer>
    )}
  </div>
</section>

<style>
  .osa-section-block {
    display: grid;
    grid-template-columns: minmax(80px, 120px) 1fr;
    column-gap: var(--space-7);
    padding: var(--space-7) 0 var(--space-6);
    border-top: 1px solid var(--rule);
    align-items: start;
  }
  .osa-section-block:last-of-type { border-bottom: 1px solid var(--rule); }

  .osa-section-block__head {
    position: sticky;
    top: var(--space-5);
    display: grid;
    gap: var(--space-3);
    align-self: start;
  }
  .osa-section-block__eyebrow {
    color: var(--fg);
    font-family: var(--font-mono);
    font-size: var(--text-md);
    letter-spacing: var(--tracking-wide);
    font-weight: 600;
  }
  .osa-section-block__rule {
    display: block;
    width: 24px;
    height: 2px;
    background: var(--fg);
  }

  .osa-section-block__content {
    display: grid;
    gap: var(--space-4);
    max-width: 64ch;
  }
  .osa-section-block__heading {
    margin: 0;
    font-size: var(--text-3xl);
    letter-spacing: var(--tracking-tight);
    line-height: var(--lh-snug);
    font-weight: 600;
  }
  .osa-section-block__body { color: var(--fg); }
  .osa-section-block__body :global(p) { margin: 0 0 var(--space-3); }
  .osa-section-block__body :global(p:last-child) { margin-bottom: 0; }
  .osa-section-block__foot { margin-top: var(--space-1); }

  @media (max-width: 960px) {
    .osa-section-block {
      grid-template-columns: 1fr;
      row-gap: var(--space-3);
      padding: var(--space-6) 0 var(--space-5);
    }
    .osa-section-block__head {
      position: static;
      grid-template-columns: auto 1fr;
      align-items: center;
      gap: var(--space-3);
    }
    .osa-section-block__rule { width: 40px; }
  }

  .osa-inline-cta {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    font: 600 var(--text-sm) / 1 var(--font-sans);
    letter-spacing: var(--tracking-wide);
    color: var(--fg);
    text-decoration: underline;
    text-underline-offset: 3px;
    text-decoration-thickness: 1px;
    transition: text-underline-offset var(--dur-base) var(--ease-standard);
  }
  .osa-inline-cta:hover { text-underline-offset: 5px; opacity: 1; }
  .osa-inline-cta__chevron {
    width: 10px;
    height: 10px;
    background: currentColor;
    clip-path: polygon(0 0, 100% 50%, 0 100%);
    flex-shrink: 0;
    transition: transform var(--dur-base) var(--ease-standard);
  }
  .osa-inline-cta:hover .osa-inline-cta__chevron { transform: translateX(3px); }
</style>
