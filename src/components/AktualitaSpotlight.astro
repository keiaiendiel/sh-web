---
/*
 * AktualitaSpotlight: landing-page feature slot for the newest aktualita.
 *
 * Reads the aktuality collection, picks the most recent non-draft entry,
 * renders a magazine-style split (large hero on one side, eyebrow + title +
 * lead on the other), and follows it with a "Dalsi aktuality" CTA that points
 * to /aktuality/.
 */
import { getCollection } from 'astro:content';
import { withBase } from '../utils/url';

const all = await getCollection('aktuality', e => !e.data.draft);
const sorted = all.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
const latest = sorted[0];

const dateFormatter = new Intl.DateTimeFormat('cs-CZ', {
  day: 'numeric',
  month: 'long',
  year: 'numeric',
});

// Guarded rendering: if the collection is empty (should not happen in
// production, but Storybook and test fixtures might have it), we still want
// the component to short-circuit cleanly instead of throwing.
const href = latest ? withBase(`/aktuality/${latest.id}/`) : withBase('/aktuality/');
const humanDate = latest ? dateFormatter.format(latest.data.date) : '';
const isoDate = latest ? latest.data.date.toISOString().slice(0, 10) : '';
const firstTag = latest?.data.tags?.[0];
---
{latest && (
  <section class="osa-spotlight section" aria-labelledby="spotlight-title">
    <div class="container-wide">
      <header class="osa-spotlight__head" data-reveal>
        <span class="osa-eyebrow">Aktuálně</span>
        <h2 class="osa-h2 osa-spotlight__section-title">Nejnovější z OSA</h2>
      </header>

      <a class="osa-spotlight__card osa-nolink" href={href} aria-labelledby="spotlight-title">
        <div class="osa-spotlight__media" aria-hidden={latest.data.hero_alt ? undefined : 'true'}>
          <img src={withBase(latest.data.hero)} alt={latest.data.hero_alt ?? ''} loading="lazy" decoding="async" />
        </div>
        <div class="osa-spotlight__body">
          <div class="osa-spotlight__eyebrow">
            <time datetime={isoDate}>{humanDate}</time>
            {firstTag && (
              <>
                <span class="osa-spotlight__sep" aria-hidden="true"> · </span>
                <span>{firstTag}</span>
              </>
            )}
          </div>
          <h3 id="spotlight-title" class="osa-spotlight__title">{latest.data.title}</h3>
          <p class="osa-spotlight__lead">{latest.data.lead}</p>
          <span class="osa-spotlight__cta">
            Celý článek
            <span class="osa-spotlight__arrow" aria-hidden="true">→</span>
          </span>
        </div>
      </a>

      <div class="osa-spotlight__more" data-reveal data-reveal-delay="2">
        <a class="btn" href={withBase('/aktuality/')} data-wipe>Další aktuality</a>
      </div>
    </div>
  </section>
)}

<style>
  /*
   * Layout contract:
   *   - Outer section uses the main tier (container-wide, 1440 px) so the
   *     spotlight aligns with Landing's Hero, Gallery and ManifestoStrip.
   *   - Card is a 2-column grid on >=900 px (media left, body right). Below
   *     that it collapses to a single column with media on top.
   *   - Card is itself an <a>: the whole area is the click target. Inner
   *     elements carry no links, so there are no nested interactive regions.
   *   - osa-nolink disables the site-wide `a:hover { opacity: .6 }` rule so
   *     the card's local hover vocabulary (image saturation, rule bloom,
   *     arrow nudge, lead colour flip) can run cleanly.
   */

  .osa-spotlight {
    border-top: 1px solid var(--rule);
  }

  .osa-spotlight__head {
    display: grid;
    gap: var(--space-2);
    margin: 0 0 var(--space-6);
    max-width: 72ch;
  }
  .osa-spotlight__section-title {
    margin: 0;
  }

  /* ---------- Card ---------- */

  .osa-spotlight__card {
    display: grid;
    grid-template-columns: 1.25fr 1fr;
    gap: 0;
    border: 1px solid var(--rule);
    background: var(--bg);
    color: var(--fg);
    text-decoration: none;
    isolation: isolate;
  }
  @media (max-width: 900px) {
    .osa-spotlight__card { grid-template-columns: 1fr; }
  }

  /* ---------- Media ---------- */

  .osa-spotlight__media {
    aspect-ratio: 3 / 2;
    overflow: hidden;
    background: var(--k-5);
    border-right: 1px solid var(--rule);
  }
  @media (max-width: 900px) {
    .osa-spotlight__media {
      border-right: 0;
      border-bottom: 1px solid var(--rule);
      aspect-ratio: 16 / 9;
    }
  }
  .osa-spotlight__media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: saturate(0.92);
    transform: scale(1);
    transition:
      filter var(--dur-wipe, 280ms) var(--ease-quart, cubic-bezier(0.25, 1, 0.5, 1)),
      transform var(--dur-wipe, 280ms) var(--ease-quart, cubic-bezier(0.25, 1, 0.5, 1));
  }
  .osa-spotlight__card:hover .osa-spotlight__media img,
  .osa-spotlight__card:focus-visible .osa-spotlight__media img {
    filter: saturate(1.05);
    transform: scale(1.02);
  }

  /* ---------- Body ---------- */

  .osa-spotlight__body {
    display: grid;
    align-content: center;
    gap: var(--space-4);
    padding: clamp(var(--space-5), 3vw, var(--space-7));
  }
  .osa-spotlight__eyebrow {
    font-family: var(--font-sans);
    font-weight: 500;
    font-size: var(--text-2xs);
    letter-spacing: var(--tracking-wider);
    text-transform: uppercase;
    color: var(--fg);
    display: inline-flex;
    flex-wrap: wrap;
    align-items: baseline;
  }
  .osa-spotlight__eyebrow time { color: var(--fg); }
  .osa-spotlight__sep { color: var(--fg-muted); margin: 0 0.25em; }

  .osa-spotlight__title {
    font-family: var(--font-sans);
    font-weight: 600;
    font-size: clamp(1.75rem, 2.4vw + 0.5rem, var(--text-3xl));
    line-height: var(--lh-snug);
    letter-spacing: var(--tracking-tight);
    color: var(--fg);
    margin: 0;
    text-wrap: balance;
  }

  .osa-spotlight__lead {
    font-family: var(--font-sans);
    font-weight: 500;
    font-size: var(--text-md);
    line-height: var(--lh-normal);
    color: var(--k-50);
    margin: 0;
    max-width: 50ch;
    transition: color var(--dur-wipe, 280ms) var(--ease-quart, cubic-bezier(0.25, 1, 0.5, 1));
  }
  .osa-spotlight__card:hover .osa-spotlight__lead,
  .osa-spotlight__card:focus-visible .osa-spotlight__lead {
    color: var(--fg);
  }

  .osa-spotlight__cta {
    display: inline-flex;
    align-items: baseline;
    gap: var(--space-2);
    font-family: var(--font-sans);
    font-weight: 600;
    font-size: var(--text-sm);
    letter-spacing: var(--tracking-wide);
    color: var(--fg);
    border-bottom: 1px solid var(--rule);
    padding-bottom: 4px;
    width: fit-content;
    margin-top: var(--space-2);
    transition:
      border-color var(--dur-fast) linear,
      transform var(--dur-wipe, 280ms) var(--ease-quart, cubic-bezier(0.25, 1, 0.5, 1));
  }
  .osa-spotlight__arrow {
    display: inline-block;
    transition: transform var(--dur-base) var(--ease-standard);
  }
  .osa-spotlight__card:hover .osa-spotlight__cta,
  .osa-spotlight__card:focus-visible .osa-spotlight__cta {
    border-bottom-color: var(--fg);
  }
  .osa-spotlight__card:hover .osa-spotlight__arrow,
  .osa-spotlight__card:focus-visible .osa-spotlight__arrow {
    transform: translateX(4px);
  }

  /* ---------- Focus ---------- */

  .osa-spotlight__card:focus-visible {
    outline: 2px solid var(--fg);
    outline-offset: -2px;
  }

  /* ---------- More row ---------- */

  .osa-spotlight__more {
    margin-top: var(--space-6);
    display: flex;
    justify-content: flex-start;
  }

  /* ---------- Reduced motion ---------- */

  @media (prefers-reduced-motion: reduce) {
    .osa-spotlight__media img,
    .osa-spotlight__arrow,
    .osa-spotlight__lead,
    .osa-spotlight__cta { transition: none; }
  }
</style>
