---
---
<form class="hub-form hub-form--investor" data-form="investor" novalidate>
  <fieldset>
    <legend>Mám zájem investovat.</legend>
    <p class="hub-form__intro">Pošleme vám podrobnější dokumentaci a ozveme se, jakmile bude jasnější časování.</p>

    <label>Jméno a příjmení <input type="text" name="name" required minlength="2" /></label>
    <label>E-mail <input type="email" name="email" required /></label>
    <label>Telefon (volitelné) <input type="tel" name="phone" /></label>

    <fieldset class="hub-form__inset">
      <legend>Typ zájemce</legend>
      <label><input type="radio" name="kind" value="fyzicka" required /> Fyzická osoba</label>
      <label><input type="radio" name="kind" value="pravnicka" /> Právnická osoba</label>
      <label><input type="radio" name="kind" value="poradce" /> Poradce</label>
      <label><input type="radio" name="kind" value="fond" /> Investiční fond</label>
    </fieldset>

    <label>Orientační výše zájmu (Kč, volitelné) <input type="number" name="amount" min="0" step="100000" /></label>
    <label>Cílový roční výnos (%, volitelné) <input type="number" name="targetYield" min="0" max="20" step="0.1" /></label>
    <label class="hub-form__textarea-label">Poznámka (volitelné) <textarea name="note" rows="4" placeholder="Co byste rád(a) o záměru věděl(a) jako první?"></textarea></label>
  </fieldset>

  <button type="submit" class="hub-form__submit">Odeslat zájem</button>
  <output class="hub-form__success" hidden>
    Děkujeme. Zařadíme vás do okruhu, se kterým postupně komunikujeme detail záměru. Ozveme se vám individuálně.
  </output>
</form>

<style>
  .hub-form { display: grid; gap: 24px; max-width: 720px; }
  .hub-form fieldset { border: 0; padding: 0; }
  .hub-form > fieldset > legend { font-weight: 700; font-size: 22px; margin-bottom: 8px; }
  .hub-form__inset { padding: 16px; border: 1px solid var(--k-20, #d4d4d4) !important; border-radius: 4px; }
  .hub-form__inset > legend { font-size: 14px; font-weight: 600; padding: 0 6px; margin-left: -6px; }
  .hub-form label { display: flex; flex-direction: column; gap: 6px; padding: 6px 0; line-height: 1.5; }
  .hub-form__inset label { flex-direction: row; align-items: center; gap: 10px; }
  .hub-form input[type='text'],
  .hub-form input[type='email'],
  .hub-form input[type='tel'],
  .hub-form input[type='number'],
  .hub-form textarea { width: 100%; padding: 10px 12px; border: 1px solid var(--k-30); border-radius: 4px; font: inherit; box-sizing: border-box; }
  .hub-form textarea { resize: vertical; min-height: 100px; }
  .hub-form__textarea-label { display: grid; gap: 6px; }
  .hub-form__intro { font-size: 14px; color: var(--k-70, #4a4a4a); margin: 0 0 8px; }
  .hub-form__submit { padding: 14px 24px; background: var(--accent); color: var(--accent-on); border: 0; font-weight: 600; cursor: pointer; font-size: 16px; justify-self: start; }
  .hub-form__submit:disabled { opacity: 0.5; cursor: default; }
  .hub-form__success { padding: 16px 20px; background: var(--k-10, #ececec); border-left: 3px solid var(--accent); display: block; }
  .hub-form__success[hidden] { display: none; }
</style>

<script is:inline>
  document.addEventListener('DOMContentLoaded', () => {
    document.querySelectorAll('[data-form="investor"]').forEach((form) => {
      form.addEventListener('submit', (e) => {
        e.preventDefault();
        // eslint-disable-next-line no-console
        console.log('[investor form payload]', Object.fromEntries(new FormData(form)));
        const success = form.querySelector('.hub-form__success');
        if (success) success.hidden = false;
        const submitBtn = form.querySelector('button[type="submit"]');
        if (submitBtn) submitBtn.disabled = true;
      });
    });
  });
</script>
