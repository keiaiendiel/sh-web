---
/*
 * PhotoGrid , reálná foto-mřížka (ne zig-zag). Hover zoom, klik otevře
 * Lightbox (musí být na stránce vložen jednou). Volitelný nadpis + „více".
 *
 *   eyebrow? / heading?  , hlavička nad mřížkou
 *   images               , [{ src, alt }] (syrové cesty, withBase uvnitř)
 *   columns?             , počet sloupců na desktopu (default 4)
 *   aspect?              , aspect-ratio buňky (default "4 / 3")
 *   group                , id skupiny pro lightbox (cyklení prev/next)
 *   moreHref? / moreLabel?
 */
import Icon from './Icon.astro';
import Arrow from './Arrow.astro';
import { withBase } from '../utils/url';

interface Props {
  eyebrow?: string;
  heading?: string;
  images: { src: string; alt: string }[];
  columns?: number;
  aspect?: string;
  group: string;
  moreHref?: string;
  moreLabel?: string;
}
const { eyebrow, heading, images, columns = 4, aspect = '4 / 3', group, moreHref, moreLabel } = Astro.props;
---
<section class="pg" data-reveal>
  {(eyebrow || heading || moreHref) && (
    <header class="pg__head">
      <div class="pg__head-text">
        {eyebrow && <p class="pg__eyebrow">{eyebrow}</p>}
        {heading && <h3 class="pg__heading">{heading}</h3>}
      </div>
      {moreHref && (
        <a class="pg__more osa-nolink" href={withBase(moreHref)}>
          <span>{moreLabel ?? 'Zobrazit více'}</span>
          <Arrow dir="right" variant="chevron" size={16} weight={2.4} />
        </a>
      )}
    </header>
  )}
  <div class="pg__grid" style={`--pg-cols:${columns};--pg-aspect:${aspect};`}>
    {images.map((im) => (
      <button
        type="button"
        class="pg__cell"
        data-lb
        data-lb-src={withBase(im.src)}
        data-lb-alt={im.alt}
        data-lb-group={group}
        aria-label={`Zvětšit fotku: ${im.alt}`}>
        <img src={withBase(im.src)} alt={im.alt} loading="lazy" decoding="async" />
        <span class="pg__zoom" aria-hidden="true"><Icon name="maximize-2" size={18} strokeWidth={2} /></span>
      </button>
    ))}
  </div>
</section>

<style>
  .pg { width: 100%; }
  .pg__head {
    display: flex; align-items: flex-end; justify-content: space-between; gap: var(--space-4);
    margin-bottom: var(--space-4);
  }
  .pg__eyebrow {
    font: 500 var(--text-2xs) / 1 var(--font-sans);
    letter-spacing: var(--tracking-wider); text-transform: uppercase;
    color: var(--accent); margin: 0 0 6px;
  }
  .pg__heading {
    font: 600 clamp(1.375rem, 2.4vw, 1.875rem) / 1.1 var(--font-sans);
    letter-spacing: var(--tracking-tight); margin: 0; color: var(--fg);
  }
  .pg__more {
    display: inline-flex; align-items: center; gap: 8px; flex-shrink: 0;
    font: 600 var(--text-sm) / 1 var(--font-sans);
    color: var(--accent); text-decoration: none;
    padding: 8px 0;
  }
  .pg__more:hover { color: var(--plum-deep); }
  .pg__more :global(svg) { transition: transform 200ms var(--ease-quart); }
  .pg__more:hover :global(svg) { transform: translateX(3px); }

  .pg__grid {
    display: grid;
    grid-template-columns: repeat(var(--pg-cols, 4), minmax(0, 1fr));
    gap: clamp(10px, 1.4vw, 18px);
  }
  .pg__cell {
    position: relative;
    padding: 0; border: 0; margin: 0;
    border-radius: var(--radius-input);
    overflow: hidden;
    cursor: zoom-in;
    background: var(--bg-muted);
    aspect-ratio: var(--pg-aspect, 4 / 3);
    isolation: isolate;
  }
  .pg__cell img {
    width: 100%; height: 100%; object-fit: cover; display: block;
    transition: transform 640ms var(--ease-quart);
  }
  .pg__cell:hover img,
  .pg__cell:focus-visible img { transform: scale(1.06); }
  .pg__zoom {
    position: absolute; top: 10px; right: 10px;
    display: inline-flex; align-items: center; justify-content: center;
    width: 34px; height: 34px; border-radius: 999px;
    background: hsl(var(--hue) 41% 13% / 0.55);
    color: #fff;
    backdrop-filter: blur(3px); -webkit-backdrop-filter: blur(3px);
    opacity: 0; transform: scale(0.8);
    transition: opacity 220ms var(--ease-quart), transform 220ms var(--ease-quart);
  }
  .pg__cell:hover .pg__zoom,
  .pg__cell:focus-visible .pg__zoom { opacity: 1; transform: scale(1); }
  .pg__cell:focus-visible { outline: 2px solid var(--accent); outline-offset: 3px; }

  @media (max-width: 900px) {
    .pg__grid { grid-template-columns: repeat(min(var(--pg-cols, 4), 3), minmax(0, 1fr)); }
  }
  @media (max-width: 560px) {
    .pg__grid { grid-template-columns: repeat(2, minmax(0, 1fr)); }
  }
  @media (prefers-reduced-motion: reduce) {
    .pg__cell img, .pg__zoom, .pg__more :global(svg) { transition: none; }
  }
</style>
