---
/*
 * DataTable , obecná datová tabulka pro /investori/ nad buňkami z exportu
 * (scripts/import-zamer.py): buňka = { d: display, v: raw, f?: vzorec, h?: link }.
 *
 *   headers   , popisky sloupců (string nebo buňka s odkazem)
 *   rows      , řádky buněk
 *   foot      , volitelný součtový řádek (display stringy, '' = prázdná buňka)
 *   markYear  , zvýrazní řádek aktuálního roku (první sloupec = rok)
 *
 * Zarovnání: sloupec s většinou číselných hodnot doprava (tabular-nums).
 */
type Cell = { d: string; v?: unknown; f?: string; h?: string } | string;
type FootCell = string | { label?: string; value: string };

interface Props {
  headers: Cell[];
  rows: Cell[][];
  foot?: FootCell[];
  markYear?: boolean;
  label?: string;
}

const { headers, rows, foot, markYear = false, label } = Astro.props;

const CURRENT_YEAR = 2026;

const d = (c: Cell) => (typeof c === 'string' ? c : (c?.d ?? ''));
const v = (c: Cell) => (typeof c === 'string' ? c : c?.v);
const h = (c: Cell) => (typeof c === 'string' ? undefined : c?.h);

const colCount = headers.length;
const numericCol: boolean[] = Array.from({ length: colCount }, (_, i) => {
  let nums = 0;
  let filled = 0;
  for (const row of rows) {
    const val = v(row[i]);
    if (val === null || val === undefined || val === '' || val === '-') continue;
    filled += 1;
    if (typeof val === 'number') nums += 1;
  }
  return filled > 0 && nums / filled >= 0.5;
});
---
<div class="inv-table-wrap">
  <table class="inv-table" aria-label={label}>
    <thead>
      <tr>
        {headers.map((head, i) => (
          <th class:list={[{ num: numericCol[i] }]} data-no-typograf>
            {h(head) ? <a href={h(head)} target="_blank" rel="noopener">{d(head)}</a> : d(head)}
          </th>
        ))}
      </tr>
    </thead>
    <tbody>
      {rows.map((row) => (
        <tr class:list={[{ 'is-current': markYear && v(row[0]) === CURRENT_YEAR }]}>
          {row.map((cell, i) => (
            <td class:list={[{ num: numericCol[i], txt: !numericCol[i] }]} data-no-typograf>
              {h(cell) ? <a href={h(cell)} target="_blank" rel="noopener">{d(cell)}</a> : d(cell)}
            </td>
          ))}
        </tr>
      ))}
    </tbody>
    {foot && (
      <tfoot>
        <tr>
          {foot.map((cell, i) => {
            const value = typeof cell === 'string' ? cell : cell.value;
            const lbl = typeof cell === 'string' ? undefined : cell.label;
            return (
              <td class:list={[{ num: numericCol[i] }]} data-no-typograf>
                {lbl && <span class="foot-label">{lbl}</span>}
                {value}
              </td>
            );
          })}
        </tr>
      </tfoot>
    )}
  </table>
</div>

<style>
  td, th { white-space: pre-line; }
  .foot-label {
    display: block;
    font: 500 var(--text-2xs) / 1.3 var(--font-sans);
    letter-spacing: var(--tracking-wide);
    color: var(--fg-subtle);
    text-transform: none;
    margin-bottom: 2px;
  }
</style>
