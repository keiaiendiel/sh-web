---
/*
 * NewsCard , karta novinky (3-sloupcový grid). Obrázek nahoře, pod ním
 * datum + kategorie, nadpis, perex a patička se zdrojem + šipkou. Hover:
 * lift + zoom obrázku + posun šipky.
 *
 *   date / category / title / excerpt / source
 *   image  , { src, alt } nebo { placeholder, alt }
 *   href   , odkaz na článek (zatím # placeholder)
 */
import Arrow from './Arrow.astro';
import Icon from './Icon.astro';
import { withBase } from '../utils/url';

interface Props {
  date: string;
  category?: string;
  title: string;
  excerpt: string;
  source?: string;
  image: { src?: string; placeholder?: string; alt: string };
  href?: string;
}
const { date, category, title, excerpt, source = 'OSA II, z.s.', image, href = '#' } = Astro.props;
const isHash = href === '#';
---
<article class="news-card" data-reveal>
  <a class="news-card__link osa-nolink" href={isHash ? '#' : withBase(href)} aria-disabled={isHash ? 'true' : undefined}>
    <div class="news-card__media">
      {image.src ? (
        <img src={withBase(image.src)} alt={image.alt} loading="lazy" decoding="async" />
      ) : (
        <div class="news-card__placeholder" role="img" aria-label={image.alt}>
          <Icon name="image" size={24} strokeWidth={1.75} />
          <span>{image.placeholder}</span>
        </div>
      )}
    </div>
    <div class="news-card__body">
      <p class="news-card__meta">{date}{category && <> · <span class="news-card__cat">{category}</span></>}</p>
      <h3 class="news-card__title">{title}</h3>
      <p class="news-card__excerpt">{excerpt}</p>
      <div class="news-card__foot">
        <span class="news-card__source">{source}</span>
        <Arrow dir="right" variant="chevron" size={16} weight={2.4} class="news-card__arrow" />
      </div>
    </div>
  </a>
</article>

<style>
  .news-card {
    border: 1px solid var(--border-muted);
    border-radius: var(--radius-input);
    overflow: hidden;
    background: var(--bg);
    transition: transform 320ms var(--ease-quart), box-shadow 320ms var(--ease-quart), border-color 320ms var(--ease-quart);
  }
  .news-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 18px 40px hsl(var(--hue) 41% 13% / 0.12);
    border-color: var(--accent-rule);
  }
  .news-card__link { display: flex; flex-direction: column; height: 100%; text-decoration: none; color: inherit; }
  .news-card__media {
    aspect-ratio: 16 / 10;
    overflow: hidden;
    background: var(--bg-muted);
  }
  .news-card__media img {
    width: 100%; height: 100%; object-fit: cover; display: block;
    transition: transform 640ms var(--ease-quart);
  }
  .news-card:hover .news-card__media img { transform: scale(1.05); }
  .news-card__placeholder {
    width: 100%; height: 100%;
    display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 10px;
    padding: var(--space-5); text-align: center;
    color: var(--plum-deep);
    background:
      radial-gradient(ellipse at 85% 110%, hsl(calc(var(--hue) + 44) 28% 74% / 0.32) 0%, transparent 55%),
      linear-gradient(135deg, hsl(var(--hue) 22% 90%) 0%, hsl(var(--hue) 30% 82%) 100%);
  }
  .news-card__placeholder span { font: 500 var(--text-sm) / 1.4 var(--font-sans); max-width: 30ch; }

  .news-card__body {
    display: flex; flex-direction: column;
    gap: var(--space-3);
    padding: var(--space-5);
    flex: 1 1 auto;
  }
  .news-card__meta {
    font: 600 var(--text-2xs) / 1.2 var(--font-sans);
    letter-spacing: var(--tracking-wider);
    text-transform: uppercase;
    color: var(--fg-subtle);
    margin: 0;
  }
  .news-card__cat { color: var(--accent); }
  .news-card__title {
    font: 600 clamp(1.125rem, 1.6vw, 1.375rem) / 1.18 var(--font-sans);
    letter-spacing: var(--tracking-tight);
    color: var(--fg);
    margin: 0;
    text-wrap: balance;
    display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;
  }
  .news-card__excerpt {
    font: 500 var(--text-sm) / 1.55 var(--font-sans);
    color: var(--fg-muted);
    margin: 0;
    display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical; overflow: hidden;
  }
  .news-card__foot {
    margin-top: auto;
    padding-top: var(--space-3);
    border-top: 1px solid var(--border-muted);
    display: flex; align-items: center; justify-content: space-between; gap: var(--space-3);
  }
  .news-card__source {
    font: 600 var(--text-2xs) / 1 var(--font-sans);
    letter-spacing: var(--tracking-wide);
    color: var(--fg-subtle);
  }
  .news-card__arrow { color: var(--accent); transition: transform 220ms var(--ease-quart); }
  .news-card:hover .news-card__arrow { transform: translateX(3px); }

  @media (prefers-reduced-motion: reduce) {
    .news-card, .news-card__media img, .news-card__arrow { transition: none; }
  }
</style>
