---
interface Props {
  slug: string;
  name: string;
  description: string;
  accent: 'red' | 'coral' | 'mustard' | 'olive' | 'forest' | 'teal' | 'blue' | 'plum';
  relationship: 'autonomni' | 'pilotni' | 've-spanku';
  status?: 'realizovany' | 'pripravovany' | 've-spanku' | 'draft';
  topic?: 'urbanismus' | 'kultura' | 'sport' | 'media' | 'vzdelavani' | 'tvorba' | 'komunita' | 'larp';
  external_url?: string;
  featured?: boolean;
  filterable?: boolean;
}
const {
  slug, name, description, relationship,
  status, topic, external_url, filterable = false,
} = Astro.props;

const topicLabel: Record<NonNullable<Props['topic']>, string> = {
  urbanismus:  'Urbanismus',
  kultura:     'Kultura',
  sport:       'Sport',
  media:       'Média',
  vzdelavani:  'Vzdělávání',
  tvorba:      'Tvorba',
  komunita:    'Komunita',
  larp:        'LARP',
};

const href = external_url ?? `/projekty/${slug}/`;
const isExternal = !!external_url;
const isPaused = status === 've-spanku' || relationship === 've-spanku';

const tags: string[] = [];
if (topic) tags.push(topicLabel[topic]);
if (isPaused) tags.push('Ve spánku');
if (relationship === 'pilotni' && !isPaused) tags.push('Pilotní');
---
<a
  href={href}
  class="project-card"
  rel={isExternal ? 'noopener' : undefined}
  target={isExternal ? '_blank' : undefined}
  data-filterable={filterable ? '' : undefined}
  data-status={status}
  data-topic={topic}>
  <div class="project-card__top">
    <span class="project-card__tags osa-eyebrow">
      {tags.map((t, i) => (
        <>
          {i > 0 && <span class="project-card__tagsep" aria-hidden="true"> · </span>}
          <span class="project-card__tag">{t}</span>
        </>
      ))}
    </span>
    <h3 class="project-card__title">{name}</h3>
  </div>
  <div class="project-card__bottom">
    <p class="project-card__desc">{description}</p>
    <span class="project-card__link">
      <span class="project-card__chevron" aria-hidden="true"></span>
      <span>
        {external_url
          ? new URL(external_url).hostname.replace(/^www\./, '')
          : 'vlastní doména v přípravě'}
      </span>
    </span>
  </div>
</a>

<style>
  /* Clean typographic card. Title solid, description light gray. Hover
     animates a soft inversion using a black panel that wipes up from the
     bottom via clip-path, no layout shift, title stays in place. */
  /* Layout contract: tag+name pinned to top, description+link pinned to bottom,
     variable whitespace is the single flexible element in between. */
  .project-card {
    position: relative;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    gap: var(--space-6);
    padding: var(--space-5);
    min-height: 260px;
    border-right: 1px solid var(--rule);
    border-bottom: 1px solid var(--rule);
    background: var(--bg);
    color: var(--fg);
    text-decoration: none;
    isolation: isolate;
    overflow: hidden;
  }
  .project-card::before {
    content: '';
    position: absolute;
    inset: 0;
    background: var(--k-100);
    clip-path: inset(100% 0 0 0);
    transition: clip-path 360ms cubic-bezier(0.16, 1, 0.3, 1);
    z-index: 0;
    pointer-events: none;
  }
  .project-card:hover::before,
  .project-card:focus-visible::before {
    clip-path: inset(0 0 0 0);
  }
  .project-card > * { position: relative; z-index: 1; }

  .project-card__top,
  .project-card__bottom {
    display: grid;
    gap: var(--space-3);
  }
  .project-card__tags {
    font-size: var(--text-2xs);
    letter-spacing: var(--tracking-wider);
    color: var(--fg-muted);
    transition: color 280ms cubic-bezier(0.16, 1, 0.3, 1);
  }
  .project-card__tagsep { opacity: 0.6; }
  .project-card__title {
    font-family: var(--font-sans);
    font-weight: 600;
    font-size: var(--text-2xl);
    line-height: var(--lh-snug);
    letter-spacing: var(--tracking-tight);
    color: var(--fg);
    margin: 0;
    transition: color 280ms cubic-bezier(0.16, 1, 0.3, 1);
  }
  .project-card__desc {
    font-family: var(--font-sans);
    font-weight: 500;
    font-size: var(--text-sm);
    line-height: var(--lh-normal);
    color: var(--fg-muted);
    margin: 0;
    transition: color 280ms cubic-bezier(0.16, 1, 0.3, 1);
  }

  /* Hover: title + tags become white; description stays light gray. */
  .project-card:hover .project-card__title,
  .project-card:focus-visible .project-card__title,
  .project-card:hover .project-card__tags,
  .project-card:focus-visible .project-card__tags,
  .project-card:hover .project-card__link,
  .project-card:focus-visible .project-card__link {
    color: var(--k-0);
  }
  .project-card:hover .project-card__desc,
  .project-card:focus-visible .project-card__desc {
    color: var(--k-30);
  }
  .project-card:focus-visible { outline: 2px solid var(--fg); outline-offset: -2px; }

  @media (prefers-reduced-motion: reduce) {
    .project-card::before { transition: none; }
    .project-card__title, .project-card__tags, .project-card__desc { transition: none; }
  }
  .project-card__link {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    font-family: var(--font-sans);
    font-weight: 500;
    font-size: var(--text-sm);
    color: inherit;
    text-decoration: underline;
    text-underline-offset: 3px;
  }
  .project-card__chevron {
    display: inline-block;
    width: 10px;
    height: 10px;
    clip-path: polygon(0 0, 100% 50%, 0 100%);
    background: currentColor;
  }
</style>
