---
interface Props {
  slug: string;
  name: string;
  description: string;
  accent: 'red' | 'coral' | 'mustard' | 'olive' | 'forest' | 'teal' | 'blue' | 'plum';
  relationship: 'autonomni' | 'pilotni' | 've-spanku';
  status?: 'realizovany' | 'pripravovany' | 've-spanku' | 'draft';
  topic?: 'urbanismus' | 'kultura' | 'sport' | 'media' | 'vzdelavani' | 'tvorba' | 'komunita' | 'larp';
  external_url?: string;
  featured?: boolean;
  filterable?: boolean;
}
const {
  slug, name, description, relationship,
  status, topic, external_url, filterable = false,
} = Astro.props;

const topicLabel: Record<NonNullable<Props['topic']>, string> = {
  urbanismus:  'Urbanismus',
  kultura:     'Kultura',
  sport:       'Sport',
  media:       'Média',
  vzdelavani:  'Vzdělávání',
  tvorba:      'Tvorba',
  komunita:    'Komunita',
  larp:        'LARP',
};

const href = external_url ?? `/projekty/${slug}/`;
const isExternal = !!external_url;
const tagLabel = topic ? topicLabel[topic] : undefined;
const isPaused = status === 've-spanku' || relationship === 've-spanku';
---
<a
  href={href}
  class="project-card"
  rel={isExternal ? 'noopener' : undefined}
  target={isExternal ? '_blank' : undefined}
  data-filterable={filterable ? '' : undefined}
  data-status={status}
  data-topic={topic}>
  <div class="project-card__head">
    {tagLabel && <span class="project-card__tag osa-eyebrow">{tagLabel}</span>}
    {isPaused && <span class="project-card__tag osa-eyebrow project-card__tag--paused">Ve spánku</span>}
  </div>
  <div class="project-card__body">
    <h3 class="project-card__title">{name}</h3>
    <p class="project-card__desc">{description}</p>
  </div>
  <div class="project-card__foot">
    <span class="project-card__link">
      <span class="project-card__chevron" aria-hidden="true"></span>
      <span>
        {external_url
          ? new URL(external_url).hostname.replace(/^www\./, '')
          : 'vlastní doména v přípravě'}
      </span>
    </span>
  </div>
</a>

<style>
  .project-card {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    padding: var(--space-5);
    min-height: 240px;
    border-right: 1px solid var(--rule);
    border-bottom: 1px solid var(--rule);
    background: var(--bg);
    color: var(--fg);
    text-decoration: none;
    transition:
      background var(--dur-base) var(--ease-standard),
      color      var(--dur-base) var(--ease-standard);
  }
  .project-card:hover,
  .project-card:focus-visible {
    background: var(--fg);
    color: var(--bg);
    outline: none;
  }
  .project-card__head {
    display: flex;
    gap: var(--space-3);
    flex-wrap: wrap;
    align-items: flex-start;
  }
  .project-card__tag {
    font-size: var(--text-2xs);
    letter-spacing: var(--tracking-wider);
    padding: 2px 8px;
    border: 1px solid currentColor;
    color: currentColor;
  }
  .project-card__tag--paused { opacity: 0.6; }
  .project-card__body { margin-top: auto; display: grid; gap: var(--space-2); }
  .project-card__title {
    font-family: var(--font-sans);
    font-weight: 600;
    font-size: var(--text-2xl);
    line-height: var(--lh-snug);
    letter-spacing: var(--tracking-tight);
    color: inherit;
    margin: 0;
  }
  .project-card__desc {
    font-family: var(--font-sans);
    font-weight: 500;
    font-size: var(--text-sm);
    line-height: var(--lh-normal);
    color: inherit;
    opacity: 0.8;
    margin: 0;
  }
  .project-card__foot { display: flex; align-items: center; opacity: 0.82; }
  .project-card__link {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    font-family: var(--font-sans);
    font-weight: 500;
    font-size: var(--text-sm);
    color: inherit;
    text-decoration: underline;
    text-underline-offset: 3px;
  }
  .project-card__chevron {
    display: inline-block;
    width: 10px;
    height: 10px;
    clip-path: polygon(0 0, 100% 50%, 0 100%);
    background: currentColor;
  }
</style>
