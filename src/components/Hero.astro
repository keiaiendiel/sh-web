---
import OsaGlyph from './OsaGlyph.astro';
import SVGPattern from './SVGPattern.astro';
---
<section class="osa-hero osa-dark">
  <SVGPattern variant="dark" opacity={0.18}>
    <div class="container-wide osa-hero__inner">
      <div class="osa-hero__eyebrow osa-eyebrow">
        <OsaGlyph size="13px" />
        <span>Nezávislý spolek, od roku 2006</span>
      </div>
      <h1 class="osa-hero__h1">
        Občanské sdružení Alternativa II, z.s. je platforma pro autonomní kulturní, sportovní a společenské projekty.
        <span class="osa-hero__motto">Pomáháme tvořit…</span>
      </h1>
      <p class="osa-hero__strapline">
        Bez státních dotací. Dobrovolnickou prací a metodou DIY.
      </p>
    </div>
  </SVGPattern>
</section>

<style>
  .osa-hero {
    --fg: var(--k-0);
    --fg-muted: var(--k-30);
    --bg: var(--k-100);
    background: var(--bg);
    color: var(--fg);
  }
  .osa-hero__inner {
    padding: clamp(var(--space-8), 12vw, var(--space-10)) var(--gutter) var(--space-9);
    display: grid;
    gap: var(--space-6);
    max-width: 980px;
    margin: 0 auto;
  }
  .osa-hero__eyebrow {
    display: inline-flex; align-items: center; gap: var(--space-2);
    color: var(--fg-muted);
  }
  .osa-hero__h1 {
    font-family: var(--font-sans);
    font-weight: 600;
    font-size: clamp(2.25rem, 5vw + 0.5rem, var(--text-5xl));
    line-height: var(--lh-snug);
    letter-spacing: var(--tracking-tight);
    color: var(--fg);
    margin: 0;
    text-wrap: balance;
  }
  .osa-hero__motto {
    display: block;
    color: var(--fg-muted);
    margin-top: var(--space-4);
    font-weight: 500;
  }
  .osa-hero__strapline {
    font-family: var(--font-sans);
    font-weight: 500;
    font-size: var(--text-lg);
    color: var(--fg-muted);
    max-width: 48ch;
    margin: 0;
  }
</style>
