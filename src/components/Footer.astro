---
import SVGPattern from './SVGPattern.astro';
import { withBase } from '../utils/url';
const year = new Date().getFullYear();
---
<footer class="osa-footer osa-dark">
  <SVGPattern variant="dark" opacity={0.14}>
    <div class="container-wide osa-footer__inner">
      <div class="osa-footer__top">
        <div class="osa-footer__brandcol">
          <img src={withBase('/logo/OSA-Logo-White-Full.svg')} alt="Občanské sdružení Alternativa II" class="osa-footer__logo" />
          <p class="osa-footer__motto">Pomáháme tvořit…</p>
        </div>

        <div class="osa-footer__col">
          <div class="osa-eyebrow osa-footer__label">Navigace</div>
          <ul class="osa-footer__links">
            <li><a href={withBase('/')}>Úvod</a></li>
            <li><a href={withBase('/o-spolku/')}>O spolku</a></li>
            <li><a href={withBase('/projekty/')}>Projekty</a></li>
            <li><a href={withBase('/zapojte-se/')}>Zapojte se</a></li>
            <li><a href={withBase('/kontakty/')}>Kontakty</a></li>
          </ul>
        </div>

        <div class="osa-footer__col">
          <div class="osa-eyebrow osa-footer__label">Kontakt</div>
          <address class="osa-footer__body">
            <a href="mailto:info@osa2.cz">info@osa2.cz</a><br />
            <a href="tel:+420777786476">+420 777 786 476</a><br />
            Terronská 894/56<br />
            160 00 Praha 6
          </address>
        </div>

        <div class="osa-footer__col">
          <div class="osa-eyebrow osa-footer__label">Právní údaje</div>
          <p class="osa-footer__body osa-mono">
            IČ 270 26 345<br />
            DIČ CZ 270 26 345<br />
            Spis. zn. L 16540
          </p>
        </div>
      </div>

      <div class="rule rule--rev osa-footer__sep" role="presentation"></div>

      <p class="osa-footer__legal osa-mono">
        © {year} Občanské sdružení Alternativa II, z.s.
      </p>
    </div>
  </SVGPattern>
</footer>

<style>
  .osa-footer {
    --fg: var(--k-0);
    --fg-muted: var(--k-30);
    --bg: var(--k-100);
    color: var(--fg);
    background: var(--bg);
  }
  .osa-footer__inner    { padding: var(--space-9) var(--gutter) var(--space-6); }
  .osa-footer__top      {
    display: grid;
    grid-template-columns: 1.4fr 1fr 1fr 1fr;
    gap: var(--space-7);
    align-items: start;
  }
  .osa-footer__brandcol { display: grid; gap: var(--space-4); }
  .osa-footer__logo     { display: block; width: 100%; max-width: 160px; height: auto; }
  @media (max-width: 960px) { .osa-footer__logo { max-width: 140px; } }
  .osa-footer__motto    {
    font-family: var(--font-sans);
    font-weight: 500;
    font-size: var(--text-lg);
    color: var(--fg);
    margin: 0;
  }
  .osa-footer__label    { color: var(--fg-muted); margin-bottom: var(--space-3); }
  .osa-footer__body,
  .osa-footer__body a   { color: var(--fg); font-style: normal; font-size: var(--text-sm); line-height: var(--lh-relaxed); }
  .osa-footer__links    { display: grid; gap: var(--space-2); font-size: var(--text-sm); }
  .osa-footer__sep      { margin: var(--space-7) 0 var(--space-4); opacity: 0.4; }
  .osa-footer__legal    { color: var(--fg-muted); font-size: var(--text-xs); margin: 0; }
  @media (max-width: 960px) {
    .osa-footer__top { grid-template-columns: 1fr 1fr; }
  }
  /* Stay on two columns even on narrow phones per client direction.
     Brand + motto column stacks above the three meta columns, which
     share the two-column grid. */
  @media (max-width: 560px) {
    .osa-footer__top {
      grid-template-columns: 1fr 1fr;
      gap: var(--space-5);
    }
    .osa-footer__brandcol { grid-column: 1 / -1; }
    .osa-footer__inner { padding: var(--space-7) var(--gutter) var(--space-5); }
  }
</style>
