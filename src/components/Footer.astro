---
import { getEntry } from 'astro:content';
import { withBase } from '../utils/url';
import Arrow from './Arrow.astro';

const orgEntry = await getEntry('org', 'identity');
const org = orgEntry?.data;

const buildDate = new Date().toLocaleDateString('cs-CZ', {
  day: 'numeric', month: 'numeric', year: 'numeric',
});

/* Tři rezervační CTA na celou šířku (nahrazují zrušený landing banner). */
const reserveActions = [
  { href: '/rezervace/?cesta=apartman',   label: 'Pronajmout apartmán' },
  { href: '/rezervace/?cesta=luzko',      label: 'Pronajmout lůžko' },
  { href: '/rezervace/?cesta=stipendium', label: 'Požádat o stipendium' },
];

/* Adresa areálu , sdílená mezi odkazem „Otevřít v Mapách" a spodním pruhem. */
const gmapsHref = 'https://www.google.com/maps?q=Dolní+Kasárna+798,+250+67+Klecany';

/* Spodní pruh , drobné odkazy oddělené středovou tečkou. */
const bottomLinks: { href: string; label: string; external?: boolean }[] = [
  { href: '/kontakty/', label: 'Adresa' },
  { href: gmapsHref,    label: 'Mapa', external: true },
  { href: '/kontakty/', label: 'Kontakty' },
  { href: '/novinky/',  label: 'Akce' },
];
---
<footer class="hub-footer">
  {/* Dva sloupce: vlevo kontakty, adresa, odkazy a meta; vpravo mapa stejně vysoká. */}
  <div class="hub-footer__inner">
    {/* Levý sloupec. */}
    <div class="hub-footer__col hub-footer__col--main">
      <p class="hub-footer__label">Kontakty</p>
      <p class="hub-footer__contact-line"><a href="mailto:vpd@osa2.cz">vpd@osa2.cz</a></p>
      {org?.predseda?.phone && <p class="hub-footer__contact-line"><a href={`tel:${org.predseda.phone.replace(/\s/g,'')}`}>{org.predseda.phone}</a></p>}

      <p class="hub-footer__label hub-footer__label--mt">Adresa</p>
      <p class="hub-footer__map-intro">Kampus projektu Startovací Hub naleznete v rozvojovém území na adrese:</p>
      <p class="hub-footer__map-address">
        <strong>Dolní Kasárna 798, 250 67 Klecany (Praha-sever)</strong>
      </p>

      <p class="hub-footer__operator">
        Projekt Startovací Hub je realizován pod záštitou Občanského sdružení Alternativa II a partnerských organizací.
      </p>

      {/* Zvýrazněná orámovaná tlačítka vedle sebe. */}
      <div class="hub-footer__nav-btns">
        <a class="hub-footer__nav-btn osa-nolink" href={withBase('/investori/')}>
          <span>Pro investory</span>
          <Arrow dir="right" variant="chevron" size={15} weight={2.4} />
        </a>
        <a class="hub-footer__nav-btn osa-nolink" href={withBase('/struktura-webu/')}>
          <span>Struktura webu</span>
          <Arrow dir="right" variant="chevron" size={15} weight={2.4} />
        </a>
      </div>

      {/* Meta , drobné odkazy + datum. */}
      <div class="hub-footer__meta">
        <nav class="hub-footer__bottom-links" aria-label="Doplňkové odkazy">
          {bottomLinks.map((l, i) => (
            <>
              {i > 0 && <span class="hub-footer__sep" aria-hidden="true">·</span>}
              {l.external
                ? <a href={l.href} target="_blank" rel="noopener">{l.label}</a>
                : <a href={withBase(l.href)}>{l.label}</a>}
            </>
          ))}
        </nav>
        <p class="hub-footer__updated">Poslední aktualizace webu proběhla {buildDate}</p>
      </div>
    </div>

    {/* Pravý sloupec , odkaz do map + lazy Leaflet mapa, výška dorovnává levý sloupec. */}
    <div class="hub-footer__col hub-footer__col--map">
      <p class="hub-footer__map-link">
        <a href={gmapsHref} target="_blank" rel="noopener">Otevřít v Mapách <Arrow dir="right" variant="chevron" size={13} weight={2.4} /></a>
      </p>
      <div class="hub-footer__map-wrap">
        <div class="hub-footer__map" data-map-frame role="application" aria-label="Mapa Hubu Klecany"></div>
      </div>
    </div>
  </div>

  {/* Rezervační pruh přesunut pod oba sloupce. */}
  <div class="hub-footer__reserve" aria-label="Rezervace">
    {reserveActions.map((a) => (
      <a class="hub-footer__act-btn osa-nolink" href={withBase(a.href)}>
        <span>{a.label}</span>
        <Arrow dir="right" variant="chevron" size={16} weight={2.4} />
      </a>
    ))}
  </div>
</footer>

<script is:inline>
  /* Footer map: lazy init až při scrollu k patičce. Reusuje sdílený
     window.__hubLoadLeaflet z Base.astro (jeden Leaflet pro footer i /okoli/). */
  (function () {
    function init(el) {
      if (el.dataset.mapBound) return;
      el.dataset.mapBound = '1';
      var center = [50.179823, 14.406268];
      /* Mobile: nižší zoom (14) pro širší kontext, popup label se na malé
         ploše neúměrně rve. Desktop: zoom 16, plná detail kasárna. */
      var isMobile = window.matchMedia && window.matchMedia('(max-width: 760px)').matches;
      var initialZoom = isMobile ? 14 : 16;
      /* Stejný styling jako /okoli/ embed, žádný filter ani blend. */
      var map = L.map(el, {
        center: center, zoom: initialZoom,
        zoomControl: false, attributionControl: false,
        scrollWheelZoom: false,
      });
      var tiles = L.tileLayer('https://{s}.basemaps.cartocdn.com/rastertiles/voyager_nolabels/{z}/{x}/{y}{r}.png', {
        attribution: '&copy; <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a> &copy; <a href="https://carto.com/">CARTO</a>',
        subdomains: 'abcd', maxZoom: 19,
      }).addTo(map);
      var icon = L.divIcon({
        html:
          '<svg width="30" height="40" viewBox="0 0 28 36" fill="none" xmlns="http://www.w3.org/2000/svg">' +
          '<path d="M14 0C6.27 0 0 6.27 0 14c0 9.33 14 22 14 22S28 23.33 28 14C28 6.27 21.73 0 14 0z" fill="#5A2A5F"/>' +
          '<circle cx="14" cy="14" r="5" fill="#ffffff"/>' +
          '</svg>',
        className: '', iconSize: [30, 40], iconAnchor: [15, 40], popupAnchor: [0, -42],
      });
      var gmaps = 'https://www.google.com/maps?q=Dolní+Kasárna+798,+250+67+Klecany';
      var popupHtml =
        '<a href="' + gmaps + '" target="_blank" rel="noopener" class="ok-map-popup">' +
          '<strong>Dolní Kasárna 798, Klecany</strong>' +
          '<span class="ok-map-popup__cta">Otevřít v Mapách →</span>' +
        '</a>';
      L.marker(center, { icon: icon })
        .addTo(map)
        .bindPopup(popupHtml, { className: 'ok-map-popup-wrap' })
        .openPopup();
      L.control.attribution({ prefix: false }).addTo(map);
      /* Stejný invalidateSize beat jako /okoli/ embed: cold load + SPA
         návrat + pozdější resize (font swap, image reflow). Tile load event
         + ResizeObserver + window.load fallback. */
      requestAnimationFrame(function () { map.invalidateSize(); });
      [80, 250, 800, 1600].forEach(function (ms) {
        setTimeout(function () { map.invalidateSize(); }, ms);
      });
      tiles.once('load', function () { map.invalidateSize(); });
      if ('ResizeObserver' in window) {
        var ro = new ResizeObserver(function () { map.invalidateSize(); });
        ro.observe(el);
      }
      window.addEventListener('load', function () { map.invalidateSize(); }, { once: true });
      document.addEventListener('visibilitychange', function () {
        if (!document.hidden) map.invalidateSize();
      });
    }

    function bind() {
      var el = document.querySelector('.hub-footer [data-map-frame]');
      if (!el || !window.__hubLoadLeaflet) return;
      if (!('IntersectionObserver' in window)) {
        window.__hubLoadLeaflet(function () { init(el); });
        return;
      }
      var io = new IntersectionObserver(function (entries) {
        entries.forEach(function (e) {
          if (e.isIntersecting) {
            window.__hubLoadLeaflet(function () { init(el); });
            io.unobserve(e.target);
          }
        });
      }, { rootMargin: '300px 0px' });
      io.observe(el);
    }

    document.addEventListener('astro:page-load', bind);
  }());
</script>


<style>
  /* Plum-deep inverted footer s brand-warm gradientem (sjednoceno s rezervace
     tile, footer dark surfaces napříč webem). */
  .hub-footer {
    background:
      radial-gradient(ellipse at 88% 105%, hsl(calc(var(--hue) + 44) 30% 70% / 0.16) 0%, transparent 50%),
      linear-gradient(135deg, hsl(var(--hue) 41% 13%) 0%, hsl(var(--hue) 36% 17%) 100%);
    color: #fff;
    border-top: 1px solid var(--accent);
    padding: var(--space-7) 0 var(--space-6);
  }

  /* === Rezervační pruh (3 CTA na celou šířku) === */
  .hub-footer__reserve {
    width: calc(100% - 2 * var(--gutter));
    max-width: var(--container-wide);
    margin: var(--space-7) auto 0;
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: clamp(10px, 1.4vw, 18px);
  }
  .hub-footer__act-btn {
    display: inline-flex; align-items: center; justify-content: space-between; gap: var(--space-3);
    padding: clamp(15px, 1.6vw, 20px) clamp(18px, 1.8vw, 26px);
    font: 700 var(--text-md) / 1.1 var(--font-sans);
    color: var(--plum-deep); background: var(--rose);
    border-radius: var(--radius-input); text-decoration: none !important;
    transition: background 180ms var(--ease-quart), transform 180ms var(--ease-quart);
  }
  .hub-footer__act-btn:hover,
  .hub-footer__act-btn:focus-visible {
    background: #fff; color: var(--plum-deep); transform: translateY(-2px); outline: none;
  }
  .hub-footer__act-btn:focus-visible { outline: 2px solid #fff; outline-offset: 2px; }
  .hub-footer__act-btn :global(svg) { transition: transform 180ms var(--ease-quart); color: var(--plum-deep); flex-shrink: 0; }
  .hub-footer__act-btn:hover :global(svg) { transform: translateX(3px); }

  /* Dva sloupce: Kontakty & informace | Adresa s mapou. */
  .hub-footer__inner {
    width: calc(100% - 2 * var(--gutter));
    max-width: var(--container-wide);
    margin: 0 auto;
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: var(--space-7) clamp(24px, 4vw, 64px);
    align-items: stretch;
  }

  /* Zvýrazněná orámovaná tlačítka (Pro investory, Struktura webu) vedle sebe. */
  .hub-footer__nav-btns {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3);
    margin: var(--space-5) 0;
  }
  .hub-footer__col a.hub-footer__nav-btn {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    padding: 11px 18px;
    font: 600 var(--text-sm) / 1.1 var(--font-sans);
    color: var(--cream);
    background: hsl(0 0% 100% / 0.05);
    border: 1px solid hsl(0 0% 100% / 0.3);
    border-radius: var(--radius-input);
    text-decoration: none;
    transition: background 180ms var(--ease-quart), color 180ms var(--ease-quart),
      border-color 180ms var(--ease-quart), transform 180ms var(--ease-quart);
  }
  .hub-footer__col a.hub-footer__nav-btn:hover,
  .hub-footer__col a.hub-footer__nav-btn:focus-visible {
    background: var(--rose);
    color: var(--plum-deep);
    border-color: var(--rose);
    transform: translateY(-2px);
    outline: none;
  }
  .hub-footer__col a.hub-footer__nav-btn:focus-visible {
    outline: 2px solid var(--rose);
    outline-offset: 2px;
  }
  .hub-footer__nav-btn :global(svg) {
    transition: transform 180ms var(--ease-quart);
    flex-shrink: 0;
  }
  .hub-footer__nav-btn:hover :global(svg) { transform: translateX(3px); }

  .hub-footer__col p { margin: 0 0 6px; line-height: 1.5; font-size: var(--text-sm); color: rgba(255, 255, 255, 0.85); }
  .hub-footer__col a {
    color: var(--cream);
    text-decoration: underline;
    text-decoration-color: rgba(255, 255, 255, 0.28);
    text-underline-offset: 3px;
    transition: color 180ms ease, text-decoration-color 180ms ease;
  }
  .hub-footer__col a:hover,
  .hub-footer__col a:focus-visible {
    color: var(--rose);
    text-decoration-color: var(--rose);
    outline: none;
  }
  .hub-footer__col a:focus-visible {
    outline: 2px solid var(--rose);
    outline-offset: 2px;
    border-radius: 2px;
  }

  /* Pravý sloupec , odkaz nahoře + mapa, která dorovná výšku levého sloupce. */
  .hub-footer__col--map { display: flex; flex-direction: column; gap: var(--space-3); }
  .hub-footer__map-wrap {
    position: relative;
    flex: 1 1 auto;
    min-height: 260px;
    border-radius: var(--radius-input);
    overflow: hidden;
    background: var(--bg-muted);
    border: 1px solid var(--accent-rule);
    /* Isolation: isolate vytváří lokální stacking context, takže Leaflet
       interní z-indexy nepřebíjejí header/menu. */
    isolation: isolate;
  }
  /* Footer mapa: absolutně vyplní wrapper , nepřispívá k výšce (žádný runaway). */
  .hub-footer__map {
    position: absolute;
    inset: 0;
  }
  .hub-footer__map :global(.leaflet-container) {
    width: 100%;
    height: 100%;
    background: var(--k-05);
    font-family: var(--font-sans);
    z-index: 0;
  }
  .hub-footer__map :global(.leaflet-tile-pane) {
    filter: saturate(1.14) brightness(1.05);
  }
  .hub-footer__map :global(.leaflet-control-attribution) {
    background: rgba(255, 255, 255, 0.92) !important;
    color: var(--fg-muted) !important;
    font-size: 10px !important;
    padding: 1px 6px !important;
  }
  .hub-footer__map :global(.leaflet-control-attribution a) { color: var(--fg) !important; }
  .hub-footer__map :global(.ok-map-popup-wrap .leaflet-popup-content-wrapper) {
    background: #fff;
    color: var(--fg);
    border-radius: var(--radius-input);
    box-shadow: 0 10px 28px hsl(var(--hue) 39% 27% / 0.18);
    padding: 4px 8px;
  }
  .hub-footer__map :global(.ok-map-popup-wrap .leaflet-popup-tip) {
    background: #fff;
    box-shadow: 0 10px 28px hsl(var(--hue) 39% 27% / 0.18);
  }
  .hub-footer__map :global(.ok-map-popup) {
    display: flex;
    flex-direction: column;
    gap: 2px;
    text-decoration: none;
    color: var(--fg);
    padding: 6px 8px;
    min-width: 160px;
  }
  .hub-footer__map :global(.ok-map-popup strong) {
    font: 600 13px / 1.3 var(--font-sans);
    color: var(--fg);
  }
  .hub-footer__map :global(.ok-map-popup__cta) {
    font: 500 12px / 1.3 var(--font-sans);
    color: var(--accent);
  }

  .hub-footer__map-intro {
    margin: 0 0 var(--space-2) !important;
    font: 500 var(--text-sm) / 1.5 var(--font-sans) !important;
    color: rgba(255, 255, 255, 0.85) !important;
  }
  .hub-footer__map-address {
    margin: 0 0 var(--space-3) !important;
    font: 500 var(--text-sm) / 1.5 var(--font-sans) !important;
    color: rgba(255, 255, 255, 0.85) !important;
  }
  .hub-footer__map-address strong { color: #fff; font-weight: 600; }
  .hub-footer__map-link { margin: 0 !important; }
  .hub-footer__col .hub-footer__map-link a {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    font: 500 var(--text-sm) / 1.4 var(--font-sans);
    color: var(--rose);
    text-decoration: none;
    border-bottom: 1px solid rgba(200, 155, 176, 0.4);
    padding-bottom: 1px;
  }
  .hub-footer__col .hub-footer__map-link a:hover {
    color: #fff;
    border-bottom-color: var(--rose);
  }

  /* Section labels */
  .hub-footer__label {
    font-size: var(--text-2xs);
    letter-spacing: var(--tracking-wider);
    text-transform: uppercase;
    color: var(--rose);
    margin-bottom: var(--space-3) !important;
    font-weight: 600;
  }
  .hub-footer__label--mt { margin-top: var(--space-5) !important; }
  /* Kontakty */
  .hub-footer__contact-line { font-size: var(--text-sm); }
  .hub-footer__operator {
    margin-top: var(--space-4) !important;
    font-size: var(--text-xs) !important;
    color: rgba(255, 255, 255, 0.55) !important;
    line-height: 1.5 !important;
  }

  /* Meta blok , uvnitř levého sloupce (drobné odkazy + datum). */
  .hub-footer__meta {
    margin-top: var(--space-5);
    padding-top: var(--space-4);
    border-top: 1px solid hsl(0 0% 100% / 0.12);
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }
  /* Drobné odkazy oddělené středovou tečkou. */
  .hub-footer__bottom-links {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 4px var(--space-2);
    font-size: var(--text-sm);
  }
  .hub-footer__bottom-links a {
    color: rgba(255, 255, 255, 0.78);
    text-decoration: none;
    transition: color 180ms ease;
  }
  .hub-footer__bottom-links a:hover,
  .hub-footer__bottom-links a:focus-visible {
    color: var(--rose);
    outline: none;
  }
  .hub-footer__bottom-links a:focus-visible {
    outline: 2px solid var(--rose);
    outline-offset: 2px;
    border-radius: 2px;
  }
  .hub-footer__sep {
    color: rgba(255, 255, 255, 0.35);
    user-select: none;
  }
  .hub-footer__updated {
    font-size: var(--text-xs) !important;
    color: rgba(255, 255, 255, 0.55) !important;
    margin: 0 !important;
  }

  /* Responsive */
  /* Tablet portrait a níž , vše do jednoho sloupce (i rezervační pruh). */
  @media (max-width: 860px) {
    .hub-footer__reserve,
    .hub-footer__inner { grid-template-columns: 1fr; }
    .hub-footer__inner { gap: var(--space-6); }
    .hub-footer__map-wrap { flex: none; aspect-ratio: 16 / 9; min-height: 0; }
  }
  @media (max-width: 560px) {
    .hub-footer__col p { overflow-wrap: anywhere; word-break: break-word; }
  }

  /* Mobile: popup label se na malé footer mapě rozplácne, shrink. */
  @media (max-width: 760px) {
    .hub-footer__map :global(.ok-map-popup-wrap .leaflet-popup-content-wrapper) { padding: 2px 4px; }
    .hub-footer__map :global(.ok-map-popup) { padding: 4px 6px; min-width: 0; gap: 1px; }
    .hub-footer__map :global(.ok-map-popup strong) { font-size: 11px; }
    .hub-footer__map :global(.ok-map-popup__cta)   { font-size: 10px; }
    .hub-footer__map :global(.leaflet-marker-icon svg) { width: 22px !important; height: 30px !important; }
  }

  @media (prefers-reduced-motion: reduce) {
    .hub-footer__act-btn, .hub-footer__col a, .hub-footer__nav-btn,
    .hub-footer__act-btn :global(svg),
    .hub-footer__nav-btn :global(svg) { transition: none; }
  }
</style>
