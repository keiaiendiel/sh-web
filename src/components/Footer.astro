---
import { getEntry } from 'astro:content';
import { withBase } from '../utils/url';

const orgEntry = await getEntry('org', 'identity');
const org = orgEntry?.data;

/* Build-time stamp. Aktualizováno = den nejnovějšího deployu. */
const buildDate = new Date().toLocaleDateString('cs-CZ', {
  day: 'numeric', month: 'numeric', year: 'numeric',
});
---
<footer class="hub-footer">
  <div class="hub-footer__inner">
    <div class="hub-footer__col hub-footer__col--brand">
      <p class="hub-footer__brand">Startovací Hub Klecany</p>
      <p class="hub-footer__tagline">Bývalé vojenské kasárny nad Vltavou. Otevíráme postupně od roku 2026.</p>
      <p class="hub-footer__status">V projektové přípravě</p>
    </div>

    <div class="hub-footer__col">
      <p class="hub-footer__label">Kontakt</p>
      <p><a href="mailto:vpd@osa2.cz">vpd@osa2.cz</a></p>
      <p>Horní Kasárna Klecany<br />250 67 Klecany</p>
      <p class="hub-footer__chip">
        <a href={withBase('/rezervace/')} class="hub-footer__chip-link">Stavte se na prohlídku →</a>
      </p>
    </div>

    <div class="hub-footer__col">
      <p class="hub-footer__label">Související</p>
      <p><a href="https://www.alternativa2.info/" rel="noopener">alternativa2.info</a> <span class="hub-footer__hint">mateřský web OSA II</span></p>
      <p><a href="https://vepde.com" rel="noopener">vepde.com</a> <span class="hub-footer__hint">záměr VPD pro investory</span></p>
      <p><a href={withBase('/gdpr/')}>Ochrana osobních údajů</a></p>
    </div>

    <div class="hub-footer__col hub-footer__col--legal">
      <p class="hub-footer__label">Provozovatel</p>
      <p>Občanské sdružení Alternativa II, z.s.</p>
      <p>IČO {org?.ico ?? 'bude doplněno'} · Předseda Marek Semerád</p>
      <p class="hub-footer__legal">
        Nabídka rezervací je nezávazná. Slouží k&nbsp;registraci zájmu, není kupní ani nájemní smlouvou.
      </p>
      <p class="hub-footer__updated">Aktualizováno {buildDate}</p>
    </div>
  </div>
</footer>

<style>
  .hub-footer {
    background: var(--bg);
    color: var(--fg);
    border-top: 1px solid var(--border-muted);
    padding: var(--space-8) var(--gutter) var(--space-7);
  }
  .hub-footer__inner {
    display: grid;
    grid-template-columns: 1.4fr 1fr 1fr 1.2fr;
    gap: var(--space-7) var(--space-6);
    max-width: var(--container-wide);
    margin: 0 auto;
  }
  .hub-footer__col p { margin: 0 0 6px; line-height: 1.5; font-size: var(--text-sm); }
  .hub-footer__col a { color: inherit; text-decoration: underline; text-decoration-color: var(--border-muted); text-underline-offset: 3px; }
  .hub-footer__col a:hover { text-decoration-color: var(--accent); color: var(--accent); }

  .hub-footer__brand { font-weight: 700; font-size: var(--text-lg); margin-bottom: 6px; }
  .hub-footer__tagline { color: var(--fg-muted); max-width: 36ch; }
  .hub-footer__status {
    display: inline-block;
    margin-top: var(--space-3);
    padding: 4px 8px;
    font: 600 var(--text-2xs) / 1 var(--font-sans);
    letter-spacing: var(--tracking-wider);
    text-transform: uppercase;
    color: var(--accent);
    border: 1px solid var(--accent-rule);
    border-radius: var(--radius-input);
    background: var(--accent-soft);
  }

  .hub-footer__label {
    font-size: var(--text-2xs);
    letter-spacing: var(--tracking-wider);
    text-transform: uppercase;
    color: var(--fg-muted);
    margin-bottom: var(--space-3);
  }
  .hub-footer__muted { color: var(--fg-muted); font-size: var(--text-xs); }
  .hub-footer__hint { color: var(--fg-muted); font-size: var(--text-xs); margin-left: 4px; }
  .hub-footer__legal { font-size: var(--text-xs); color: var(--fg-muted); margin-top: var(--space-3); max-width: 38ch; line-height: 1.4; }
  .hub-footer__updated { font-size: var(--text-2xs); color: var(--fg-subtle, var(--fg-muted)); margin-top: var(--space-3); letter-spacing: var(--tracking-wider); text-transform: uppercase; font-variant-numeric: tabular-nums; }

  .hub-footer__chip { margin-top: var(--space-3) !important; }
  .hub-footer__chip-link {
    display: inline-flex;
    align-items: center;
    padding: 10px 14px;
    min-height: 40px;
    font: 600 var(--text-xs) / 1 var(--font-sans);
    color: var(--accent);
    background: var(--accent-soft);
    border: 1px solid var(--accent-rule);
    border-radius: var(--radius-input);
    text-decoration: none !important;
    transition: background 180ms ease, border-color 180ms ease, transform 180ms ease;
  }
  @media (max-width: 640px) {
    .hub-footer__chip-link { padding: 12px 16px; min-height: 44px; }
  }
  .hub-footer__chip-link:hover,
  .hub-footer__chip-link:focus-visible {
    background: var(--accent);
    color: var(--accent-on, #fff) !important;
    border-color: var(--accent);
    transform: translateY(-1px);
    outline: none;
  }

  @media (max-width: 1024px) {
    .hub-footer__inner { grid-template-columns: 1fr 1fr; }
  }
  @media (max-width: 600px) {
    .hub-footer__inner { grid-template-columns: 1fr; }
  }
</style>
