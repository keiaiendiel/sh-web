---
import { getEntry } from 'astro:content';
import { withBase } from '../utils/url';

const orgEntry = await getEntry('org', 'identity');
const org = orgEntry?.data;

const buildDate = new Date().toLocaleDateString('cs-CZ', {
  day: 'numeric', month: 'numeric', year: 'numeric',
});

/* Dev-only map tuner: floating panel se slidery pro filter parametry.
   Aktivní jen v `pnpm dev`, v produkčním buildu se vůbec nerenderuje. */
const isDev = import.meta.env.DEV;
---
<footer class="hub-footer">
  <div class="hub-footer__inner">
    <div class="hub-footer__col hub-footer__col--brand">
      <p class="hub-footer__brand">Startovací Hub Klecany</p>
      <p class="hub-footer__address">
        Horní Kasárna<br />
        250 67 Klecany
      </p>
      <div class="hub-footer__map" data-map-frame role="application" aria-label="Mapa Hubu Klecany"></div>
      <p class="hub-footer__map-address">
        <strong>Horní kasárna Klecany</strong>
        <a href="https://maps.app.goo.gl/vCF6VbW7Z49sggau6" target="_blank" rel="noopener">Otevřít v Mapách <span aria-hidden="true">→</span></a>
      </p>
    </div>

    <div class="hub-footer__col hub-footer__col--contact">
      <p class="hub-footer__label">Kontakt</p>
      <p class="hub-footer__contact-lede">Stavte se na prohlídku, nebo se zapojte do našich aktivit.</p>
      <p class="hub-footer__chip">
        <a href={withBase('/rezervace/')} class="hub-footer__chip-link">Domluvit prohlídku <span aria-hidden="true">→</span></a>
      </p>
      <p class="hub-footer__contact-line"><a href="mailto:vpd@osa2.cz">vpd@osa2.cz</a></p>
      {org?.predseda?.phone && <p class="hub-footer__contact-line"><a href={`tel:${org.predseda.phone.replace(/\s/g,'')}`}>{org.predseda.phone}</a></p>}
      <p class="hub-footer__operator">
        Provozuje Občanské sdružení Alternativa II, z.s.<br />
        IČO {org?.ico ?? 'bude doplněno'}
      </p>
    </div>

    <div class="hub-footer__col hub-footer__col--links">
      <p class="hub-footer__label">Odkazy</p>
      <p><a href="https://www.alternativa2.info/" rel="noopener">alternativa2.info</a> <span class="hub-footer__hint">mateřský web OSA II</span></p>
      <p><a href="https://vepde.com" rel="noopener">vepde.com</a> <span class="hub-footer__hint">záměr VPD pro investory</span></p>
      <p><a href={withBase('/kontakty/')}>Kontakty</a></p>
      <p><a href={withBase('/faq/')}>Časté otázky</a></p>
      <p><a href={withBase('/gdpr/')}>Ochrana osobních údajů</a></p>
    </div>

    {isDev && (
      <aside class="hub-footer__map-tuner" id="map-tuner" aria-label="Dev: ladění barev mapy">
        <header class="hub-footer__map-tuner-head">
          <strong>Map tuner</strong>
          <button type="button" data-tuner-toggle aria-label="Skrýt panel">−</button>
        </header>
        <div class="hub-footer__map-tuner-body">
          <label>
            <span>Sepia <output data-tuner-out="sepia">0.35</output></span>
            <input type="range" min="0" max="1" step="0.05" value="0.35" data-tuner="sepia" />
          </label>
          <label>
            <span>Saturate <output data-tuner-out="saturate">0.85</output></span>
            <input type="range" min="0" max="2" step="0.05" value="0.85" data-tuner="saturate" />
          </label>
          <label>
            <span>Hue rotate <output data-tuner-out="hue">200°</output></span>
            <input type="range" min="0" max="360" step="5" value="200" data-tuner="hue" />
          </label>
          <label>
            <span>Brightness <output data-tuner-out="brightness">0.94</output></span>
            <input type="range" min="0.4" max="1.5" step="0.02" value="0.94" data-tuner="brightness" />
          </label>
          <label>
            <span>Contrast <output data-tuner-out="contrast">1.05</output></span>
            <input type="range" min="0.5" max="1.8" step="0.02" value="1.05" data-tuner="contrast" />
          </label>
          <label>
            <span>Invert <output data-tuner-out="invert">0</output></span>
            <input type="range" min="0" max="1" step="0.05" value="0" data-tuner="invert" />
          </label>
          <div class="hub-footer__map-tuner-preset">
            <button type="button" data-tuner-preset="palette">Paleta var(--hue)</button>
            <button type="button" data-tuner-preset="navy">Navy</button>
            <button type="button" data-tuner-preset="reset">Default</button>
          </div>
          <textarea class="hub-footer__map-tuner-out" data-tuner-css readonly aria-label="Výsledný CSS filter"></textarea>
          <div class="hub-footer__map-tuner-actions">
            <button type="button" data-tuner-copy>Copy CSS</button>
            <span class="hub-footer__map-tuner-hint">jen v dev, do produkce se nedostane</span>
          </div>
        </div>
      </aside>
    )}

    <div class="hub-footer__col hub-footer__col--actions">
      <a class:list={['hub-footer__action', 'hub-footer__action--primary']} href={withBase('/rezervace/')}>
        Rezervujte si místo<span aria-hidden="true"> →</span>
      </a>
      <span class="hub-footer__action hub-footer__action--soon" aria-disabled="true">
        Aktuality<span class="hub-footer__action-hint">chystáme</span>
      </span>
      <p class="hub-footer__reservation-note">
        Nabídka rezervací je nezávazná, slouží k registraci zájmu.
      </p>
      <p class="hub-footer__status">V projektové přípravě</p>
      <p class="hub-footer__updated">Aktualizováno {buildDate}</p>
    </div>
  </div>
</footer>

<script is:inline>
  /* Footer map: lazy init až při scrollu k patičce. Reusuje sdílený
     window.__hubLoadLeaflet z Base.astro (jeden Leaflet pro footer i /okoli/). */
  (function () {
    function init(el) {
      if (el.dataset.mapBound) return;
      el.dataset.mapBound = '1';
      var center = [50.181447, 14.424094];
      var map = L.map(el, {
        center: center, zoom: 14,
        zoomControl: false, attributionControl: false,
        scrollWheelZoom: false, dragging: true,
      });
      L.tileLayer('https://{s}.basemaps.cartocdn.com/rastertiles/voyager_nolabels/{z}/{x}/{y}{r}.png', {
        subdomains: 'abcd', maxZoom: 19,
      }).addTo(map);
      var icon = L.divIcon({
        html:
          '<svg width="28" height="38" viewBox="0 0 28 36" fill="none" xmlns="http://www.w3.org/2000/svg">' +
          '<path d="M14 0C6.27 0 0 6.27 0 14c0 9.33 14 22 14 22S28 23.33 28 14C28 6.27 21.73 0 14 0z" fill="#c89bb0"/>' +
          '<circle cx="14" cy="14" r="5" fill="#2d1430"/>' +
          '</svg>',
        className: 'hub-footer__map-pin',
        iconSize: [28, 38], iconAnchor: [14, 38], popupAnchor: [0, -40],
      });
      var gmaps = 'https://maps.app.goo.gl/vCF6VbW7Z49sggau6';
      var popupHtml =
        '<a href="' + gmaps + '" target="_blank" rel="noopener" class="hub-footer__map-popup">' +
          '<strong>Horní kasárna Klecany</strong>' +
          '<span>Otevřít v Mapách →</span>' +
        '</a>';
      L.marker(center, { icon: icon })
        .addTo(map)
        .bindPopup(popupHtml, { className: 'hub-footer__map-popup-wrap' })
        .openPopup();
    }

    function bind() {
      var el = document.querySelector('.hub-footer [data-map-frame]');
      if (!el || !window.__hubLoadLeaflet) return;
      if (!('IntersectionObserver' in window)) {
        window.__hubLoadLeaflet(function () { init(el); });
        return;
      }
      var io = new IntersectionObserver(function (entries) {
        entries.forEach(function (e) {
          if (e.isIntersecting) {
            window.__hubLoadLeaflet(function () { init(el); });
            io.unobserve(e.target);
          }
        });
      }, { rootMargin: '300px 0px' });
      io.observe(el);
    }

    document.addEventListener('astro:page-load', bind);
  }());
</script>

{isDev && (
  <script is:inline>
    /* Map tuner: čte slidery, propaguje CSS proměnné na .hub-footer__map,
       generuje výsledný filter string a umí zkopírovat. Jen v dev. */
    (function () {
      function bindTuner() {
        var panel = document.getElementById('map-tuner');
        if (!panel || panel.dataset.tunerBound) return;
        panel.dataset.tunerBound = '1';
        var map = document.querySelector('.hub-footer__map');
        if (!map) return;

        var inputs = panel.querySelectorAll('input[data-tuner]');
        var output = panel.querySelector('[data-tuner-css]');
        var toggle = panel.querySelector('[data-tuner-toggle]');
        var copyBtn = panel.querySelector('[data-tuner-copy]');
        var presets = panel.querySelectorAll('[data-tuner-preset]');

        var values = {
          sepia: 0.35, saturate: 0.85, hue: 200,
          brightness: 0.94, contrast: 1.05, invert: 0,
        };

        function updateOutput() {
          var fs = 'invert(' + values.invert + ') ' +
                   'sepia(' + values.sepia + ') ' +
                   'saturate(' + values.saturate + ') ' +
                   'hue-rotate(' + values.hue + 'deg) ' +
                   'brightness(' + values.brightness + ') ' +
                   'contrast(' + values.contrast + ')';
          if (output) output.value = 'filter: ' + fs + ';';
        }

        function applyValues() {
          map.style.setProperty('--map-sepia', String(values.sepia));
          map.style.setProperty('--map-saturate', String(values.saturate));
          map.style.setProperty('--map-hue', String(values.hue));
          map.style.setProperty('--map-brightness', String(values.brightness));
          map.style.setProperty('--map-contrast', String(values.contrast));
          map.style.setProperty('--map-invert', String(values.invert));
          updateOutput();
        }

        function setFromInputs() {
          inputs.forEach(function (input) {
            var key = input.getAttribute('data-tuner');
            var val = parseFloat(input.value);
            values[key] = val;
            var out = panel.querySelector('[data-tuner-out="' + key + '"]');
            if (out) {
              if (key === 'hue') out.textContent = val + '°';
              else out.textContent = val.toString();
            }
          });
          applyValues();
        }

        inputs.forEach(function (input) {
          input.addEventListener('input', setFromInputs);
        });

        toggle.addEventListener('click', function () {
          panel.classList.toggle('is-collapsed');
          toggle.textContent = panel.classList.contains('is-collapsed') ? '+' : '−';
        });

        copyBtn.addEventListener('click', function () {
          if (!navigator.clipboard) return;
          navigator.clipboard.writeText(output.value).then(function () {
            var label = copyBtn.textContent;
            copyBtn.textContent = 'Zkopírováno';
            setTimeout(function () { copyBtn.textContent = label; }, 1200);
          });
        });

        presets.forEach(function (btn) {
          btn.addEventListener('click', function () {
            var preset = btn.getAttribute('data-tuner-preset');
            var newVals;
            if (preset === 'palette') {
              newVals = { sepia: 0.4, saturate: 0.9, hue: 215, brightness: 0.92, contrast: 1.08, invert: 0 };
            } else if (preset === 'navy') {
              newVals = { sepia: 0.6, saturate: 0.7, hue: 195, brightness: 0.85, contrast: 1.15, invert: 0 };
            } else {
              newVals = { sepia: 0.35, saturate: 0.85, hue: 200, brightness: 0.94, contrast: 1.05, invert: 0 };
            }
            Object.keys(newVals).forEach(function (k) {
              var input = panel.querySelector('input[data-tuner="' + k + '"]');
              if (input) input.value = newVals[k];
            });
            setFromInputs();
          });
        });

        setFromInputs();
      }

      document.addEventListener('astro:page-load', bindTuner);
    }());
  </script>
)}

<style>
  /* Plum-deep inverted footer. 4-col grid, brand col span 2 na desktopu.
     OSM map iframe s filter invert+desaturate aby zapadla do tmavého bg. */
  .hub-footer {
    background: var(--plum-deep);
    color: #fff;
    border-top: 1px solid var(--accent);
    padding: var(--space-8) 0 var(--space-7);
  }
  .hub-footer__inner {
    width: calc(100% - 2 * var(--gutter));
    max-width: var(--container-wide);
    margin: 0 auto;
    display: grid;
    grid-template-columns: 2fr 1fr 1fr 1fr;
    gap: var(--space-7) var(--space-6);
  }

  .hub-footer__col p { margin: 0 0 6px; line-height: 1.5; font-size: var(--text-sm); color: rgba(255, 255, 255, 0.85); }
  .hub-footer__col a {
    color: var(--cream);
    text-decoration: underline;
    text-decoration-color: rgba(255, 255, 255, 0.28);
    text-underline-offset: 3px;
    transition: color 180ms ease, text-decoration-color 180ms ease;
  }
  .hub-footer__col a:hover,
  .hub-footer__col a:focus-visible {
    color: var(--rose);
    text-decoration-color: var(--rose);
    outline: none;
  }
  .hub-footer__col a:focus-visible {
    outline: 2px solid var(--rose);
    outline-offset: 2px;
    border-radius: 2px;
  }

  /* Column 1: Brand + Address + Map */
  .hub-footer__brand {
    font-weight: 700;
    font-size: var(--text-xl);
    margin-bottom: var(--space-3);
    color: #fff;
    letter-spacing: var(--tracking-tight);
  }
  .hub-footer__address {
    color: rgba(255, 255, 255, 0.85);
    margin-bottom: var(--space-4) !important;
  }
  .hub-footer__map {
    position: relative;
    aspect-ratio: 16 / 9;
    border-radius: var(--radius-input);
    overflow: hidden;
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid rgba(255, 255, 255, 0.14);
    margin-top: var(--space-5);
    /* Filter řízený CSS proměnnými, aby šel live-tweakovat z dev tuneru
        (panel je v pravém dolním rohu jen v `pnpm dev`). Defaulty jsou
        současný production tint. */
    --map-sepia: 0.35;
    --map-saturate: 0.85;
    --map-hue: 200;
    --map-brightness: 0.94;
    --map-contrast: 1.05;
    --map-invert: 0;
    filter:
      invert(var(--map-invert))
      sepia(var(--map-sepia))
      saturate(var(--map-saturate))
      hue-rotate(calc(var(--map-hue) * 1deg))
      brightness(var(--map-brightness))
      contrast(var(--map-contrast));
  }
  .hub-footer__map :global(.leaflet-container) {
    width: 100%;
    height: 100%;
    background: var(--plum-deep);
    font-family: var(--font-sans);
    cursor: grab;
  }
  .hub-footer__map :global(.leaflet-container:active) { cursor: grabbing; }
  /* Schovat attribution + report a problem text */
  .hub-footer__map :global(.leaflet-control-attribution),
  .hub-footer__map :global(.leaflet-control-zoom),
  .hub-footer__map :global(.leaflet-bar) { display: none !important; }
  /* Pin styling */
  .hub-footer__map :global(.hub-footer__map-pin) {
    background: transparent;
    border: 0;
  }
  /* Popup: cream bg, plum-deep text */
  .hub-footer__map :global(.hub-footer__map-popup-wrap .leaflet-popup-content-wrapper) {
    background: var(--cream);
    color: var(--plum-deep);
    border-radius: var(--radius-input);
    box-shadow: 0 10px 28px hsl(var(--hue) 41% 13% / 0.32);
    padding: 4px 6px;
  }
  .hub-footer__map :global(.hub-footer__map-popup-wrap .leaflet-popup-tip) {
    background: var(--cream);
    box-shadow: 0 10px 28px hsl(var(--hue) 41% 13% / 0.32);
  }
  .hub-footer__map :global(.hub-footer__map-popup) {
    display: flex;
    flex-direction: column;
    gap: 2px;
    text-decoration: none;
    color: var(--plum-deep);
    padding: 6px 8px;
    min-width: 160px;
  }
  .hub-footer__map :global(.hub-footer__map-popup strong) {
    font: 600 13px / 1.3 var(--font-sans);
    color: var(--plum-deep);
  }
  .hub-footer__map :global(.hub-footer__map-popup span) {
    font: 500 12px / 1.3 var(--font-sans);
    color: var(--accent);
  }
  .hub-footer__map :global(.hub-footer__map-popup:hover span) {
    text-decoration: underline;
  }

  /* Address line pod mapou (matchuje /okoli/ pattern) */
  .hub-footer__map-address {
    margin: var(--space-3) 0 0 !important;
    font: 500 var(--text-sm) / 1.5 var(--font-sans) !important;
    color: rgba(255, 255, 255, 0.85) !important;
    display: flex !important;
    align-items: baseline;
    gap: var(--space-3);
    flex-wrap: wrap;
  }
  .hub-footer__map-address strong { color: #fff; font-weight: 600; }
  .hub-footer__col a.hub-footer__map-address__link,
  .hub-footer__col .hub-footer__map-address a {
    color: var(--rose);
    text-decoration: none;
    border-bottom: 1px solid rgba(200, 155, 176, 0.4);
    padding-bottom: 1px;
  }
  .hub-footer__col .hub-footer__map-address a:hover {
    color: #fff;
    border-bottom-color: var(--rose);
  }

  /* Section labels */
  .hub-footer__label {
    font-size: var(--text-2xs);
    letter-spacing: var(--tracking-wider);
    text-transform: uppercase;
    color: var(--rose);
    margin-bottom: var(--space-3) !important;
    font-weight: 600;
  }

  /* Column 2: Contact + Operator */
  .hub-footer__contact-lede {
    color: rgba(255, 255, 255, 0.85);
    margin-bottom: var(--space-3) !important;
    max-width: 30ch;
  }
  .hub-footer__contact-line { font-size: var(--text-sm); }
  .hub-footer__operator {
    margin-top: var(--space-4) !important;
    font-size: var(--text-xs) !important;
    color: rgba(255, 255, 255, 0.55) !important;
    line-height: 1.5 !important;
  }

  /* Chip CTA */
  .hub-footer__chip { margin: var(--space-3) 0 var(--space-4) !important; }
  .hub-footer__col a.hub-footer__chip-link {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    padding: 10px 16px;
    min-height: 40px;
    font: 600 var(--text-xs) / 1 var(--font-sans);
    color: var(--plum-deep);
    background: var(--rose);
    border: 1px solid var(--rose);
    border-radius: var(--radius-input);
    text-decoration: none !important;
    transition: background 180ms ease, transform 180ms ease;
  }
  .hub-footer__col a.hub-footer__chip-link:hover,
  .hub-footer__col a.hub-footer__chip-link:focus-visible {
    background: #fff;
    color: var(--plum-deep);
    border-color: #fff;
    transform: translateY(-1px);
    outline: none;
  }
  .hub-footer__col a.hub-footer__chip-link:focus-visible {
    outline: 2px solid #fff;
    outline-offset: 2px;
  }

  .hub-footer__hint { color: rgba(255, 255, 255, 0.55); font-size: var(--text-xs); margin-left: 4px; display: inline-block; }

  /* Column 4: Actions (no label, just buttons + status + meta) */
  .hub-footer__col--actions { display: flex; flex-direction: column; gap: var(--space-2); }
  .hub-footer__action {
    display: inline-flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-2);
    padding: 14px 18px;
    min-height: 48px;
    font: 600 var(--text-sm) / 1 var(--font-sans);
    border-radius: var(--radius-input);
    text-decoration: none !important;
    transition: background 180ms ease, color 180ms ease, transform 180ms ease, border-color 180ms ease;
  }
  .hub-footer__col a.hub-footer__action--primary {
    color: var(--plum-deep);
    background: var(--rose);
    border: 1px solid var(--rose);
  }
  .hub-footer__col a.hub-footer__action--primary:hover,
  .hub-footer__col a.hub-footer__action--primary:focus-visible {
    background: #fff;
    color: var(--plum-deep);
    border-color: #fff;
    transform: translateY(-1px);
    outline: none;
  }
  .hub-footer__col a.hub-footer__action--primary:focus-visible {
    outline: 2px solid #fff;
    outline-offset: 2px;
  }
  .hub-footer__action--soon {
    color: rgba(255, 255, 255, 0.55);
    background: transparent;
    border: 1px dashed rgba(255, 255, 255, 0.28);
    cursor: not-allowed;
  }
  .hub-footer__action-hint {
    font-weight: 500;
    font-size: var(--text-2xs);
    letter-spacing: var(--tracking-wider);
    text-transform: uppercase;
    color: var(--rose);
    margin-left: var(--space-2);
  }

  .hub-footer__reservation-note {
    margin-top: var(--space-3) !important;
    font-size: var(--text-xs) !important;
    color: rgba(255, 255, 255, 0.55) !important;
    line-height: 1.5;
  }

  .hub-footer__status {
    display: inline-block;
    margin-top: var(--space-4) !important;
    padding: 4px 8px;
    font: 600 var(--text-2xs) / 1 var(--font-sans);
    letter-spacing: var(--tracking-wider);
    text-transform: uppercase;
    color: var(--rose);
    border: 1px solid rgba(255, 255, 255, 0.22);
    border-radius: var(--radius-input);
    background: rgba(255, 255, 255, 0.08);
    align-self: flex-start;
  }
  .hub-footer__updated {
    font-size: var(--text-2xs) !important;
    color: rgba(255, 255, 255, 0.45) !important;
    letter-spacing: var(--tracking-wider);
    text-transform: uppercase;
    font-variant-numeric: tabular-nums;
    margin: var(--space-2) 0 0 !important;
  }

  /* Responsive */
  @media (max-width: 1024px) {
    .hub-footer__inner { grid-template-columns: 1fr 1fr; }
    .hub-footer__col--brand { grid-column: span 2; }
    .hub-footer__map { aspect-ratio: 21 / 9; }
  }
  @media (max-width: 600px) {
    .hub-footer__inner { grid-template-columns: 1fr 1fr; gap: var(--space-6) var(--space-5); }
    .hub-footer__col--brand { grid-column: span 2; }
    .hub-footer__col--actions { grid-column: span 2; }
    .hub-footer__map { aspect-ratio: 21 / 9; }
    .hub-footer__col a.hub-footer__chip-link { padding: 12px 18px; min-height: 44px; }
    .hub-footer__col--contact,
    .hub-footer__col--links { min-width: 0; }
    .hub-footer__col--contact p,
    .hub-footer__col--links p { overflow-wrap: anywhere; word-break: break-word; }
  }

  @media (prefers-reduced-motion: reduce) {
