---
/*
 * Lightbox , sdílený overlay pro zvětšení fotek. Vlož jednou na stránku.
 * Jakýkoli prvek s data-lb (+ data-lb-src, data-lb-alt, data-lb-group) ho
 * po kliknutí otevře. Prev/next cyklí v rámci skupiny. Esc / klik na pozadí
 * zavírá. Bez závislostí.
 */
import Icon from './Icon.astro';
---
<div class="lightbox" data-lightbox-root hidden>
  <button class="lightbox__close" type="button" data-lb-close aria-label="Zavřít náhled">
    <Icon name="x" size={24} strokeWidth={2} />
  </button>
  <button class="lightbox__nav lightbox__nav--prev" type="button" data-lb-prev aria-label="Předchozí fotka">
    <Icon name="chevron-left" size={28} strokeWidth={2} />
  </button>
  <figure class="lightbox__figure" data-lb-stop>
    <img class="lightbox__img" data-lb-img alt="" />
    <figcaption class="lightbox__caption" data-lb-caption></figcaption>
  </figure>
  <button class="lightbox__nav lightbox__nav--next" type="button" data-lb-next aria-label="Další fotka">
    <Icon name="chevron-right" size={28} strokeWidth={2} />
  </button>
</div>

<script is:inline>
  (function () {
    if (window.__hubLightboxBound) return;
    window.__hubLightboxBound = true;

    var group = [];
    var index = 0;

    function bind() {
      var root = document.querySelector('[data-lightbox-root]');
      if (!root || root.dataset.lbBound === '1') {
        attachTriggers();
        return;
      }
      root.dataset.lbBound = '1';
      var img = root.querySelector('[data-lb-img]');
      var caption = root.querySelector('[data-lb-caption]');

      function render() {
        var item = group[index];
        if (!item) return;
        img.src = item.src;
        img.alt = item.alt || '';
        caption.textContent = item.alt || '';
        var prev = root.querySelector('[data-lb-prev]');
        var next = root.querySelector('[data-lb-next]');
        var multi = group.length > 1;
        prev.style.display = multi ? '' : 'none';
        next.style.display = multi ? '' : 'none';
      }
      function open() {
        root.hidden = false;
        void root.offsetWidth;
        root.classList.add('is-open');
        document.documentElement.classList.add('osa-nav-lock');
        render();
      }
      function close() {
        root.classList.remove('is-open');
        document.documentElement.classList.remove('osa-nav-lock');
        setTimeout(function () { if (!root.classList.contains('is-open')) root.hidden = true; }, 240);
      }
      function step(d) { index = (index + d + group.length) % group.length; render(); }

      window.__hubLightboxOpen = function (g, i) { group = g; index = i; open(); };

      root.addEventListener('click', function (e) {
        if (e.target.closest('[data-lb-close]')) { close(); return; }
        if (e.target.closest('[data-lb-prev]')) { step(-1); return; }
        if (e.target.closest('[data-lb-next]')) { step(1); return; }
        if (!e.target.closest('[data-lb-stop]')) { close(); }
      });
      document.addEventListener('keydown', function (e) {
        if (root.hidden) return;
        if (e.key === 'Escape') close();
        else if (e.key === 'ArrowLeft') step(-1);
        else if (e.key === 'ArrowRight') step(1);
      });
      attachTriggers();
    }

    function attachTriggers() {
      var triggers = document.querySelectorAll('[data-lb]:not([data-lb-trig])');
      triggers.forEach(function (t) {
        t.dataset.lbTrig = '1';
        t.addEventListener('click', function (e) {
          e.preventDefault();
          var grpName = t.getAttribute('data-lb-group') || 'default';
          var members = [].slice.call(document.querySelectorAll('[data-lb][data-lb-group="' + grpName + '"]'));
          var g = members.map(function (m) {
            return { src: m.getAttribute('data-lb-src'), alt: m.getAttribute('data-lb-alt') || '' };
          });
          var i = members.indexOf(t);
          if (window.__hubLightboxOpen) window.__hubLightboxOpen(g, i < 0 ? 0 : i);
        });
      });
    }

    document.addEventListener('astro:page-load', bind);
  }());
</script>

<style>
  .lightbox {
    position: fixed; inset: 0; z-index: 300;
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: center;
    gap: clamp(8px, 2vw, 24px);
    padding: clamp(16px, 4vw, 48px);
    background: hsl(var(--hue) 41% 8% / 0.92);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    opacity: 0;
    transition: opacity 240ms var(--ease-quart);
  }
  .lightbox[hidden] { display: none; }
  .lightbox.is-open { opacity: 1; }

  .lightbox__figure {
    grid-column: 2;
    margin: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-3);
    max-height: 100%;
    min-width: 0;
  }
  .lightbox__img {
    max-width: 100%;
    max-height: calc(100dvh - 140px);
    object-fit: contain;
    border-radius: var(--radius-input);
    box-shadow: 0 24px 80px hsl(var(--hue) 41% 5% / 0.6);
    transform: scale(0.96);
    transition: transform 320ms var(--ease-quart);
  }
  .lightbox.is-open .lightbox__img { transform: scale(1); }
  .lightbox__caption {
    font: 500 var(--text-sm) / 1.5 var(--font-sans);
    color: rgba(255, 255, 255, 0.82);
    text-align: center;
    max-width: 60ch;
  }

  .lightbox__close {
    position: absolute; top: clamp(12px, 3vw, 28px); right: clamp(12px, 3vw, 28px);
    z-index: 2;
  }
  .lightbox__close,
  .lightbox__nav {
    display: inline-flex; align-items: center; justify-content: center;
    width: 48px; height: 48px;
    border-radius: 999px;
    border: 1px solid rgba(255, 255, 255, 0.32);
    background: rgba(255, 255, 255, 0.08);
    color: #fff; cursor: pointer;
    backdrop-filter: blur(4px); -webkit-backdrop-filter: blur(4px);
    transition: background 200ms var(--ease-quart), border-color 200ms var(--ease-quart), transform 200ms var(--ease-quart);
  }
  .lightbox__nav--prev { grid-column: 1; }
  .lightbox__nav--next { grid-column: 3; }
  .lightbox__close:hover,
  .lightbox__nav:hover {
    background: rgba(255, 255, 255, 0.18);
    border-color: #fff;
    transform: scale(1.06);
  }
  .lightbox__close:focus-visible,
  .lightbox__nav:focus-visible { outline: 2px solid #fff; outline-offset: 3px; }

  @media (max-width: 640px) {
    .lightbox__nav { width: 40px; height: 40px; }
    .lightbox__img { max-height: calc(100dvh - 180px); }
  }
  @media (prefers-reduced-motion: reduce) {
    .lightbox, .lightbox__img, .lightbox__close, .lightbox__nav { transition: none; }
  }
</style>
