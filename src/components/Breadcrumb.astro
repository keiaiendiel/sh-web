---
/*
 * Breadcrumb , stylová „eyebrow" drobečková navigace. Ukazuje, kde jsem
 * (Úvod · Zázemí · Gastronomie), poslední segment je aktuální, předchozí
 * jsou odkazy o úroveň výš. Barva přes currentColor → funguje na všech
 * variantách hero (tmavé i světlé pozadí).
 *
 *   currentLabel? , přepíše label posledního segmentu (detail pages)
 *   class?        , extra třída
 */
import { withBase } from '../utils/url';
import { buildTrail } from '../utils/breadcrumbs';

interface Props {
  currentLabel?: string;
  class?: string;
}
const { currentLabel, class: cls = '' } = Astro.props;

const baseHref = withBase('/');
let clean = Astro.url.pathname;
if (clean.startsWith(baseHref)) clean = '/' + clean.slice(baseHref.length);
const trail = buildTrail(clean, currentLabel);
---
<nav class={`crumbs ${cls}`} aria-label="Drobečková navigace">
  {trail.map((c, i) => (
    <>
      {i > 0 && <span class="crumbs__dot" aria-hidden="true">·</span>}
      {c.current ? (
        <span class="crumbs__current" aria-current="page">{c.name}</span>
      ) : (
        <a class="crumbs__link osa-nolink" href={withBase(c.key)}>{c.name}</a>
      )}
    </>
  ))}
</nav>

<style>
  .crumbs {
    display: inline-flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 7px;
    font: 500 var(--text-2xs) / 1.3 var(--font-sans);
    letter-spacing: var(--tracking-wider);
    text-transform: uppercase;
    color: inherit;
  }
  .crumbs__link {
    color: currentColor;
    opacity: 0.58;
    text-decoration: none;
    transition: opacity 160ms var(--ease-quart);
    white-space: nowrap;
  }
  .crumbs__link:hover,
  .crumbs__link:focus-visible { opacity: 1; outline: none; }
  .crumbs__link:focus-visible { text-decoration: underline; text-underline-offset: 3px; }
  .crumbs__current {
    color: currentColor;
    opacity: 1;
    font-weight: 700;
    white-space: nowrap;
  }
  .crumbs__dot { opacity: 0.4; }
</style>
