---
/*
 * OSA diagonal-line pattern, inline SVG. Uses `currentColor` so line color
 * binds to parent text color. Zero bytes over the wire beyond the inline DOM.
 *
 * Plan section 5.5 — replaces pozadi_light.jpg / pozadi_dark.jpg.
 */
interface Props {
  /** Visual variant. Controls background fill; stroke uses currentColor. */
  variant?: 'light' | 'dark';
  /** Opacity multiplier on the pattern (0..1). Default 0.22. */
  opacity?: number;
  /** Extra class on the outer wrapper. */
  class?: string;
}
const { variant = 'light', opacity = 0.22, class: className } = Astro.props;
const patternId = `osa-diag-${variant}-${Math.random().toString(36).slice(2, 8)}`;
const bg = variant === 'dark' ? 'var(--k-100)' : 'var(--k-0)';
const strokeColor = variant === 'dark' ? 'var(--k-70)' : 'var(--k-70)';
---
<div class:list={['svg-pattern', className]} data-variant={variant} style={`background:${bg}`}>
  <svg
    class="svg-pattern__fill"
    aria-hidden="true"
    style={`color:${strokeColor}`}
    preserveAspectRatio="xMidYMid slice">
    <defs>
      <pattern id={patternId} width="12" height="20.78" patternUnits="userSpaceOnUse" patternTransform="rotate(0)">
        <path d="M0,0 L12,20.78" stroke="currentColor" stroke-width="1" fill="none" vector-effect="non-scaling-stroke" opacity={opacity} />
      </pattern>
    </defs>
    <rect width="100%" height="100%" fill={`url(#${patternId})`}></rect>
  </svg>
  <div class="svg-pattern__content"><slot /></div>
</div>
<style>
  .svg-pattern {
    position: relative;
    isolation: isolate;
  }
  .svg-pattern__fill {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    z-index: 0;
    pointer-events: none;
  }
  .svg-pattern__content {
    position: relative;
    z-index: 1;
  }
</style>
