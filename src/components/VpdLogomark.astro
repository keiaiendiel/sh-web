---
/*
 * VPD logomark — 60° bevelled bar over three stacked Atyp Special Bold
 * words "Veřejně / Prospěšný / Developer". Reversible single-block.
 *
 * Color binds to currentColor; the surrounding scope (osa-dark / light)
 * decides whether the mark renders white or black.
 *
 * The wrapping element is a <span> so consumers can place it inside an
 * <h1> and supply screen-reader text via .sr-only sibling.
 */
interface Props {
  class?: string;
}
const { class: className } = Astro.props;
---
<span class:list={['vpd-logomark', className]} aria-hidden="true">
  <span class="vpd-logomark__bar"></span>
  <span class="vpd-logomark__word">Veřejně</span>
  <span class="vpd-logomark__word">Prospěšný</span>
  <span class="vpd-logomark__word">Developer</span>
</span>

<style>
  .vpd-logomark {
    display: grid;
    gap: 0;
    width: max-content;
    max-width: 100%;
    font-family: var(--font-sans);
    font-weight: 600;
    font-size: clamp(1.75rem, 3.4vw + 0.5rem, 2.875rem);
    line-height: 1;
    letter-spacing: var(--tracking-tight);
    color: currentColor;
    /* Pull the mark down so the bar's top edge lands on the cap-line of
       a sibling subhead. The line-box inset above cap-top is ≈0.15em. */
    padding-top: clamp(0.25rem, 0.35vw, 0.4rem);
  }
  .vpd-logomark__bar {
    display: block;
    height: 0.45em;
    width: 100%;
    background: currentColor;
    /* 60° bevel at bottom-left: overhang = h × cot(60°) ≈ h × 0.5774 */
    clip-path: polygon(0.26em 0, 100% 0, 100% 100%, 0 100%);
    margin-bottom: 0.18em;
  }
  .vpd-logomark__word {
    display: block;
    line-height: 1;
  }
  /* sr-only utility for the H1 text */
  :global(.sr-only) {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }
</style>
