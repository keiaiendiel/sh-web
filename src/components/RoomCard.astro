---
/**
 * RoomCard, karta typu ubytování pro /ubytovani/ overview. Vertikální
 * layout: image 4:3 nahoře, tělo s eyebrow, title, 2-col meta, popis,
 * cenový blok a Detail/Rezervovat CTA řadou. Pattern z předchozí verze
 * webu (commit bf46e2d). Visible price, m² a kapacita jsou klíčové pro
 * long-stay rozhodování per booking konvencí (Zoku, Habyt, Scape).
 */
import { withBase } from '../utils/url';

interface Props {
  eyebrow: string;
  name: string;
  velikost: string;
  kapacita: string;
  popis: string;
  cenaAnchor: number;
  perOsoba?: string;
  thumbnail?: string;
  thumbnailAlt?: string;
  detailHref: string;
  reserveHref: string;
}

const {
  eyebrow,
  name,
  velikost,
  kapacita,
  popis,
  cenaAnchor,
  perOsoba,
  thumbnail,
  thumbnailAlt = '',
  detailHref,
  reserveHref,
} = Astro.props;

const fmt = (n: number) => n.toLocaleString('cs-CZ');
---
<article class="room-card">
  <a class="room-card__thumb-link osa-nolink" href={detailHref} aria-label={`Detail typu ${name}`}>
    <div class="room-card__thumb">
      {thumbnail ? (
        <img src={withBase(thumbnail)} alt={thumbnailAlt} loading="lazy" decoding="async" />
      ) : (
        <div class="room-card__placeholder" aria-hidden="true">
          <span class="room-card__placeholder-icon">▢</span>
        </div>
      )}
      <svg class="room-card__corner" viewBox="0 0 90 90" aria-hidden="true" data-ribbon-reveal>
        <path d="M 12 78 C 30 50, 50 50, 78 22" />
      </svg>
    </div>
  </a>
  <div class="room-card__body">
    <div class="room-card__head">
      <h3 class="room-card__name">
        <a href={detailHref}>{name}</a>
      </h3>
      <p class="room-card__price">
        <span class="room-card__price-prefix">od </span>
        <span class="room-card__price-num">{fmt(cenaAnchor)}</span>
        <span class="room-card__price-unit"> Kč<span class="room-card__price-period">/měsíc</span></span>
      </p>
    </div>
    <dl class="room-card__meta">
      <div><dt>Velikost</dt><dd>{velikost}</dd></div>
      <div><dt>Kapacita</dt><dd>{kapacita}</dd></div>
    </dl>
    <div class="room-card__cta">
      <a class="room-card__cta-secondary" href={detailHref}>Detail →</a>
      <a class="room-card__cta-primary" href={reserveHref}>Rezervovat</a>
    </div>
  </div>
</article>

<style>
  .room-card {
    display: grid;
    grid-template-rows: auto 1fr;
    border: 1px solid var(--border-muted);
    border-radius: var(--radius-input);
    background: var(--bg);
    overflow: hidden;
    transition: border-color 200ms ease, transform 200ms ease, box-shadow 200ms ease;
  }
  .room-card:hover {
    border-color: var(--accent);
    transform: translateY(-2px);
    box-shadow: 0 6px 20px rgba(0, 0, 0, 0.06);
  }
  .room-card__thumb-link {
    display: block;
    text-decoration: none;
  }
  .room-card__thumb {
    position: relative;
    aspect-ratio: 4 / 3;
    background: var(--k-05);
    overflow: hidden;
  }
  .room-card__thumb img {
    width: 100%; height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 400ms ease;
  }
  .room-card:hover .room-card__thumb img {
    transform: scale(1.02);
  }
  /* Corner ribbon accent v top-right thumb area, snake-draw on first reveal.
     Stroke je white (vidí se přes foto) s plum při no-thumb placeholderu. */
  .room-card__corner {
    position: absolute;
    top: 10px;
    right: 10px;
    width: 56px;
    height: 56px;
    pointer-events: none;
    overflow: visible;
    z-index: 2;
    filter: drop-shadow(0 1px 2px rgba(0, 0, 0, 0.35));
    transition: transform 280ms var(--ease-standard);
  }
  .room-card__corner path {
    fill: none;
    stroke: #ffffff;
    stroke-width: 5;
    stroke-linecap: round;
    stroke-linejoin: round;
    opacity: 0.92;
  }
  .room-card__placeholder + .room-card__corner path,
  .room-card__thumb:not(:has(img)) .room-card__corner path {
    stroke: var(--accent);
  }
  .room-card__corner[data-ribbon-reveal] path {
    stroke-dasharray: 1;
    stroke-dashoffset: 1;
    pathLength: 1;
  }
  .room-card__corner[data-ribbon-reveal].is-revealed path {
    animation: ribbon-snake-draw 1.8s var(--ease-snake) forwards;
  }
  .room-card:hover .room-card__corner {
    transform: translate(2px, -2px);
  }
  @media (prefers-reduced-motion: reduce) {
    .room-card__corner[data-ribbon-reveal] path,
    .room-card__corner[data-ribbon-reveal].is-revealed path {
      stroke-dashoffset: 0;
      animation: none;
    }
    .room-card__corner { transition: none; }
  }
  .room-card__placeholder {
    display: flex;
    align-items: center;
    justify-content: center;
    height: 100%;
    background: var(--accent-soft);
    color: var(--accent);
  }
  .room-card__placeholder-icon {
    font-size: 2rem;
    line-height: 1;
  }
  .room-card__body {
    display: grid;
    gap: 10px;
    padding: 16px 18px 18px;
  }
  .room-card__head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 12px;
  }
  .room-card__name {
    font: 600 var(--text-lg) / 1.25 var(--font-sans);
    margin: 0;
    letter-spacing: var(--tracking-tight);
  }
  .room-card__name a {
    color: inherit;
    text-decoration: none;
  }
  .room-card__name a:hover {
    color: var(--accent);
  }
  .room-card__price {
    margin: 0;
    font: 600 var(--text-lg) / 1.25 var(--font-sans);
    color: var(--accent);
    letter-spacing: var(--tracking-tight);
    font-variant-numeric: tabular-nums;
    white-space: nowrap;
    flex-shrink: 0;
  }
  .room-card__price-prefix {
    font-weight: 500;
    color: var(--fg-soft, var(--fg));
  }
  .room-card__price-num { display: inline; }
  .room-card__price-unit {
    font-weight: 500;
    color: var(--fg-soft, var(--fg));
  }
  @media (max-width: 760px) {
    .room-card__price-period { display: none; }
  }
  .room-card__meta {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 12px;
    margin: 0;
    padding: 10px 0;
    border-top: 1px solid var(--border-muted);
    border-bottom: 1px solid var(--border-muted);
  }
  .room-card__meta > div { display: grid; gap: 2px; }
  .room-card__meta dt {
    font: 600 10px / 1.3 var(--font-sans);
    letter-spacing: var(--tracking-wider);
    text-transform: uppercase;
    color: var(--fg-subtle);
    margin: 0;
  }
  .room-card__meta dd {
    font-size: var(--text-sm);
    color: var(--fg);
    margin: 0;
    line-height: 1.35;
  }
  .room-card__cta {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    margin-top: 8px;
    flex-wrap: wrap;
  }
  .room-card__cta-secondary {
    display: inline-flex;
    align-items: center;
    font: 600 var(--text-sm) / 1 var(--font-sans);
    color: var(--fg);
    text-decoration: none;
    padding: 10px 0;
    min-height: 44px;
    border-bottom: 1px solid currentColor;
    transition: color 200ms ease;
  }
  .room-card__cta-secondary:hover { color: var(--accent); }
  .room-card__cta-primary {
    display: inline-flex;
    align-items: center;
    font: 600 var(--text-sm) / 1 var(--font-sans);
    color: var(--accent-on);
    background: var(--accent);
    padding: 12px 18px;
    min-height: 44px;
    border-radius: var(--radius-input);
    text-decoration: none;
    transition: background 200ms ease;
  }
  .room-card__cta-primary:hover {
    background: var(--k-100);
  }
</style>
