---
import { getCollection } from 'astro:content';
const pillars = (await getCollection('pillars'))
  .sort((a, b) => a.data.n.localeCompare(b.data.n));
---
<section class="osa-manifesto">
  <div class="container-wide osa-manifesto__inner">
    <header class="osa-manifesto__head" data-reveal>
      <span class="osa-eyebrow">Ekonomický model</span>
      <h2 class="osa-h1 osa-manifesto__title">Tři pilíře soběstačnosti.</h2>
      <p class="osa-manifesto__lede osa-body">
        Spolek stojí na třech zdrojích. Dobrovolnická práce, DIY metoda a vlastní hospodářská činnost dohromady tvoří základ, který nepotřebuje státní rozpočet.
      </p>
    </header>
    <ol class="osa-manifesto__list" data-reveal>
      {pillars.map((p) => (
        <li class="osa-manifesto__item">
          <span class="osa-manifesto__num">{p.data.n}</span>
          <div class="osa-manifesto__text">
            <h3 class="osa-manifesto__itemtitle">{p.data.title}</h3>
            <p class="osa-manifesto__itembody">{p.data.body}</p>
          </div>
        </li>
      ))}
    </ol>
  </div>
</section>

<style>
  .osa-manifesto {
    border-bottom: 1px solid var(--rule);
  }
  .osa-manifesto__inner {
    padding: var(--space-9) var(--gutter);
    display: grid;
    gap: var(--space-8);
    max-width: var(--container-wide);
    margin: 0 auto;
  }
  @media (max-width: 960px) {
    .osa-manifesto__inner {
      gap: var(--space-6);
      padding: var(--space-7) var(--gutter);
    }
  }

  .osa-manifesto__head {
    display: grid;
    gap: var(--space-4);
    max-width: 64ch;
  }
  .osa-manifesto__title { margin: 0; }
  .osa-manifesto__lede {
    margin: 0;
    color: var(--fg-muted);
    max-width: 60ch;
  }

  .osa-manifesto__list {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0;
    border-top: 1px solid var(--rule);
    border-left: 1px solid var(--rule);
  }
  @media (max-width: 960px) {
    .osa-manifesto__list { grid-template-columns: 1fr; }
  }
  .osa-manifesto__item {
    display: grid;
    grid-template-rows: auto auto 1fr;
    gap: var(--space-3);
    padding: var(--space-5);
    border-right: 1px solid var(--rule);
    border-bottom: 1px solid var(--rule);
    min-height: 220px;
    align-content: start;
  }

  .osa-manifesto__num {
    font-family: var(--font-mono);
    font-weight: 600;
    font-size: var(--text-lg);
    letter-spacing: var(--tracking-wide);
    color: var(--fg-muted);
  }
  .osa-manifesto__text { display: grid; gap: var(--space-3); }
  .osa-manifesto__itemtitle {
    margin: 0;
    font-weight: 600;
    font-size: var(--text-2xl);
    letter-spacing: var(--tracking-tight);
    line-height: var(--lh-snug);
    color: var(--fg);
    text-wrap: balance;
  }
  .osa-manifesto__itembody {
    margin: 0;
    color: var(--fg-muted);
    max-width: 48ch;
  }

  @media (max-width: 720px) {
    .osa-manifesto__item { padding: var(--space-4); min-height: 0; }
    .osa-manifesto__itemtitle { font-size: var(--text-xl); }
  }
</style>
