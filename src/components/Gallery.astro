---
/*
 * Gallery - responsive hover-expand photo grid.
 * Pure CSS, no JS. Columns reflow on hover: the hovered cell takes more
 * space, neighbors shrink proportionally. Reduced-motion falls back to
 * a static grid.
 *
 * Images in /public/images/ (10 placeholders shipped; add more as needed).
 * Rendered as decorative `aria-hidden` so screen readers skip them.
 */
interface Image { src: string; alt?: string; }
interface Props { images?: Image[]; }

const defaultImages: Image[] = [
  { src: '/images/474156246_1114489417070378_2341453958952153769_n.jpg' },
  { src: '/images/474471670_1114489410403712_957261942198756524_n.jpg' },
  { src: '/images/482961798_1034307312060063_7263597780288843545_n.jpg' },
  { src: '/images/482988216_1034307212060073_6494869551613273029_n.jpg' },
  { src: '/images/484066885_1034307245393403_8313211835074985229_n.jpg' },
  { src: '/images/104045992_3071753609537666_1134765034325896387_n.jpg' },
  { src: '/images/104082964_3071753366204357_6028419542031153786_n.jpg' },
  { src: '/images/104085418_3071753449537682_3735031019996797978_n.jpg' },
  { src: '/images/104121012_3071751469537880_2823918225370078705_n.jpg' },
  { src: '/images/83622937_3071752986204395_5087212010441728965_n.jpg' },
];

const { images = defaultImages } = Astro.props;
---
<section class="osa-gallery section">
  <div class="container-wide">
    <header class="osa-gallery__head">
      <span class="osa-eyebrow">Galerie</span>
      <h2 class="osa-h2 osa-gallery__title">Z provozu spolkových prostorů.</h2>
    </header>
    <ul class="osa-gallery__grid" role="list" aria-hidden="true">
      {images.map(img => (
        <li class="osa-gallery__cell">
          <img src={img.src} alt={img.alt ?? ''} loading="lazy" decoding="async" class="osa-gallery__img" />
        </li>
      ))}
    </ul>
  </div>
</section>

<style>
  .osa-gallery__head {
    display: grid;
    gap: var(--space-3);
    max-width: 56ch;
    margin: 0 0 var(--space-7);
  }
  .osa-gallery__title { margin: 0; }

  .osa-gallery__grid {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    grid-auto-rows: 180px;
    gap: 2px;
    border: 1px solid var(--rule);
  }
  @media (max-width: 960px) { .osa-gallery__grid { grid-template-columns: repeat(3, 1fr); grid-auto-rows: 160px; } }
  @media (max-width: 480px) { .osa-gallery__grid { grid-template-columns: repeat(2, 1fr); grid-auto-rows: 140px; } }

  .osa-gallery__cell {
    overflow: hidden;
    background: var(--bg-muted);
    transition: transform var(--dur-base) var(--ease-standard);
  }
  .osa-gallery__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    filter: grayscale(1) contrast(1.05);
    transition: filter var(--dur-base) var(--ease-standard),
                transform var(--dur-base) var(--ease-standard);
  }
  .osa-gallery__cell:hover {
    z-index: 2;
  }
  .osa-gallery__cell:hover .osa-gallery__img {
    filter: grayscale(0) contrast(1);
    transform: scale(1.03);
  }
  @media (prefers-reduced-motion: reduce) {
    .osa-gallery__cell:hover .osa-gallery__img { transform: none; }
  }
</style>
