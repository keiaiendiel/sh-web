---
/*
 * Gallery — inline horizontal carousel for image groups inside zigzag rows
 * and on /o-arealu/. Mobile: native scroll-snap (touch swipe). Desktop:
 * arrow buttons + dot indicator + counter. Falls back to a single image
 * when only one image is given.
 *
 * Aspect ratio is controlled by the parent via the `aspectRatio` prop
 * (default 4/3 to match the prior zigzag image ratio).
 */
import Icon from './Icon.astro';

interface GalleryImage {
  src: string;
  alt: string;
}
interface Props {
  images: GalleryImage[];
  ariaLabel: string;
  /** First slide gets loading=eager (use only on above-the-fold rows). */
  eager?: boolean;
  /** CSS aspect-ratio for the viewport, e.g. "4 / 3" or "16 / 10". */
  aspectRatio?: string;
}
const { images, ariaLabel, eager = false, aspectRatio = '4 / 3' } = Astro.props;
const single = images.length <= 1;
---
{single ? (
  <figure class="gallery gallery--single" style={`--gallery-aspect: ${aspectRatio};`}>
    <img
      src={images[0]?.src}
      alt={images[0]?.alt ?? ''}
      loading={eager ? 'eager' : 'lazy'}
      decoding="async"
    />
  </figure>
) : (
  <div
    class="gallery"
    data-gallery
    role="region"
    aria-roledescription="carousel"
    aria-label={ariaLabel}
    style={`--gallery-aspect: ${aspectRatio};`}>
    <div class="gallery__viewport" data-gallery-viewport tabindex="0">
      {images.map((img, i) => (
        <figure class="gallery__slide" data-gallery-slide aria-roledescription="slide" aria-label={`${i + 1} / ${images.length}`}>
          <img
            src={img.src}
            alt={img.alt}
            loading={eager && i === 0 ? 'eager' : 'lazy'}
            decoding="async"
          />
        </figure>
      ))}
    </div>
    <button type="button" class="gallery__btn gallery__btn--prev" data-gallery-prev aria-label="Předchozí snímek">
      <Icon name="chevron-left" size={22} strokeWidth={2} />
    </button>
    <button type="button" class="gallery__btn gallery__btn--next" data-gallery-next aria-label="Další snímek">
      <Icon name="chevron-right" size={22} strokeWidth={2} />
    </button>
    <div class="gallery__dots" role="tablist" aria-label={`Pozice v galerii: ${ariaLabel}`}>
      {images.map((_, i) => (
        <button
          type="button"
          class="gallery__dot"
          data-gallery-dot={i}
          aria-label={`Snímek ${i + 1} z ${images.length}`}>
        </button>
      ))}
    </div>
  </div>
)}

<script is:inline>
  /* Gallery init — runs on every astro:page-load (SPA nav). Idempotent: each
     gallery gets a `data-gallery-bound` flag so re-fires don't double-attach.
     The `window.__hubGalleryBound` guard keeps the page-load listener at one
     copy even when this component renders multiple times in the same page
     (each <Gallery> instance inlines this script with is:inline). */
  (function () {
    if (window.__hubGalleryBound) return;
    window.__hubGalleryBound = true;
    function initGalleries() {
      var galleries = document.querySelectorAll('[data-gallery]:not([data-gallery-bound])');
      galleries.forEach(function (gallery) {
        gallery.dataset.galleryBound = '1';
        var viewport = gallery.querySelector('[data-gallery-viewport]');
        var slides = [].slice.call(gallery.querySelectorAll('[data-gallery-slide]'));
        var dots = [].slice.call(gallery.querySelectorAll('[data-gallery-dot]'));
        var prevBtn = gallery.querySelector('[data-gallery-prev]');
        var nextBtn = gallery.querySelector('[data-gallery-next]');
        if (!viewport || !slides.length) return;

        var current = 0;

        function setActive(idx) {
          current = Math.max(0, Math.min(slides.length - 1, idx));
          dots.forEach(function (d, i) { d.classList.toggle('is-active', i === current); });
          if (prevBtn) prevBtn.disabled = current === 0;
          if (nextBtn) nextBtn.disabled = current === slides.length - 1;
        }

        function scrollToSlide(idx) {
          var slide = slides[idx];
          if (!slide || !viewport) return;
          viewport.scrollTo({ left: slide.offsetLeft, behavior: 'smooth' });
          setActive(idx);
        }

        if (prevBtn) prevBtn.addEventListener('click', function () { scrollToSlide(current - 1); });
        if (nextBtn) nextBtn.addEventListener('click', function () { scrollToSlide(current + 1); });
        dots.forEach(function (d, i) { d.addEventListener('click', function () { scrollToSlide(i); }); });

        var scrollTimer;
        viewport.addEventListener('scroll', function () {
          window.clearTimeout(scrollTimer);
          scrollTimer = window.setTimeout(function () {
            var idx = Math.round(viewport.scrollLeft / viewport.clientWidth);
            setActive(idx);
          }, 80);
        });

        viewport.addEventListener('keydown', function (e) {
          if (e.key === 'ArrowLeft') { e.preventDefault(); scrollToSlide(current - 1); }
          else if (e.key === 'ArrowRight') { e.preventDefault(); scrollToSlide(current + 1); }
        });

        setActive(0);
      });
    }
    document.addEventListener('astro:page-load', initGalleries);
  }());
</script>

<style>
  .gallery {
    position: relative;
    --gallery-radius: var(--radius-input);
  }
  .gallery--single { margin: 0; }
  .gallery--single img {
    width: 100%;
    aspect-ratio: var(--gallery-aspect, 4 / 3);
    object-fit: cover;
    display: block;
    border-radius: var(--gallery-radius);
  }
  .gallery__viewport {
    display: flex;
    overflow-x: auto;
    overflow-y: hidden;
    scroll-snap-type: x mandatory;
    scroll-behavior: smooth;
    scrollbar-width: none;
    -ms-overflow-style: none;
    border-radius: var(--gallery-radius);
    aspect-ratio: var(--gallery-aspect, 4 / 3);
    background: var(--bg-muted);
  }
  .gallery__viewport::-webkit-scrollbar { display: none; }
  .gallery__viewport:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 4px;
  }
  .gallery__slide {
    flex: 0 0 100%;
    width: 100%;
    height: 100%;
    margin: 0;
    scroll-snap-align: start;
    scroll-snap-stop: always;
  }
  .gallery__slide img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  /* Arrow buttons — desktop only. Touch swipe handles mobile.
     Bílý outline kruh + bílý chevron (Lucide SVG centruje precizně, žádný
     drift z guillemet glyphů). Soft drop-shadow drží čitelnost přes světlé
     i tmavé snímky bez bílé výplně, která by zakryla obrázek. */
  .gallery__btn {
    position: absolute;
    top: calc(50% - 22px);
    width: 44px; height: 44px;
    border-radius: 999px;
    border: 1.5px solid rgba(255, 255, 255, 0.85);
    background: transparent;
    color: #fff;
    cursor: pointer;
    display: grid;
    place-items: center;
    opacity: 0.78;
    filter: drop-shadow(0 1px 4px rgba(0, 0, 0, 0.45));
    transition:
      opacity 160ms var(--ease-decel),
      border-color 160ms var(--ease-decel),
      transform 160ms var(--ease-decel);
    z-index: 2;
  }
  .gallery__btn :global(svg) {
    /* Optické vyvážení chevronu — left chevron sedí o 1 px doprava od centra
       SVG viewBoxu, right naopak doleva, takže vizuálně visí stranou. Drobný
       posun srovná na optickou střednici tlačítka. */
    display: block;
    stroke: currentColor;
  }
  .gallery__btn--prev :global(svg) { transform: translateX(-1px); }
  .gallery__btn--next :global(svg) { transform: translateX(1px); }
  .gallery__btn:hover {
    opacity: 1;
    border-color: #fff;
    transform: scale(1.05);
  }
  .gallery__btn:focus-visible {
    opacity: 1;
    outline: 2px solid #fff;
    outline-offset: 2px;
  }
  .gallery__btn:disabled {
    opacity: 0.25;
    cursor: default;
    pointer-events: none;
  }
  .gallery__btn--prev { left: 12px; }
  .gallery__btn--next { right: 12px; }

  @media (max-width: 720px) {
    .gallery__btn { display: none; }
  }

  /* Dot indicator — visible on every breakpoint. */
  .gallery__dots {
    display: flex;
    justify-content: center;
    gap: 6px;
    margin-top: 14px;
  }
  .gallery__dot {
    width: 8px; height: 8px;
    border-radius: 999px;
    border: 0;
    padding: 0;
    background: var(--border-muted);
    cursor: pointer;
    transition:
      background 200ms var(--ease-decel),
      width 200ms var(--ease-decel);
  }
  .gallery__dot.is-active {
    background: var(--accent);
    width: 24px;
  }
  .gallery__dot:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 3px;
  }

  @media (prefers-reduced-motion: reduce) {
    .gallery__viewport { scroll-behavior: auto; }
    .gallery__btn,
    .gallery__dot { transition: none; }
  }
</style>
