---
/*
 * Gallery - 4x2 uniform grid. Every cell same aspect ratio so the grid is
 * always fully packed. No black gutters (2 px). Soft grayscale default,
 * color reveal on hover.
 */
interface Image { src: string; alt?: string; }
interface Props { images?: Image[]; }

const defaultImages: Image[] = [
  { src: '/images/474156246_1114489417070378_2341453958952153769_n.jpg' },
  { src: '/images/474471670_1114489410403712_957261942198756524_n.jpg' },
  { src: '/images/484066885_1034307245393403_8313211835074985229_n.jpg' },
  { src: '/images/104085418_3071753449537682_3735031019996797978_n.jpg' },
  { src: '/images/482961798_1034307312060063_7263597780288843545_n.jpg' },
  { src: '/images/83622937_3071752986204395_5087212010441728965_n.jpg' },
  { src: '/images/104082964_3071753366204357_6028419542031153786_n.jpg' },
  { src: '/images/482988216_1034307212060073_6494869551613273029_n.jpg' },
];

const { images = defaultImages } = Astro.props;
---
<section class="osa-gallery section--loose" data-reveal>
  <div class="container-wide">
    <header class="osa-gallery__head">
      <span class="osa-eyebrow">Galerie</span>
      <h2 class="osa-h2 osa-gallery__title">Z provozu spolkových prostorů.</h2>
    </header>
    <ul class="osa-gallery__grid" role="list" aria-hidden="true">
      {images.slice(0, 8).map((img) => (
        <li class="osa-gallery__cell">
          <img
            src={img.src}
            alt={img.alt ?? ''}
            loading="lazy"
            decoding="async"
            class="osa-gallery__img" />
        </li>
      ))}
    </ul>
  </div>
</section>

<style>
  .osa-gallery__head {
    display: grid;
    gap: var(--space-3);
    max-width: 56ch;
    margin: 0 0 var(--space-6);
  }
  .osa-gallery__title { margin: 0; }

  /* 4x2 grid, every cell 4:3 aspect. Fully packed, no gaps. */
  .osa-gallery__grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 2px;
  }
  .osa-gallery__cell {
    position: relative;
    overflow: hidden;
    background: var(--bg-muted);
    aspect-ratio: 4 / 3;
  }
  @media (max-width: 960px) { .osa-gallery__grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 540px) { .osa-gallery__grid { grid-template-columns: 1fr; } }

  .osa-gallery__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: grayscale(1) brightness(0.92);
    transition:
      filter 480ms cubic-bezier(0.16, 1, 0.3, 1),
      transform 600ms cubic-bezier(0.16, 1, 0.3, 1);
  }
  .osa-gallery__cell:hover .osa-gallery__img {
    filter: grayscale(0) brightness(1);
    transform: scale(1.03);
  }
  @media (prefers-reduced-motion: reduce) {
    .osa-gallery__img { transition: none; }
    .osa-gallery__cell:hover .osa-gallery__img { transform: none; }
  }
</style>
