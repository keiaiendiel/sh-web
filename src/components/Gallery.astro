---
/*
 * Gallery , inline horizontal carousel for image groups inside zigzag rows
 * and on /o-arealu/. Mobile: native scroll-snap (touch swipe). Desktop:
 * arrow buttons + dot indicator + counter. Falls back to a single image
 * when only one image is given.
 *
 * Aspect ratio is controlled by the parent via the `aspectRatio` prop
 * (default 4/3 to match the prior zigzag image ratio).
 */
import Icon from './Icon.astro';

type GalleryImage =
  | { src: string; alt: string }
  | { placeholder: string; alt: string };
interface Props {
  images: GalleryImage[];
  ariaLabel: string;
  /** First slide gets loading=eager (use only on above-the-fold rows). */
  eager?: boolean;
  /** CSS aspect-ratio for the viewport, e.g. "4 / 3" or "16 / 10". */
  aspectRatio?: string;
}
const { images, ariaLabel, eager = false, aspectRatio = '4 / 3' } = Astro.props;
const single = images.length <= 1;
const isImage = (i: GalleryImage): i is { src: string; alt: string } => 'src' in i;
---
{single ? (
  <figure class="gallery gallery--single" style={`--gallery-aspect: ${aspectRatio};`}>
    {images[0] && isImage(images[0]) ? (
      <img
        src={images[0].src}
        alt={images[0].alt ?? ''}
        loading={eager ? 'eager' : 'lazy'}
        decoding="async"
      />
    ) : (
      <div class="gallery__placeholder" role="img" aria-label={images[0]?.alt ?? ariaLabel}>
        <span class="gallery__placeholder-icon" aria-hidden="true">▢</span>
        <span class="gallery__placeholder-note">{images[0] && !isImage(images[0]) ? images[0].placeholder : 'Foto doplníme'}</span>
      </div>
    )}
  </figure>
) : (
  <div
    class="gallery"
    data-gallery
    role="region"
    aria-roledescription="carousel"
    aria-label={ariaLabel}
    style={`--gallery-aspect: ${aspectRatio};`}>
    <div class="gallery__viewport" data-gallery-viewport tabindex="0">
      {images.map((img, i) => (
        <figure class="gallery__slide" data-gallery-slide aria-roledescription="slide" aria-label={`${i + 1} / ${images.length}`}>
          {isImage(img) ? (
            <img
              src={img.src}
              alt={img.alt}
              loading={eager && i === 0 ? 'eager' : 'lazy'}
              decoding="async"
            />
          ) : (
            <div class="gallery__placeholder" role="img" aria-label={img.alt}>
              <span class="gallery__placeholder-icon" aria-hidden="true">▢</span>
              <span class="gallery__placeholder-note">{img.placeholder}</span>
              <span class="gallery__placeholder-badge">Foto se připravuje</span>
            </div>
          )}
        </figure>
      ))}
    </div>
    <div class="gallery__controls" role="group" aria-label={`Ovládání galerie: ${ariaLabel}`}>
      <button type="button" class="gallery__nav gallery__nav--prev" data-gallery-prev aria-label="Předchozí snímek">
        <Icon name="chevron-left" size={18} strokeWidth={2} />
      </button>
      <div class="gallery__dots" role="tablist" aria-label={`Pozice v galerii: ${ariaLabel}`}>
        {images.map((_, i) => (
          <button
            type="button"
            class="gallery__dot"
            data-gallery-dot={i}
            aria-label={`Snímek ${i + 1} z ${images.length}`}>
          </button>
        ))}
      </div>
      <button type="button" class="gallery__nav gallery__nav--next" data-gallery-next aria-label="Další snímek">
        <Icon name="chevron-right" size={18} strokeWidth={2} />
      </button>
    </div>
  </div>
)}

<script is:inline>
  /* Gallery init , runs on every astro:page-load (SPA nav). Idempotent: each
     gallery gets a `data-gallery-bound` flag so re-fires don't double-attach.
     The `window.__hubGalleryBound` guard keeps the page-load listener at one
     copy even when this component renders multiple times in the same page
     (each <Gallery> instance inlines this script with is:inline). */
  (function () {
    if (window.__hubGalleryBound) return;
    window.__hubGalleryBound = true;
    function initGalleries() {
      var galleries = document.querySelectorAll('[data-gallery]:not([data-gallery-bound])');
      galleries.forEach(function (gallery) {
        gallery.dataset.galleryBound = '1';
        var viewport = gallery.querySelector('[data-gallery-viewport]');
        var slides = [].slice.call(gallery.querySelectorAll('[data-gallery-slide]'));
        var dots = [].slice.call(gallery.querySelectorAll('[data-gallery-dot]'));
        var prevBtn = gallery.querySelector('[data-gallery-prev]');
        var nextBtn = gallery.querySelector('[data-gallery-next]');
        if (!viewport || !slides.length) return;

        var current = 0;

        function setActive(idx) {
          current = Math.max(0, Math.min(slides.length - 1, idx));
          dots.forEach(function (d, i) { d.classList.toggle('is-active', i === current); });
          if (prevBtn) prevBtn.disabled = current === 0;
          if (nextBtn) nextBtn.disabled = current === slides.length - 1;
        }

        function scrollToSlide(idx) {
          var slide = slides[idx];
          if (!slide || !viewport) return;
          viewport.scrollTo({ left: slide.offsetLeft, behavior: 'smooth' });
          setActive(idx);
        }

        if (prevBtn) prevBtn.addEventListener('click', function () { scrollToSlide(current - 1); });
        if (nextBtn) nextBtn.addEventListener('click', function () { scrollToSlide(current + 1); });
        dots.forEach(function (d, i) { d.addEventListener('click', function () { scrollToSlide(i); }); });

        var scrollTimer;
        viewport.addEventListener('scroll', function () {
          window.clearTimeout(scrollTimer);
          scrollTimer = window.setTimeout(function () {
            var idx = Math.round(viewport.scrollLeft / viewport.clientWidth);
            setActive(idx);
          }, 80);
        });

        viewport.addEventListener('keydown', function (e) {
          if (e.key === 'ArrowLeft') { e.preventDefault(); scrollToSlide(current - 1); }
          else if (e.key === 'ArrowRight') { e.preventDefault(); scrollToSlide(current + 1); }
        });

        setActive(0);
      });
    }
    document.addEventListener('astro:page-load', initGalleries);
  }());
</script>

<style>
  .gallery {
    position: relative;
    --gallery-radius: var(--radius-input);
  }
  .gallery--single { margin: 0; }
  .gallery--single img {
    width: 100%;
    aspect-ratio: var(--gallery-aspect, 4 / 3);
    object-fit: cover;
    display: block;
    border-radius: var(--gallery-radius);
  }
  .gallery__viewport {
    display: flex;
    overflow-x: auto;
    overflow-y: hidden;
    scroll-snap-type: x mandatory;
    scroll-behavior: smooth;
    scrollbar-width: none;
    -ms-overflow-style: none;
    border-radius: var(--gallery-radius);
    aspect-ratio: var(--gallery-aspect, 4 / 3);
    background: var(--bg-muted);
  }
  .gallery__viewport::-webkit-scrollbar { display: none; }
  .gallery__viewport:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 4px;
  }
  .gallery__slide {
    flex: 0 0 100%;
    width: 100%;
    height: 100%;
    margin: 0;
    scroll-snap-align: start;
    scroll-snap-stop: always;
  }
  .gallery__slide img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  /* Placeholder slide: zobrazuje se ve slotech kde vizualizace zatím
     není dodaná z vault Visualizations/. Mini text říká, co tam bude. */
  .gallery__placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 12px;
    padding: clamp(16px, 4vw, 32px);
    text-align: center;
    background: var(--accent-soft);
    color: var(--accent);
  }
  .gallery__placeholder-icon {
    font-size: 2rem;
    line-height: 1;
    opacity: 0.45;
  }
  .gallery__placeholder-note {
    font: 500 var(--text-sm) / 1.45 var(--font-sans);
    color: var(--fg);
    max-width: 38ch;
  }
  .gallery__placeholder-badge {
    font: 600 var(--text-2xs) / 1 var(--font-sans);
    letter-spacing: var(--tracking-wider);
    text-transform: uppercase;
    color: var(--accent);
    padding: 4px 10px;
    border: 1px solid var(--accent-rule);
    border-radius: var(--radius-input);
    background: rgba(255, 255, 255, 0.5);
  }

  /* Controls row: prev + dots + next sedí na jednom řádku pod obrázkem,
     žádné šipky nepřekrývají vizuál. Plum accent. */
  .gallery__controls {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 12px;
    margin-top: 14px;
  }

  /* Chevron nav buttons , inline s dot indikátorem, malé plum kruhy. */
  .gallery__nav {
    width: 32px;
    height: 32px;
    border-radius: 999px;
    border: 1px solid var(--accent-rule);
    background: transparent;
    color: var(--accent);
    cursor: pointer;
    display: grid;
    place-items: center;
    flex-shrink: 0;
    transition:
      background 220ms cubic-bezier(0.2, 0, 0, 1),
      border-color 220ms cubic-bezier(0.2, 0, 0, 1),
      transform 220ms cubic-bezier(0.2, 0, 0, 1);
  }
  .gallery__nav :global(svg) {
    display: block;
    stroke: currentColor;
  }
  /* Optické vyvážení chevronu (visí stranou v SVG viewBoxu). */
  .gallery__nav--prev :global(svg) { transform: translateX(-1px); }
  .gallery__nav--next :global(svg) { transform: translateX(1px); }
  .gallery__nav:hover {
    background: var(--accent-soft);
    border-color: var(--accent);
    transform: scale(1.06);
  }
  .gallery__nav--prev:hover :global(svg) { transform: translateX(-3px); }
  .gallery__nav--next:hover :global(svg) { transform: translateX(3px); }
  .gallery__nav:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 3px;
  }
  .gallery__nav:disabled {
    opacity: 0.25;
    cursor: default;
    pointer-events: none;
    transform: none;
  }
  .gallery__nav :global(svg) {
    transition: transform 220ms cubic-bezier(0.2, 0, 0, 1);
  }

  /* Dot indicator s plynulou expand animací (capsule lengthens). Active
     dot expanduje ze 6 px na 28 px s cubic-bezier ease + jemný pulse
     scale pro „aha" moment při změně. */
  .gallery__dots {
    display: flex;
    align-items: center;
    gap: 6px;
  }
  .gallery__dot {
    width: 6px;
    height: 6px;
    border-radius: 999px;
    border: 0;
    padding: 0;
    background: var(--border-muted);
    cursor: pointer;
    transition:
      background 320ms cubic-bezier(0.2, 0, 0, 1),
      width 360ms cubic-bezier(0.2, 0, 0, 1),
      transform 220ms cubic-bezier(0.2, 0, 0, 1);
  }
  .gallery__dot:hover {
    background: var(--accent-rule);
    transform: scale(1.4);
  }
  .gallery__dot.is-active {
    background: var(--accent);
    width: 28px;
    animation: gallery-dot-pulse 480ms cubic-bezier(0.2, 0, 0, 1);
  }
  .gallery__dot.is-active:hover { transform: scale(1.05); }
  .gallery__dot:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 3px;
  }
  @keyframes gallery-dot-pulse {
    0%   { transform: scale(0.6); }
    50%  { transform: scale(1.15); }
    100% { transform: scale(1); }
  }

  @media (prefers-reduced-motion: reduce) {
    .gallery__viewport { scroll-behavior: auto; }
    .gallery__nav,
    .gallery__nav :global(svg),
    .gallery__dot { transition: none; animation: none; }
  }
</style>
