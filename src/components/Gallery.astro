---
/*
 * Gallery - 4x2 uniform grid on desktop, horizontal filmstrip on mobile.
 * Images display in natural color (gallery is the one colorful surface of
 * the site). Entrance: clip-path frame-draw staggered per cell. Hover: soft
 * zoom + subtle contrast lift. Mobile: horizontal scroll-snap with partial peek.
 */
import { withBase } from '../utils/url';
interface Image { src: string; alt?: string; }
interface Props { images?: Image[]; }

const defaultImages: Image[] = [
  { src: '/images/474156246_1114489417070378_2341453958952153769_n.jpg' },
  { src: '/images/474471670_1114489410403712_957261942198756524_n.jpg' },
  { src: '/images/484066885_1034307245393403_8313211835074985229_n.jpg' },
  { src: '/images/104085418_3071753449537682_3735031019996797978_n.jpg' },
  { src: '/images/482961798_1034307312060063_7263597780288843545_n.jpg' },
  { src: '/images/83622937_3071752986204395_5087212010441728965_n.jpg' },
  { src: '/images/104082964_3071753366204357_6028419542031153786_n.jpg' },
  { src: '/images/482988216_1034307212060073_6494869551613273029_n.jpg' },
];

const { images = defaultImages } = Astro.props;
---
<section class="osa-gallery section--loose">
  <div class="container-wide">
    <header class="osa-gallery__head" data-reveal>
      <span class="osa-eyebrow">Galerie</span>
      <h2 class="osa-h2 osa-gallery__title">Z provozu spolkových prostorů.</h2>
    </header>
    <ul class="osa-gallery__grid" role="list" aria-hidden="true">
      {images.slice(0, 8).map((img, i) => (
        <li
          class="osa-gallery__cell"
          data-reveal
          data-reveal-delay={String((i % 3) + 1)}>
          <img
            src={withBase(img.src)}
            alt={img.alt ?? ''}
            loading="lazy"
            decoding="async"
            class="osa-gallery__img" />
        </li>
      ))}
    </ul>
  </div>
</section>

<style>
  .osa-gallery {
    /* Allow horizontal overflow on mobile filmstrip without scrollbar leak */
    overflow-x: clip;
  }
  .osa-gallery__head {
    display: grid;
    gap: var(--space-3);
    max-width: 56ch;
    margin: 0 0 var(--space-6);
  }
  .osa-gallery__title { margin: 0; }

  /* Desktop: 4x2 grid, every cell 4:3 aspect. Frameless at rest. */
  .osa-gallery__grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 2px;
    padding: 0;
    margin: 0;
    list-style: none;
  }
  .osa-gallery__cell {
    position: relative;
    overflow: hidden;
    background: var(--bg-muted);
    aspect-ratio: 4 / 3;
  }

  /* ---------- Frame-draw entrance --------
     Each cell gets a ::after cover that retreats downward on reveal, exposing
     the image from top-to-bottom. Per-cell delay set via data-reveal-delay (1-3).
     The cell itself uses default [data-reveal] opacity+translate subtly muted. */
  [data-reveal].osa-gallery__cell {
    opacity: 1;
    transform: none;
    transition: none;
  }
  .osa-gallery__cell::after {
    content: '';
    position: absolute;
    inset: 0;
    background: var(--fg);
    clip-path: inset(0 0 0 0);
    transition: clip-path 720ms var(--ease-expo, cubic-bezier(0.16, 1, 0.3, 1));
    pointer-events: none;
    z-index: 2;
  }
  [data-reveal].osa-gallery__cell.shown::after {
    clip-path: inset(0 0 100% 0);
  }

  /* Colour by default (client direction); hover only nudges zoom + a hint
     of extra saturation. Earlier monochrome-at-rest treatment was dropped. */
  .osa-gallery__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    filter: saturate(0.95) contrast(1.02);
    transition:
      transform 620ms var(--ease-expo, cubic-bezier(0.16, 1, 0.3, 1)),
      filter 520ms var(--ease-quart, cubic-bezier(0.25, 1, 0.5, 1));
  }
  .osa-gallery__cell:hover .osa-gallery__img,
  .osa-gallery__cell:focus-within .osa-gallery__img {
    transform: scale(1.04);
    filter: saturate(1.08) contrast(1.04);
  }

  /* ---------- Mobile filmstrip --------
     Below 720px, flip the 4x2 grid into a horizontal scroll-snap row so users
     can swipe through. Partial-peek of next cell by setting width to ~84vw. */
  @media (max-width: 720px) {
    .osa-gallery__grid {
      display: flex;
      flex-direction: row;
      overflow-x: auto;
      scroll-snap-type: x mandatory;
      scrollbar-width: none;
      -webkit-overflow-scrolling: touch;
      padding: 0 var(--gutter) 0 var(--gutter);
      gap: 4px;
      background: transparent;
      border: 0;
      margin-left: calc(var(--gutter) * -1);
      margin-right: calc(var(--gutter) * -1);
    }
    .osa-gallery__grid::-webkit-scrollbar { display: none; }
    .osa-gallery__cell {
      flex: 0 0 84vw;
      scroll-snap-align: start;
      aspect-ratio: 4 / 3;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .osa-gallery__cell::after { display: none; }
    .osa-gallery__img { transition: none; }
    .osa-gallery__cell:hover .osa-gallery__img { transform: none; filter: none; }
  }
</style>
