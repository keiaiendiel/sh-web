---
/*
 * Gallery - 4x2 uniform grid on desktop, horizontal filmstrip on mobile.
 * Images display in natural color (gallery is the one colorful surface of
 * the site). Entrance: clip-path frame-draw staggered per cell. Hover: soft
 * zoom + subtle contrast lift. Mobile: horizontal scroll-snap with partial peek.
 */
import { withBase } from '../utils/url';
interface Image { src: string; alt?: string; }
interface Props {
  /**
   * Accepts either an array of Image objects ({ src, alt? }) for richer
   * captions, or a plain string[] of image paths. Strings are normalized
   * to { src } internally so the rest of the component is unchanged.
   * Paths in either form may be raw `/images/...` paths OR already wrapped
   * by withBase() — withBase strips a leading base it already sees, so it
   * is idempotent and safe either way.
   */
  images?: Array<Image | string>;
  /**
   * When null, hides the big H2 under the eyebrow. Useful when the gallery
   * is embedded inside a longer article (the article already owns the page
   * headline and a "Z provozu spolkových prostorů." line would read as a
   * second, misplaced title).
   */
  title?: string | null;
}

const defaultImages: Image[] = [
  { src: '/images/474156246_1114489417070378_2341453958952153769_n.jpg' },
  { src: '/images/474471670_1114489410403712_957261942198756524_n.jpg' },
  { src: '/images/484066885_1034307245393403_8313211835074985229_n.jpg' },
  { src: '/images/104085418_3071753449537682_3735031019996797978_n.jpg' },
  { src: '/images/482961798_1034307312060063_7263597780288843545_n.jpg' },
  { src: '/images/83622937_3071752986204395_5087212010441728965_n.jpg' },
  { src: '/images/104082964_3071753366204357_6028419542031153786_n.jpg' },
  { src: '/images/482988216_1034307212060073_6494869551613273029_n.jpg' },
];

const { images: rawImages = defaultImages, title = 'Z provozu spolkových prostorů.' } = Astro.props;
const images: Image[] = rawImages.map((it) => (typeof it === 'string' ? { src: it } : it));

const BASE = import.meta.env.BASE_URL.replace(/\/$/, '');
function srcWithBase(s: string): string {
  // Idempotent: if the path already starts with the configured base, return as-is;
  // otherwise wrap. Lets callers pass either raw `/images/...` or pre-wrapped paths.
  if (BASE && s.startsWith(BASE + '/')) return s;
  return withBase(s);
}
---
<section class="osa-gallery section--loose">
  <div class="container-wide">
    <header class="osa-gallery__head" data-reveal>
      <span class="osa-eyebrow">Galerie</span>
      {title && <h2 class="osa-h2 osa-gallery__title">{title}</h2>}
    </header>
    <ul class="osa-gallery__grid" role="list">
      {images.slice(0, 8).map((img, i) => (
        <li
          class="osa-gallery__cell"
          data-reveal
          data-reveal-delay={String((i % 3) + 1)}>
          <button
            type="button"
            class="osa-gallery__trigger"
            data-lightbox-src={srcWithBase(img.src)}
            data-lightbox-alt={img.alt ?? ''}
            data-lightbox-index={String(i)}
            aria-label={img.alt ? `Zobrazit fotografii: ${img.alt}` : `Zobrazit fotografii ${i + 1}`}>
            <img
              src={srcWithBase(img.src)}
              alt={img.alt ?? ''}
              loading="lazy"
              decoding="async"
              class="osa-gallery__img" />
          </button>
        </li>
      ))}
    </ul>
  </div>

  <div class="osa-lightbox" role="dialog" aria-modal="true" aria-label="Prohlížeč fotografií" hidden>
    <button type="button" class="osa-lightbox__close" aria-label="Zavřít">
      <span aria-hidden="true">×</span>
    </button>
    <button type="button" class="osa-lightbox__nav osa-lightbox__nav--prev" aria-label="Předchozí fotografie">
      <span aria-hidden="true">‹</span>
    </button>
    <button type="button" class="osa-lightbox__nav osa-lightbox__nav--next" aria-label="Další fotografie">
      <span aria-hidden="true">›</span>
    </button>
    <figure class="osa-lightbox__stage">
      <img class="osa-lightbox__img" alt="" />
      <figcaption class="osa-lightbox__caption osa-mono"></figcaption>
    </figure>
  </div>
</section>

<script is:inline>
  (function () {
    document.addEventListener('DOMContentLoaded', function () {
      document.querySelectorAll('.osa-gallery').forEach(function (gallery) {
        var triggers = [].slice.call(gallery.querySelectorAll('.osa-gallery__trigger'));
        var lb       = gallery.querySelector('.osa-lightbox');
        if (triggers.length === 0 || !lb) return;

        var img   = lb.querySelector('.osa-lightbox__img');
        var cap   = lb.querySelector('.osa-lightbox__caption');
        var close = lb.querySelector('.osa-lightbox__close');
        var prev  = lb.querySelector('.osa-lightbox__nav--prev');
        var next  = lb.querySelector('.osa-lightbox__nav--next');
        var index = 0;

        function render(i) {
          index = (i + triggers.length) % triggers.length;
          var t = triggers[index];
          img.src = t.getAttribute('data-lightbox-src');
          img.alt = t.getAttribute('data-lightbox-alt') || '';
          cap.textContent = (index + 1) + ' / ' + triggers.length
            + (img.alt ? ' · ' + img.alt : '');
        }

        function open(i) {
          render(i);
          lb.hidden = false;
          requestAnimationFrame(function () { lb.classList.add('open'); });
          document.documentElement.classList.add('osa-lightbox-lock');
          close.focus();
        }

        function shut() {
          lb.classList.remove('open');
          document.documentElement.classList.remove('osa-lightbox-lock');
          setTimeout(function () {
            if (!lb.classList.contains('open')) lb.hidden = true;
          }, 220);
        }

        triggers.forEach(function (t, i) {
          t.addEventListener('click', function () { open(i); });
        });
        close.addEventListener('click', shut);
        prev.addEventListener('click', function () { render(index - 1); });
        next.addEventListener('click', function () { render(index + 1); });
        lb.addEventListener('click', function (e) {
          // tap on the backdrop (not on the image or controls) closes
          if (e.target === lb || e.target.classList.contains('osa-lightbox__stage')) shut();
        });
        document.addEventListener('keydown', function (e) {
          if (lb.hidden) return;
          if (e.key === 'Escape') shut();
          else if (e.key === 'ArrowLeft') render(index - 1);
          else if (e.key === 'ArrowRight') render(index + 1);
        });
      });
    });
  }());
</script>

<style>
  .osa-gallery {
    /* Allow horizontal overflow on mobile filmstrip without scrollbar leak */
    overflow-x: clip;
  }
  .osa-gallery__head {
    display: grid;
    gap: var(--space-3);
    max-width: 56ch;
    margin: 0 0 var(--space-6);
  }
  .osa-gallery__title { margin: 0; }

  /* Desktop: 4x2 grid, every cell 4:3 aspect. Frameless at rest. */
  .osa-gallery__grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 2px;
    padding: 0;
    margin: 0;
    list-style: none;
  }
  .osa-gallery__cell {
    position: relative;
    overflow: hidden;
    background: var(--bg-muted);
    aspect-ratio: 4 / 3;
  }
  /* Button wrapper around each image: clickable, but strips the default
     button chrome so the photo stays the whole canvas of the cell. */
  .osa-gallery__trigger {
    display: block;
    width: 100%;
    height: 100%;
    padding: 0;
    margin: 0;
    border: 0;
    background: transparent;
    cursor: zoom-in;
    color: inherit;
  }
  .osa-gallery__trigger:focus-visible {
    outline: 2px solid var(--fg);
    outline-offset: -2px;
  }

  /* ---------- Frame-draw entrance --------
     Each cell gets a ::after cover that retreats downward on reveal, exposing
     the image from top-to-bottom. Per-cell delay set via data-reveal-delay (1-3).
     The cell itself uses default [data-reveal] opacity+translate subtly muted. */
  [data-reveal].osa-gallery__cell {
    opacity: 1;
    transform: none;
    transition: none;
  }
  .osa-gallery__cell::after {
    content: '';
    position: absolute;
    inset: 0;
    background: var(--fg);
    clip-path: inset(0 0 0 0);
    transition: clip-path 720ms var(--ease-expo, cubic-bezier(0.16, 1, 0.3, 1));
    pointer-events: none;
    z-index: 2;
  }
  [data-reveal].osa-gallery__cell.shown::after {
    clip-path: inset(0 0 100% 0);
  }

  /* Colour by default (client direction); hover only nudges zoom + a hint
     of extra saturation. Earlier monochrome-at-rest treatment was dropped. */
  .osa-gallery__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    filter: saturate(0.95) contrast(1.02);
    transition:
      transform 900ms var(--ease-expo, cubic-bezier(0.16, 1, 0.3, 1)),
      filter 640ms var(--ease-quart, cubic-bezier(0.25, 1, 0.5, 1));
  }
  .osa-gallery__cell:hover .osa-gallery__img,
  .osa-gallery__cell:focus-within .osa-gallery__img {
    transform: scale(1.015);
    filter: saturate(1.05) contrast(1.02);
  }

  /* ---------- Mobile filmstrip --------
     Below 720px, flip the 4x2 grid into a horizontal scroll-snap row so users
     can swipe through. Partial-peek of next cell by setting width to ~84vw. */
  @media (max-width: 720px) {
    .osa-gallery__grid {
      display: flex;
      flex-direction: row;
      overflow-x: auto;
      scroll-snap-type: x mandatory;
      scrollbar-width: none;
      -webkit-overflow-scrolling: touch;
      padding: 0 var(--gutter) 0 var(--gutter);
      gap: 4px;
      background: transparent;
      border: 0;
      margin-left: calc(var(--gutter) * -1);
      margin-right: calc(var(--gutter) * -1);
    }
    .osa-gallery__grid::-webkit-scrollbar { display: none; }
    .osa-gallery__cell {
      flex: 0 0 84vw;
      scroll-snap-align: start;
      aspect-ratio: 4 / 3;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .osa-gallery__cell::after { display: none; }
    .osa-gallery__img { transition: none; }
    .osa-gallery__cell:hover .osa-gallery__img { transform: none; filter: none; }
  }

  /*
   * Lightbox: minimal full-viewport overlay with one image + caption and
   * prev/close/next controls. Opens on gallery image click. Keyboard:
   * ESC close, ArrowLeft/ArrowRight navigate. Tap on backdrop or on the
   * empty stage area also closes.
   */
  /* The hidden attribute MUST win over display:grid or the lightbox
     overlay stays in the layer above the whole page and silently eats
     every click/tap. The :not([hidden]) guard keeps the display:grid
     only when the lightbox is actually being shown. */
  .osa-lightbox[hidden] { display: none; }
  .osa-lightbox:not([hidden]) {
    position: fixed;
    inset: 0;
    z-index: 40;
    background: #000;
    display: grid;
    place-items: center;
    padding: clamp(16px, 4vw, 48px);
    opacity: 0;
    transition: opacity 220ms var(--ease-quart, cubic-bezier(0.25, 1, 0.5, 1));
  }
  .osa-lightbox.open { opacity: 1; }
  .osa-lightbox__stage {
    display: grid;
    gap: var(--space-3);
    justify-items: center;
    max-width: min(1280px, 100%);
    max-height: 100%;
    margin: 0;
  }
  .osa-lightbox__img {
    display: block;
    max-width: 100%;
    max-height: calc(100vh - 120px);
    object-fit: contain;
    background: transparent;
  }
  .osa-lightbox__caption {
    color: rgba(255, 255, 255, 0.7);
    font-size: var(--text-xs);
    text-align: center;
    max-width: 56ch;
  }
  .osa-lightbox__close,
  .osa-lightbox__nav {
    position: absolute;
    width: 44px;
    height: 44px;
    padding: 0;
    border: 0;
    background: transparent;
    color: #fff;
    font-family: var(--font-sans);
    font-size: 28px;
    line-height: 1;
    cursor: pointer;
    display: grid;
    place-items: center;
    opacity: 0.85;
    transition: opacity 140ms linear;
  }
  .osa-lightbox__close:hover,
  .osa-lightbox__nav:hover,
  .osa-lightbox__close:focus-visible,
  .osa-lightbox__nav:focus-visible { opacity: 1; }
  .osa-lightbox__close:focus-visible,
  .osa-lightbox__nav:focus-visible { outline: 2px solid #fff; outline-offset: 2px; }
  .osa-lightbox__close {
    top: 16px;
    right: 16px;
    font-size: 32px;
  }
  .osa-lightbox__nav--prev { left: 8px;  top: 50%; transform: translateY(-50%); font-size: 44px; }
  .osa-lightbox__nav--next { right: 8px; top: 50%; transform: translateY(-50%); font-size: 44px; }

  :global(html.osa-lightbox-lock),
  :global(html.osa-lightbox-lock body) { overflow: hidden; }

  @media (prefers-reduced-motion: reduce) {
    .osa-lightbox { transition: none; }
  }
  @media (max-width: 560px) {
    .osa-lightbox__nav--prev { font-size: 36px; left: 4px; }
    .osa-lightbox__nav--next { font-size: 36px; right: 4px; }
    .osa-lightbox__close    { top: 8px; right: 8px; }
  }
</style>
