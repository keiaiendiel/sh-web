---
import { getCollection } from 'astro:content';

interface Props {
  expanded?: boolean;
  dark?: boolean;
  /**
   * When true, the matrix uses the narrower `container` (1200px) so its
   * left/right edges line up with body-copy sections on pages like
   * /o-spolku/ where text blocks define the page's baseline margin.
   */
  narrow?: boolean;
}
const { expanded = false, dark = false, narrow = false } = Astro.props;

const values = (await getCollection('values'))
  .sort((a, b) => a.data.order - b.data.order);
---
<script is:inline>
  /*
   * Single-open accordion. Click on a cell:
   *   - if already open, close it;
   *   - otherwise, close any open sibling and open this one.
   * Plain click logic; no :hover / :focus tricks so touch and mouse
   * behave the same on desktop and mobile.
   */
  (function () {
    document.addEventListener('DOMContentLoaded', function () {
      document.querySelectorAll('.osa-values__grid').forEach(function (grid) {
        grid.addEventListener('click', function (e) {
          var cell = e.target.closest('.osa-values__cell');
          if (!cell || !grid.contains(cell)) return;
          var wasOpen = cell.classList.contains('is-open');
          grid.querySelectorAll('.osa-values__cell.is-open').forEach(function (c) {
            c.classList.remove('is-open');
          });
          if (!wasOpen) cell.classList.add('is-open');
        });
        // Keyboard: Enter / Space on a focused cell toggles it.
        grid.addEventListener('keydown', function (e) {
          if (e.key !== 'Enter' && e.key !== ' ') return;
          var cell = e.target.closest('.osa-values__cell');
          if (!cell) return;
          e.preventDefault();
          cell.click();
        });
      });
    });
  }());
</script>

<section class:list={['osa-values', 'section', { 'osa-dark': dark }]}>
  <div class:list={[narrow ? 'container' : 'container-wide']}>
    <header class="osa-values__head" data-reveal>
      <span class="osa-eyebrow">§ 16 hodnot</span>
      <h2 class="osa-h2 osa-values__title">Hodnoty spolku jsou axiomy, nikoli aspirace.</h2>
    </header>
    <ul
      class:list={['osa-values__grid', { 'osa-values__grid--expanded': expanded }]}
      role="list">
      {values.map((v, i) => (
        <li
          class="osa-values__cell"
          tabindex={expanded ? undefined : '0'}
          data-reveal
          data-reveal-delay={String((i % 3) + 1)}>
          <span class="osa-values__num">{String(v.data.order).padStart(2, '0')}</span>
          <span class="osa-values__name">{v.data.name}</span>
          <span class="osa-values__gloss">{v.data.gloss}</span>
        </li>
      ))}
    </ul>
  </div>
</section>

<style>
  /*
   * 4x4 value grid driven by a single-open accordion. No :hover / :focus
   * affordance: only the explicit `.is-open` class reveals the gloss and
   * inverts colours, so the state is identical across desktop and touch.
   */

  .osa-values__head {
    display: grid;
    gap: var(--space-3);
    max-width: 64ch;
    margin: 0 0 var(--space-7);
  }
  .osa-values__title { margin: 0; }

  .osa-values__grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 0;
    border-top: 1px solid var(--rule);
    border-left: 1px solid var(--rule);
  }
  @media (max-width: 960px) { .osa-values__grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 560px) { .osa-values__grid { grid-template-columns: 1fr; } }

  .osa-values__cell {
    position: relative;
    padding: var(--space-5);
    border-right: 1px solid var(--rule);
    border-bottom: 1px solid var(--rule);
    display: grid;
    grid-template-rows: auto auto 0fr;
    gap: var(--space-3);
    min-height: 150px;
    background: var(--bg);
    color: var(--fg);
    cursor: pointer;
    overflow: hidden;
    transition:
      grid-template-rows 280ms var(--ease-quart, cubic-bezier(0.25, 1, 0.5, 1)),
      background 200ms var(--ease-quart, cubic-bezier(0.25, 1, 0.5, 1)),
      color 200ms var(--ease-quart, cubic-bezier(0.25, 1, 0.5, 1));
  }
  .osa-values__cell:focus-visible {
    outline: 2px solid var(--fg);
    outline-offset: -2px;
  }

  /* Expanded mode (e.g. /o-spolku): show gloss statically, no toggle. */
  .osa-values__grid--expanded .osa-values__cell {
    grid-template-rows: auto auto 1fr;
    cursor: default;
  }

  /* Single-open: only this class reveals the gloss + inverts colours. */
  .osa-values__cell.is-open {
    grid-template-rows: auto auto 1fr;
    background: var(--fg);
    color: var(--bg);
  }

  /* Desktop hover: restores the original "peek on hover" affordance from
     pre-accordion days. Tap-only mobile (<=560px) keeps the is-open-only
     behaviour below; here hover is an additive preview that doesn't alter
     the JS-managed is-open state. Also guarded by pointer:fine so a
     stylus/touch device that emulates hover doesn't trigger sticky state. */
  @media (min-width: 561px) and (hover: hover) and (pointer: fine) {
    .osa-values__cell:hover,
    .osa-values__cell:focus-visible {
      grid-template-rows: auto auto 1fr;
      background: var(--fg);
      color: var(--bg);
    }
  }

  .osa-values__num {
    font-family: var(--font-sans);
    font-weight: 500;
    font-size: var(--text-2xs);
    letter-spacing: var(--tracking-wider);
    opacity: 0.55;
    color: inherit;
  }

  .osa-values__name {
    font-family: var(--font-sans);
    font-weight: 600;
    font-size: var(--text-lg);
    line-height: var(--lh-snug);
    letter-spacing: var(--tracking-tight);
    color: inherit;
    text-wrap: balance;
  }

  .osa-values__gloss {
    overflow: hidden;
    font-family: var(--font-sans);
    font-weight: 500;
    font-size: var(--text-sm);
    line-height: var(--lh-normal);
    color: inherit;
    opacity: 0.82;
  }

  /*
   * Mobile: one-line row [number | name], tappable, expands in place.
   * Gloss hides via display:none when closed (grid-template-rows 0fr was
   * unreliable in some mobile browsers). Single-open behaviour is shared
   * with desktop through the same `.is-open` class.
   */
  @media (max-width: 560px) {
    .osa-values__grid {
      border-left: 0;
      border-top: 0;
    }
    .osa-values__cell {
      display: grid;
      grid-template-columns: auto 1fr;
      grid-template-rows: auto;
      column-gap: var(--space-3);
      row-gap: var(--space-2);
      align-items: center;
      min-height: 0;
      padding: var(--space-3) var(--space-4);
      border-right: 0;
      transition: background 200ms linear, color 200ms linear;
    }
    .osa-values__num  { grid-column: 1; grid-row: 1; }
    .osa-values__name { grid-column: 2; grid-row: 1; font-size: var(--text-sm); line-height: var(--lh-tight); min-width: 0; }
    .osa-values__gloss {
      grid-column: 1 / -1;
      grid-row: 2;
      display: none;
      font-size: var(--text-xs);
    }
    .osa-values__cell.is-open .osa-values__gloss { display: block; }
  }

  @media (prefers-reduced-motion: reduce) {
    .osa-values__cell { transition: background 0ms, color 0ms; }
  }
</style>
