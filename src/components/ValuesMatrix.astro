---
import { getCollection } from 'astro:content';

interface Props { expanded?: boolean; dark?: boolean; }
const { expanded = false, dark = false } = Astro.props;

const values = (await getCollection('values'))
  .sort((a, b) => a.data.order - b.data.order);
---
<section class:list={['osa-values', 'section', { 'osa-dark': dark }]}>
  <div class="container-wide">
    <header class="osa-values__head">
      <span class="osa-eyebrow">§ 16 hodnot</span>
      <h2 class="osa-h2 osa-values__title">Hodnoty spolku jsou axiomy, nikoli aspirace.</h2>
    </header>
    <ul
      class:list={['osa-values__grid', { 'osa-values__grid--expanded': expanded }]}
      role="list">
      {values.map(v => (
        <li class="osa-values__cell">
          <span class="osa-values__num osa-mono">{String(v.data.order).padStart(2, '0')}</span>
          <span class="osa-values__name">{v.data.name}</span>
          <span class="osa-values__gloss">{v.data.gloss}</span>
        </li>
      ))}
    </ul>
  </div>
</section>

<style>
  .osa-values__head {
    display: grid;
    gap: var(--space-3);
    max-width: 64ch;
    margin: 0 0 var(--space-7);
  }
  .osa-values__title { margin: 0; }

  .osa-values__grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 0;
    border-top: 1px solid var(--rule);
    border-left: 1px solid var(--rule);
  }
  @media (max-width: 960px) { .osa-values__grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 480px) { .osa-values__grid { grid-template-columns: 1fr; } }

  .osa-values__cell {
    position: relative;
    padding: var(--space-5);
    border-right: 1px solid var(--rule);
    border-bottom: 1px solid var(--rule);
    display: grid;
    grid-template-rows: auto auto 0fr;
    gap: var(--space-2);
    transition: grid-template-rows var(--dur-base) var(--ease-standard),
                background var(--dur-fast) linear,
                color var(--dur-fast) linear;
    background: var(--bg);
    color: var(--fg);
  }
  .osa-values__cell:hover,
  .osa-values__cell:focus-within,
  .osa-values__grid--expanded .osa-values__cell {
    grid-template-rows: auto auto 1fr;
    background: var(--fg);
    color: var(--bg);
  }
  .osa-values__num   { font-size: var(--text-xs); opacity: 0.55; }
  .osa-values__name  {
    font: 600 var(--text-md) / var(--lh-snug) var(--font-sans);
    letter-spacing: var(--tracking-tight);
    color: inherit;
    text-wrap: balance;
  }
  .osa-values__gloss {
    overflow: hidden;
    font-size: var(--text-sm);
    line-height: var(--lh-normal);
    color: inherit;
    opacity: 0.82;
  }
</style>
