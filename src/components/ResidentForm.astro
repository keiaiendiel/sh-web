---
/*
 * ResidentForm — booking-style rezervační formulář.
 *
 * Tři očíslované sekce (Typ + termín → Kontakt → Souhlas) na jedné stránce.
 * Po submitu se zobrazí success state „Ozveme se do 24 hodin". Backend zatím
 * jen console.log (per CLAUDE.md open loop).
 *
 * URL parametr `?typ=capsule` pre-fillne typ jednotky — link z RoomCard
 * tlačítka „Rezervovat termín" tohle využívá. Pokud parametr není, výchozí
 * stav je „rozhodne se později".
 *
 * Sekce jsou viditelné najednou (žádný multi-step wizard) — pattern z Pod
 * Hotels / Habyt: long-stay rezervace nemá smysl rozdělovat na kroky, host
 * potřebuje vidět cenu před odesláním kontaktu.
 */

import { getCollection } from 'astro:content';

const rooms = (await getCollection('rooms')).sort((a, b) => a.data.order - b.data.order);

const stayLengths = [
  { v: '1-3',  label: '1–3 měsíce' },
  { v: '3-6',  label: '3–6 měsíců' },
  { v: '6-12', label: '6–12 měsíců' },
  { v: '12+',  label: '12 a více měsíců' },
];
---
<form class="rsv-form" data-form="reservation" novalidate>

  <fieldset class="rsv-form__step">
    <legend>
      <span class="rsv-form__num">01</span>
      <span class="rsv-form__heading">Vyberte typ ubytování</span>
      <span class="rsv-form__hint">Můžete si nechat rozhodnutí na nás — napište nám v poznámce, čeho hledáte.</span>
    </legend>
    <div class="rsv-form__rooms">
      {rooms.map((r) => {
        const price = new Intl.NumberFormat('cs-CZ').format(r.data.priceFrom);
        return (
          <label class="rsv-form__room" data-type={r.data.type}>
            <input type="radio" name="roomType" value={r.data.type} />
            <span class="rsv-form__room-thumb" aria-hidden="true">
              <img src={r.data.thumbnail} alt="" loading="lazy" decoding="async" />
            </span>
            <span class="rsv-form__room-body">
              <span class="rsv-form__room-name">{r.data.shortName}</span>
              <span class="rsv-form__room-meta">{r.data.size} · {r.data.capacity}</span>
              <span class="rsv-form__room-price">
                <span class="rsv-form__room-price-prefix">od</span>
                <span class="osa-figs">{price}</span>
                <span class="rsv-form__room-price-unit">Kč/měsíc</span>
              </span>
            </span>
          </label>
        );
      })}
      <label class="rsv-form__room rsv-form__room--undecided">
        <input type="radio" name="roomType" value="undecided" />
        <span class="rsv-form__room-body">
          <span class="rsv-form__room-name">Ještě nevím, poraďte mi</span>
          <span class="rsv-form__room-meta">Domluvíme se podle vaší situace.</span>
        </span>
      </label>
    </div>

    <div class="rsv-form__grid-2">
      <label class="rsv-form__field">
        <span class="rsv-form__label">Orientační termín nastěhování</span>
        <input type="month" name="moveIn" required />
      </label>
      <label class="rsv-form__field">
        <span class="rsv-form__label">Předpokládaná délka pobytu</span>
        <select name="stayLength" required>
          <option value="" disabled selected>Vyberte délku</option>
          {stayLengths.map((s) => (
            <option value={s.v}>{s.label}</option>
          ))}
        </select>
      </label>
    </div>
  </fieldset>

  <fieldset class="rsv-form__step">
    <legend>
      <span class="rsv-form__num">02</span>
      <span class="rsv-form__heading">Kontakt</span>
      <span class="rsv-form__hint">Někdo z rezervačního oddělení vám obvykle do 24 hodin zavolá. Vaše údaje použijeme jen pro vyřízení rezervace.</span>
    </legend>
    <div class="rsv-form__grid-2">
      <label class="rsv-form__field">
        <span class="rsv-form__label">Jméno a příjmení</span>
        <input type="text" name="name" required autocomplete="name" minlength="2" maxlength="80" />
      </label>
      <label class="rsv-form__field">
        <span class="rsv-form__label">E-mail</span>
        <input type="email" name="email" required autocomplete="email" />
      </label>
    </div>
    <div class="rsv-form__grid-2">
      <label class="rsv-form__field">
        <span class="rsv-form__label">Telefon</span>
        <input type="tel" name="phone" required autocomplete="tel" />
      </label>
      <label class="rsv-form__field">
        <span class="rsv-form__label">Poznámka <span class="rsv-form__optional">(volitelná)</span></span>
        <input type="text" name="note" maxlength="280" placeholder="Pár vět o vás nebo doplňující otázka." />
      </label>
    </div>

    <label class="rsv-form__checkbox rsv-form__checkbox--optional">
      <input type="checkbox" name="scholarship" />
      <span><strong>Mám zájem o pobytové stipendium nebo dotovaný režim.</strong> Pošlete mi info, pokud na něj můžu mít nárok.</span>
    </label>
  </fieldset>

  <label class="rsv-form__checkbox rsv-form__checkbox--optional">
    <input type="checkbox" name="consent" required />
    <span><strong>Souhlasím se zpracováním údajů</strong> za účelem vyřízení rezervace. Údaje použijeme jen na komunikaci s vámi, nezveřejníme ani nepředáváme dál.</span>
  </label>

  <div class="rsv-form__submit">
    <button type="submit" class="rsv-form__btn">Odeslat rezervaci →</button>
    <p class="rsv-form__small">Rezervace je nezávazná. Smlouvu řešíme až s nastěhováním.</p>
  </div>

  <div class="rsv-form__success" data-success hidden>
    <span class="osa-eyebrow">Rezervace odeslána</span>
    <h2>Zavoláme do 24 hodin.</h2>
    <p>Vaši rezervaci jsme přijali. Někdo z rezervačního oddělení vám obvykle do 24 hodin zavolá s detailem dostupnosti, cenou pro vaši délku pobytu a dalšími kroky.</p>
  </div>
</form>

<script is:inline>
  (function () {
    var form = document.querySelector('form[data-form="reservation"]');
    if (!form) return;

    // Preselect type from URL ?typ=capsule (link z RoomCard).
    var params = new URLSearchParams(window.location.search);
    var preType = params.get('typ');
    if (preType) {
      var radio = form.querySelector('input[name="roomType"][value="' + preType + '"]');
      if (radio) radio.checked = true;
    }

    form.addEventListener('submit', function (e) {
      e.preventDefault();
      if (!form.reportValidity()) return;
      var data = Object.fromEntries(new FormData(form).entries());
      // eslint-disable-next-line no-console
      console.log('[Rezervace] Submit payload:', data);
      var success = form.querySelector('[data-success]');
      // Hide form contents, show success message.
      Array.prototype.forEach.call(form.children, function (child) {
        if (child !== success) child.hidden = true;
      });
      success.hidden = false;
      success.scrollIntoView({ behavior: 'smooth', block: 'center' });
    });
  }());
</script>

<style>
  .rsv-form {
    display: grid;
    gap: clamp(32px, 5vw, 56px);
  }
  .rsv-form__step {
    border: 0;
    padding: 0;
    margin: 0;
    display: grid;
    gap: 24px;
  }
  .rsv-form__step legend {
    display: grid;
    gap: 6px;
    padding: 0;
    margin-bottom: 4px;
  }
  .rsv-form__num {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--accent);
    letter-spacing: 0.12em;
    text-transform: uppercase;
    display: block;
    margin-bottom: 2px;
  }
  .rsv-form__heading {
    font-family: var(--font-sans);
    font-size: clamp(22px, 2.4vw, 28px);
    font-weight: 600;
    color: var(--fg);
    line-height: 1.15;
    letter-spacing: var(--tracking-tight);
    display: block;
    text-wrap: balance;
  }
  .rsv-form__hint {
    font-size: 14px;
    color: var(--fg-muted);
    line-height: 1.6;
    margin-top: 8px;
    display: block;
    max-width: 56ch;
  }

  .rsv-form__rooms {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 12px;
  }
  @media (max-width: 600px) {
    .rsv-form__rooms { grid-template-columns: 1fr; }
  }
  .rsv-form__room {
    position: relative;
    display: grid;
    grid-template-columns: 88px 1fr;
    gap: 12px;
    padding: 12px;
    border: 1px solid var(--border-muted);
    border-radius: var(--radius-input);
    background: var(--bg);
    cursor: pointer;
    transition:
      border-color var(--dur-base) var(--ease-decel),
      background var(--dur-base) var(--ease-decel);
  }
  .rsv-form__room:hover { border-color: var(--accent-rule); }
  .rsv-form__room input {
    position: absolute;
    inset: 0;
    opacity: 0;
    cursor: pointer;
  }
  .rsv-form__room:has(input:checked) {
    border-color: var(--accent);
    background: var(--accent-soft);
  }
  .rsv-form__room--undecided {
    grid-template-columns: 1fr;
    grid-column: 1 / -1;
  }
  .rsv-form__room-thumb {
    aspect-ratio: 1;
    background: var(--k-05);
    border-radius: 4px;
    overflow: hidden;
  }
  .rsv-form__room-thumb img {
    width: 100%; height: 100%;
    object-fit: cover;
    display: block;
  }
  .rsv-form__room-body {
    display: grid;
    gap: 4px;
    align-content: center;
  }
  .rsv-form__room-name {
    font-weight: 600;
    font-size: 15px;
    color: var(--fg);
    line-height: 1.25;
  }
  .rsv-form__room-meta {
    font-size: 12px;
    color: var(--fg-subtle);
    line-height: 1.4;
  }
  .rsv-form__room-price {
    display: inline-flex;
    align-items: baseline;
    gap: 4px;
    margin-top: 4px;
  }
  .rsv-form__room-price-prefix {
    font-size: 11px;
    color: var(--fg-subtle);
  }
  .rsv-form__room-price .osa-figs {
    font-weight: 600;
    font-size: 15px;
    color: var(--accent);
  }
  .rsv-form__room-price-unit {
    font-size: 12px;
    color: var(--fg-muted);
  }

  .rsv-form__pills {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }
  .rsv-form__pill {
    position: relative;
    display: inline-flex;
    align-items: center;
    padding: 8px 16px;
    border: 1px solid var(--border-muted);
    border-radius: 999px;
    font-size: 14px;
    color: var(--fg);
    cursor: pointer;
    transition:
      border-color var(--dur-base) var(--ease-decel),
      background var(--dur-base) var(--ease-decel);
  }
  .rsv-form__pill input {
    position: absolute;
    inset: 0;
    opacity: 0;
    cursor: pointer;
  }
  .rsv-form__pill:has(input:checked) {
    border-color: var(--accent);
    background: var(--accent-soft);
    color: var(--accent);
    font-weight: 600;
  }

  .rsv-form__grid-2 {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 20px;
  }
  @media (max-width: 600px) {
    .rsv-form__grid-2 { grid-template-columns: 1fr; gap: 16px; }
  }
  .rsv-form__field {
    display: grid;
    gap: 8px;
  }
  .rsv-form__label {
    font-size: 13px;
    font-weight: 600;
    color: var(--fg);
    line-height: 1.4;
    letter-spacing: 0.005em;
  }
  .rsv-form__optional {
    color: var(--fg-subtle);
    font-weight: 400;
    letter-spacing: 0;
  }
  .rsv-form__field input,
  .rsv-form__field select {
    font: inherit;
    font-size: 15px;
    color: var(--fg);
    padding: 12px 16px;
    border: 1px solid var(--border-muted);
    border-radius: var(--radius-input);
    background: var(--bg);
    transition: border-color var(--dur-fast) linear, box-shadow var(--dur-fast) linear;
  }
  .rsv-form__field input::placeholder {
    color: var(--fg-subtle);
  }
  .rsv-form__field input:focus,
  .rsv-form__field select:focus {
    outline: none;
    border-color: var(--accent);
    box-shadow: 0 0 0 3px var(--accent-soft);
  }

  .rsv-form__checkbox {
    display: flex;
    gap: 14px;
    align-items: flex-start;
    cursor: pointer;
    font-size: 14px;
    line-height: 1.6;
    color: var(--fg);
  }
  .rsv-form__checkbox input {
    margin-top: 4px;
    flex-shrink: 0;
    accent-color: var(--accent);
    width: 16px; height: 16px;
  }
  .rsv-form__checkbox--optional {
    margin-top: 8px;
    padding: 16px 18px;
    background: var(--accent-soft);
    border: 1px solid var(--accent-rule);
    border-radius: var(--radius-input);
  }
  .rsv-form__checkbox--optional strong {
    color: var(--fg);
    font-weight: 600;
  }

  .rsv-form__submit {
    display: grid;
    gap: 14px;
    justify-items: start;
    margin-top: 8px;
  }
  .rsv-form__btn {
    font: 600 16px / 1 var(--font-sans);
    color: var(--accent-on);
    background: var(--accent);
    padding: 16px 32px;
    border-radius: var(--radius-input);
    border: 0;
    cursor: pointer;
    letter-spacing: var(--tracking-tight);
    transition: background var(--dur-base) var(--ease-decel), transform var(--dur-fast) linear;
  }
  .rsv-form__btn:hover { background: var(--k-100); }
  .rsv-form__btn:active { transform: translateY(1px); }
  .rsv-form__small {
    font-size: 12px;
    color: var(--fg-subtle);
    line-height: 1.5;
    margin: 0;
    max-width: 48ch;
  }

  .rsv-form__success {
    text-align: center;
    padding: clamp(40px, 6vw, 56px) clamp(28px, 4vw, 48px);
    border: 1px solid var(--accent);
    border-radius: var(--radius-input);
    background: var(--accent-soft);
    display: grid;
    gap: 14px;
  }
  .rsv-form__success[hidden] { display: none; }
  .rsv-form__success .osa-eyebrow { color: var(--accent); display: block; }
  .rsv-form__success h2 {
    font-family: var(--font-sans);
    font-size: clamp(26px, 3vw, 34px);
    font-weight: 600;
    margin: 4px 0 0;
    line-height: 1.1;
    letter-spacing: var(--tracking-tight);
    text-wrap: balance;
  }
  .rsv-form__success p {
    font-size: 15px;
    color: var(--fg);
    line-height: 1.6;
    margin: 0 auto;
    max-width: 52ch;
    text-wrap: pretty;
  }
</style>
