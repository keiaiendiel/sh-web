---
---
<form class="hub-form hub-form--resident" data-form="resident" novalidate>
  <fieldset class="hub-form__group">
    <legend>
      <span class="hub-form__eyebrow">Krok 1</span>
      <span class="hub-form__legend">Mám zájem o nezávaznou před-rezervaci</span>
    </legend>
    <div class="hub-form__inputs">
      <label class="hub-form__field">
        <span class="hub-form__field-label">Počet jednotek 1+kk</span>
        <input type="number" name="units" min="1" max="50" value="1" required inputmode="numeric" />
      </label>
      <label class="hub-form__field">
        <span class="hub-form__field-label">Termín nastěhování</span>
        <input type="month" name="moveInMonth" required />
      </label>
    </div>
  </fieldset>

  <fieldset class="hub-form__group">
    <legend>
      <span class="hub-form__eyebrow">Krok 2</span>
      <span class="hub-form__legend">Doba nájmu</span>
    </legend>
    <div class="hub-form__choices">
      <label><input type="radio" name="duration" value="1m" required /> <span>1 měsíc</span></label>
      <label><input type="radio" name="duration" value="1y" /> <span>1 rok</span></label>
      <label><input type="radio" name="duration" value="5y" /> <span>5 let</span></label>
      <label class="hub-form__row">
        <input type="radio" name="duration" value="other" />
        <span>Jiná délka</span>
        <input type="text" name="durationOther" placeholder="např. 6 měsíců" class="hub-form__inline" />
      </label>
    </div>
  </fieldset>

  <fieldset class="hub-form__group">
    <legend>
      <span class="hub-form__eyebrow">Krok 3</span>
      <span class="hub-form__legend">Právo prodloužit nájem</span>
    </legend>
    <div class="hub-form__choices">
      <label><input type="radio" name="extension" value="none" required /> <span>Bez prodloužení</span></label>
      <label class="hub-form__row">
        <input type="radio" name="extension" value="finite" />
        <span>Možnost prodloužit</span>
        <input type="number" name="extensionTimes" min="1" max="20" placeholder="3" class="hub-form__inline-num" />
        <span>krát na stejnou dobu</span>
      </label>
      <label><input type="radio" name="extension" value="indefinite" /> <span>Možnost prodlužovat opakovaně bez omezení</span></label>
    </div>
  </fieldset>

  <fieldset class="hub-form__group">
    <legend>
      <span class="hub-form__eyebrow">Krok 4</span>
      <span class="hub-form__legend">Pobytové stipendium</span>
    </legend>
    <p class="hub-form__hint">Stipendijní režim je pro lidi, kteří by Hubu dávali smysl, ale bez podpory by si pobyt nemohli dovolit. Není to slevový kód, je to popsaný výběr.</p>
    <div class="hub-form__choices">
      <label><input type="radio" name="stipend" value="no" required /> <span>Nemám zájem o stipendium</span></label>
      <label><input type="radio" name="stipend" value="yes" /> <span>Mám zájem o stipendium</span></label>
    </div>
  </fieldset>

  <fieldset class="hub-form__group hub-form__stipend" data-stipend="yes" hidden>
    <legend>
      <span class="hub-form__eyebrow">Krok 5</span>
      <span class="hub-form__legend">Záměr nebo projekt v Hubu</span>
    </legend>
    <div class="hub-form__inputs">
      <label class="hub-form__textarea-label">
        <span class="hub-form__field-label">Co byste rád(a) ve Startovacím Hubu rozjel(a)?</span>
        <textarea name="stipendIntent" rows="4" minlength="40" maxlength="500" placeholder="Studium, výzkum, pilotní projekt, kulturní program, vlastní podnikání."></textarea>
      </label>
      <label class="hub-form__textarea-label">
        <span class="hub-form__field-label">Něco o vás</span>
        <textarea name="stipendAbout" rows="4" minlength="40" maxlength="500" placeholder="Pár vět o vašem příběhu a o tom, proč by stipendium dávalo smysl."></textarea>
      </label>
    </div>
  </fieldset>

  <fieldset class="hub-form__group">
    <legend>
      <span class="hub-form__eyebrow">Krok 6</span>
      <span class="hub-form__legend">Kontakt</span>
    </legend>
    <div class="hub-form__inputs">
      <label class="hub-form__field">
        <span class="hub-form__field-label">Jméno a příjmení</span>
        <input type="text" name="name" required minlength="2" />
      </label>
      <label class="hub-form__field">
        <span class="hub-form__field-label">E-mail</span>
        <input type="email" name="email" required />
      </label>
      <label class="hub-form__field">
        <span class="hub-form__field-label">Telefon (volitelné)</span>
        <input type="tel" name="phone" />
      </label>
      <label class="hub-form__check"><input type="checkbox" name="consent" required /> <span>Souhlasím se zasláním informací k nabídce.</span></label>
    </div>
  </fieldset>

  <button type="submit" class="hub-form__submit">Odeslat nezávaznou před-rezervaci</button>

  <output class="hub-form__success" hidden>
    Děkujeme. Zapsali jsme vaši nezávaznou před-rezervaci. Není to smlouva. Ozveme se vám, jakmile budeme mít konkrétní nabídku odpovídající vašim preferencím.
  </output>
</form>

<style>
  .hub-form { display: grid; gap: 0; }
  .hub-form__group {
    border: 0; padding: 28px 0; margin: 0;
    display: grid; gap: 16px;
    border-bottom: 1px solid var(--k-10);
  }
  .hub-form__group:last-of-type { border-bottom: 0; }
  .hub-form__group legend {
    display: flex; flex-direction: column; gap: 6px;
    padding: 0; margin: 0 0 4px;
  }
  .hub-form__eyebrow {
    font-size: 11px; letter-spacing: 0.08em; text-transform: uppercase;
    color: var(--k-60); font-weight: 600;
  }
  .hub-form__legend {
    font-size: 18px; font-weight: 600; line-height: 1.3;
    color: var(--k-100);
  }

  .hub-form__inputs { display: grid; gap: 16px; }
  .hub-form__choices { display: grid; gap: 4px; }

  .hub-form label {
    display: flex; align-items: flex-start; gap: 12px;
    padding: 10px 12px; cursor: pointer;
    border: 1px solid transparent;
    transition: background 150ms cubic-bezier(0.16,1,0.3,1), border-color 150ms;
    border-radius: 4px; line-height: 1.5;
  }
  .hub-form__choices label:hover { background: var(--k-05); }
  .hub-form input[type='radio'],
  .hub-form input[type='checkbox'] {
    margin-top: 2px; accent-color: var(--accent);
    width: 18px; height: 18px; flex-shrink: 0;
  }
  .hub-form__choices label:has(input:checked) { background: var(--k-05); border-color: var(--k-30); }
  .hub-form__choices label:focus-within { outline: 2px solid var(--accent); outline-offset: 2px; }

  .hub-form__field { flex-direction: column; align-items: stretch; gap: 8px; padding: 4px 0; cursor: default; }
  .hub-form__field:hover { background: transparent; }
  .hub-form__field-label { font-weight: 500; font-size: 13px; color: var(--k-90); letter-spacing: 0.01em; }
  .hub-form__textarea-label { flex-direction: column; align-items: stretch; gap: 8px; padding: 4px 0; cursor: default; }
  .hub-form__textarea-label:hover { background: transparent; }

  .hub-form__row { flex-wrap: wrap; align-items: center; }
  .hub-form input[type='text'],
  .hub-form input[type='email'],
  .hub-form input[type='tel'],
  .hub-form input[type='number'],
  .hub-form input[type='month'],
  .hub-form textarea {
    width: 100%; padding: 12px 14px;
    border: 1px solid var(--k-30); border-radius: 4px;
    font: inherit; box-sizing: border-box;
    background: var(--bg, #fff); color: inherit;
    transition: border-color 150ms cubic-bezier(0.16,1,0.3,1);
  }
  .hub-form input:focus,
  .hub-form textarea:focus {
    border-color: var(--accent); outline: 0;
    box-shadow: 0 0 0 3px rgba(208, 52, 44, 0.12);
  }
  .hub-form input[name='units'],
  .hub-form input[name='moveInMonth'] { max-width: 280px; }
  .hub-form input.hub-form__inline { display: inline-block; width: auto; max-width: 200px; }
  .hub-form input.hub-form__inline-num { display: inline-block; width: 80px; flex: 0 0 80px; }
  .hub-form textarea { resize: vertical; min-height: 110px; }

  .hub-form__hint {
    font-size: 13px; color: var(--k-70);
    margin: 0; max-width: 720px; line-height: 1.55;
  }
  .hub-form__check { gap: 12px; align-items: flex-start; padding: 8px 12px; border-radius: 4px; }
  .hub-form__check:hover { background: var(--k-05); }

  .hub-form__submit {
    margin-top: 16px;
    padding: 16px 32px;
    background: var(--accent); color: var(--accent-on);
    border: 0; border-radius: 4px;
    font-weight: 600; font-size: 16px;
    cursor: pointer; justify-self: start;
    transition: transform 150ms cubic-bezier(0.16,1,0.3,1), box-shadow 150ms;
  }
  .hub-form__submit:hover {
    transform: translateY(-1px);
    box-shadow: 0 8px 24px rgba(208, 52, 44, 0.25);
  }
  .hub-form__submit:active { transform: translateY(0); }
  .hub-form__submit:disabled { opacity: 0.5; cursor: default; transform: none; box-shadow: none; }

  .hub-form__success {
    margin-top: 16px;
    padding: 24px 28px;
    background: var(--k-100); color: var(--bg);
    border-left: 4px solid var(--accent);
    font-size: 17px; line-height: 1.55;
    display: block;
  }
  .hub-form__success[hidden] { display: none; }

  .hub-form__stipend[hidden] { display: none; }
  .hub-form__stipend {
    animation: hub-form-reveal 280ms cubic-bezier(0.16,1,0.3,1) both;
  }
  @keyframes hub-form-reveal {
    from { opacity: 0; transform: translateY(-8px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  @media (max-width: 640px) {
    .hub-form__group { padding: 24px 0; }
    .hub-form__legend { font-size: 17px; }
    .hub-form input[name='units'],
    .hub-form input[name='moveInMonth'] { max-width: none; }
    .hub-form__submit { width: 100%; justify-self: stretch; }
  }
</style>

<script is:inline>
  document.addEventListener('DOMContentLoaded', () => {
    document.querySelectorAll('[data-form="resident"]').forEach((form) => {
      // Reveal stipend follow-up when "yes" is selected.
      form.addEventListener('change', (e) => {
        if (e.target.name !== 'stipend') return;
        const value = e.target.value;
        form.querySelectorAll('[data-stipend]').forEach((b) => {
          b.hidden = b.dataset.stipend !== value;
        });
      });
      // Static success state on submit.
      form.addEventListener('submit', (e) => {
        e.preventDefault();
        const data = Object.fromEntries(new FormData(form));
        // eslint-disable-next-line no-console
        console.log('[pre-reservation payload]', data);
        const success = form.querySelector('.hub-form__success');
        if (success) success.hidden = false;
        const submitBtn = form.querySelector('button[type="submit"]');
        if (submitBtn) submitBtn.disabled = true;
      });
    });
  });
</script>
