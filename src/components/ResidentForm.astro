---
/*
 * ResidentForm — pre-reservation flow.
 *
 * Structure follows the research spec in
 * /12 Startovaci Hub/research/Optimal form and calculator.docx
 * with two practical adjustments per the redesign brief:
 *   • Step 0 keeps "počet jednotek 1+kk" + "termín nastěhování" side-by-side.
 *   • Step 2b carries a single optional checkbox for renewal right.
 *
 * Backend wiring deferred (per CLAUDE.md). Submit = console.log + success state.
 */

const roles = [
  { v: 'paying',     label: 'Platící rezident' },
  { v: 'stipend',    label: 'Stipendium' },
  { v: 'work-trade', label: 'Work-trade / správce' },
  { v: 'creator',    label: 'Rezident-tvůrce' },
  { v: 'unsure',     label: 'Ještě nevím, rozhodne cena a podmínky' },
];

const stay = [
  { v: '1-3m',   label: '1–3 měsíce' },
  { v: '3-6m',   label: '3–6 měsíců' },
  { v: '6-12m',  label: '6–12 měsíců' },
  { v: '12m+',   label: '12 a více měsíců' },
  { v: 'unsure', label: 'Ještě nevím' },
];

const budget = [
  { v: '0-4k',    label: 'Do 4 000 Kč' },
  { v: '4-6k',    label: '4 001–6 000' },
  { v: '6-8k',    label: '6 001–8 000' },
  { v: '8-10k',   label: '8 001–10 000' },
  { v: '10-12k',  label: '10 001–12 000' },
  { v: '12k+',    label: 'Více než 12 000' },
  { v: 'stipend', label: 'Jen stipendijní režim' },
];

const place = [
  { v: 'capsule',  label: 'Kapsle / nejlevnější lůžko' },
  { v: 'private',  label: 'Klidnější uzavíratelné místo' },
  { v: 'single',   label: 'Jednolůžkový pokoj' },
  { v: 'shared',   label: 'Sdílený pokoj' },
  { v: 'bunka',    label: 'Stavební buňka 1+kk (jen pro přípravné družstvo)' },
  { v: 'price',    label: 'Rozhodne cena' },
];

const prague = [
  { v: 'daily',    label: 'Denně v pracovní dny' },
  { v: '2-3w',     label: '2–3× týdně' },
  { v: 'weekly',   label: '1× týdně nebo méně' },
  { v: 'not',      label: 'Praha pro mě není hlavní důvod' },
];

const priorities = [
  { v: 'price',        label: 'Co nejnižší cena' },
  { v: 'access',       label: 'Rychlá dostupnost do Prahy' },
  { v: 'flexible',     label: 'Krátký a flexibilní pobyt' },
  { v: 'quiet',        label: 'Klid na práci nebo studium' },
  { v: 'community',    label: 'Komunita a společné prostory' },
  { v: 'fairness',     label: 'Férová pravidla a smysl projektu' },
  { v: 'contribute',   label: 'Možnost přispět jinak než penězi' },
];

const social = [
  { v: 'quiet',     label: 'Spíš klid a soukromí' },
  { v: 'between',   label: 'Něco mezi' },
  { v: 'community', label: 'Spíš komunita' },
];
---
<form class="rsv-form" data-form="resident" novalidate>

  <fieldset class="rsv-form__step">
    <legend>
      <span class="rsv-form__num">01</span>
      <span class="rsv-form__heading">Praktické vstupy</span>
      <span class="rsv-form__hint">Orientační čísla. Můžete je kdykoliv upřesnit.</span>
    </legend>
    <div class="rsv-form__grid-2">
      <label class="rsv-form__field">
        <span class="rsv-form__label">Počet jednotek 1+kk</span>
        <input type="number" name="units" min="1" max="50" value="1" required inputmode="numeric" />
      </label>
      <label class="rsv-form__field">
        <span class="rsv-form__label">Orientační termín nastěhování</span>
        <input type="month" name="moveIn" required />
      </label>
    </div>
  </fieldset>

  <fieldset class="rsv-form__step">
    <legend>
      <span class="rsv-form__num">02</span>
      <span class="rsv-form__heading">Jakou roli v Hubu hledáte?</span>
      <span class="rsv-form__hint">Vyberte cestu, která je vám dnes nejbližší. Hub počítá s každou z nich rovnocenně.</span>
    </legend>
    <div class="rsv-form__pills">
      {roles.map((r) => (
        <label class="rsv-form__pill">
          <input type="radio" name="role" value={r.v} required />
          <span>{r.label}</span>
        </label>
      ))}
    </div>
  </fieldset>

  <fieldset class="rsv-form__step">
    <legend>
      <span class="rsv-form__num">03</span>
      <span class="rsv-form__heading">Jak dlouho byste chtěl(a) v Hubu zůstat?</span>
      <span class="rsv-form__hint">Vyberte nejpravděpodobnější variantu.</span>
    </legend>
    <div class="rsv-form__pills">
      {stay.map((s) => (
        <label class="rsv-form__pill">
          <input type="radio" name="stay" value={s.v} required />
          <span>{s.label}</span>
        </label>
      ))}
    </div>
    <label class="rsv-form__check rsv-form__check--inline">
      <input type="checkbox" name="renewal" />
      <span>Chtěl(a) bych mít možnost prodlužovat nájem opakovaně.</span>
    </label>
  </fieldset>

  <fieldset class="rsv-form__step">
    <legend>
      <span class="rsv-form__num">04</span>
      <span class="rsv-form__heading">Jaký rozpočet byste měl(a) reálně k dispozici?</span>
      <span class="rsv-form__hint">Včetně základních služeb. Konkrétní cena se ladí s přípravným družstvem; orientační rozsahy najdete v poznámce u jednotlivých formátů.</span>
    </legend>
    <div class="rsv-form__pills rsv-form__pills--with-suffix">
      {budget.map((b) => (
        <label class="rsv-form__pill">
          <input type="radio" name="budget" value={b.v} required />
          <span>{b.label}{b.v !== 'stipend' && b.v !== '0-4k' ? ' Kč' : ''}{b.v === '0-4k' ? '' : ''}</span>
        </label>
      ))}
    </div>
  </fieldset>

  <fieldset class="rsv-form__step">
    <legend>
      <span class="rsv-form__num">05</span>
      <span class="rsv-form__heading">O jaký typ místa byste měl(a) největší zájem?</span>
      <span class="rsv-form__hint">Nejde o rezervaci konkrétního pokoje, jen o vaši první preferenci.</span>
    </legend>
    <div class="rsv-form__pills">
      {place.map((p) => (
        <label class="rsv-form__pill">
          <input type="radio" name="place" value={p.v} required />
          <span>{p.label}</span>
        </label>
      ))}
    </div>
  </fieldset>

  <fieldset class="rsv-form__step">
    <legend>
      <span class="rsv-form__num">06</span>
      <span class="rsv-form__heading">Jak často potřebujete být v Praze?</span>
      <span class="rsv-form__hint">Pomáhá nám posoudit, jestli pro vás bude dojezdová doba do Prahy únosná. Kyvadlový bus areálu jezdí přes špičku, jinak PID.</span>
    </legend>
    <div class="rsv-form__pills">
      {prague.map((p) => (
        <label class="rsv-form__pill">
          <input type="radio" name="prague" value={p.v} required />
          <span>{p.label}</span>
        </label>
      ))}
    </div>
  </fieldset>

  <fieldset class="rsv-form__step">
    <legend>
      <span class="rsv-form__num">07</span>
      <span class="rsv-form__heading">Co bude při rozhodování nejdůležitější?</span>
      <span class="rsv-form__hint">Vyberte nejvýš dvě priority.</span>
    </legend>
    <div class="rsv-form__pills" data-max="2">
      {priorities.map((p) => (
        <label class="rsv-form__pill">
          <input type="checkbox" name="priorities" value={p.v} />
          <span>{p.label}</span>
        </label>
      ))}
    </div>
  </fieldset>

  <fieldset class="rsv-form__step">
    <legend>
      <span class="rsv-form__num">08</span>
      <span class="rsv-form__heading">Kolik společného života v Hubu byste chtěl(a)?</span>
      <span class="rsv-form__hint">Stačí jedna odpověď.</span>
    </legend>
    <div class="rsv-form__pills">
      {social.map((s) => (
        <label class="rsv-form__pill">
          <input type="radio" name="social" value={s.v} required />
          <span>{s.label}</span>
        </label>
      ))}
    </div>
  </fieldset>

  <fieldset class="rsv-form__step rsv-form__branch" data-branch hidden>
    <legend>
      <span class="rsv-form__num">09</span>
      <span class="rsv-form__heading" data-branch-heading>Něco navíc</span>
      <span class="rsv-form__hint" data-branch-hint>Vyplňte stručně, neformálně.</span>
    </legend>
    <div class="rsv-form__inputs">
      <label class="rsv-form__field">
        <span class="rsv-form__label" data-branch-label-1>Co byste rád(a) v Hubu rozjel(a)?</span>
        <textarea name="branchIntent" rows="4" minlength="40" maxlength="500"></textarea>
      </label>
      <label class="rsv-form__field">
        <span class="rsv-form__label">Pár vět o vás</span>
        <textarea name="branchAbout" rows="4" minlength="40" maxlength="500" placeholder="Životní situace, co vás na Hubu chytlo, proč právě teď."></textarea>
      </label>
    </div>
  </fieldset>

  <fieldset class="rsv-form__step">
    <legend>
      <span class="rsv-form__num">10</span>
      <span class="rsv-form__heading">Kam vám máme poslat další informace?</span>
      <span class="rsv-form__hint">Posíláme privátní zprávu s aktuálním stavem projektu, termínem nejbližšího setkání družstva a detailem buňky 1+kk. Zhruba do dvou týdnů od vyplnění.</span>
    </legend>
    <div class="rsv-form__grid-2">
      <label class="rsv-form__field">
        <span class="rsv-form__label">Jméno a příjmení</span>
        <input type="text" name="name" required minlength="2" autocomplete="name" />
      </label>
      <label class="rsv-form__field">
        <span class="rsv-form__label">E-mail</span>
        <input type="email" name="email" required autocomplete="email" />
      </label>
    </div>
    <label class="rsv-form__field rsv-form__field--phone">
      <span class="rsv-form__label">Telefon (volitelné)</span>
      <input type="tel" name="phone" autocomplete="tel" inputmode="tel" />
    </label>
    <label class="rsv-form__check">
      <input type="checkbox" name="consent" required />
      <span>Souhlasím se zasláním informací k tomuto záměru na uvedený e-mail.</span>
    </label>
  </fieldset>

  <button type="submit" class="rsv-form__submit" data-submit>
    <span class="rsv-form__submit-label">Zapsat nezávazný zájem →</span>
    <span class="rsv-form__submit-overlay" aria-hidden="true">
      <span class="rsv-form__submit-spinner"></span>
    </span>
    <span class="rsv-form__submit-overlay rsv-form__submit-check" aria-hidden="true">
      <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><polyline points="4 12 10 18 20 6" /></svg>
      <span>Hotovo</span>
    </span>
  </button>

  <output class="rsv-form__success" hidden>
    <span class="rsv-form__success-eyebrow">Hotovo</span>
    <h3>Vítejte v přípravném družstvu.</h3>
    <p>Zapsali jsme váš nezávazný zájem. Není to rezervace, není to pořadník a není to slib přidělené jednotky. Z odpovědí skládáme první kohortu. Do dvou týdnů vám pošleme privátní zprávu s aktuálním stavem, termínem nejbližšího setkání družstva a detailem 1+kk buňky.</p>
    <p>Pokud jste vybral(a) stipendium, work-trade nebo roli rezidenta-tvůrce, doptáme se na detail samostatně.</p>
  </output>
</form>

<style>
  .rsv-form {
    display: grid; gap: 0;
    font-family: var(--font-sans);
  }

  .rsv-form__step {
    border: 0; padding: 40px 0 32px; margin: 0;
    display: grid; gap: 20px;
    border-bottom: 1px solid var(--k-10);
  }
  .rsv-form__step:first-of-type { padding-top: 0; }
  .rsv-form__step:last-of-type { border-bottom: 0; }

  .rsv-form__step legend {
    display: grid; gap: 6px;
    padding: 0; margin: 0;
    grid-template-columns: minmax(0, 1fr);
  }
  .rsv-form__num {
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--accent);
    letter-spacing: 0.04em;
    margin-top: 8px;
  }
  .rsv-form__heading {
    font-size: clamp(18px, 1.6vw, 22px);
    font-weight: 600;
    line-height: 1.3;
    color: var(--k-100);
  }
  .rsv-form__hint {
    font-size: 14px; line-height: 1.55;
    color: var(--fg-muted);
    max-width: 64ch;
  }

  /* Pills (radio + checkbox row) */
  .rsv-form__pills {
    display: flex; flex-wrap: wrap; gap: 8px;
  }
  .rsv-form__pill { position: relative; margin: 0; }
  .rsv-form__pill input {
    position: absolute; opacity: 0; pointer-events: none;
    width: 0; height: 0;
  }
  .rsv-form__pill span {
    display: inline-block;
    padding: 11px 18px;
    border: 1px solid var(--border-muted);
    border-radius: var(--radius-input);
    font-size: 14px;
    font-weight: 500;
    line-height: 1.2;
    color: var(--fg);
    background: var(--bg);
    cursor: pointer;
    user-select: none;
    transition:
      border-color var(--dur-base) var(--ease-decel),
      background var(--dur-base) var(--ease-decel),
      color var(--dur-base) var(--ease-decel),
      transform var(--dur-fast) var(--ease-decel);
  }
  .rsv-form__pill:hover span { border-color: var(--accent); color: var(--k-100); }
  .rsv-form__pill input:checked + span {
    background: var(--accent);
    color: var(--accent-on);
    border-color: var(--accent);
  }
  .rsv-form__pill input:focus-visible + span {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
  }
  .rsv-form__pill input:checked:active + span,
  .rsv-form__pill input:active + span { transform: scale(0.97); }

  /* Two-column grids */
  .rsv-form__grid-2 {
    display: grid; grid-template-columns: 1fr 1fr; gap: 16px;
  }
  @media (max-width: 640px) {
    .rsv-form__grid-2 { grid-template-columns: 1fr; }
  }

  .rsv-form__inputs { display: grid; gap: 16px; }

  /* Field (input/textarea wrapper) */
  .rsv-form__field {
    display: grid; gap: 6px;
  }
  .rsv-form__label {
    font-size: 13px; font-weight: 500;
    color: var(--fg);
    letter-spacing: 0.01em;
  }
  .rsv-form input[type='text'],
  .rsv-form input[type='email'],
  .rsv-form input[type='tel'],
  .rsv-form input[type='number'],
  .rsv-form input[type='month'],
  .rsv-form textarea {
    width: 100%;
    padding: 12px 14px;
    border: 1px solid var(--border-muted);
    border-radius: var(--radius-input);
    font: 500 15px / 1.4 var(--font-sans);
    background: var(--bg);
    color: inherit;
    box-sizing: border-box;
    transition:
      border-color var(--dur-base) var(--ease-decel),
      box-shadow var(--dur-base) var(--ease-decel);
  }
  .rsv-form input:focus,
  .rsv-form textarea:focus {
    outline: 0;
    border-color: var(--accent);
    box-shadow: 0 0 0 3px var(--accent-soft);
  }
  /* Calmer month picker — strip the Chrome date picker chrome and tint
     the indicator so it matches the brand. */
  .rsv-form input[type='month'] {
    appearance: none;
    -webkit-appearance: none;
    font-variant-numeric: tabular-nums;
    cursor: pointer;
    color: var(--fg);
  }
  .rsv-form input[type='month']::-webkit-calendar-picker-indicator {
    cursor: pointer;
    opacity: 0.55;
    filter: grayscale(1);
    padding: 4px;
    transition: opacity var(--dur-fast) linear;
  }
  .rsv-form input[type='month']:hover::-webkit-calendar-picker-indicator { opacity: 0.85; }
  .rsv-form input[type='month']::-webkit-datetime-edit-fields-wrapper { padding: 0; }
  .rsv-form input[type='month']::-webkit-datetime-edit { padding: 0; }
  .rsv-form input[type='month']:not(:focus):invalid {
    color: var(--fg-subtle);
  }
  .rsv-form textarea {
    resize: vertical;
    min-height: 110px;
    font-family: var(--font-sans);
  }

  /* Phone field — narrower on desktop */
  .rsv-form__field--phone { max-width: 320px; }
  @media (max-width: 640px) {
    .rsv-form__field--phone { max-width: none; }
  }

  /* Single checkbox (renewal, consent) */
  .rsv-form__check {
    display: flex; align-items: flex-start; gap: 12px;
    padding: 8px 0;
    cursor: pointer;
    line-height: 1.5;
  }
  .rsv-form__check--inline { padding-top: 4px; }
  .rsv-form__check input[type='checkbox'] {
    width: 18px; height: 18px;
    margin: 2px 0 0 0;
    accent-color: var(--accent);
    flex-shrink: 0;
  }
  .rsv-form__check span {
    font-size: 14px; color: var(--fg);
  }
  .rsv-form__check input:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
    border-radius: 2px;
  }

  /* Branch reveal */
  .rsv-form__branch[hidden] { display: none; }
  .rsv-form__branch:not([hidden]) {
    animation: rsv-form-reveal 320ms var(--ease-decel) both;
  }
  @keyframes rsv-form-reveal {
    from { opacity: 0; transform: translateY(-6px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  /* Submit */
  /* Submit — primary plum, wipe retract on hover. */
  .rsv-form__submit {
    position: relative;
    isolation: isolate;
    overflow: hidden;
    margin-top: 24px;
    padding: 16px 32px;
    background: transparent;
    color: #fff;
    border: 1px solid var(--accent);
    border-radius: var(--radius-input);
    font: 600 16px / 1 var(--font-sans);
    cursor: pointer;
    justify-self: start;
    transition: color 160ms cubic-bezier(0.65, 0, 0.35, 1);
  }
  .rsv-form__submit::after {
    content: "";
    position: absolute;
    inset: 0;
    background: var(--accent);
    z-index: -1;
    clip-path: inset(0 0 0 0);
    transition: clip-path 220ms cubic-bezier(0.65, 0, 0.35, 1);
  }
  .rsv-form__submit:hover,
  .rsv-form__submit:focus-visible { color: var(--accent); }
  .rsv-form__submit:hover::after,
  .rsv-form__submit:focus-visible::after { clip-path: inset(100% 0 0 0); }
  .rsv-form__submit:disabled { cursor: default; }
  .rsv-form__submit:disabled::after { clip-path: inset(0 0 0 0); }

  /* 3-state submit morph: label → spinner → check.
     The label sits in normal flow; spinner and check overlays absolutely
     fill the button so morph transitions never affect layout. */
  .rsv-form__submit-label {
    display: inline-flex;
    transition: opacity 180ms cubic-bezier(0.32, 0.72, 0, 1),
                transform 180ms cubic-bezier(0.32, 0.72, 0, 1);
  }
  .rsv-form__submit-overlay {
    position: absolute; inset: 0;
    display: flex; align-items: center; justify-content: center; gap: 10px;
    opacity: 0; transform: translateY(4px);
    pointer-events: none;
    transition: opacity 180ms cubic-bezier(0.32, 0.72, 0, 1),
                transform 180ms cubic-bezier(0.32, 0.72, 0, 1);
  }
  .rsv-form__submit-spinner {
    width: 16px; height: 16px;
    border: 2px solid currentColor;
    border-top-color: transparent;
    border-radius: 50%;
    box-sizing: border-box;
    animation: rsv-spin 720ms linear infinite;
    animation-play-state: paused;
  }
  .rsv-form__submit.is-loading .rsv-form__submit-label { opacity: 0; transform: translateY(-4px); }
  .rsv-form__submit.is-loading .rsv-form__submit-overlay:not(.rsv-form__submit-check) {
    opacity: 1; transform: none;
  }
  .rsv-form__submit.is-loading .rsv-form__submit-spinner { animation-play-state: running; }
  .rsv-form__submit.is-success .rsv-form__submit-label { opacity: 0; }
  .rsv-form__submit.is-success .rsv-form__submit-overlay:not(.rsv-form__submit-check) { opacity: 0; }
  .rsv-form__submit.is-success .rsv-form__submit-check { opacity: 1; transform: none; }
  .rsv-form__submit-check svg {
    /* Stroke draws from 0 to full when .is-success is added. dasharray
       length matches the polyline path (~30 units in viewBox). */
    stroke-dasharray: 30;
    stroke-dashoffset: 30;
    transition: stroke-dashoffset 360ms cubic-bezier(0.16, 1, 0.3, 1) 80ms;
  }
  .rsv-form__submit.is-success .rsv-form__submit-check svg {
    stroke-dashoffset: 0;
  }
  @keyframes rsv-spin { to { transform: rotate(360deg); } }
  @keyframes rsv-success-in {
    from { opacity: 0; transform: translateY(8px); }
    to   { opacity: 1; transform: translateY(0); }
  }
  @media (prefers-reduced-motion: reduce) {
    .rsv-form__submit-spinner { animation: none; }
    .rsv-form__submit-check svg { transition: none; stroke-dashoffset: 0; }
  }
  .rsv-form__submit:focus-visible {
    outline: 3px solid var(--accent-soft);
    outline-offset: 2px;
  }
  @media (prefers-reduced-motion: reduce) {
    .rsv-form__submit,
    .rsv-form__submit::after { transition: none; }
  }

  /* Success panel */
  .rsv-form__success {
    margin-top: 24px;
    padding: 32px 28px;
    background: var(--k-100);
    color: var(--bg);
    border-left: 4px solid var(--accent);
    border-radius: var(--radius-input);
    display: grid; gap: 8px;
  }
  .rsv-form__success[hidden] { display: none; }
  .rsv-form__success-eyebrow {
    font-family: var(--font-mono);
    font-size: 12px; letter-spacing: 0.06em;
    color: var(--accent-on);
    opacity: 0.7;
    text-transform: uppercase;
  }
  .rsv-form__success h3 {
    font-size: 22px; font-weight: 600;
    line-height: 1.3; margin: 0;
  }
  .rsv-form__success p {
    font-size: 15px; line-height: 1.55;
    color: rgba(255,255,255,0.85);
    margin: 0; max-width: 56ch;
  }

  @media (prefers-reduced-motion: reduce) {
    .rsv-form__pill span,
    .rsv-form input,
    .rsv-form textarea,
    .rsv-form__submit,
    .rsv-form__branch { transition: none; animation: none; }
  }
</style>

<script is:inline>
  document.addEventListener('astro:page-load', () => {
    document.querySelectorAll('[data-form="resident"]').forEach((form) => {
      if (form.dataset.formBound === '1') return;
      form.dataset.formBound = '1';
      // Max-2 enforcement on priorities (uncheck the oldest if user picks a third)
      const priorityBoxes = form.querySelectorAll('input[name="priorities"]');
      let priorityOrder = [];
      priorityBoxes.forEach((box) => {
        box.addEventListener('change', () => {
          if (box.checked) {
            priorityOrder.push(box);
            if (priorityOrder.length > 2) {
              const oldest = priorityOrder.shift();
              oldest.checked = false;
            }
          } else {
            priorityOrder = priorityOrder.filter((b) => b !== box);
          }
        });
      });

      // Role branching: show step 09 only for stipend / work-trade / creator,
      // and tweak the heading + first label for context.
      const branchRoles = {
        stipend: {
          heading: 'Proč pro vás dává stipendium smysl právě teď?',
          hint: 'Životní situace stačí stručně. Nepotřebujeme dlouhé vysvětlování.',
          label1: 'V čem si představujete přínos pro Hub?',
        },
        'work-trade': {
          heading: 'Co umíte nabídnout výměnou za zvýhodněné bydlení?',
          hint: 'Napište 1–3 konkrétní činnosti a odhad hodin týdně.',
          label1: 'S čím byste uměl(a) reálně pomoct?',
        },
        creator: {
          heading: 'Co byste do Hubu přinesl(a) jako tvůrce?',
          hint: 'Obor, forma výstupu, případně odkaz na ukázku v textu níže.',
          label1: 'Co tvoříte a co byste v Hubu rozjel(a)?',
        },
      };
      const branch = form.querySelector('[data-branch]');
      const branchHeading = form.querySelector('[data-branch-heading]');
      const branchHint = form.querySelector('[data-branch-hint]');
      const branchLabel1 = form.querySelector('[data-branch-label-1]');
      const branchTextareas = branch ? branch.querySelectorAll('textarea') : [];

      form.addEventListener('change', (e) => {
        if (e.target.name !== 'role') return;
        const cfg = branchRoles[e.target.value];
        if (cfg) {
          branch.hidden = false;
          if (branchHeading) branchHeading.textContent = cfg.heading;
          if (branchHint) branchHint.textContent = cfg.hint;
          if (branchLabel1) branchLabel1.textContent = cfg.label1;
          branchTextareas.forEach((t) => t.required = true);
        } else {
          branch.hidden = true;
          branchTextareas.forEach((t) => { t.required = false; t.value = ''; });
        }
      });

      // Submit: console.log payload + 3-state morph (label → spinner → check)
      // → static success panel. Backend wiring is still TODO; the visual
      // contract is in place so the eventual fetch() drop-in keeps the same
      // is-loading / is-success choreography.
      form.addEventListener('submit', (e) => {
        e.preventDefault();
        const data = Object.fromEntries(new FormData(form));
        data.priorities = Array.from(form.querySelectorAll('input[name="priorities"]:checked')).map((b) => b.value);
        // eslint-disable-next-line no-console
        console.log('[pre-reservation payload]', data);

        const submitBtn = form.querySelector('[data-submit]');
        const success = form.querySelector('.rsv-form__success');
        if (!submitBtn) return;

        submitBtn.disabled = true;
        submitBtn.classList.add('is-loading');

        // Stand-in for network round-trip — replace with actual fetch().
        setTimeout(() => {
          submitBtn.classList.remove('is-loading');
          submitBtn.classList.add('is-success');
          if (success) {
            success.hidden = false;
            success.style.animation = 'rsv-success-in 520ms cubic-bezier(0.16,1,0.3,1) both';
          }
          setTimeout(() => {
            success?.scrollIntoView({ behavior: 'smooth', block: 'center' });
          }, 120);
        }, 720);
      });
    });
  });
</script>
