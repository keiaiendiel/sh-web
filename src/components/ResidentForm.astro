---
---
<form class="hub-form hub-form--resident" data-form="resident" novalidate>
  <p class="hub-form__intro">Přijímání nezávazných před-rezervací spuštěno. Vyplnění není závazné. Pomáhá nám připravit nabídku pro lidi, kteří mají reálný zájem.</p>

  <fieldset>
    <legend>Mám zájem o nezávaznou před-rezervaci</legend>
    <label class="hub-form__field">
      <span class="hub-form__field-label">Počet jednotek 1+kk</span>
      <input type="number" name="units" min="1" max="50" value="1" required inputmode="numeric" />
    </label>
    <label class="hub-form__field">
      <span class="hub-form__field-label">Termín nastěhování</span>
      <input type="month" name="moveInMonth" required />
    </label>
  </fieldset>

  <fieldset>
    <legend>Doba nájmu</legend>
    <label><input type="radio" name="duration" value="1m" required /> 1 měsíc</label>
    <label><input type="radio" name="duration" value="1y" /> 1 rok</label>
    <label><input type="radio" name="duration" value="5y" /> 5 let</label>
    <label class="hub-form__row">
      <input type="radio" name="duration" value="other" />
      <span>Jiná délka</span>
      <input type="text" name="durationOther" placeholder="např. 6 měsíců" class="hub-form__inline" />
    </label>
  </fieldset>

  <fieldset>
    <legend>Právo prodloužit nájem</legend>
    <label><input type="radio" name="extension" value="none" required /> Bez prodloužení</label>
    <label class="hub-form__row">
      <input type="radio" name="extension" value="finite" />
      <span>Možnost prodloužit</span>
      <input type="number" name="extensionTimes" min="1" max="20" placeholder="3" class="hub-form__inline-num" />
      <span>krát na stejnou dobu</span>
    </label>
    <label><input type="radio" name="extension" value="indefinite" /> Možnost prodlužovat opakovaně bez omezení</label>
  </fieldset>

  <fieldset>
    <legend>Pobytové stipendium</legend>
    <p class="hub-form__hint">Stipendijní režim je pro lidi, kteří by Hubu dávali smysl, ale bez podpory by si pobyt nemohli dovolit. Není to slevový kód, je to popsaný výběr.</p>
    <label><input type="radio" name="stipend" value="no" required /> Nemám zájem o stipendium</label>
    <label><input type="radio" name="stipend" value="yes" /> Mám zájem o stipendium</label>
  </fieldset>

  <fieldset class="hub-form__stipend" data-stipend="yes" hidden>
    <legend>Záměr nebo projekt v Hubu</legend>
    <label class="hub-form__textarea-label">
      <span class="hub-form__field-label">Co byste rád(a) ve Startovacím Hubu rozjel(a)?</span>
      <textarea name="stipendIntent" rows="4" minlength="40" maxlength="500" placeholder="Studium, výzkum, pilotní projekt, kulturní program, vlastní podnikání."></textarea>
    </label>
    <label class="hub-form__textarea-label">
      <span class="hub-form__field-label">Něco o vás</span>
      <textarea name="stipendAbout" rows="4" minlength="40" maxlength="500" placeholder="Pár vět o vašem příběhu a o tom, proč by stipendium dávalo smysl."></textarea>
    </label>
  </fieldset>

  <fieldset>
    <legend>Kontakt</legend>
    <label class="hub-form__field">
      <span class="hub-form__field-label">Jméno a příjmení</span>
      <input type="text" name="name" required minlength="2" />
    </label>
    <label class="hub-form__field">
      <span class="hub-form__field-label">E-mail</span>
      <input type="email" name="email" required />
    </label>
    <label class="hub-form__field">
      <span class="hub-form__field-label">Telefon (volitelné)</span>
      <input type="tel" name="phone" />
    </label>
    <label class="hub-form__check"><input type="checkbox" name="consent" required /> Souhlasím se zasláním informací k nabídce.</label>
  </fieldset>

  <button type="submit" class="hub-form__submit">Odeslat nezávaznou před-rezervaci</button>

  <output class="hub-form__success" hidden>
    Děkujeme. Zapsali jsme vaši nezávaznou před-rezervaci. Není to smlouva. Ozveme se vám, jakmile budeme mít konkrétní nabídku odpovídající vašim preferencím.
  </output>
</form>

<style>
  .hub-form { display: grid; gap: 32px; max-width: 720px; }
  .hub-form fieldset { border: 0; padding: 0; margin: 0; display: grid; gap: 8px; }
  .hub-form legend { font-weight: 600; margin: 0 0 12px; font-size: 17px; padding: 0; }
  .hub-form label { display: flex; align-items: center; gap: 10px; padding: 6px 0; line-height: 1.5; }
  .hub-form__field { flex-direction: column; align-items: stretch; gap: 6px; }
  .hub-form__field-label { font-weight: 500; font-size: 14px; color: var(--k-90); }
  .hub-form__row { flex-wrap: wrap; }
  .hub-form input[type='text'],
  .hub-form input[type='email'],
  .hub-form input[type='tel'],
  .hub-form input[type='number'],
  .hub-form input[type='month'],
  .hub-form textarea { width: 100%; padding: 10px 12px; border: 1px solid var(--k-30); border-radius: 4px; font: inherit; box-sizing: border-box; background: var(--bg, #fff); color: inherit; }
  .hub-form input[name='units'], .hub-form input[name='moveInMonth'] { max-width: 280px; }
  .hub-form__inline { display: inline-block; width: auto; max-width: 200px; }
  .hub-form__inline-num { display: inline-block; width: 80px; }
  .hub-form textarea { resize: vertical; min-height: 100px; }
  .hub-form__textarea-label { flex-direction: column; align-items: stretch; gap: 6px; }
  .hub-form__intro { font-size: 14px; color: var(--k-70); margin: 0; max-width: 720px; line-height: 1.55; }
  .hub-form__hint { font-size: 13px; color: var(--k-70); margin: 0 0 12px; max-width: 720px; line-height: 1.55; }
  .hub-form__check { gap: 8px; align-items: center; }
  .hub-form__submit { padding: 14px 28px; background: var(--accent, var(--k-100)); color: var(--accent-on, var(--bg, #fff)); border: 0; font-weight: 600; cursor: pointer; font-size: 16px; justify-self: start; }
  .hub-form__submit:disabled { opacity: 0.5; cursor: default; }
  .hub-form__success { padding: 16px 20px; background: var(--k-10); border-left: 3px solid var(--accent, var(--k-100)); display: block; line-height: 1.55; }
  .hub-form__success[hidden] { display: none; }
  .hub-form__stipend[hidden] { display: none; }
</style>

<script is:inline>
  document.addEventListener('DOMContentLoaded', () => {
    document.querySelectorAll('[data-form="resident"]').forEach((form) => {
      // Reveal stipend follow-up when "yes" is selected.
      form.addEventListener('change', (e) => {
        if (e.target.name !== 'stipend') return;
        const value = e.target.value;
        form.querySelectorAll('[data-stipend]').forEach((b) => {
          b.hidden = b.dataset.stipend !== value;
        });
      });
      // Static success state on submit.
      form.addEventListener('submit', (e) => {
        e.preventDefault();
        const data = Object.fromEntries(new FormData(form));
        // eslint-disable-next-line no-console
        console.log('[pre-reservation payload]', data);
        const success = form.querySelector('.hub-form__success');
        if (success) success.hidden = false;
        const submitBtn = form.querySelector('button[type="submit"]');
        if (submitBtn) submitBtn.disabled = true;
      });
    });
  });
</script>
