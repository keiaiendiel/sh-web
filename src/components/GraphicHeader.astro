---
/*
 * GraphicHeader - full-bleed strip using one of the OSA graphic assets.
 * Assets in /public/graphics/graphic-asset-header_{1..6}.svg.
 * Two sizes: 'strip' (64 px, a divider between sections) and 'band' (108 px,
 * a heavier marker). Light / dark variants match the surrounding section.
 */
interface Props {
  /** Which asset 1..6 */
  n?: 1 | 2 | 3 | 4 | 5 | 6;
  /** Surface variant */
  variant?: 'light' | 'dark';
  /** Height preset */
  size?: 'strip' | 'band';
  /** Extra class */
  class?: string;
}
const { n = 1, variant = 'light', size = 'strip', class: className } = Astro.props;
const src = `/graphics/graphic-asset-header_${n}.svg`;
---
<div class:list={['osa-gh', `osa-gh--${variant}`, `osa-gh--${size}`, className]} aria-hidden="true">
  <img src={src} alt="" class="osa-gh__img" loading="lazy" decoding="async" />
</div>

<style>
  .osa-gh {
    display: block;
    width: 100%;
    overflow: hidden;
    line-height: 0;
  }
  .osa-gh--light { background: var(--k-0);   }
  .osa-gh--dark  { background: var(--k-100); }

  .osa-gh--strip { height: 64px; }
  .osa-gh--band  { height: 108px; }

  .osa-gh__img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: left center;
  }
  /* Black-on-transparent SVGs invert on dark surfaces so they render white. */
  .osa-gh--dark .osa-gh__img { filter: invert(1); }
</style>
