---
/*
 * FloatingAction , mobile-only floating arrow button bottom-right.
 *
 *   - Na landing (/): scroll-to-top, viditelný až po scrollu > 600 px.
 *   - Na ostatních stránkách: back to landing (link na /).
 *
 * Hidden on desktop (>= 1025 px). Render do Base.astro takže existuje na
 * každé stránce a JS rozhodne mode podle URL.
 */
import { withBase } from '../utils/url';

const home = withBase('/');
---
<a
  id="floating-action"
  class="floating-action"
  href={home}
  aria-label="Zpět na hlavní stránku"
  data-fa-mode="back"
  hidden>
  <svg viewBox="0 0 24 24" width="22" height="22" aria-hidden="true">
    <path d="M19 12H5" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" fill="none" />
    <path d="M12 5l-7 7 7 7" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" fill="none" />
  </svg>
</a>

<script is:inline>
  (function () {
    if (window.__hubFaBound) return;
    window.__hubFaBound = true;

    function bind() {
      var el = document.getElementById('floating-action');
      if (!el) return;
      var base = el.getAttribute('href').replace(/\/$/, '');
      var isHome = window.location.pathname.replace(/\/$/, '') === base;

      if (isHome) {
        /* Scroll-to-top mode: show after 600 px, click → smooth scroll to top. */
        el.setAttribute('aria-label', 'Skrolovat zpátky nahoru');
        el.setAttribute('data-fa-mode', 'top');
        el.removeAttribute('href');
        el.setAttribute('role', 'button');
        el.setAttribute('tabindex', '0');
        var svg = el.querySelector('svg');
        if (svg) {
          /* Up arrow instead of left arrow */
          svg.innerHTML =
            '<path d="M12 19V5" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" fill="none"/>' +
            '<path d="M5 12l7-7 7 7" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" fill="none"/>';
        }

        function check() {
          if (window.scrollY > 600) el.removeAttribute('hidden');
          else el.setAttribute('hidden', '');
        }
        function go(e) {
          if (e && e.preventDefault) e.preventDefault();
          window.scrollTo({ top: 0, behavior: 'smooth' });
        }
        el.addEventListener('click', go);
        el.addEventListener('keydown', function (e) {
          if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); go(); }
        });
        window.addEventListener('scroll', check, { passive: true });
        check();
      } else {
        /* Back mode: always visible. */
        el.removeAttribute('hidden');
      }
    }

    document.addEventListener('astro:page-load', bind);
  }());
</script>

<style>
  .floating-action {
    position: fixed;
    bottom: clamp(20px, 5vw, 32px);
    right: clamp(20px, 5vw, 32px);
    width: 52px;
    height: 52px;
    display: none;
    align-items: center;
    justify-content: center;
    border-radius: 999px;
    background: var(--plum-deep);
    color: #fff;
    box-shadow: 0 8px 24px rgba(45, 20, 48, 0.32), 0 1px 2px rgba(0,0,0,0.10);
    text-decoration: none;
    z-index: 40;
    cursor: pointer;
    transition: transform 320ms cubic-bezier(0.32, 0.72, 0, 1),
                box-shadow 320ms cubic-bezier(0.32, 0.72, 0, 1),
                opacity 280ms cubic-bezier(0.32, 0.72, 0, 1);
  }
  @media (max-width: 1024px) {
    .floating-action { display: inline-flex; }
  }
  .floating-action[hidden] {
    opacity: 0;
    transform: translateY(12px) scale(0.92);
    pointer-events: none;
    display: none;
  }
  .floating-action[data-fa-mode="top"]:not([hidden]) {
    display: inline-flex;
    animation: floating-action-pop 360ms cubic-bezier(0.32, 0.72, 0, 1);
  }
  .floating-action:hover,
  .floating-action:focus-visible {
    transform: translateY(-2px) scale(1.04);
    box-shadow: 0 14px 32px rgba(45, 20, 48, 0.40), 0 2px 4px rgba(0,0,0,0.12);
    outline: none;
  }
  .floating-action:active {
    transform: translateY(0) scale(0.96);
  }
  .floating-action:focus-visible {
    outline: 2px solid var(--rose);
    outline-offset: 4px;
  }
  .floating-action svg { display: block; }

  @keyframes floating-action-pop {
    from { transform: translateY(20px) scale(0.7); opacity: 0; }
    to   { transform: translateY(0) scale(1); opacity: 1; }
  }
  @media (prefers-reduced-motion: reduce) {
    .floating-action {
      transition: none;
      animation: none;
    }
  }
</style>
