---
/*
 * FloatingAction , mobile-only floating arrow button bottom-right.
 *
 *   - Na landing (/): scroll-to-top, viditelný až po scrollu > 600 px.
 *   - Na ostatních stránkách: back to landing (link na /).
 *
 * Styling sjednocený s landing .lp-hero__scroll-cue (glass-morph kruh bez
 * solid fillu, ikona dělá těžkou práci). Hidden on desktop (>= 1025 px).
 * Render do Base.astro takže existuje na každé stránce, JS rozhoduje mode
 * podle URL.
 */
import { withBase } from '../utils/url';
import Icon from './Icon.astro';

const home = withBase('/');
---
<a
  id="floating-action"
  class="floating-action"
  href={home}
  aria-label="Zpět na hlavní stránku"
  data-fa-mode="back"
  hidden>
  <span class="floating-action__icon" data-fa-icon="back" aria-hidden="true">
    <Icon name="arrow-left" size={22} strokeWidth={2} />
  </span>
  <span class="floating-action__icon" data-fa-icon="top" aria-hidden="true" hidden>
    <Icon name="chevron-up" size={22} strokeWidth={2} />
  </span>
</a>

<script is:inline>
  (function () {
    if (window.__hubFaBound) return;
    window.__hubFaBound = true;

    function bind() {
      var el = document.getElementById('floating-action');
      if (!el) return;
      var base = el.getAttribute('href').replace(/\/$/, '');
      var path = window.location.pathname.replace(/\/$/, '');
      var isHome = path === base;
      /* Rezervační formulář (5-step wizard) má vlastní bottom-fixed CTA bar
         + sticky sidebar, floating action by se s nimi překrýval. Schováme. */
      var isRezervace = /\/rezervace$/.test(path);
      if (isRezervace) {
        el.setAttribute('hidden', '');
        el.setAttribute('data-fa-disabled', '');
        return;
      }

      var iconBack = el.querySelector('[data-fa-icon="back"]');
      var iconTop = el.querySelector('[data-fa-icon="top"]');

      /* Mirror header's is-stuck onto the floating action so when the user has
         scrolled past the dark hero (white content area below) we switch from
         white glass to plum glass. Same trigger as the header sticky swap. */
      var header = document.querySelector('.hub-header--overlay');
      if (header) {
        var syncOverlap = function () {
          if (header.classList.contains('is-stuck')) el.setAttribute('data-overlap', 'light');
          else el.removeAttribute('data-overlap');
        };
        syncOverlap();
        var mo = new MutationObserver(syncOverlap);
        mo.observe(header, { attributes: true, attributeFilter: ['class'] });
      } else {
        el.removeAttribute('data-overlap');
      }

      if (isHome) {
        /* Scroll-to-top mode: show after 600 px, click → smooth scroll to top. */
        el.setAttribute('aria-label', 'Skrolovat zpátky nahoru');
        el.setAttribute('data-fa-mode', 'top');
        el.removeAttribute('href');
        el.setAttribute('role', 'button');
        el.setAttribute('tabindex', '0');
        if (iconBack) iconBack.setAttribute('hidden', '');
        if (iconTop) iconTop.removeAttribute('hidden');

        function check() {
          if (window.scrollY > 600) el.removeAttribute('hidden');
          else el.setAttribute('hidden', '');
        }
        function go(e) {
          if (e && e.preventDefault) e.preventDefault();
          window.scrollTo({ top: 0, behavior: 'smooth' });
        }
        el.addEventListener('click', go);
        el.addEventListener('keydown', function (e) {
          if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); go(); }
        });
        window.addEventListener('scroll', check, { passive: true });
        check();
      } else {
        /* Back mode: always visible, back arrow shown. */
        if (iconBack) iconBack.removeAttribute('hidden');
        if (iconTop) iconTop.setAttribute('hidden', '');
        el.removeAttribute('hidden');
      }
    }

    document.addEventListener('astro:page-load', bind);
  }());
</script>

<style>
  /* Glass-morph kruh sjednocený s .lp-hero__scroll-cue: 48×48, žádný solid
     fill, jen translucent backdrop + thin border. Pod dark hero (deep/ink)
     bílá ikona + bílý border; pod light hero (cream/rose) plum-deep ikona
     + plum-deep border. body[data-hero-tone] (z SubpageHero) řídí který. */
  .floating-action {
    position: fixed;
    bottom: clamp(20px, 5vw, 32px);
    right: clamp(20px, 5vw, 32px);
    width: 48px;
    height: 48px;
    display: none;
    align-items: center;
    justify-content: center;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.06);
    border: 1px solid rgba(255, 255, 255, 0.32);
    backdrop-filter: blur(6px);
    -webkit-backdrop-filter: blur(6px);
    color: #fff;
    text-decoration: none;
    z-index: 40;
    cursor: pointer;
    transition:
      transform 320ms cubic-bezier(0.32, 0.72, 0, 1),
      background 220ms cubic-bezier(0.32, 0.72, 0, 1),
      border-color 220ms cubic-bezier(0.32, 0.72, 0, 1),
      color 220ms cubic-bezier(0.32, 0.72, 0, 1),
      opacity 280ms cubic-bezier(0.32, 0.72, 0, 1);
  }
  .floating-action__icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    line-height: 0;
  }
  .floating-action__icon[hidden] { display: none; }

  /* Light hero (cream / rose): plum-deep accent místo bílé */
  :global(body[data-hero-tone="light"]) .floating-action,
  .floating-action[data-overlap="light"] {
    background: hsl(var(--hue) 41% 13% / 0.06);
    border-color: hsl(var(--hue) 41% 13% / 0.22);
    color: var(--plum-deep);
  }

  /* Desktop: úplně schované. Mobile (< 1025 px): zobrazeno (back mode),
     nebo zobrazeno až po scrollu > 600 px (top mode přes JS). */
  @media (max-width: 1024px) {
    .floating-action { display: inline-flex; }
    .floating-action[data-fa-mode="top"]:not([hidden]) {
      display: inline-flex;
      animation: floating-action-pop 360ms cubic-bezier(0.32, 0.72, 0, 1);
    }
  }
  .floating-action[hidden] {
    opacity: 0;
    transform: translateY(12px) scale(0.92);
    pointer-events: none;
    display: none;
  }
  .floating-action:hover,
  .floating-action:focus-visible {
    transform: translateY(-2px) scale(1.04);
    background: rgba(255, 255, 255, 0.14);
    border-color: rgba(255, 255, 255, 0.5);
    outline: none;
  }
  :global(body[data-hero-tone="light"]) .floating-action:hover,
  :global(body[data-hero-tone="light"]) .floating-action:focus-visible,
  .floating-action[data-overlap="light"]:hover,
  .floating-action[data-overlap="light"]:focus-visible {
    background: hsl(var(--hue) 41% 13% / 0.12);
    border-color: hsl(var(--hue) 41% 13% / 0.4);
  }
  .floating-action:active {
    transform: translateY(0) scale(0.96);
  }
  .floating-action:focus-visible {
    outline: 2px solid var(--rose);
    outline-offset: 4px;
  }

  @keyframes floating-action-pop {
    from { transform: translateY(20px) scale(0.7); opacity: 0; }
    to   { transform: translateY(0) scale(1); opacity: 1; }
  }
  @media (prefers-reduced-motion: reduce) {
    .floating-action {
      transition: none;
      animation: none;
    }
  }
</style>
