---
/*
 * FloatingAction , dvě floating tlačítka (glass-morph kruhy 48×48).
 *
 *   - fa-back  (vlevo dole):  „o úroveň výš" / zpět. JEN na podstránkách,
 *                             vždy viditelný. Skrytý na landing (/).
 *   - fa-top   (vpravo dole): scroll-to-top. Na VŠECH stránkách, viditelný
 *                             až po scrollu (> 480 px).
 *
 * Pravidlo (klient 16. 6. 2026): zpět = vždy vlevo, nahoru = vždy vpravo,
 * aby byl směr jednoznačný napříč celým fraktálem. Landing tedy ukazuje jen
 * šipku nahoru vpravo; podstránka navíc šipku zpět vlevo.
 *
 * Render do Base.astro (transition:persist) → existuje na každé stránce,
 * JS rozhoduje viditelnost podle URL. Pozice respektuje safe-area insety
 * (notch je na telefonu na šířku po stranách, ne nahoře/dole).
 */
import { withBase } from '../utils/url';
import Icon from './Icon.astro';

const home = withBase('/');
---
<div class="floating-actions" data-fa-home={home}>
  <a
    id="fa-back"
    class="floating-action floating-action--back"
    href={home}
    aria-label="O úroveň výš"
    hidden>
    <Icon name="arrow-left" size={22} strokeWidth={2} />
  </a>
  <button
    type="button"
    id="fa-top"
    class="floating-action floating-action--top"
    aria-label="Skrolovat zpátky nahoru"
    hidden>
    <Icon name="chevron-up" size={22} strokeWidth={2} />
  </button>
</div>

<script is:inline>
  (function () {
    if (window.__hubFaBound) return;
    window.__hubFaBound = true;

    var SCROLL_SHOW = 480;
    var moBound = false;

    /* Scroll-to-top listener navázaný JEN jednou (button + window přežijí
       client-side navigace díky transition:persist). */
    function setupTop() {
      var top = document.getElementById('fa-top');
      if (!top || top.__bound) return;
      top.__bound = true;
      top.addEventListener('click', function () {
        window.scrollTo({ top: 0, behavior: 'smooth' });
      });
      var onScroll = function () {
        var t = document.getElementById('fa-top');
        if (!t) return;
        if (t.hasAttribute('data-fa-disabled')) { t.setAttribute('hidden', ''); return; }
        if (window.scrollY > SCROLL_SHOW) t.removeAttribute('hidden');
        else t.setAttribute('hidden', '');
      };
      window.addEventListener('scroll', onScroll, { passive: true });
      top.__check = onScroll;
    }

    /* Glass tone (white ↔ plum) zrcadlí header is-stuck na obě tlačítka.
       body[data-hero-tone="light"] z SubpageHero řeší zbytek přes CSS. */
    function syncTone(wrap) {
      var header = document.querySelector('.hub-header--overlay');
      var els = wrap.querySelectorAll('.floating-action');
      function apply() {
        var light = !!(header && header.classList.contains('is-stuck'));
        els.forEach(function (e) {
          if (light) e.setAttribute('data-overlap', 'light');
          else e.removeAttribute('data-overlap');
        });
      }
      apply();
      if (header && !moBound) {
        moBound = true;
        new MutationObserver(apply).observe(header, { attributes: true, attributeFilter: ['class'] });
      }
    }

    function bind() {
      var wrap = document.querySelector('.floating-actions');
      if (!wrap) return;

      var base = (wrap.getAttribute('data-fa-home') || '/').replace(/\/$/, '');
      var path = window.location.pathname.replace(/\/$/, '');
      var isHome = path === base;
      /* Rezervační wizard má vlastní bottom-fixed CTA bar + sticky sidebar,
         floating tlačítka by kolidovala. Schováme obě. */
      var isRezervace = /\/rezervace$/.test(path);

      var back = document.getElementById('fa-back');
      var top = document.getElementById('fa-top');

      setupTop();

      if (isRezervace) {
        if (back) back.setAttribute('hidden', '');
        if (top) { top.setAttribute('hidden', ''); top.setAttribute('data-fa-disabled', ''); }
        return;
      }
      if (top) top.removeAttribute('data-fa-disabled');

      /* Zpět: jen na podstránkách, odkaz o úroveň výš, vždy viditelný. */
      if (back) {
        if (isHome) {
          back.setAttribute('hidden', '');
        } else {
          var trimmed = window.location.pathname.replace(/\/$/, '');
          var parent = trimmed.slice(0, trimmed.lastIndexOf('/') + 1) || (base + '/');
          back.setAttribute('href', parent);
          back.removeAttribute('hidden');
        }
      }

      /* Nahoru: viditelnost řídí scroll (na všech stránkách). */
      if (top && top.__check) top.__check();

      syncTone(wrap);
    }

    document.addEventListener('astro:page-load', bind);
  }());
</script>

<style>
  /* Glass-morph kruh sjednocený s .lp-hero__scroll-cue: 48×48, žádný solid
     fill, jen translucent backdrop + thin border. Pod dark hero (deep/ink)
     bílá ikona + bílý border; pod light hero (cream/rose) plum-deep ikona
     + plum-deep border. body[data-hero-tone] (z SubpageHero) řídí který. */
  .floating-action {
    position: fixed;
    /* Safe-area: na telefonu na šířku je notch po stranách, proto max() s
       env() insetem (žádný efekt tam kde inset = 0). */
    bottom: max(clamp(20px, 5vw, 32px), env(safe-area-inset-bottom, 0px));
    width: 48px;
    height: 48px;
    margin: 0;
    padding: 0;
    appearance: none;
    -webkit-appearance: none;
    font: inherit;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.06);
    border: 1px solid rgba(255, 255, 255, 0.32);
    backdrop-filter: blur(6px);
    -webkit-backdrop-filter: blur(6px);
    color: #fff;
    text-decoration: none;
    z-index: 40;
    cursor: pointer;
    transition:
      transform 320ms cubic-bezier(0.32, 0.72, 0, 1),
      background 220ms cubic-bezier(0.32, 0.72, 0, 1),
      border-color 220ms cubic-bezier(0.32, 0.72, 0, 1),
      color 220ms cubic-bezier(0.32, 0.72, 0, 1),
      opacity 280ms cubic-bezier(0.32, 0.72, 0, 1);
  }
  /* Nahoru = vždy vpravo. Zpět = vždy vlevo. */
  .floating-action--top  { right: max(clamp(20px, 5vw, 32px), env(safe-area-inset-right, 0px)); }
  .floating-action--back { left:  max(clamp(20px, 5vw, 32px), env(safe-area-inset-left, 0px)); }

  .floating-action :global(svg) { display: block; }

  /* Light hero (cream / rose): plum-deep accent místo bílé */
  :global(body[data-hero-tone="light"]) .floating-action,
  .floating-action[data-overlap="light"] {
    background: hsl(var(--hue) 41% 13% / 0.06);
    border-color: hsl(var(--hue) 41% 13% / 0.22);
    color: var(--plum-deep);
  }

  /* Scroll-to-top pop při objevení. */
  .floating-action--top:not([hidden]) {
    animation: floating-action-pop 360ms cubic-bezier(0.32, 0.72, 0, 1);
  }
  .floating-action[hidden] {
    opacity: 0;
    transform: translateY(12px) scale(0.92);
    pointer-events: none;
    display: none;
  }
  .floating-action:hover,
  .floating-action:focus-visible {
    transform: translateY(-2px) scale(1.04);
    background: rgba(255, 255, 255, 0.14);
    border-color: rgba(255, 255, 255, 0.5);
    outline: none;
  }
  :global(body[data-hero-tone="light"]) .floating-action:hover,
  :global(body[data-hero-tone="light"]) .floating-action:focus-visible,
  .floating-action[data-overlap="light"]:hover,
  .floating-action[data-overlap="light"]:focus-visible {
    background: hsl(var(--hue) 41% 13% / 0.12);
    border-color: hsl(var(--hue) 41% 13% / 0.4);
  }
  .floating-action:active {
    transform: translateY(0) scale(0.96);
  }
  .floating-action:focus-visible {
    outline: 2px solid var(--rose);
    outline-offset: 4px;
  }

  /* Telefon na šířku (nízký viewport): menší kruhy, blíž k rohům, ať
     nepřekrývají obsah na úzkém pruhu výšky. */
  @media (orientation: landscape) and (max-height: 480px) {
    .floating-action {
      width: 42px;
      height: 42px;
      bottom: max(12px, env(safe-area-inset-bottom, 0px));
    }
    .floating-action--top  { right: max(12px, env(safe-area-inset-right, 0px)); }
    .floating-action--back { left:  max(12px, env(safe-area-inset-left, 0px)); }
  }

  @keyframes floating-action-pop {
    from { transform: translateY(20px) scale(0.7); opacity: 0; }
    to   { transform: translateY(0) scale(1); opacity: 1; }
  }
  @media (prefers-reduced-motion: reduce) {
    .floating-action {
      transition: none;
      animation: none;
    }
  }
</style>
