---
// Phase 1: hardcoded 6 seed projects (ported from ui_kits/osa-web/Sections.jsx:68-75).
// Phase 2 refactors this to pull from Content Collections.
import ProjectCard from './ProjectCard.astro';

const projects = [
  { slug: 'kreativni-prostory', name: 'Kreativní Prostory CZ', description: 'Síť hudebních zkušeben, dílen a ateliérů pro amatérské i profesionální tvůrce.', accent: 'forest',  relationship: 'autonomni', external_url: 'https://kreativniprostory.cz' },
  { slug: 'vyletna',             name: 'Výletná',              description: 'Obnova dřevěné klubovny architekta Bohumíra Kozáka z roku 1926 v Letenských sadech.',    accent: 'coral',   relationship: 'autonomni', external_url: 'https://podporujvyletnou.cz' },
  { slug: 'diy-dilny',           name: 'DIY dílny',            description: 'Řemeslné dílny a sdílené vybavení pro kutilskou, dřevařskou a kovovýrobní práci.',      accent: 'mustard', relationship: 'autonomni', external_url: 'https://diydilny.cz' },
  { slug: 'gas-town',            name: 'Gas Town',             description: 'Technická a motoristická dílna v bývalém armádním areálu v Klecanech, setkávání Kafe a Káry.', accent: 'teal', relationship: 'autonomni', external_url: 'https://gastown.cz' },
  { slug: 'metro-farm',          name: 'Metro Farm',           description: 'Komunitní zahrady a městské zemědělství, propojování obyvatel a krajiny.',               accent: 'olive',   relationship: 'autonomni', external_url: 'https://metrofarm.cz' },
  { slug: 'junktown',            name: 'Junktown',             description: 'Nekomerční post-apokalyptický LARP festival na raketové základně Bratronice.',          accent: 'plum',    relationship: 'autonomni', external_url: 'https://junktown.postapofestival.cz' },
];
---
<section class="osa-rozcestnik section">
  <div class="container-wide">
    <header class="osa-rozcestnik__head">
      <span class="osa-eyebrow osa-rozcestnik__eyebrow">Rozcestník</span>
      <h2 class="osa-h2 osa-rozcestnik__title">Autonomní projekty pod hlavičkou spolku</h2>
      <p class="osa-body osa-rozcestnik__lede">
        Projekty si vedou vlastní prostory, weby a členskou základnu. Spolek jim poskytuje právní a organizační zázemí.
      </p>
    </header>
    <ul class="osa-rozcestnik__grid" role="list">
      {projects.map(p => (
        <li><ProjectCard {...p} /></li>
      ))}
    </ul>
  </div>
</section>

<style>
  .osa-rozcestnik__head {
    display: grid;
    gap: var(--space-3);
    max-width: 64ch;
    margin: 0 0 var(--space-7);
  }
  .osa-rozcestnik__title { margin: 0; }
  .osa-rozcestnik__lede  { margin: 0; color: var(--fg-muted); max-width: 56ch; }
  .osa-rozcestnik__grid  {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 0;
    border-top: 1px solid var(--rule);
    border-left: 1px solid var(--rule);
  }
</style>
