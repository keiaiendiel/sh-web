---
import { getCollection } from 'astro:content';
import ProjectCard from './ProjectCard.astro';
import { withBase } from '../utils/url';

const all = await getCollection('subProjects', entry =>
  entry.data.status !== 'draft' && entry.data.status !== 've-spanku',
);
const projects = all
  .sort((a, b) => (a.data.order ?? 999) - (b.data.order ?? 999))
  .slice(0, 12);
// First 6 projects show on mobile; the rest fold behind a CTA.
const MOBILE_LIMIT = 6;
---
<section class="osa-rozcestnik section">
  <div class="container-wide">
    <header class="osa-rozcestnik__head" data-reveal>
      <span class="osa-eyebrow osa-rozcestnik__eyebrow">Rozcestník</span>
      <h2 class="osa-h2 osa-rozcestnik__title">Autonomní projekty pod hlavičkou spolku</h2>
      <p class="osa-body osa-rozcestnik__lede">
        Projekty si vedou vlastní prostory, weby a členskou základnu. Spolek jim poskytuje právní a organizační zázemí.
      </p>
    </header>
    <ul class="osa-rozcestnik__grid" role="list">
      {projects.map((p, i) => (
        <li
          data-reveal
          data-reveal-delay={String((i % 3) + 1)}
          class:list={[{ 'osa-rozcestnik__overflow': i >= MOBILE_LIMIT }]}
        ><ProjectCard
          slug={p.id}
          name={p.data.name}
          description={p.data.description}
          accent={p.data.accent}
          relationship={p.data.relationship}
          status={p.data.status}
          topic={p.data.topic}
          external_url={p.data.external_url}
        /></li>
      ))}
    </ul>
    <div class="osa-rozcestnik__more" data-reveal>
      <a class="btn" href={withBase('/projekty/')} data-wipe>Ostatní projekty</a>
    </div>
  </div>
</section>

<style>
  .osa-rozcestnik__head {
    display: grid;
    gap: var(--space-3);
    max-width: 64ch;
    margin: 0 0 var(--space-7);
  }
  .osa-rozcestnik__title { margin: 0; }
  .osa-rozcestnik__lede  { margin: 0; color: var(--fg-muted); max-width: 56ch; }
  .osa-rozcestnik__grid  {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    grid-auto-rows: 1fr;
    gap: 0;
    border-top: 1px solid var(--rule);
    border-left: 1px solid var(--rule);
  }
  .osa-rozcestnik__grid > li { display: flex; }
  .osa-rozcestnik__grid > li > * { flex: 1; }
  /* Below-the-fold "Ostatní projekty" CTA is shown only on mobile where
     the card grid is folded. On desktop the grid already shows everything,
     so the CTA would be redundant. */
  .osa-rozcestnik__more {
    display: none;
    margin: var(--space-6) 0 0;
    justify-content: flex-start;
  }
  @media (max-width: 720px) {
    /* Hide the overflow tail (items beyond the first 6) and surface the
       "Ostatní projekty" link instead. Keeps the landing page calm on
       a phone without hiding anything structurally from crawlers.
       Specificity note: `.grid > li { display: flex }` above outranks a
       bare `.overflow { display: none }`, so we anchor both classes here. */
    .osa-rozcestnik__grid > li.osa-rozcestnik__overflow { display: none; }
    .osa-rozcestnik__more { display: flex; }
  }
</style>
